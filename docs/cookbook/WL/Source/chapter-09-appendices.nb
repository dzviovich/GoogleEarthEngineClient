Cell[CellGroupData[{

Cell["12. Precipitation Accumulation from CHIRPS", "Section",ExpressionUUID->"bc666ef8-2a59-b147-9488-49738a86fddf"],

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"bbox", " ", "=", " ", 
    RowBox[{"{", 
     RowBox[{"32.0", ",", " ", 
      RowBox[{"-", "5.0"}], ",", " ", "42.0", ",", " ", "5.0"}], "}"}]}], 
   ";"}], "\n"}], "\n", 
 RowBox[{"precip", " ", "=", "\n", "    ", 
  RowBox[{"GEECollection", "[", "\"\<UCSB-CHG/CHIRPS/DAILY\>\"", "]"}]}], "\n", 
 RowBox[{"    ", 
  RowBox[{"//", " ", 
   RowBox[{"GEEFilterDate", "[", 
    RowBox[{"\"\<2023-03-01\>\"", ",", " ", "\"\<2023-05-31\>\""}], 
    "]"}]}]}], "\n", 
 RowBox[{"    ", 
  RowBox[{"//", " ", 
   RowBox[{"GEEFilterBounds", "[", "bbox", "]"}]}]}], "\n", 
 RowBox[{"    ", 
  RowBox[{"//", " ", "GEECollectionSum"}]}], "\n", 
 RowBox[{"    ", 
  RowBox[{"//", " ", 
   RowBox[{"GEESelectBands", "[", 
    RowBox[{"{", "\"\<precipitation_sum\>\"", "}"}], "]"}]}]}], "\n", 
 RowBox[{"    ", 
  RowBox[{
   RowBox[{"//", " ", 
    RowBox[{"GEEVisualize", "[", 
     RowBox[{"<|", "\n", "        ", 
      RowBox[{
       RowBox[{"\"\<min\>\"", " ", "->", " ", "0"}], ",", " ", 
       RowBox[{"\"\<max\>\"", " ", "->", " ", "800"}], ",", "\n", "        ", 
       RowBox[{"\"\<palette\>\"", " ", "->", " ", 
        RowBox[{"{", 
         RowBox[{"\"\<white\>\"", ",", " ", "\"\<lightblue\>\"", ",", 
          " ", "\"\<blue\>\"", ",", " ", "\"\<purple\>\""}], "}"}]}]}], "\n", 
      "    ", "|>"}], "]"}]}], ";"}], "\n"}], "\n", 
 RowBox[{"GEEComputePixels", "[", 
