Cell[TextData[{
 StyleBox["Tip:",
  FontWeight->Bold],
 " Select bands before aggregation to avoid suffix issues:"
}], "Text",ExpressionUUID->"2a7229c8-a4f5-a747-a4c2-4d456b381943"],

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{"This", " ", 
    RowBox[{"works", ":", " ", 
     RowBox[{"select", " ", "before", " ", "median"}]}]}], " ", "*)"}], "\n", 
  RowBox[{
   RowBox[{
    RowBox[{"coll", " ", "//", " ", 
     RowBox[{"GEESelectBands", "[", 
      RowBox[{"{", 
       RowBox[{"\"\<B4\>\"", ",", " ", "\"\<B3\>\"", ",", " ", "\"\<B2\>\""}],
        "}"}], "]"}]}], " ", "//", " ", "GEEMedian"}], "\n", "\n", 
   RowBox[{"(*", " ", 
    RowBox[{
    "This", " ", "may", " ", "fail", " ", "if", " ", "you", " ", "reference", 
     " ", "\"\<B4\>\"", " ", "after", " ", "median"}], " ", "*)"}], "\n", 
   RowBox[{
    RowBox[{"coll", " ", "//", " ", "GEEMedian"}], " ", "//", " ", 
    RowBox[{"GEESelectBands", "[", 
     RowBox[{"{", "\"\<B4\>\"", "}"}], "]"}], "  ", 
    RowBox[{"(*", " ", 
     RowBox[{"needs", " ", "\"\<B4_median\>\""}], " ", "*)"}]}]}]}]], "Input",\
ExpressionUUID->"412c8459-000f-9b46-9f0d-47508980e73c"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Bounding Box and Memory Limits", "Section",ExpressionUUID->"5fc7e93e-98f7-2a49-a57a-e9e77189acd8"],

Cell["\<\
GEE imposes server-side limits on the number of pixels in a single request. \
If your request fails:\
\>", "Text",ExpressionUUID->"6ff2c98d-dbb0-6e41-9f49-c67e6cda33a7"],

Cell["Reduce the bounding box area", "Item",ExpressionUUID->"457ba9a8-8730-6f46-bb69-cf113013333d"],

Cell[TextData[{
 "Increase the ",
 Cell["\"ImageSize\"", "InlineCode",ExpressionUUID->
  "f951914b-f209-5847-8d4b-9083e5d75b33"],
 " denominator (fewer pixels requested)"
}], "Item",ExpressionUUID->"42729783-c6db-5643-ad24-dd83adaa3a23"],

Cell["Use a coarser-resolution dataset", "Item",ExpressionUUID->"eab76eaa-b972-994d-831c-6229181e09a4"],

Cell["Process in tiles and stitch locally", "Item",ExpressionUUID->"b83281de-f206-7944-aa37-abc5a06fe9b0"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Rate Limiting and Quotas", "Section",ExpressionUUID->"4e0cc048-c62f-b841-9959-a20706250c88"],

Cell["\<\
Google Earth Engine enforces per-project quotas. If you receive HTTP 429 \
responses:\
\>", "Text",ExpressionUUID->"20ea6b05-c650-364d-a02b-46452d3c4d0d"],

Cell[TextData[{
 "Add ",
 Cell["Pause[1]", "InlineCode",ExpressionUUID->
  "4a447db8-3486-0c47-a96c-c892adbd2978"],
 " between batch requests"
}], "Item",ExpressionUUID->"3e832df2-4ab7-3346-b2de-9dbc3642340e"],

Cell[TextData[{
 "Reduce concurrency (avoid ",
 Cell["ParallelMap", "InlineCode",ExpressionUUID->
  "e25a4636-6cd2-7644-bdf2-0d7bc835131b"],
 " over GEE calls)"
}], "Item",ExpressionUUID->"1b88cf6d-782f-ee4c-aa4f-11d9d7a83d4a"],

Cell["Monitor quota usage in the Google Cloud Console", "Item",ExpressionUUID->"76c4cd9b-846b-df4e-9034-3f74c901245f"]
}, Open  ]],

Cell[CellGroupData[{

Cell["VisParams Not Working", "Section",ExpressionUUID->"2864b856-3ee3-d74f-8464-b0a4a058a990"],

Cell[TextData[{
 "If the image appears all-black or all-white after applying ",
 Cell["GEEVisualize", "InlineCode",ExpressionUUID->
  "629a5af0-bca2-9141-b5a4-e3da79b89eee"],
 ":"
}], "Text",ExpressionUUID->"42c54309-1e5c-ae48-821e-d4430b8f8395"],

Cell[TextData[{
 "The ",
 Cell["\"min\"", "InlineCode",ExpressionUUID->
  "4a844384-2f70-704f-a652-583a36258d16"],
 " and ",
 Cell["\"max\"", "InlineCode",ExpressionUUID->
  "b941076c-b360-2048-9dfb-8851a83b7dea"],
 " values do not match the data range. Use ",
 Cell["GEEReduceRegion", "InlineCode",ExpressionUUID->
  "bf625e71-c4f2-3544-8edb-280c3b03e186"],
 " with ",
 Cell["\"min\"", "InlineCode",ExpressionUUID->
  "2cb7b0e7-b044-5a48-a654-95ea2cf31a63"],
 " and ",
 Cell["\"max\"", "InlineCode",ExpressionUUID->
  "b641d213-a516-9c4a-9d2c-10e338854e98"],
 " reducers to find actual data range."
}], "Item",ExpressionUUID->"4b3ae142-613f-cf41-ba0b-50664951bc1e"],

Cell["\<\
For surface reflectance data, Sentinel-2 values are typically 0--10000 (not \
0--1).\
\>", "Item",ExpressionUUID->"7bfb4f03-da93-1141-9450-64916ba0d877"],

Cell["\<\
For Landsat Collection 2, surface reflectance has a scale factor of 0.0000275 \
and offset of -0.2.\
\>", "Item",ExpressionUUID->"c9f9caf0-d9d8-024b-a5de-e0abe53367be"],

Cell["\<\
Temperature products are often in Kelvin (scaled). Check the dataset \
documentation for scale factors.\
\>", "Item",ExpressionUUID->"3d3161d9-574c-0f4b-bf28-824f00a47197"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Band Selection: Before vs. After Aggregation", "Section",ExpressionUUID->"86db5620-bb66-c044-9a67-b964b773d98a"],

Cell["\<\
A common source of confusion is when to select bands in the pipeline:\
\>", "Text",ExpressionUUID->"42e97d1b-959a-1840-b6a2-32132e6c574f"],

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{"Preferred", ":", " ", 
    RowBox[{"select", " ", "bands", " ", "before", " ", "aggregation"}]}], 
   " ", "*)"}], "\n", 
  RowBox[{"(*", " ", 
   RowBox[{
    RowBox[{"Fewer", " ", "bands", " ", "processed"}], " ", "=", " ", 
    RowBox[{"faster", " ", "computation"}]}], " ", "*)"}], "\n", 
  RowBox[{
   RowBox[{"GEECollection", "[", "\"\<COPERNICUS/S2_SR_HARMONIZED\>\"", "]"}],
    "\n", 
   RowBox[{"//", " ", 
    RowBox[{"GEEFilterDate", "[", 
     RowBox[{"\"\<2023-06-01\>\"", ",", " ", "\"\<2023-09-01\>\""}], "]"}]}], 
   "\n", 
   RowBox[{"//", " ", 
    RowBox[{"GEESelectBands", "[", 
     RowBox[{"{", 
      RowBox[{"\"\<B4\>\"", ",", " ", "\"\<B3\>\"", ",", " ", "\"\<B2\>\""}], 
      "}"}], "]"}]}], "\n", 
   RowBox[{"//", " ", "GEEMedian"}], "\n", "\n", 
   RowBox[{"(*", " ", 
    RowBox[{"Alternative", ":", " ", 
     RowBox[{"select", " ", "after", " ", "aggregation"}]}], " ", "*)"}], 
   "\n", 
   RowBox[{"(*", " ", 
    RowBox[{
    "Band", " ", "names", " ", "may", " ", "have", " ", "suffixes", " ", 
     "depending", " ", "on", " ", "the", " ", "reducer"}], " ", "*)"}], "\n", 
   RowBox[{"GEECollection", "[", "\"\<COPERNICUS/S2_SR_HARMONIZED\>\"", "]"}],
    "\n", 
   RowBox[{"//", " ", 
    RowBox[{"GEEFilterDate", "[", 
     RowBox[{"\"\<2023-06-01\>\"", ",", " ", "\"\<2023-09-01\>\""}], "]"}]}], 
   "\n", 
   RowBox[{"//", " ", "GEEMedian"}], "\n", 
   RowBox[{"//", " ", 
    RowBox[{"GEESelectBands", "[", 
     RowBox[{"{", 
      RowBox[{"\"\<B4_median\>\"", ",", " ", "\"\<B3_median\>\"", ",", 
       " ", "\"\<B2_median\>\""}], "}"}], "]"}]}]}]}]], "Input",ExpressionUUID\
->"b1ac1837-ada0-ec43-a5c8-3f894ed8acce"],

Cell["", "Text",
 CellFrame->{{0, 0}, {0, 
  1}},ExpressionUUID->"8b66dbf7-0490-db45-b3f0-089170dca672"]
}, Open  ]]
}, Open  ]],

Cell[CellGroupData[{

Cell["Appendix F: Glossary", "Chapter",ExpressionUUID->"04882c1a-9e28-1547-9421-41e14fade7e0"],

Cell[TextData[{
 StyleBox["Asset",
  FontWeight->Bold],
 " A named resource in the Google Earth Engine data catalog, identified by a \
string path such as ",
 Cell["\"USGS/SRTMGL1_003\"", "InlineCode",ExpressionUUID->
  "2d208dfc-4b48-3a42-93a3-96d9fe5083ff"],
 ". Assets can be images, image collections, tables, or folders."
}], "Text",ExpressionUUID->"4ed12bbd-f96d-fb46-a744-4f7bed412728"],

Cell[TextData[{
 StyleBox["Band",
  FontWeight->Bold],
 " A single channel of data within an image. Each band has a name, data type, \
and spatial resolution. For example, Sentinel-2 band ",
 Cell["\"B4\"", "InlineCode",ExpressionUUID->
  "44991b95-783d-9242-b811-03b625a77553"],
 " is the red channel at 10 m resolution."
}], "Text",ExpressionUUID->"98377333-7f5f-924f-acd0-e9784dc21bd3"],

Cell[TextData[{
 StyleBox["Bounding Box",
  FontWeight->Bold],
 " A rectangular geographic extent specified as ",
 Cell["{west, south, east, north}", "InlineCode",ExpressionUUID->
  "76d11016-75d2-d647-9a81-00aa0d2d9a9d"],
 " in decimal degrees (EPSG:4326). Used to define the spatial scope of pixel \
retrieval."
}], "Text",ExpressionUUID->"b67e16f5-7fd8-c54b-b126-02a52d9465ce"],

Cell[TextData[{
 StyleBox["Collection",
  FontWeight->Bold],
 " See ImageCollection."
}], "Text",ExpressionUUID->"c4c99695-cef8-4d49-9839-7146ad710325"],

Cell[TextData[{
 StyleBox["Composite",
  FontWeight->Bold],
 " A single image created by combining multiple images from a collection, \
typically using a reducer such as median or mosaic. Compositing reduces cloud \
contamination and fills data gaps."
}], "Text",ExpressionUUID->"757738e1-0702-4f45-aab8-2af95e749f4a"],

Cell[TextData[{
 StyleBox["Expression Tree",
  FontWeight->Bold],
 " The internal representation of a GEE computation. Functions like ",
 Cell["GEEFilterDate", "InlineCode",ExpressionUUID->
  "62248e85-1c37-7a47-8167-e1b50999510c"],
 ", ",
 Cell["GEEMedian", "InlineCode",ExpressionUUID->
  "7848b73d-7561-ec4c-af0c-88b9775fe46c"],
 ", and ",
 Cell["GEESelectBands", "InlineCode",ExpressionUUID->
  "3f35c12f-1229-9e48-80f6-de7189f644dc"],
 " build nested Association structures that are serialized to JSON and sent \
to the GEE REST API for server-side execution."
}], "Text",ExpressionUUID->"d6223a83-ce79-0947-9c03-a8dfd2381ac3"],

Cell[TextData[{
 StyleBox["Feature",
  FontWeight->Bold],
 " A geographic object consisting of a geometry and a set of properties \
(key-value pairs). Analogous to a row in a GIS attribute table."
}], "Text",ExpressionUUID->"3ca47d2c-9fb0-d94a-a284-e2dae76c6458"],

Cell[TextData[{
 StyleBox["FeatureCollection",
  FontWeight->Bold],
 " A collection of Features, analogous to a vector layer or shapefile. \
Created with ",
 Cell["GEEFeatureCollection", "InlineCode",ExpressionUUID->
  "362e07ab-7904-424d-b97f-6f90c05b5952"],
 " and queried with ",
 Cell["GEEComputeFeatures", "InlineCode",ExpressionUUID->
  "8f38fcd9-2e1f-7e4d-ba27-8f0e8a0c8be5"],
 "."
}], "Text",ExpressionUUID->"b1d74c2b-4de7-1343-893e-47322b30fbec"],

Cell[TextData[{
 StyleBox["Geometry",
  FontWeight->Bold],
 " A geographic shape -- point, line, polygon, or rectangle -- used for \
spatial filtering, clipping, and region reduction. Created with ",
 Cell["GEEGeometry", "InlineCode",ExpressionUUID->
  "12c3f82a-580a-d243-97ce-111c1e61dc62"],
 ", ",
 Cell["GEEPolygon", "InlineCode",ExpressionUUID->
  "5a0392c3-0c10-5940-a091-f2dec143d9ca"],
 ", or ",
 Cell["GEELineString", "InlineCode",ExpressionUUID->
  "b5c0742e-8707-7e4a-83ad-1cb4fcbc0833"],
 "."
}], "Text",ExpressionUUID->"0689ffb0-a4c1-d44b-af55-8cf1c7197506"],

Cell[TextData[{
 StyleBox["Image",
  FontWeight->Bold],
 " The fundamental raster data type in GEE. An Image contains one or more \
bands, each with pixel values, a coordinate reference system, and metadata \
properties."
}], "Text",ExpressionUUID->"292f014e-0a64-ec4e-b279-afb822c6ec75"],

Cell[TextData[{
 StyleBox["ImageCollection",
  FontWeight->Bold],
 " An ordered set of Images, typically from the same sensor and covering \
different dates or locations. Created with ",
 Cell["GEECollection", "InlineCode",ExpressionUUID->
  "579c26a6-070a-104a-908c-1aac6c83d6cd"],
 " and refined with filter and aggregation functions."
}], "Text",ExpressionUUID->"fb52cf8a-fc4b-0342-bdd8-8026e45d837a"],

Cell[TextData[{
 StyleBox["Mask",
  FontWeight->Bold],
 " A per-pixel binary flag indicating whether a pixel is valid (1) or \
invalid/missing (0). Masked pixels are excluded from computations and \
display. Manipulated with ",
 Cell["GEEUpdateMask", "InlineCode",ExpressionUUID->
  "1c25f3b9-76a3-0549-8c3d-a6454c819fdf"],
 ", ",
 Cell["GEEUnmask", "InlineCode",ExpressionUUID->
  "68e05293-5a08-d841-ba4a-54033e75d9e1"],
 ", and ",
 Cell["GEESelfMask", "InlineCode",ExpressionUUID->
  "2eb69357-efb9-da4c-9799-7d1695615709"],
 "."
}], "Text",ExpressionUUID->"5ec9c843-7c8d-a940-baf9-419be8d29813"],

Cell[TextData[{
 StyleBox["Mosaic",
  FontWeight->Bold],
 " A compositing method that overlays images in order, with later images \
covering earlier ones. The last valid pixel wins. Created with ",
 Cell["GEEMosaic", "InlineCode",ExpressionUUID->
  "76b4f45f-e2bc-e642-bbe5-8844c1cd4c8a"],
 "."
}], "Text",ExpressionUUID->"9c623deb-7bff-9645-a34f-496d0f4ec3e2"],

Cell[TextData[{
 StyleBox["NDVI (Normalized Difference Vegetation Index)",
  FontWeight->Bold],
 " A spectral index computed as (NIR - Red) / (NIR + Red). Values range from \
-1 to 1, where higher values indicate denser vegetation. Computed with ",
 Cell["GEENormalizedDifference[{\"B8\", \"B4\"}]", "InlineCode",
  ExpressionUUID->"010b9963-dfa1-7b40-bed4-d157188b257b"],
 " for Sentinel-2."
}], "Text",ExpressionUUID->"df138450-24c5-f94e-a73a-b3585dcf8d6d"],

Cell[TextData[{
 StyleBox["Pixel",
  FontWeight->Bold],
 " The smallest spatial unit in a raster image. Each pixel has one value per \
band and covers a ground area determined by the image resolution."
}], "Text",ExpressionUUID->"6e6d4b92-009f-5e41-bdd0-49d59ce4601b"],

Cell[TextData[{
 StyleBox["Reducer",
  FontWeight->Bold],
 " An aggregation operation applied across images in a collection (temporal \
reduction) or across pixels in a region (spatial reduction). Examples include \
mean, median, min, max, sum, and standard deviation."
}], "Text",ExpressionUUID->"a4f7db68-b54c-f44e-a6e1-396af70900fc"],

Cell[TextData[{
 StyleBox["Scale",
  FontWeight->Bold],
 " The spatial resolution of a computation in meters per pixel. When using ",
 Cell["GEEReduceRegion", "InlineCode",ExpressionUUID->
  "db5a50a0-aca3-054b-9377-27906796fb5d"],
 ", the scale parameter controls how finely pixels are sampled within the \
region."
}], "Text",ExpressionUUID->"9de0748d-6354-d845-a750-aefd1fc444d3"],

Cell[TextData[{
 StyleBox["Surface Reflectance",
  FontWeight->Bold],
 " Satellite measurements corrected for atmospheric effects, representing the \
fraction of sunlight reflected by the Earth's surface. Sentinel-2 SR values \
range from 0 to 10000 (scale factor 0.0001)."
}], "Text",ExpressionUUID->"3bb7b077-2f44-3947-95d3-491513464fc4"],

Cell[TextData[{
 StyleBox["VisParams (Visualization Parameters)",
  FontWeight->Bold],
 " An Association controlling how image values are mapped to display colors. \
Common keys include ",
 Cell["\"min\"", "InlineCode",ExpressionUUID->
  "0b3b716b-25af-9b41-a530-5050b13148f2"],
 ", ",
 Cell["\"max\"", "InlineCode",ExpressionUUID->
  "9825fac5-de44-d74f-b0c1-ef958b00fc1e"],
 ", ",
 Cell["\"palette\"", "InlineCode",ExpressionUUID->
  "924c5716-f09f-e84e-9604-f8a61b816544"],
 ", ",
 Cell["\"bands\"", "InlineCode",ExpressionUUID->
  "fea07661-2e49-a149-95d4-a1c8e0b9cd17"],
 ", and ",
 Cell["\"gamma\"", "InlineCode",ExpressionUUID->
  "c2447495-e9cf-e943-81b4-ddfb5b851a96"],
 ". Applied with ",
 Cell["GEEVisualize", "InlineCode",ExpressionUUID->
  "91fe680f-fd1b-b040-ab52-071154daea78"],
 "."
}], "Text",ExpressionUUID->"3ff253d3-d972-dd43-814f-fe10be38b1bc"]
}, Open  ]]
}, Open  ]]
},
WindowSize->{581.25, 654},
WindowMargins->{{993, Automatic}, {Automatic, 171.75}},
FrontEndVersion->"14.3 for Microsoft Windows (64-bit) (July 8, 2025)",
