Cell[CellGroupData[{

Cell["Appendix C: Common Pipeline Patterns", "Chapter",ExpressionUUID->"216ddfe5-d365-574f-b929-1984db1051d7"],

Cell[CellGroupData[{

Cell["1. Cloud-Free RGB Composite (Sentinel-2)", "Section",ExpressionUUID->"f198ef57-919d-ef4a-a1ed-8a19db1973eb"],

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"bbox", " ", "=", " ", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{"-", "122.5"}], ",", " ", "37.7", ",", " ", 
      RowBox[{"-", "122.3"}], ",", " ", "37.9"}], "}"}]}], ";"}], "\n"}], "\n", 
 RowBox[{"composite", " ", "=", "\n", "    ", 
  RowBox[{
  "GEECollection", "[", "\"\<COPERNICUS/S2_SR_HARMONIZED\>\"", "]"}]}], "\n", 
 RowBox[{"    ", 
  RowBox[{"//", " ", 
   RowBox[{"GEEFilterDate", "[", 
    RowBox[{"\"\<2023-06-01\>\"", ",", " ", "\"\<2023-09-01\>\""}], 
    "]"}]}]}], "\n", 
 RowBox[{"    ", 
  RowBox[{"//", " ", 
   RowBox[{"GEEFilterBounds", "[", "bbox", "]"}]}]}], "\n", 
 RowBox[{"    ", 
  RowBox[{"//", " ", 
   RowBox[{"GEEFilterProperty", "[", 
    RowBox[{"\"\<CLOUDY_PIXEL_PERCENTAGE\>\"", ",", " ", "\"\<LessThan\>\"", ",",
      " ", "20"}], "]"}]}]}], "\n", 
 RowBox[{"    ", 
  RowBox[{"//", " ", 
   RowBox[{"GEESelectBands", "[", 
    RowBox[{"{", 
     RowBox[{"\"\<B4\>\"", ",", " ", "\"\<B3\>\"", ",", " ", "\"\<B2\>\""}], 
     "}"}], "]"}]}]}], "\n", 
 RowBox[{"    ", 
  RowBox[{"//", " ", "GEEMedian"}]}], "\n", 
 RowBox[{"    ", 
  RowBox[{
   RowBox[{"//", " ", 
    RowBox[{"GEEVisualize", "[", 
     RowBox[{"<|", 
      RowBox[{
       RowBox[{"\"\<min\>\"", " ", "->", " ", "0"}], ",", " ", 
       RowBox[{"\"\<max\>\"", " ", "->", " ", "3000"}]}], "|>"}], "]"}]}], 
   ";"}], "\n"}], "\n", 
 RowBox[{"GEEComputePixels", "[", 
  RowBox[{"bbox", ",", " ", "composite"}], "]"}]}], "Input",ExpressionUUID->\
"922b2a85-c9d6-0f4b-b8bc-0691a124ccbd"]
}, Open  ]],

