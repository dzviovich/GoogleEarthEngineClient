Cell[TextData[{
 StyleBox["Note:",
  FontWeight->Bold],
 " ",
 Cell["MOD04_3K", "InlineCode",ExpressionUUID->
  "d29dd90b-3528-914d-ba00-202001de420c"],
 " offers higher spatial resolution (3 km) but with more noise and fewer \
valid retrievals. ",
 Cell["MOD04_L2", "InlineCode",ExpressionUUID->
  "2e7c695d-587f-1946-9bf4-2cd516f4eb22"],
 " (10 km, used in Chapter 3) provides more stable retrievals over a wider \
range of surface types. Choose based on your spatial resolution needs."
}], "Text",
 CellFrame->{{True, False}, {
   False, False}},ExpressionUUID->"4ce26474-e880-4042-8632-1f4f6f616f4a"]
}, Open  ]],

