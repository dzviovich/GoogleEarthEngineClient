Cell["Appendix E: Troubleshooting", "Chapter",ExpressionUUID->"644a8a88-fbc1-9c48-9663-116b5c657e49"],

Cell[CellGroupData[{

Cell["Authentication Errors", "Section",ExpressionUUID->"4ef7778b-2178-fa48-82ef-d64144238804"],

Cell[TextData[{
 Cell["GEEConnect::keynotfound", "InlineCode",ExpressionUUID->
  "b8290a90-25b6-ad49-8fb9-0fba21d1f8a9"],
 StyleBox[" -- Key file not found",
  FontWeight->Bold]
}], "Text",ExpressionUUID->"d5dfce77-0f91-204f-8c21-4f3ccb009438"],

Cell["\<\
The service account JSON key file path is incorrect or the file does not \
exist.\
\>", "Text",ExpressionUUID->"93c17bb1-9514-494c-8df8-f6f492b482e9"],

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{
   "Verify", " ", "the", " ", "file", " ", "exists", " ", "before", " ", 
    "calling", " ", "GEEConnect"}], " ", "*)"}], "\n", 
  RowBox[{
   RowBox[{"FileExistsQ", "[", "\"\<path/to/key.json\>\"", "]"}], "\n", 
   RowBox[{"(*", " ", 
    RowBox[{"Use", " ", "an", " ", "absolute", " ", "path"}], " ", "*)"}], "\n", 
   RowBox[{"GEEConnect", "[", 
    RowBox[{"FileNameJoin", "[", 
     RowBox[{"{", 
      RowBox[{
      "$HomeDirectory", ",", " ", "\"\<keys\>\"", ",", 
       " ", "\"\<gee-service-account.json\>\""}], "}"}], "]"}], 
    "]"}]}]}]], "Input",ExpressionUUID->"2ff26b39-43a1-0940-8ac9-\
25e7fc8354f8"],

Cell[TextData[{
 Cell["GEEConnect::invalidkey", "InlineCode",ExpressionUUID->
  "745d866e-8ae7-7844-a051-6f3f3b2a17e0"],
 StyleBox[" -- Invalid service account JSON key",
  FontWeight->Bold]
}], "Text",ExpressionUUID->"f26be46f-545e-7146-b69d-781a76f0fb10"],

Cell["\<\
The file exists but is not a valid GEE service account key. Ensure you \
downloaded a JSON key (not P12) from the Google Cloud Console under IAM > \
Service Accounts.\
\>", "Text",ExpressionUUID->"29f0cd66-56a1-3742-9b12-ac159a6044d4"],

Cell[TextData[{
 Cell["GEEConnect::authfail", "InlineCode",ExpressionUUID->
  "d8786b92-06b4-2041-b983-04df3547e0f9"],
 StyleBox[" -- Failed to obtain access token",
  FontWeight->Bold]
}], "Text",ExpressionUUID->"ef0a9b5e-42a7-5843-9c8f-1d051591f749"],

Cell["\<\
The service account exists but authentication failed. Common causes:\
\>", "Text",ExpressionUUID->"bbf74327-52f9-fc4d-834f-8e906168238e"],

Cell["The Earth Engine API is not enabled for the project", "Item",ExpressionUUID->"259341c5-b14a-8146-baef-641ee103fab9"],

Cell["The service account does not have Earth Engine access", "Item",ExpressionUUID->"7dd1656c-8cef-4342-9252-a43c666e3c03"],

Cell["Network connectivity issues or proxy interference", "Item",ExpressionUUID->"889d6813-01fc-7649-94fb-2723647f5e84"]
}, Open  ]],

Cell[CellGroupData[{

Cell["API Errors", "Section",ExpressionUUID->"99fe3633-c2aa-9243-aae1-888a2fa93cae"],

Cell[TextData[{
 Cell["GEEComputePixels::apierr", "InlineCode",ExpressionUUID->
  "418121b0-5df6-d14b-94fa-3be81027ed72"],
 StyleBox[" -- Expression tree errors",
  FontWeight->Bold]
}], "Text",ExpressionUUID->"6590560e-7a9d-574d-97f6-99f8ede409fb"],

Cell["\<\
This is the most common runtime error. Typical causes and fixes:\
\>", "Text",ExpressionUUID->"37a3c9f6-a70e-0944-a45d-0a892efad1b4"],

Cell[BoxData[
 TemplateBox[<|
  "Summary" -> 
   TemplateBox[<|
     "RowCount" -> 4, "ColumnCount" -> 3, "ColumnTypes" -> 
      Grid[{{"Symptom", "String"}, {"Cause", "String"}, {
         "Fix", "InertExpression"}}, Alignment -> Left], "Backend" -> 
      "Tabular`Backend`WolframKernel", "UUID" -> 
      "Tabular-ab5ba6b6-cc39-4e1f-a97f-fcb7ba8f720b", "Form" -> StandardForm, 
      "Interpretable" -> True|>, "TabularSummary", 
     BaseStyle -> (DynamicUpdating -> True)], "Main" -> TableViewBox[
     Tabular[<|
      "RawSchema" -> <|
        "ColumnProperties" -> <|
          "Symptom" -> <|"ElementType" -> "String"|>, 
           "Cause" -> <|"ElementType" -> "String"|>, 
           "Fix" -> <|"ElementType" -> "InertExpression"|>|>, "KeyColumns" -> 
         None, "Backend" -> "WolframKernel"|>, "Options" -> {}, 
       "BackendData" -> <|"ColumnData" -> DataStructure["ColumnTable", {{
             
             TabularColumn[<|
              "Data" -> {{
                 3, {0, 16, 50, 73, 90}, 
                  "\"Band not found\"\"Image.select: Band ... not \
found\"\"Geometry out of range\"\"Too many pixels\""}, {}, None}, 
               "ElementType" -> "String"|>], 
             
             TabularColumn[<|
              "Data" -> {{
                 3, {0, 49, 84, 110, 150}, 
                  "Selecting a band that does not exist in the imageBand name \
changed after aggregationCoordinates in wrong orderRegion too large for the \
requested scale"}, {}, None}, "ElementType" -> "String"|>], 
             TabularColumn[<|"Data" -> {{
                  Row[{"Check band names with ", 
                    Style[
                    "GEEGetAssetInfo", "Code", "ShowStringCharacters" -> 
                    False]}], 
                  Row[{"Use suffixed names: ", 
                    Style[
                    "\"B4_median\"", "Code", "ShowStringCharacters" -> False],
                     " instead of ", 
                    Style[
                    "\"B4\"", "Code", "ShowStringCharacters" -> False]}], 
                  Row[{"Use ", 
                    Style[
                    "{west, south, east, north}", "Code", 
                    "ShowStringCharacters" -> False], " not ", 
                    Style[
                    "{south, west, north, east}", "Code", 
                    "ShowStringCharacters" -> False]}], 
                  "Reduce bounding box size or increase scale"}, {}, None}, 
               "ElementType" -> "InertExpression", "CachedOriginalExpression" -> {
                 Row[{"Check band names with ", 
                   Style[
                   "GEEGetAssetInfo", "Code", "ShowStringCharacters" -> 
                    False]}], 
                 Row[{"Use suffixed names: ", 
                   Style[
                   "\"B4_median\"", "Code", "ShowStringCharacters" -> False], 
                   " instead of ", 
                   Style["\"B4\"", "Code", "ShowStringCharacters" -> False]}], 
                 Row[{"Use ", 
                   Style[
                   "{west, south, east, north}", "Code", 
                    "ShowStringCharacters" -> False], " not ", 
