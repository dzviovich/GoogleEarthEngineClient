Cell[CellGroupData[{

Cell["11. Crop Classification Training Data Extraction", "Section",ExpressionUUID->"73e07558-e4bf-a242-92e7-9f20164aca70"],

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{
   "Extract", " ", "spectral", " ", "signatures", " ", "by", " ", "land", " ",
     "cover", " ", "type", " ", "from", " ", "CDL"}], " ", "*)"}], "\n", 
  RowBox[{
   RowBox[{
    RowBox[{"bbox", " ", "=", " ", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"-", "93.5"}], ",", " ", "41.5", ",", " ", 
       RowBox[{"-", "93.0"}], ",", " ", "42.0"}], "}"}]}], ";"}], "\n", "\n", 
   RowBox[{"s2", " ", "=", "\n", "    ", 
    RowBox[{
    "GEECollection", "[", "\"\<COPERNICUS/S2_SR_HARMONIZED\>\"", "]"}]}], "\n",
    "    ", 
   RowBox[{"//", " ", 
    RowBox[{"GEEFilterDate", "[", 
     RowBox[{"\"\<2023-07-01\>\"", ",", " ", "\"\<2023-08-01\>\""}], "]"}]}], 
   "\n", "    ", 
   RowBox[{"//", " ", 
    RowBox[{"GEEFilterBounds", "[", "bbox", "]"}]}], "\n", "    ", 
   RowBox[{"//", " ", "GEEMedian"}], "\n", "    ", 
   RowBox[{
    RowBox[{"//", " ", 
     RowBox[{"GEESelectBands", "[", 
      RowBox[{"{", 
       RowBox[{"\"\<B2\>\"", ",", " ", "\"\<B3\>\"", ",", " ", "\"\<B4\>\"", ",",
         " ", "\"\<B8\>\"", ",", " ", "\"\<B11\>\"", ",", 
        " ", "\"\<B12\>\""}], "}"}], "]"}]}], ";"}], "\n", "\n", 
   RowBox[{"(*", " ", 
    RowBox[{"Sample", " ", "random", " ", "pixels"}], " ", "*)"}], "\n", 
   RowBox[{
    RowBox[{"samples", " ", "=", " ", 
     RowBox[{"GEECompute", "[", 
      RowBox[{"GEESample", "[", 
       RowBox[{"s2", ",", " ", 
        RowBox[{"GEEGeometry", "[", "bbox", "]"}], ",", " ", "100"}], "]"}], 
      "]"}]}], ";"}], "\n", "\n", 
   RowBox[{"(*", " ", 
    RowBox[{
    "Convert", " ", "to", " ", "Dataset", " ", "for", " ", "analysis"}], " ", 
    "*)"}], "\n", 
   RowBox[{
