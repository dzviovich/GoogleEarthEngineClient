      RowBox[{"-", "104.9"}], ",", " ", "40.1"}], "}"}]}], ";"}], "\n"}], "\n", 
 RowBox[{"ndvi", " ", "=", "\n", "    ", 
  RowBox[{
  "GEECollection", "[", "\"\<COPERNICUS/S2_SR_HARMONIZED\>\"", "]"}]}], "\n", 
 RowBox[{"    ", 
  RowBox[{"//", " ", 
   RowBox[{"GEEFilterDate", "[", 
    RowBox[{"\"\<2023-07-01\>\"", ",", " ", "\"\<2023-08-01\>\""}], 
