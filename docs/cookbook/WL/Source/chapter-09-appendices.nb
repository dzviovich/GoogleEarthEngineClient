                  Style[
                  "GEECollectionSum", "Code", "ShowStringCharacters" -> 
                   False]}, {}, None}, "ElementType" -> "InertExpression", 
               "CachedOriginalExpression" -> {
                 Style["GEEMedian", "Code", "ShowStringCharacters" -> False], 
                 Style["GEEMean", "Code", "ShowStringCharacters" -> False], 
                 Style[
                 "GEECollectionMin", "Code", "ShowStringCharacters" -> False], 
                 Style[
                 "GEECollectionMax", "Code", "ShowStringCharacters" -> False], 
                 Style[
                 "GEECollectionSum", "Code", "ShowStringCharacters" -> 
                  False]}|>], 
             TabularColumn[<|"Data" -> {{
                  Row[{
                    Style["B4", "Code", "ShowStringCharacters" -> False], 
                    " becomes ", 
                    Style[
                    "B4_median", "Code", "ShowStringCharacters" -> False]}], 
                  Row[{
                    Style["B4", "Code", "ShowStringCharacters" -> False], 
                    " becomes ", 
                    Style[
                    "B4_mean", "Code", "ShowStringCharacters" -> False]}], 
                  Row[{
                    Style["B4", "Code", "ShowStringCharacters" -> False], 
                    " becomes ", 
                    Style[
                    "B4_min", "Code", "ShowStringCharacters" -> False]}], 
                  Row[{
                    Style["B4", "Code", "ShowStringCharacters" -> False], 
                    " becomes ", 
                    Style[
                    "B4_max", "Code", "ShowStringCharacters" -> False]}], 
                  Row[{
                    Style["B4", "Code", "ShowStringCharacters" -> False], 
                    " becomes ", 
                    Style[
                    "B4_sum", "Code", "ShowStringCharacters" -> False]}]}, {},
                  None}, "ElementType" -> "InertExpression", 
               "CachedOriginalExpression" -> {
                 Row[{
                   Style["B4", "Code", "ShowStringCharacters" -> False], 
                   " becomes ", 
                   Style[
                   "B4_median", "Code", "ShowStringCharacters" -> False]}], 
                 Row[{
                   Style["B4", "Code", "ShowStringCharacters" -> False], 
                   " becomes ", 
                   Style[
                   "B4_mean", "Code", "ShowStringCharacters" -> False]}], 
                 Row[{
                   Style["B4", "Code", "ShowStringCharacters" -> False], 
                   " becomes ", 
                   Style["B4_min", "Code", "ShowStringCharacters" -> False]}], 
                 Row[{
                   Style["B4", "Code", "ShowStringCharacters" -> False], 
                   " becomes ", 
                   Style["B4_max", "Code", "ShowStringCharacters" -> False]}], 
                 Row[{
                   Style["B4", "Code", "ShowStringCharacters" -> False], 
