Cell[CellGroupData[{

Cell["5. Time Series Extraction (Monthly Loop Pattern)", "Section",ExpressionUUID->"5119e32a-f621-f54b-b644-193f844b3ea3"],

Cell["\<\
Use this to build per-month statistics for trend analysis or seasonal \
decomposition.\
\>", "Text",ExpressionUUID->"6403a2d1-a7c5-b74f-8d0e-e58d01ff4dce"],

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"bbox", " ", "=", " ", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{"-", "93.3"}], ",", " ", "41.5", ",", " ", 
      RowBox[{"-", "93.1"}], ",", " ", "41.7"}], "}"}]}], ";"}], "\n", 
  RowBox[{"(*", " ", 
   RowBox[{
   "Month", " ", "13", " ", "normalizes", " ", "to", " ", "January", " ", 
    "of", " ", "next", " ", "year"}], " ", "*)"}]}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"months", " ", "=", " ", 
    RowBox[{"Table", "[", "\n", "    ", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{
        RowBox[{"DateString", "[", 
         RowBox[{
          RowBox[{"{", 
           RowBox[{"2023", ",", " ", "m", ",", " ", "1"}], "}"}], ",", 
          " ", "\"\<ISODate\>\""}], "]"}], ",", "\n", "     ", 
        RowBox[{"DateString", "[", 
         RowBox[{
          RowBox[{"{", 
           RowBox[{"2023", ",", " ", 
            RowBox[{"m", " ", "+", " ", "1"}], ",", " ", "1"}], "}"}], ",", 
          " ", "\"\<ISODate\>\""}], "]"}]}], "}"}], ",", "\n", "    ", 
      RowBox[{"{", 
       RowBox[{"m", ",", " ", "1", ",", " ", "12"}], "}"}]}], "\n", "]"}]}], 
   ";"}], "\n"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"monthlyNDVI", " ", "=", " ", 
    RowBox[{"Table", "[", "\n", "    ", 
     RowBox[{
      RowBox[{"Module", "[", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{"img", ",", " ", "result"}], "}"}], ",", "\n", "        ", 
        RowBox[{
         RowBox[{"img", " ", "=", "\n", "            ", 
          RowBox[{
           RowBox[{
            RowBox[{
             RowBox[{
              RowBox[{
              "GEECollection", "[", "\"\<COPERNICUS/S2_SR_HARMONIZED\>\"", 
               "]"}], "\n", "            ", "//", " ", 
              RowBox[{"GEEFilterDate", "[", 
               RowBox[{"start", ",", " ", "end"}], "]"}]}], "\n", 
             "            ", "//", " ", 
             RowBox[{"GEEFilterBounds", "[", "bbox", "]"}]}], "\n", 
            "            ", "//", " ", "GEEMedian"}], "\n", "            ", "//",
            " ", 
           RowBox[{"GEENormalizedDifference", "[", 
            RowBox[{"{", 
             RowBox[{"\"\<B8\>\"", ",", " ", "\"\<B4\>\""}], "}"}], "]"}]}]}],
          ";", "\n", "        ", 
         RowBox[{"result", " ", "=", " ", 
          RowBox[{"GEECompute", "[", 
           RowBox[{"GEEReduceRegion", "[", 
            RowBox[{"img", ",", " ", 
             RowBox[{"GEEGeometry", "[", "bbox", "]"}], ",", 
             " ", "\"\<mean\>\"", ",", " ", "100"}], "]"}], "]"}]}], ";", 
         "\n", "        ", 
         RowBox[{"result", "[", "\"\<nd\>\"", "]"}]}]}], "\n", "    ", "]"}], 
      ",", "\n", "    ", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{"start", ",", " ", "end"}], "}"}], ",", " ", "months"}], 
       "}"}]}], "\n", "]"}]}], ";"}], "\n"}], "\n", 
 RowBox[{"DateListPlot", "[", "\n", "    ", 
  RowBox[{
   RowBox[{"TimeSeries", "[", 
    RowBox[{"monthlyNDVI", ",", " ", 
     RowBox[{"{", 
      RowBox[{"DateObject", " ", "/@", " ", 
       RowBox[{"months", "[", 
        RowBox[{"[", 
         RowBox[{"All", ",", " ", "1"}], "]"}], "]"}]}], "}"}]}], "]"}], ",", 
   "\n", "    ", 
   RowBox[{"PlotLabel", " ", "->", " ", "\"\<Monthly Mean NDVI\>\""}], ",", 
   "\n", "    ", 
   RowBox[{"FrameLabel", " ", "->", " ", 
    RowBox[{"{", 
     RowBox[{"\"\<Date\>\"", ",", " ", "\"\<NDVI\>\""}], "}"}]}]}], "\n", 
  "]"}]}], "Input",ExpressionUUID->"d8a6205b-282f-044e-9428-a1994eaa0fc3"]
}, Open  ]],

