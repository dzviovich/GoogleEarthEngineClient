Cell[CellGroupData[{

Cell["4. Cloud Masking with SCL Band", "Section",ExpressionUUID->"ac18abfe-a93a-504a-8772-66b07cc2ff41"],

Cell["\<\
Use this for cloud-free composites where per-image masking is needed.\
\>", "Text",ExpressionUUID->"b6d98d2b-a3e2-d049-aa0e-9f2fdabda148"],

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{
    RowBox[{"Define", " ", "a", " ", "cloud"}], "-", 
    RowBox[{
    "masking", " ", "function", " ", "using", " ", "the", " ", "Scene", " ", 
     "Classification", " ", "Layer"}]}], " ", "*)"}], "\n", 
  RowBox[{
   RowBox[{
    RowBox[{
     RowBox[{"maskClouds", "[", "img_", "]"}], " ", ":=", "\n", "    ", 
     RowBox[{"Module", "[", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{"scl", ",", " ", "mask"}], "}"}], ",", "\n", "        ", 
       RowBox[{
        RowBox[{"scl", " ", "=", " ", 
         RowBox[{"img", " ", "//", " ", 
          RowBox[{"GEESelectBands", "[", 
           RowBox[{"{", "\"\<SCL\>\"", "}"}], "]"}]}]}], ";", "\n", 
        "        ", 
        RowBox[{"(*", " ", 
         RowBox[{
          RowBox[{
           RowBox[{"SCL", " ", "values", " ", "3"}], "=", 
           RowBox[{"cloud", " ", "shadow"}]}], ",", " ", 
          RowBox[{"8", "=", 
           RowBox[{"cloud", " ", "medium"}]}], ",", " ", 
          RowBox[{"9", "=", 
           RowBox[{"cloud", " ", "high"}]}], ",", " ", 
          RowBox[{"10", "=", "cirrus"}]}], " ", "*)"}], "\n", "        ", 
        RowBox[{"mask", " ", "=", "\n", "            ", 
         RowBox[{
          RowBox[{
           RowBox[{
            RowBox[{"scl", " ", "//", " ", 
             RowBox[{"GEENotEquals", "[", "3", "]"}]}], "\n", "            ", 
            "//", " ", 
            RowBox[{"GEEAnd", "[", 
             RowBox[{"scl", " ", "//", " ", 
              RowBox[{"GEENotEquals", "[", "8", "]"}]}], "]"}]}], "\n", 
           "            ", "//", " ", 
           RowBox[{"GEEAnd", "[", 
            RowBox[{"scl", " ", "//", " ", 
             RowBox[{"GEENotEquals", "[", "9", "]"}]}], "]"}]}], "\n", 
          "            ", "//", " ", 
          RowBox[{"GEEAnd", "[", 
           RowBox[{"scl", " ", "//", " ", 
            RowBox[{"GEENotEquals", "[", "10", "]"}]}], "]"}]}]}], ";", "\n", 
        "        ", 
        RowBox[{"img", " ", "//", " ", 
         RowBox[{"GEEUpdateMask", "[", "mask", "]"}]}]}]}], "\n", "    ", 
      "]"}]}], ";"}], "\n", "\n", 
   RowBox[{
    RowBox[{"bbox", " ", "=", " ", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"-", "122.5"}], ",", " ", "37.7", ",", " ", 
       RowBox[{"-", "122.3"}], ",", " ", "37.9"}], "}"}]}], ";"}], "\n", "\n", 
   RowBox[{"composite", " ", "=", "\n", "    ", 
    RowBox[{
    "GEECollection", "[", "\"\<COPERNICUS/S2_SR_HARMONIZED\>\"", "]"}]}], "\n",
    "    ", 
   RowBox[{"//", " ", 
    RowBox[{"GEEFilterDate", "[", 
     RowBox[{"\"\<2023-01-01\>\"", ",", " ", "\"\<2023-12-31\>\""}], "]"}]}], 
   "\n", "    ", 
   RowBox[{"//", " ", 
    RowBox[{"GEEFilterBounds", "[", "bbox", "]"}]}], "\n", "    ", 
   RowBox[{"//", " ", 
    RowBox[{"GEECollectionMap", "[", "maskClouds", "]"}]}], "\n", "    ", 
   RowBox[{"//", " ", 
    RowBox[{"GEESelectBands", "[", 
     RowBox[{"{", 
      RowBox[{"\"\<B4\>\"", ",", " ", "\"\<B3\>\"", ",", " ", "\"\<B2\>\""}], 
      "}"}], "]"}]}], "\n", "    ", 
   RowBox[{"//", " ", "GEEMedian"}], "\n", "    ", 
   RowBox[{
    RowBox[{"//", " ", 
     RowBox[{"GEEVisualize", "[", 
      RowBox[{"<|", 
       RowBox[{
        RowBox[{"\"\<min\>\"", " ", "->", " ", "0"}], ",", " ", 
