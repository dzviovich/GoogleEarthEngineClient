Cell[CellGroupData[{

Cell["3. Land Surface Temperature (Landsat Thermal)", "Section",ExpressionUUID->"6350d6e4-5a1d-fc47-aea7-a1c0bb96c8ca"],

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"bbox", " ", "=", " ", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{"-", "118.5"}], ",", " ", "33.8", ",", " ", 
      RowBox[{"-", "118.1"}], ",", " ", "34.1"}], "}"}]}], ";"}], "\n", "\n", 
  RowBox[{"(*", " ", 
   RowBox[{
    RowBox[{"Landsat", " ", "8", " ", "thermal", " ", "band"}], ",", " ", 
    RowBox[{
     RowBox[{"scale", " ", "factor", " ", "0.00341802"}], " ", "+", " ", 
     "149.0"}], ",", " ", 
    RowBox[{"convert", " ", "K", " ", "to", " ", "C"}]}], " ", "*)"}]}], "\n", 
 RowBox[{"lst", " ", "=", "\n", "    ", 
