Cell[CellGroupData[{

Cell["13. Quality Mosaic (Best-Pixel Selection)", "Section",ExpressionUUID->"485f7cc4-c729-054d-b527-050c1dea6f15"],

Cell["\<\
Use this when you need the single best pixel per location rather than a \
statistical composite.\
\>", "Text",ExpressionUUID->"101af0fe-d3df-7848-ae4d-50caecf2757a"],

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"bbox", " ", "=", " ", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{"-", "122.5"}], ",", " ", "37.5", ",", " ", 
      RowBox[{"-", "121.5"}], ",", " ", "38.0"}], "}"}]}], ";"}], "\n", "\n", 
  RowBox[{"(*", " ", 
   RowBox[{
   "Select", " ", "the", " ", "pixel", " ", "with", " ", "the", " ", 
    "highest", " ", "NDVI", " ", "across", " ", "the", " ", "collection"}], 
   " ", "*)"}]}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"addNDVI", "[", "img_", "]"}], " ", ":=", "\n", "    ", 
    RowBox[{"img", " ", "//", " ", 
     RowBox[{"GEEAddBands", "[", "\n", "        ", 
      RowBox[{
       RowBox[{"img", " ", "//", " ", 
        RowBox[{"GEENormalizedDifference", "[", 
         RowBox[{"{", 
          RowBox[{"\"\<B8\>\"", ",", " ", "\"\<B4\>\""}], "}"}], "]"}]}], " ",
        "//", " ", 
       RowBox[{"GEERename", "[", 
        RowBox[{"{", "\"\<NDVI\>\"", "}"}], "]"}]}], "\n", "    ", "]"}]}]}], 
   ";"}], "\n"}], "\n", 
 RowBox[{"bestPixel", " ", "=", "\n", "    ", 
  RowBox[{
  "GEECollection", "[", "\"\<COPERNICUS/S2_SR_HARMONIZED\>\"", "]"}]}], "\n", 
 RowBox[{"    ", 
  RowBox[{"//", " ", 
   RowBox[{"GEEFilterDate", "[", 
    RowBox[{"\"\<2023-06-01\>\"", ",", " ", "\"\<2023-09-01\>\""}], 
    "]"}]}]}], "\n", 
 RowBox[{"    ", 
  RowBox[{"//", " ", 
   RowBox[{"GEEFilterBounds", "[", "bbox", "]"}]}]}], "\n", 
 RowBox[{"    ", 
  RowBox[{"//", " ", 
   RowBox[{"GEEFilterProperty", "[", 
    RowBox[{"\"\<CLOUDY_PIXEL_PERCENTAGE\>\"", ",", " ", "\"\<LessThan\>\"", ",",
      " ", "30"}], "]"}]}]}], "\n", 
 RowBox[{"    ", 
  RowBox[{"//", " ", 
   RowBox[{"GEECollectionMap", "[", "addNDVI", "]"}]}]}], "\n", 
 RowBox[{"    ", 
  RowBox[{"//", " ", 
   RowBox[{"GEEQualityMosaic", "[", "\"\<NDVI\>\"", "]"}]}]}], "\n", 
 RowBox[{"    ", 
  RowBox[{"//", " ", 
   RowBox[{"GEESelectBands", "[", 
    RowBox[{"{", 
     RowBox[{"\"\<B4\>\"", ",", " ", "\"\<B3\>\"", ",", " ", "\"\<B2\>\""}], 
     "}"}], "]"}]}]}], "\n", 
 RowBox[{"    ", 
  RowBox[{
   RowBox[{"//", " ", 
    RowBox[{"GEEVisualize", "[", 
     RowBox[{"<|", 
      RowBox[{
       RowBox[{"\"\<min\>\"", " ", "->", " ", "0"}], ",", " ", 
       RowBox[{"\"\<max\>\"", " ", "->", " ", "3000"}]}], "|>"}], "]"}]}], 
   ";"}], "\n"}], "\n", 
 RowBox[{"GEEComputePixels", "[", 
  RowBox[{"bbox", ",", " ", "bestPixel"}], "]"}]}], "Input",ExpressionUUID->\
"254e627d-03a3-f54a-8435-93528efcb8d0"]
}, Open  ]],

Cell[CellGroupData[{

Cell["14. Clipping to Custom Polygon", "Section",ExpressionUUID->"d5a5dd2f-92d5-4f49-bd18-34bbcfcd9d28"],

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{"Define", " ", "a", " ", "custom", " ", "polygon", " ", 
    RowBox[{"(", 
     RowBox[{
      RowBox[{"e", ".", "g", "."}], ",", " ", 
      RowBox[{"a", " ", "park", " ", "boundary"}]}], ")"}]}], " ", "*)"}], 
  "\n", 
  RowBox[{
   RowBox[{
    RowBox[{"parkBoundary", " ", "=", " ", 
     RowBox[{"GEEPolygon", "[", 
      RowBox[{"{", "\n", "    ", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{
          RowBox[{"-", "105.60"}], ",", " ", "40.35"}], "}"}], ",", " ", 
        RowBox[{"{", 
         RowBox[{
          RowBox[{"-", "105.50"}], ",", " ", "40.40"}], "}"}], ",", " ", 
        RowBox[{"{", 
         RowBox[{
          RowBox[{"-", "105.45"}], ",", " ", "40.38"}], "}"}], ",", "\n", 
        "    ", 
        RowBox[{"{", 
         RowBox[{
          RowBox[{"-", "105.48"}], ",", " ", "40.30"}], "}"}], ",", " ", 
        RowBox[{"{", 
         RowBox[{
          RowBox[{"-", "105.58"}], ",", " ", "40.30"}], "}"}], ",", " ", 
        RowBox[{"{", 
         RowBox[{
          RowBox[{"-", "105.60"}], ",", " ", "40.35"}], "}"}]}], "\n", "}"}], 
      "]"}]}], ";"}], "\n", "\n", 
   RowBox[{"dem", " ", "=", "\n", "    ", 
    RowBox[{"GEELoadImage", "[", "\"\<USGS/SRTMGL1_003\>\"", "]"}]}], "\n", 
   "    ", 
   RowBox[{"//", " ", 
    RowBox[{"GEEClip", "[", "parkBoundary", "]"}]}], "\n", "    ", 
   RowBox[{
    RowBox[{"//", " ", 
     RowBox[{"GEEVisualize", "[", 
      RowBox[{"<|", "\n", "        ", 
       RowBox[{
        RowBox[{"\"\<min\>\"", " ", "->", " ", "2400"}], ",", " ", 
        RowBox[{"\"\<max\>\"", " ", "->", " ", "4000"}], ",", "\n", 
        "        ", 
        RowBox[{"\"\<palette\>\"", " ", "->", " ", 
         RowBox[{"{", 
          
          RowBox[{"\"\<green\>\"", ",", " ", "\"\<yellow\>\"", ",", 
           " ", "\"\<brown\>\"", ",", " ", "\"\<white\>\""}], "}"}]}]}], "\n",
        "    ", "|>"}], "]"}]}], ";"}], "\n", "\n", 
   RowBox[{"GEEComputePixels", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
       RowBox[{"-", "105.65"}], ",", " ", "40.28", ",", " ", 
       RowBox[{"-", "105.40"}], ",", " ", "40.42"}], "}"}], ",", " ", "dem"}],
     "]"}]}]}]], "Input",ExpressionUUID->"9a5d6b9d-4e27-3b49-a1fe-\
ebf420fdff77"]
}, Open  ]],

Cell[CellGroupData[{

Cell["15. Band Math with Expression (EVI Formula)", "Section",ExpressionUUID->"a5d63aa8-516c-b440-8555-0b5884d62536"],

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"bbox", " ", "=", " ", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{"-", "95.5"}], ",", " ", "29.5", ",", " ", 
      RowBox[{"-", "95.0"}], ",", " ", "30.0"}], "}"}]}], ";"}], "\n"}], "\n", 
 RowBox[{"s2", " ", "=", "\n", "    ", 
  RowBox[{
  "GEECollection", "[", "\"\<COPERNICUS/S2_SR_HARMONIZED\>\"", "]"}]}], "\n", 
 RowBox[{"    ", 
  RowBox[{"//", " ", 
   RowBox[{"GEEFilterDate", "[", 
    RowBox[{"\"\<2023-07-01\>\"", ",", " ", "\"\<2023-08-01\>\""}], 
    "]"}]}]}], "\n", 
 RowBox[{"    ", 
  RowBox[{"//", " ", 
   RowBox[{"GEEFilterBounds", "[", "bbox", "]"}]}]}], "\n", 
 RowBox[{"    ", 
  RowBox[{
   RowBox[{"//", " ", "GEEMedian"}], ";"}], "\n", "\n", 
  RowBox[{"(*", " ", 
   RowBox[{"Enhanced", " ", "Vegetation", " ", "Index"}], " ", "*)"}]}], "\n", 
 RowBox[{"evi", " ", "=", "\n", "    ", 
  RowBox[{"s2", " ", "//", " ", 
   RowBox[{"GEEExpression", "[", "\n", "        ", 
    RowBox[{"\"\<2.5 * ((NIR - RED) / (NIR + 6 * RED - 7.5 * BLUE + 1))\>\"", 
     ",", "\n", "        ", 
     RowBox[{"<|", 
      RowBox[{
       RowBox[{"\"\<NIR\>\"", " ", "->", " ", "\"\<B8\>\""}], ",", " ", 
       RowBox[{"\"\<RED\>\"", " ", "->", " ", "\"\<B4\>\""}], ",", " ", 
       RowBox[{"\"\<BLUE\>\"", " ", "->", " ", "\"\<B2\>\""}]}], "|>"}]}], 
    "\n", "    ", "]"}]}]}], "\n", 
 RowBox[{"    ", 
  RowBox[{
   RowBox[{"//", " ", 
    RowBox[{"GEEVisualize", "[", 
     RowBox[{"<|", "\n", "        ", 
      RowBox[{
       RowBox[{"\"\<min\>\"", " ", "->", " ", 
        RowBox[{"-", "0.1"}]}], ",", " ", 
       RowBox[{"\"\<max\>\"", " ", "->", " ", "0.7"}], ",", "\n", "        ", 
       RowBox[{"\"\<palette\>\"", " ", "->", " ", 
        RowBox[{"{", 
         RowBox[{"\"\<brown\>\"", ",", " ", "\"\<yellow\>\"", ",", 
          " ", "\"\<green\>\"", ",", " ", "\"\<darkgreen\>\""}], "}"}]}]}], 
      "\n", "    ", "|>"}], "]"}]}], ";"}], "\n"}], "\n", 
 RowBox[{"GEEComputePixels", "[", 
  RowBox[{"bbox", ",", " ", "evi"}], "]"}]}], "Input",ExpressionUUID->\
"7a006e0a-4ac8-2f42-b483-b6b8e4d7cbf8"],

Cell["", "Text",
 CellFrame->{{0, 0}, {0, 
  1}},ExpressionUUID->"4b2bed9f-902e-354c-9d22-647c596ce5f9"]
}, Open  ]]
