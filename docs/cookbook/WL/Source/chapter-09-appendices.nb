Cell[TextData[{
 Cell["GEEComputePixels::notimage", "InlineCode",ExpressionUUID->
  "507e303d-54cb-2748-aef1-283cebbbc396"],
 StyleBox[" -- Server returned non-image content",
  FontWeight->Bold]
}], "Text",ExpressionUUID->"a83e3652-fd73-6341-a999-7f8ad4f91f33"],

Cell["\<\
The server returned an error document instead of image bytes. Usually means \
the expression produced no data (empty collection after filtering, fully \
masked region).\
\>", "Text",ExpressionUUID->"8fd82719-cb8a-a74f-9b81-2240b9059c9d"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Band Name Suffixes After Aggregation", "Section",ExpressionUUID->"bddc61df-2f46-7c46-b31c-cac77a4722d9"],

Cell["\<\
When you apply a reducer to a collection, band names gain a suffix:\
\>", "Text",ExpressionUUID->"29388b1b-20bf-6f40-8de1-15779f3455cc"],

Cell[BoxData[
 TemplateBox[<|
  "Summary" -> 
   TemplateBox[<|
     "RowCount" -> 5, "ColumnCount" -> 2, "ColumnTypes" -> 
      Grid[{{"Reducer", "InertExpression"}, {
         "Suffix Example", "InertExpression"}}, Alignment -> Left], "Backend" -> 
      "Tabular`Backend`WolframKernel", "UUID" -> 
      "Tabular-64d0309e-6a2f-472a-b628-7889b8ff4806", "Form" -> StandardForm, 
      "Interpretable" -> True|>, "TabularSummary", 
     BaseStyle -> (DynamicUpdating -> True)], "Main" -> TableViewBox[
     Tabular[<|
      "RawSchema" -> <|
        "ColumnProperties" -> <|
          "Reducer" -> <|"ElementType" -> "InertExpression"|>, 
           "Suffix Example" -> <|"ElementType" -> "InertExpression"|>|>, 
         "KeyColumns" -> None, "Backend" -> "WolframKernel"|>, 
       "Options" -> {}, 
       "BackendData" -> <|"ColumnData" -> DataStructure["ColumnTable", {{
             TabularColumn[<|"Data" -> {{
                  Style["GEEMedian", "Code", "ShowStringCharacters" -> False], 
                  Style["GEEMean", "Code", "ShowStringCharacters" -> False], 
                  Style[
                  "GEECollectionMin", "Code", "ShowStringCharacters" -> 
                   False], 
                  Style[
                  "GEECollectionMax", "Code", "ShowStringCharacters" -> 
