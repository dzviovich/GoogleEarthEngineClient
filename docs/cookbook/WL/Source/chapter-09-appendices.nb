Cell[CellGroupData[{

Cell["Appendix A: Function Quick Reference", "Chapter",ExpressionUUID->"0a7dfe92-5377-0148-b4aa-1bce350156a6"],

Cell[TextData[{
 "All public functions in the GoogleEarthEngineClient paclet, organized by \
category. The ",
 StyleBox["Operator",
  FontWeight->Bold],
 " column indicates whether the function supports a curried form for use with \
",
 Cell["//", "InlineCode",ExpressionUUID->
  "b84340e0-c85d-a14a-b667-87383f758d40"],
 " (postfix application)."
}], "Text",ExpressionUUID->"32b5e3e9-85e7-e541-9a44-fee892dee75e"],

Cell[TextData[{
 StyleBox["No",
  FontWeight->Bold],
 " = direct form only; ",
 StyleBox["N/A",
  FontWeight->Bold],
 " = zero-argument or variable; ",
 StyleBox["Yes",
  FontWeight->Bold],
 " = supports curried ",
 Cell["//", "InlineCode",ExpressionUUID->
  "2e214084-71ee-f44a-8f6a-5a3a8f26cb37"],
 " form."
}], "Text",ExpressionUUID->"63e1ef48-907c-3746-9f71-dfeb47d7e530"],

