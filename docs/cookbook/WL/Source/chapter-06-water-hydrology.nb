Cell[CellGroupData[{

Cell["6.3 Flood Mapping", "Chapter",ExpressionUUID->"ba632468-9f8e-c14e-bab9-15e0d8668c70"],

Cell[CellGroupData[{

Cell["SAR-Based Flood Detection", "Section",ExpressionUUID->"ab5f3b2f-2b52-2744-a754-dfc31a293d1e"],

Cell["\<\
Synthetic Aperture Radar (Sentinel-1) is the workhorse of flood mapping \
because it operates at microwave wavelengths that penetrate clouds and work \
day or night. For an introduction to Sentinel-1 SAR imagery and \
dual-polarization composites, see Section 2.5 (Sentinel-1 SAR). Over calm \
floodwater, the radar signal reflects away from the sensor (specular \
reflection), producing a characteristic drop in backscatter. This drop -- \
typically 3 dB or more in the VV polarization -- is the primary signal for \
flood detection.\
\>", "Text",ExpressionUUID->"6db4fd96-4d80-e242-8ba6-1f7334e1510d"],

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{
    RowBox[{"Example", ":", " ", 
     RowBox[{"Emilia", "-", 
      RowBox[{"Romagna", " ", "floods"}]}]}], ",", " ", "Italy", ",", " ", 
    RowBox[{"May", " ", "2023"}]}], " ", "*)"}], "\n", 
  RowBox[{
   RowBox[{
    RowBox[{"floodBox", " ", "=", " ", 
     RowBox[{"{", 
      RowBox[{"11.8", ",", " ", "44.1", ",", " ", "12.4", ",", " ", "44.5"}], 
      "}"}]}], ";"}], "\n", "\n", 
   RowBox[{"(*", " ", 
    RowBox[{"Pre", "-", 
     RowBox[{"flood", " ", 
      RowBox[{"baseline", ":", " ", 
       RowBox[{"January", " ", "2023"}]}]}]}], " ", "*)"}], "\n", 
   RowBox[{
    RowBox[{"preSAR", " ", "=", "\n", "  ", 
     RowBox[{
      RowBox[{
       RowBox[{
        RowBox[{
         RowBox[{
          RowBox[{"GEECollection", "[", "\"\<COPERNICUS/S1_GRD\>\"", "]"}], 
          " ", "//", "\n", "    ", 
          RowBox[{"GEEFilterDate", "[", 
           RowBox[{"\"\<2023-01-01\>\"", ",", " ", "\"\<2023-02-01\>\""}], 
           "]"}]}], " ", "//", "\n", "    ", 
         RowBox[{"GEEFilterBounds", "[", "floodBox", "]"}]}], " ", "//", "\n",
         "    ", 
        RowBox[{"GEEFilterProperty", "[", 
         RowBox[{"\"\<instrumentMode\>\"", ",", " ", "\"\<Equals\>\"", ",", 
          " ", "\"\<IW\>\""}], "]"}]}], " ", "//", "\n", "    ", 
       RowBox[{"GEESelectBands", "[", 
        RowBox[{"{", "\"\<VV\>\"", "}"}], "]"}]}], " ", "//", "\n", "    ", 
      "GEEMedian"}]}], ";"}], "\n", "\n", 
   RowBox[{"(*", " ", 
    RowBox[{"Post", "-", 
     RowBox[{"flood", ":", " ", 
      RowBox[{"May", " ", "2023"}]}]}], " ", "*)"}], "\n", 
   RowBox[{
    RowBox[{"postSAR", " ", "=", "\n", "  ", 
     RowBox[{
      RowBox[{
       RowBox[{
        RowBox[{
         RowBox[{
          RowBox[{"GEECollection", "[", "\"\<COPERNICUS/S1_GRD\>\"", "]"}], 
          " ", "//", "\n", "    ", 
          RowBox[{"GEEFilterDate", "[", 
           RowBox[{"\"\<2023-05-15\>\"", ",", " ", "\"\<2023-05-25\>\""}], 
           "]"}]}], " ", "//", "\n", "    ", 
         RowBox[{"GEEFilterBounds", "[", "floodBox", "]"}]}], " ", "//", "\n",
         "    ", 
        RowBox[{"GEEFilterProperty", "[", 
         RowBox[{"\"\<instrumentMode\>\"", ",", " ", "\"\<Equals\>\"", ",", 
          " ", "\"\<IW\>\""}], "]"}]}], " ", "//", "\n", "    ", 
       RowBox[{"GEESelectBands", "[", 
        RowBox[{"{", "\"\<VV\>\"", "}"}], "]"}]}], " ", "//", "\n", "    ", 
      "GEEMedian"}]}], ";"}], "\n", "\n", 
   RowBox[{"(*", " ", 
    RowBox[{"SAR", " ", "backscatter", " ", "change", " ", 
     RowBox[{"(", "dB", ")"}]}], " ", "*)"}], "\n", 
   RowBox[{
    RowBox[{"sarChange", " ", "=", " ", 
     RowBox[{"GEESubtract", "[", 
      RowBox[{"postSAR", ",", " ", "preSAR"}], "]"}]}], ";"}], "\n", "\n", 
   RowBox[{"(*", " ", 
    RowBox[{
     RowBox[{
      RowBox[{"Visualize", " ", "the", " ", 
       RowBox[{"change", ":", " ", "red"}]}], " ", "=", " ", 
      RowBox[{"decrease", " ", 
       RowBox[{"(", "flooding", ")"}]}]}], ",", " ", 
     RowBox[{"blue", " ", "=", " ", "increase"}]}], " ", "*)"}], "\n", 
   RowBox[{"changeImage", " ", "=", " ", 
    RowBox[{"GEEComputePixels", "[", 
     RowBox[{"floodBox", ",", " ", "sarChange", ",", "\n", "  ", 
      RowBox[{"\"\<VisParams\>\"", " ", "->", " ", 
       RowBox[{"<|", 
        RowBox[{
         RowBox[{"\"\<min\>\"", " ", "->", " ", 
          RowBox[{"-", "10"}]}], ",", " ", 
         RowBox[{"\"\<max\>\"", " ", "->", " ", "10"}], ",", "\n", "    ", 
         RowBox[{"\"\<palette\>\"", " ", "->", " ", 
          RowBox[{"{", 
           
           RowBox[{"\"\<#FF0000\>\"", ",", " ", "\"\<#FFFFFF\>\"", ",", 
            " ", "\"\<#0000FF\>\""}], "}"}]}]}], "|>"}]}]}], 
     "]"}]}]}]}]], "Input",ExpressionUUID->"d153e114-a59c-5245-accb-\
670605167b44"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Thresholding to Extract Flood Extent", "Section",ExpressionUUID->"d6debebb-a72f-504b-ae0a-5c20ee3043be"],

Cell["\<\
A backscatter decrease of 3 dB or more is a conservative threshold for \
identifying flooded pixels. This threshold is physically motivated: specular \
reflection from still water surfaces causes a sharp drop in received power.\
\>", "Text",ExpressionUUID->"e82753fd-81c0-4646-a656-700b6a6bea26"],

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{"Identify", " ", "flooded", " ", 
    RowBox[{"pixels", ":", " ", 
     RowBox[{
     "backscatter", " ", "dropped", " ", "by", " ", "more", " ", "than", " ", 
      "3", " ", "dB"}]}]}], " ", "*)"}], "\n", 
  RowBox[{
   RowBox[{
    RowBox[{"floodMask", " ", "=", " ", 
     RowBox[{
      RowBox[{"sarChange", " ", "//", "\n", "  ", 
       RowBox[{"GEELessThan", "[", 
        RowBox[{"-", "3"}], "]"}]}], " ", "//", "\n", "  ", "GEESelfMask"}]}],
     ";"}], "\n", "\n", 
   RowBox[{"floodImage", " ", "=", " ", 
    RowBox[{"GEEComputePixels", "[", 
     RowBox[{"floodBox", ",", " ", "floodMask", ",", "\n", "  ", 
      RowBox[{"\"\<VisParams\>\"", " ", "->", " ", 
       RowBox[{"<|", 
        RowBox[{
         RowBox[{"\"\<min\>\"", " ", "->", " ", "0"}], ",", " ", 
         RowBox[{"\"\<max\>\"", " ", "->", " ", "1"}], ",", "\n", "    ", 
         RowBox[{"\"\<palette\>\"", " ", "->", " ", 
          RowBox[{"{", "\"\<#FF4444\>\"", "}"}]}]}], "|>"}]}]}], 
     "]"}]}]}]}]], "Input",ExpressionUUID->"9d269f8c-ce80-b946-b0f6-\
a4438327f1ae"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Computing Flood Extent Area", "Section",ExpressionUUID->"a646630f-9f5f-a04a-96e8-d4492551da14"],

Cell["\<\
Multiply the binary flood mask by pixel area and sum over the region to get \
the total flooded area in square meters, then convert to square kilometers.\
\>", "Text",ExpressionUUID->"cd5bebb4-f1ca-3948-8890-4a707c51ddd4"],

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"floodGeom", " ", "=", " ", 
    RowBox[{"GEEGeometry", "[", "floodBox", "]"}]}], ";"}], "\n"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"floodAreaImage", " ", "=", " ", 
    RowBox[{"floodMask", " ", "//", " ", 
     RowBox[{"GEEMultiply", "[", 
      RowBox[{"GEEPixelArea", "[", "]"}], "]"}]}]}], ";"}], "\n"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"floodStats", " ", "=", " ", 
    RowBox[{"GEECompute", "[", "\n", "  ", 
     RowBox[{"floodAreaImage", " ", "//", " ", 
      RowBox[{"GEEReduceRegion", "[", 
       RowBox[{"floodGeom", ",", " ", "\"\<sum\>\"", ",", " ", "10"}], 
       "]"}]}], "\n", "]"}]}], ";"}], "\n"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"floodAreaKm2", " ", "=", " ", 
    RowBox[{
     RowBox[{"Lookup", "[", 
      RowBox[{"floodStats", ",", " ", "\"\<VV\>\"", ",", " ", "0"}], "]"}], 
     " ", "/", " ", "1.0*^6"}]}], ";"}], "\n", "\n", 
  RowBox[{"(*", " ", 
   RowBox[{"Display", " ", "with", " ", "proper", " ", "units"}], " ", 
   "*)"}]}], "\n", 
 RowBox[{"Quantity", "[", 
  RowBox[{"floodAreaKm2", ",", " ", 
   RowBox[{"\"\<Kilometers\>\"", "^", "2"}]}], "]"}]}], "Input",ExpressionUUID\
->"12d36c8b-5a0e-8f42-a30f-38ee6ddbb640"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Overlay Flood Extent on a Basemap", "Section",ExpressionUUID->"fe4ae537-cbcf-de47-9daa-ed2bc404a363"],

Cell["\<\
Combining flood detection results with Wolfram Language's built-in geographic \
visualization creates publication-quality maps.\
\>", "Text",ExpressionUUID->"69c07a60-78d5-de41-a5a5-59eef0812a9e"],

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{
    RowBox[{
    "Retrieve", " ", "flood", " ", "extent", " ", "as", " ", "a", " ", 
     "geo"}], "-", 
    RowBox[{"tagged", " ", "image"}]}], " ", "*)"}], "\n", 
  RowBox[{
   RowBox[{
    RowBox[{"floodGeoImg", " ", "=", " ", 
     RowBox[{"GEEImage", "[", "\n", "  ", 
      RowBox[{
       RowBox[{"GeoPosition", "[", 
        RowBox[{"{", 
         RowBox[{"44.3", ",", " ", "12.1"}], "}"}], "]"}], ",", "\n", "  ", 
       "floodMask", ",", "\n", "  ", 
       RowBox[{"GeoRange", " ", "->", " ", 
        RowBox[{"Quantity", "[", 
         RowBox[{"30", ",", " ", "\"\<Kilometers\>\""}], "]"}]}], ",", "\n", 
       "  ", 
       RowBox[{"\"\<VisParams\>\"", " ", "->", " ", 
        RowBox[{"<|", 
         RowBox[{
          RowBox[{"\"\<min\>\"", " ", "->", " ", "0"}], ",", " ", 
          RowBox[{"\"\<max\>\"", " ", "->", " ", "1"}], ",", "\n", "    ", 
          RowBox[{"\"\<palette\>\"", " ", "->", " ", 
           RowBox[{"{", "\"\<#FF0000\>\"", "}"}]}]}], "|>"}]}]}], "]"}]}], 
    ";"}], "\n", "\n", 
   RowBox[{"(*", " ", 
    RowBox[{"Overlay", " ", "on", " ", "GeoGraphics", " ", "basemap"}], " ", 
    "*)"}], "\n", 
   RowBox[{"Show", "[", "\n", "  ", 
    RowBox[{
     RowBox[{"GeoGraphics", "[", "\n", "    ", 
      RowBox[{
       RowBox[{"GeoRange", " ", "->", " ", 
        RowBox[{"{", 
         RowBox[{
          RowBox[{"{", 
           RowBox[{"44.1", ",", " ", "44.5"}], "}"}], ",", " ", 
          RowBox[{"{", 
           RowBox[{"11.8", ",", " ", "12.4"}], "}"}]}], "}"}]}], ",", "\n", 
       "    ", 
       RowBox[{"GeoBackground", " ", "->", " ", "\"\<StreetMap\>\""}], ",", 
       "\n", "    ", 
       RowBox[{"ImageSize", " ", "->", " ", "600"}]}], "]"}], ",", "\n", "  ", 
     RowBox[{"Graphics", "[", 
      RowBox[{"Inset", "[", 
       RowBox[{
       "floodGeoImg", ",", " ", "Center", ",", " ", "Center", ",", " ", 
        RowBox[{"Scaled", "[", "1", "]"}]}], "]"}], "]"}]}], "\n", 
    "]"}]}]}]], "Input",ExpressionUUID->"8b28d849-79ca-974e-9cbe-\
1a876dd51026"],

Cell[TextData[{
 "Alternatively, use ",
 Cell["GEEGeoGraphics", "InlineCode",ExpressionUUID->
  "26c46e1f-dd8b-0e4a-a1b8-c180cffb00b1"],
 " to render the flood extent directly on a GEE-sourced background."
}], "Text",ExpressionUUID->"5676443d-d851-4440-8644-c5e1c631e9e5"],

Cell[BoxData[
 RowBox[{"GEEGeoGraphics", "[", "\n", "  ", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{
     RowBox[{"Opacity", "[", "0.5", "]"}], ",", " ", "Red", ",", "\n", "   ", 
     RowBox[{"Text", "[", 
      RowBox[{"\"\<Flood Extent\>\"", ",", " ", 
       RowBox[{"GeoPosition", "[", 
        RowBox[{"{", 
         RowBox[{"44.3", ",", " ", "12.1"}], "}"}], "]"}]}], "]"}]}], "}"}], ",",
    "\n", "  ", "floodMask", ",", "\n", "  ", 
   RowBox[{"GeoRange", " ", "->", " ", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{"44.1", ",", " ", "44.5"}], "}"}], ",", " ", 
      RowBox[{"{", 
       RowBox[{"11.8", ",", " ", "12.4"}], "}"}]}], "}"}]}], ",", "\n", "  ", 
   RowBox[{"\"\<VisParams\>\"", " ", "->", " ", 
    RowBox[{"<|", 
     RowBox[{
      RowBox[{"\"\<min\>\"", " ", "->", " ", "0"}], ",", " ", 
      RowBox[{"\"\<max\>\"", " ", "->", " ", "1"}], ",", "\n", "    ", 
      RowBox[{"\"\<palette\>\"", " ", "->", " ", 
       RowBox[{"{", "\"\<#FF4444\>\"", "}"}]}]}], "|>"}]}], ",", "\n", "  ", 
   RowBox[{"ImageSize", " ", "->", " ", "600"}]}], "]"}]], "Input",ExpressionU\
UID->"c7ef06bd-432d-3f4f-b25f-b0470f6cf645"],

Cell["", "Text",
 CellFrame->{{0, 0}, {0, 
  1}},ExpressionUUID->"0945bc53-e199-b047-ae85-518b24524a2a"]
}, Open  ]]
}, Open  ]],

Cell[CellGroupData[{

Cell["6.4 Snow and Ice", "Chapter",ExpressionUUID->"591e3f3d-39c9-f044-9374-9017fb2eb170"],

Cell[CellGroupData[{

Cell["MODIS Daily Snow Cover", "Section",ExpressionUUID->"c8fb67d9-1da1-ae4c-8c1b-4216e10d837b"],

Cell[TextData[{
 "The MODIS MOD10A1 product provides daily snow cover at 500-meter \
resolution. The ",
 Cell["NDSI_Snow_Cover", "InlineCode",ExpressionUUID->
  "196c86bb-33a7-d043-8731-d400d319f130"],
 " band uses the Normalized Difference Snow Index, which exploits the high \
visible reflectance and low SWIR reflectance of snow. Values range from 0 to \
100, with values above ~40 indicating snow-covered pixels."
}], "Text",ExpressionUUID->"c5384d48-b983-cb48-a065-07b6426c8e52"],

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{
    RowBox[{
    "Snow", " ", "cover", " ", "over", " ", "the", " ", "European", " ", 
     "Alps"}], ",", " ", 
    RowBox[{"mid", "-", 
     RowBox[{"winter", " ", "2024"}]}]}], " ", "*)"}], "\n", 
  RowBox[{
   RowBox[{
    RowBox[{"alpsBox", " ", "=", " ", 
     RowBox[{"{", 
      RowBox[{"6.0", ",", " ", "45.5", ",", " ", "13.0", ",", " ", "47.5"}], 
      "}"}]}], ";"}], "\n", "\n", 
   RowBox[{
    RowBox[{"snowCover", " ", "=", "\n", "  ", 
     RowBox[{
      RowBox[{
       RowBox[{
        RowBox[{
         RowBox[{"GEECollection", "[", "\"\<MODIS/061/MOD10A1\>\"", "]"}], 
         " ", "//", "\n", "    ", 
         RowBox[{"GEEFilterDate", "[", 
          RowBox[{"\"\<2024-01-15\>\"", ",", " ", "\"\<2024-01-25\>\""}], 
          "]"}]}], " ", "//", "\n", "    ", 
        RowBox[{"GEEFilterBounds", "[", "alpsBox", "]"}]}], " ", "//", "\n", 
       "    ", 
       RowBox[{"GEESelectBands", "[", 
        RowBox[{"{", "\"\<NDSI_Snow_Cover\>\"", "}"}], "]"}]}], " ", "//", 
      "\n", "    ", "GEEMedian"}]}], ";"}], "\n", "\n", 
   RowBox[{"snowImage", " ", "=", " ", 
    RowBox[{"GEEComputePixels", "[", 
     RowBox[{"alpsBox", ",", " ", "snowCover", ",", "\n", "  ", 
      RowBox[{"\"\<VisParams\>\"", " ", "->", " ", 
       RowBox[{"<|", 
        RowBox[{
         RowBox[{"\"\<min\>\"", " ", "->", " ", "0"}], ",", " ", 
         RowBox[{"\"\<max\>\"", " ", "->", " ", "100"}], ",", "\n", "    ", 
         RowBox[{"\"\<palette\>\"", " ", "->", " ", 
          RowBox[{"{", 
           
           RowBox[{"\"\<#000000\>\"", ",", " ", "\"\<#87CEEB\>\"", ",", 
            " ", "\"\<#FFFFFF\>\""}], "}"}]}]}], "|>"}]}]}], 
     "]"}]}]}]}]], "Input",ExpressionUUID->"de01f0b7-e9d2-d04c-8caf-\
5aa991bf6356"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Snow Cover Time Series -- Tracking Seasonal Snowpack", "Section",ExpressionUUID->"78bbb6f3-b16e-3649-8c92-32e3d004abc8"],

Cell["\<\
Monitoring the seasonal evolution of snow cover area is critical for water \
resource forecasting. Mountain snowpack acts as a natural reservoir, and its \
spring melt drives downstream water supply.\
\>", "Text",ExpressionUUID->"a5756284-fd5b-194e-9a4e-480453eda639"],

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{
    RowBox[{"Compute", " ", "snow"}], "-", 
    RowBox[{
    "covered", " ", "area", " ", "for", " ", "a", " ", "given", " ", "date", " ",
      "range"}]}], " ", "*)"}], "\n", 
  RowBox[{
   RowBox[{"snowAreaForPeriod", "[", 
    RowBox[{
    "startDate_String", ",", " ", "endDate_String", ",", " ", "region_", ",", 
     "\n", "  ", "regionGeom_"}], "]"}], " ", ":=", " ", 
   RowBox[{"Module", "[", "\n", "  ", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
      "composite", ",", " ", "snowMask", ",", " ", "areaImage", ",", " ", 
       "stats"}], "}"}], ",", "\n", "\n", "  ", 
     RowBox[{
      RowBox[{"composite", " ", "=", "\n", "    ", 
       RowBox[{
        RowBox[{
         RowBox[{
          RowBox[{
           RowBox[{"GEECollection", "[", "\"\<MODIS/061/MOD10A1\>\"", "]"}], 
           " ", "//", "\n", "      ", 
           RowBox[{"GEEFilterDate", "[", 
            RowBox[{"startDate", ",", " ", "endDate"}], "]"}]}], " ", "//", 
          "\n", "      ", 
          RowBox[{"GEEFilterBounds", "[", "region", "]"}]}], " ", "//", "\n", 
         "      ", 
         RowBox[{"GEESelectBands", "[", 
          RowBox[{"{", "\"\<NDSI_Snow_Cover\>\"", "}"}], "]"}]}], " ", "//", 
        "\n", "      ", "GEEMean"}]}], ";", "\n", "\n", "  ", 
      RowBox[{"(*", " ", 
       RowBox[{
        RowBox[{"Snow", " ", "where", " ", "NDSI"}], " ", ">", " ", "40"}], 
       " ", "*)"}], "\n", "  ", 
      RowBox[{"snowMask", " ", "=", " ", 
       RowBox[{
        RowBox[{"composite", " ", "//", "\n", "    ", 
         RowBox[{"GEEGreaterThan", "[", "40", "]"}]}], " ", "//", "\n", 
        "    ", "GEESelfMask"}]}], ";", "\n", "\n", "  ", 
      RowBox[{"areaImage", " ", "=", " ", 
       RowBox[{"snowMask", " ", "//", " ", 
        RowBox[{"GEEMultiply", "[", 
         RowBox[{"GEEPixelArea", "[", "]"}], "]"}]}]}], ";", "\n", "\n", "  ", 
      RowBox[{"stats", " ", "=", " ", 
       RowBox[{"GEECompute", "[", "\n", "    ", 
        RowBox[{"areaImage", " ", "//", " ", 
         RowBox[{"GEEReduceRegion", "[", 
          RowBox[{"regionGeom", ",", " ", "\"\<sum\>\"", ",", " ", "500"}], 
          "]"}]}], "\n", "  ", "]"}]}], ";", "\n", "\n", "  ", 
      RowBox[{
       RowBox[{"Lookup", "[", 
        RowBox[{"stats", ",", " ", "\"\<NDSI_Snow_Cover\>\"", ",", " ", "0"}],
         "]"}], " ", "/", " ", "1.0*^6"}]}]}], "\n", "]"}]}]}]], "Input",Expre\
ssionUUID->"66af4f2a-954f-4a4e-9d42-bdea843d1e44"],

Cell["\<\
Build a monthly time series for one water year (October through September).\
\>", "Text",ExpressionUUID->"eb595de5-8f8b-5746-bcbe-95e3e3cbecfb"],

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"alpsGeom", " ", "=", " ", 
    RowBox[{"GEEGeometry", "[", "alpsBox", "]"}]}], ";"}], "\n", "\n", 
  RowBox[{"(*", " ", 
   RowBox[{
    RowBox[{"Water", " ", "year", " ", "2023"}], "-", "2024"}], " ", 
   "*)"}]}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"months", " ", "=", " ", 
    RowBox[{"Flatten", "[", 
     RowBox[{
      RowBox[{"{", "\n", "  ", 
       RowBox[{
        RowBox[{"Table", "[", 
         RowBox[{
          RowBox[{"{", 
           RowBox[{"2023", ",", " ", "m"}], "}"}], ",", " ", 
          RowBox[{"{", 
           RowBox[{"m", ",", " ", "10", ",", " ", "12"}], "}"}]}], "]"}], ",",
         "\n", "  ", 
        RowBox[{"Table", "[", 
         RowBox[{
          RowBox[{"{", 
           RowBox[{"2024", ",", " ", "m"}], "}"}], ",", " ", 
          RowBox[{"{", 
           RowBox[{"m", ",", " ", "1", ",", " ", "9"}], "}"}]}], "]"}]}], 
       "\n", "}"}], ",", " ", "1"}], "]"}]}], ";"}], "\n"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"snowData", " ", "=", " ", 
    RowBox[{"Table", "[", "\n", "  ", 
     RowBox[{
      RowBox[{"Module", "[", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{"start", ",", " ", "end", ",", " ", "area"}], "}"}], ",", 
        "\n", "    ", 
        RowBox[{
         RowBox[{"start", " ", "=", " ", 
          RowBox[{"DateString", "[", 
           RowBox[{
            RowBox[{"{", 
             RowBox[{"yr", ",", " ", "mo", ",", " ", "1"}], "}"}], ",", 
            " ", "\"\<ISODate\>\""}], "]"}]}], ";", "\n", "    ", 
         RowBox[{"end", " ", "=", " ", 
          RowBox[{"DateString", "[", 
           RowBox[{
            RowBox[{"DatePlus", "[", 
             RowBox[{
              RowBox[{"{", 
               RowBox[{"yr", ",", " ", "mo", ",", " ", "1"}], "}"}], ",", " ", 
              RowBox[{"{", 
               RowBox[{"1", ",", " ", "\"\<Month\>\""}], "}"}]}], "]"}], ",", 
            " ", "\"\<ISODate\>\""}], "]"}]}], ";", "\n", "    ", 
         RowBox[{"area", " ", "=", " ", 
          RowBox[{"snowAreaForPeriod", "[", 
           RowBox[{
           "start", ",", " ", "end", ",", " ", "alpsBox", ",", " ", 
            "alpsGeom"}], "]"}]}], ";", "\n", "    ", 
         RowBox[{"{", 
          RowBox[{
           RowBox[{"DateObject", "[", 
            RowBox[{"{", 
             RowBox[{"yr", ",", " ", "mo", ",", " ", "15"}], "}"}], "]"}], ",",
            " ", "area"}], "}"}]}]}], "\n", "  ", "]"}], ",", "\n", "  ", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{"yr", ",", " ", "mo"}], "}"}], ",", " ", "months"}], "}"}]}],
      "\n", "]"}]}], ";"}], "\n"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"snowSeries", " ", "=", " ", 
    RowBox[{"TimeSeries", "[", "snowData", "]"}]}], ";"}], "\n"}], "\n", 
 RowBox[{"DateListPlot", "[", 
  RowBox[{"snowSeries", ",", "\n", "  ", 
   RowBox[{
   "PlotLabel", " ", "->", 
    " ", "\"\<Alps Snow Cover Area (Water Year 2023-2024)\>\""}], ",", "\n", 
   "  ", 
   RowBox[{"FrameLabel", " ", "->", " ", 
    RowBox[{"{", 
     RowBox[{"\"\<Date\>\"", ",", 
      " ", "\"\<Snow Area (km\\[Superscript]2)\>\""}], "}"}]}], ",", "\n", 
   "  ", 
   RowBox[{"PlotStyle", " ", "->", " ", 
    RowBox[{"Directive", "[", 
     RowBox[{"Thick", ",", " ", 
      RowBox[{"RGBColor", "[", 
       RowBox[{"0.3", ",", " ", "0.5", ",", " ", "0.9"}], "]"}]}], "]"}]}], ",",
    "\n", "  ", 
   RowBox[{"Filling", " ", "->", " ", "Axis"}], ",", "\n", "  ", 
   RowBox[{"FillingStyle", " ", "->", " ", 
    RowBox[{"Directive", "[", 
     RowBox[{
      RowBox[{"Opacity", "[", "0.15", "]"}], ",", " ", "Blue"}], "]"}]}], ",",
    "\n", "  ", 
   RowBox[{"GridLines", " ", "->", " ", "Automatic"}], ",", "\n", "  ", 
   RowBox[{"ImageSize", " ", "->", " ", "Large"}]}], "]"}]}], "Input",Expressi\
onUUID->"d8f08e8d-88a7-8f47-8ba4-c6cec29aeee1"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Glacier Extent Mapping with Sentinel-2", "Section",ExpressionUUID->"ab47377e-621a-7d41-8414-f69ae6a0b30d"],

Cell["\<\
The Normalized Difference Snow Index (NDSI) can also delineate glacier \
boundaries. For glaciers, Sentinel-2 at 10/20-meter resolution provides \
sharper boundaries than MODIS. The NDSI formula uses Green (B3) and SWIR \
(B11), the same band combination as MNDWI but interpreted differently in the \
context of cryospheric mapping.\
\>", "Text",ExpressionUUID->"fe9539a9-d83a-3945-9f45-7486306f59f0"],

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{
    RowBox[{"Aletsch", " ", "Glacier"}], ",", " ", "Switzerland"}], " ", 
   "*)"}], "\n", 
  RowBox[{
   RowBox[{
    RowBox[{"glacierBox", " ", "=", " ", 
     RowBox[{"{", 
      RowBox[{
      "7.95", ",", " ", "46.38", ",", " ", "8.15", ",", " ", "46.52"}], 
      "}"}]}], ";"}], "\n", "\n", 
   RowBox[{
    RowBox[{"s2Glacier", " ", "=", "\n", "  ", 
     RowBox[{
      RowBox[{
       RowBox[{
        RowBox[{
         RowBox[{
         "GEECollection", "[", "\"\<COPERNICUS/S2_SR_HARMONIZED\>\"", "]"}], 
         " ", "//", "\n", "    ", 
         RowBox[{"GEEFilterDate", "[", 
          RowBox[{"\"\<2024-07-01\>\"", ",", " ", "\"\<2024-09-01\>\""}], 
          "]"}]}], " ", "//", "\n", "    ", 
        RowBox[{"GEEFilterBounds", "[", "glacierBox", "]"}]}], " ", "//", 
       "\n", "    ", 
       RowBox[{"GEEFilterProperty", "[", 
        RowBox[{"\"\<CLOUDY_PIXEL_PERCENTAGE\>\"", ",", 
         " ", "\"\<LessThan\>\"", ",", " ", "10"}], "]"}]}], " ", "//", "\n", 
      "    ", "GEEMedian"}]}], ";"}], "\n", "\n", 
   RowBox[{"(*", " ", 
    RowBox[{"NDSI", " ", "for", " ", 
     RowBox[{"snow", "/", "ice"}]}], " ", "*)"}], "\n", 
   RowBox[{
    RowBox[{"ndsi", " ", "=", " ", 
     RowBox[{"s2Glacier", " ", "//", " ", 
      RowBox[{"GEENormalizedDifference", "[", 
       RowBox[{"{", 
        RowBox[{"\"\<B3\>\"", ",", " ", "\"\<B11\>\""}], "}"}], "]"}]}]}], 
    ";"}], "\n", "\n", 
   RowBox[{"(*", " ", 
    RowBox[{"Glacier", " ", 
     RowBox[{"pixels", ":", " ", 
      RowBox[{"NDSI", " ", ">", " ", "0.4"}]}]}], " ", "*)"}], "\n", 
   RowBox[{
    RowBox[{"glacierMask", " ", "=", " ", 
     RowBox[{
      RowBox[{"ndsi", " ", "//", "\n", "  ", 
       RowBox[{"GEEGreaterThan", "[", "0.4", "]"}]}], " ", "//", "\n", "  ", 
      "GEESelfMask"}]}], ";"}], "\n", "\n", 
   RowBox[{"(*", " ", 
    RowBox[{"True", "-", 
     RowBox[{"color", " ", "background"}]}], " ", "*)"}], "\n", 
   RowBox[{
    RowBox[{"rgbImg", " ", "=", " ", 
     RowBox[{"GEEComputePixels", "[", 
      RowBox[{"glacierBox", ",", "\n", "  ", 
       RowBox[{"s2Glacier", " ", "//", " ", 
        RowBox[{"GEESelectBands", "[", 
         RowBox[{"{", 
          
          RowBox[{"\"\<B4\>\"", ",", " ", "\"\<B3\>\"", ",", 
           " ", "\"\<B2\>\""}], "}"}], "]"}]}], ",", "\n", "  ", 
       RowBox[{"\"\<VisParams\>\"", " ", "->", " ", 
        RowBox[{"<|", 
         RowBox[{
          RowBox[{"\"\<min\>\"", " ", "->", " ", "0"}], ",", " ", 
          RowBox[{"\"\<max\>\"", " ", "->", " ", "3000"}]}], "|>"}]}]}], 
      "]"}]}], ";"}], "\n", "\n", 
   RowBox[{"(*", " ", 
    RowBox[{"Glacier", " ", "mask", " ", "overlay"}], " ", "*)"}], "\n", 
   RowBox[{
    RowBox[{"glacierImg", " ", "=", " ", 
     RowBox[{"GEEComputePixels", "[", 
      RowBox[{"glacierBox", ",", " ", "glacierMask", ",", "\n", "  ", 
       RowBox[{"\"\<VisParams\>\"", " ", "->", " ", 
        RowBox[{"<|", 
         RowBox[{
          RowBox[{"\"\<min\>\"", " ", "->", " ", "0"}], ",", " ", 
          RowBox[{"\"\<max\>\"", " ", "->", " ", "1"}], ",", "\n", "    ", 
          RowBox[{"\"\<palette\>\"", " ", "->", " ", 
           RowBox[{"{", "\"\<#00FFFF\>\"", "}"}]}]}], "|>"}]}]}], "]"}]}], 
    ";"}], "\n", "\n", 
   RowBox[{"GraphicsRow", "[", 
    RowBox[{"{", "\n", "  ", 
     RowBox[{
      RowBox[{"Labeled", "[", 
       RowBox[{
        RowBox[{"Image", "[", 
         RowBox[{"rgbImg", ",", " ", 
          RowBox[{"ImageSize", " ", "->", " ", "400"}]}], "]"}], ",", 
        " ", "\"\<True Color\>\"", ",", " ", "Top"}], "]"}], ",", "\n", "  ", 
      RowBox[{"Labeled", "[", 
       RowBox[{
        RowBox[{"Image", "[", 
         RowBox[{"glacierImg", ",", " ", 
          RowBox[{"ImageSize", " ", "->", " ", "400"}]}], "]"}], ",", 
        " ", "\"\<Glacier Extent (NDSI > 0.4)\>\"", ",", " ", "Top"}], 
       "]"}]}], "\n", "}"}], "]"}]}]}]], "Input",ExpressionUUID->"fcfa657e-\
902d-294a-bdbd-99a2838b0509"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Multi-Year Glacier Retreat Analysis", "Section",ExpressionUUID->"978b41bc-9f01-5442-ab37-cc8bf1ab023e"],

Cell["\<\
Compare glacier extent across multiple years to quantify retreat.\
\>", "Text",ExpressionUUID->"06137272-8046-9d4f-b4f2-e30c35bf855e"],

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"glacierGeom", " ", "=", " ", 
    RowBox[{"GEEGeometry", "[", "glacierBox", "]"}]}], ";"}], "\n"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"glacierAreaForYear", "[", "year_Integer", "]"}], " ", ":=", " ", 
   RowBox[{"Module", "[", "\n", "  ", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
      "startDate", ",", " ", "endDate", ",", " ", "composite", ",", " ", 
       "ndsiImg", ",", " ", "mask", ",", " ", "areaImg", ",", " ", "stats"}], 
      "}"}], ",", "\n", "\n", "  ", 
     RowBox[{
      RowBox[{"startDate", " ", "=", " ", 
       RowBox[{
        RowBox[{"ToString", "[", "year", "]"}], " ", "<>", 
        " ", "\"\<-07-01\>\""}]}], ";", "\n", "  ", 
      RowBox[{"endDate", " ", "=", " ", 
       RowBox[{
        RowBox[{"ToString", "[", "year", "]"}], " ", "<>", 
        " ", "\"\<-09-30\>\""}]}], ";", "\n", "\n", "  ", 
      RowBox[{"composite", " ", "=", "\n", "    ", 
       RowBox[{
        RowBox[{
         RowBox[{
          RowBox[{
           RowBox[{
           "GEECollection", "[", "\"\<COPERNICUS/S2_SR_HARMONIZED\>\"", "]"}],
            " ", "//", "\n", "      ", 
           RowBox[{"GEEFilterDate", "[", 
            RowBox[{"startDate", ",", " ", "endDate"}], "]"}]}], " ", "//", 
          "\n", "      ", 
          RowBox[{"GEEFilterBounds", "[", "glacierBox", "]"}]}], " ", "//", 
         "\n", "      ", 
         RowBox[{"GEEFilterProperty", "[", 
          
          RowBox[{"\"\<CLOUDY_PIXEL_PERCENTAGE\>\"", ",", 
           " ", "\"\<LessThan\>\"", ",", " ", "15"}], "]"}]}], " ", "//", 
        "\n", "      ", "GEEMedian"}]}], ";", "\n", "\n", "  ", 
      RowBox[{"ndsiImg", " ", "=", " ", 
       RowBox[{"composite", " ", "//", " ", 
        RowBox[{"GEENormalizedDifference", "[", 
         RowBox[{"{", 
          RowBox[{"\"\<B3\>\"", ",", " ", "\"\<B11\>\""}], "}"}], "]"}]}]}], ";",
       "\n", "  ", 
      RowBox[{"mask", " ", "=", " ", 
       RowBox[{
        RowBox[{"ndsiImg", " ", "//", " ", 
         RowBox[{"GEEGreaterThan", "[", "0.4", "]"}]}], " ", "//", " ", 
        "GEESelfMask"}]}], ";", "\n", "  ", 
      RowBox[{"areaImg", " ", "=", " ", 
       RowBox[{"mask", " ", "//", " ", 
        RowBox[{"GEEMultiply", "[", 
         RowBox[{"GEEPixelArea", "[", "]"}], "]"}]}]}], ";", "\n", "\n", "  ", 
      RowBox[{"stats", " ", "=", " ", 
       RowBox[{"GEECompute", "[", "\n", "    ", 
        RowBox[{"areaImg", " ", "//", " ", 
         RowBox[{"GEEReduceRegion", "[", 
          RowBox[{"glacierGeom", ",", " ", "\"\<sum\>\"", ",", " ", "20"}], 
          "]"}]}], "\n", "  ", "]"}]}], ";", "\n", "\n", "  ", 
      RowBox[{
       RowBox[{"Lookup", "[", 
        RowBox[{"stats", ",", " ", "\"\<nd\>\"", ",", " ", "0"}], "]"}], " ", 
       "/", " ", "1.0*^6"}]}]}], "\n", "]"}]}], "\n", "\n", 
  RowBox[{"(*", " ", 
   RowBox[{
   "Compute", " ", "glacier", " ", "area", " ", "for", " ", "each", " ", 
    "summer", " ", "from", " ", "2017", " ", "to", " ", "2024"}], " ", 
   "*)"}]}], "\n", 
 RowBox[{
  RowBox[{"years", " ", "=", " ", 
   RowBox[{"Range", "[", 
    RowBox[{"2017", ",", " ", "2024"}], "]"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"glacierAreas", " ", "=", " ", 
    RowBox[{"AssociationThread", "[", 
     RowBox[{"years", ",", " ", 
      RowBox[{"glacierAreaForYear", " ", "/@", " ", "years"}]}], "]"}]}], 
   ";"}], "\n", "\n", 
  RowBox[{"(*", " ", 
   RowBox[{"Bar", " ", "chart", " ", "of", " ", "glacier", " ", "extent"}], 
   " ", "*)"}]}], "\n", 
 RowBox[{"BarChart", "[", 
  RowBox[{
   RowBox[{"Values", "[", "glacierAreas", "]"}], ",", "\n", "  ", 
   RowBox[{"ChartLabels", " ", "->", " ", 
    RowBox[{"Keys", "[", "glacierAreas", "]"}]}], ",", "\n", "  ", 
   RowBox[{
   "PlotLabel", " ", "->", " ", "\"\<Aletsch Glacier Summer Extent\>\""}], ",",
    "\n", "  ", 
   RowBox[{"AxesLabel", " ", "->", " ", 
    RowBox[{"{", 
     RowBox[{"None", ",", " ", "\"\<Area (km\\[Superscript]2)\>\""}], "}"}]}],
    ",", "\n", "  ", 
   RowBox[{"ChartStyle", " ", "->", " ", 
    RowBox[{"RGBColor", "[", 
     RowBox[{"0.3", ",", " ", "0.7", ",", " ", "0.9"}], "]"}]}], ",", "\n", 
   "  ", 
   RowBox[{"ImageSize", " ", "->", " ", "Large"}]}], "]"}]}], "Input",Expressi\
onUUID->"130a67d8-d416-8046-9b36-2f8860bb6c15"],

Cell["", "Text",
 CellFrame->{{0, 0}, {0, 
  1}},ExpressionUUID->"122228d3-512e-8645-a44a-81efcca638b5"]
}, Open  ]]
