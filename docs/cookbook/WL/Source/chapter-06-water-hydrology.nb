Notebook[{

Cell[CellGroupData[{
Cell["Chapter 6: Water Resources and Hydrology", "Title",ExpressionUUID->"5ba8ec8f-5e58-6d46-bc21-38faf9f4d7d9"],

Cell["\<\
Water is the most dynamic surface feature visible from space. Lakes expand \
and contract with the seasons, rivers flood and recede, glaciers retreat \
decade over decade, and reservoirs respond to human management decisions in \
near real time. Satellite remote sensing provides the only practical means of \
monitoring these processes at regional to global scales, and Google Earth \
Engine hosts the key datasets -- Sentinel-2 multispectral imagery, Sentinel-1 \
SAR, MODIS snow products, CHIRPS rainfall, and the JRC Global Surface Water \
dataset -- that make this monitoring possible.\
\>", "Text",ExpressionUUID->"7e4a3c90-5b98-ba4c-9682-8f906c59faee"],

Cell[TextData[{
 "This chapter walks through the full spectrum of hydrological analysis: \
detecting water bodies with spectral indices, tracking reservoir storage over \
time, and mapping floods with radar. It also covers snow and ice monitoring, \
precipitation analysis, and water quality estimation from optical imagery. \
Every example uses the ",
 Cell["GoogleEarthEngineClient", "InlineCode",ExpressionUUID->
  "565edb02-e78a-4f48-9759-568308f078d8"],
 " paclet to build server-side processing pipelines and then brings the \
results into Wolfram Language for analysis, visualization, and modeling."
}], "Text",ExpressionUUID->"fb4ece1d-2053-144f-8723-dd7241bd6bbb"],

Cell[TextData[{
 StyleBox["Prerequisite:",
  FontWeight->Bold],
 " Authenticate per Section 1.3 and load the paclet with ",
 Cell["Needs[\"GoogleEarthEngineClient`\"]", "InlineCode",ExpressionUUID->
  "16770144-48ed-024f-8bac-3405e7039855"],
 "."
}], "Text",ExpressionUUID->"a5a42c20-2ff2-104d-97c1-7a2f64b56522"],

Cell["", "Text",
 CellFrame->{{0, 0}, {0, 
  1}},ExpressionUUID->"47176136-0e5b-024d-9735-595e89019583"],

Cell[CellGroupData[{

Cell["6.1 Water Body Detection", "Chapter",ExpressionUUID->"7b9b42c2-7cee-e848-9d8b-ee4a516e52cb"],

Cell[CellGroupData[{

Cell["The Physics of Water in Satellite Imagery", "Section",ExpressionUUID->"8094d843-a6fa-fe4f-89e6-9f8dcf5f0b05"],

Cell["\<\
Water has a distinctive spectral signature: it reflects moderately in the \
visible green wavelengths and absorbs strongly in the near-infrared (NIR) and \
short-wave infrared (SWIR). This contrast is the foundation of every \
water-detection index used in remote sensing.\
\>", "Text",ExpressionUUID->"e9d6b9c0-1501-c249-bd95-291103ff26af"]
}, Open  ]],

Cell[CellGroupData[{

Cell["NDWI -- Normalized Difference Water Index", "Section",ExpressionUUID->"840b035f-03cd-294c-8778-06fbd2ece109"],

Cell["\<\
The NDWI exploits the contrast between green reflectance (Sentinel-2 Band 3) \
and NIR absorption (Band 8). Water pixels yield positive NDWI values; \
vegetation and soil yield negative values. Note that the same index applied \
to vegetation canopy water content is covered in Section 5.1.3; here the \
focus is on surface water detection.\
\>", "Text",ExpressionUUID->"70de5398-5907-ae4e-ab51-656161aec133"],

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{
    RowBox[{"Define", " ", "a", " ", "region", " ", "of", " ", 
     RowBox[{"interest", ":", " ", 
      RowBox[{"Lake", " ", "Balaton"}]}]}], ",", " ", "Hungary"}], " ", 
   "*)"}], "\n", 
  RowBox[{
   RowBox[{
    RowBox[{"bbox", " ", "=", " ", 
     RowBox[{"{", 
      RowBox[{"17.6", ",", " ", "46.7", ",", " ", "18.2", ",", " ", "47.0"}], 
      "}"}]}], ";"}], "\n", "\n", 
   RowBox[{"(*", " ", 
    RowBox[{
     RowBox[{"Build", " ", "a", " ", "cloud"}], "-", 
     RowBox[{"filtered", " ", "Sentinel"}], "-", 
     RowBox[{
     "2", " ", "composite", " ", "for", " ", "summer", " ", "2024"}]}], " ", 
    "*)"}], "\n", 
   RowBox[{
    RowBox[{"s2Composite", " ", "=", "\n", "  ", 
     RowBox[{
      RowBox[{
       RowBox[{
        RowBox[{
         RowBox[{
         "GEECollection", "[", "\"\<COPERNICUS/S2_SR_HARMONIZED\>\"", "]"}], 
         " ", "//", "\n", "    ", 
         RowBox[{"GEEFilterDate", "[", 
          RowBox[{"\"\<2024-06-01\>\"", ",", " ", "\"\<2024-09-01\>\""}], 
          "]"}]}], " ", "//", "\n", "    ", 
        RowBox[{"GEEFilterBounds", "[", "bbox", "]"}]}], " ", "//", "\n", 
       "    ", 
       RowBox[{"GEEFilterProperty", "[", 
        RowBox[{"\"\<CLOUDY_PIXEL_PERCENTAGE\>\"", ",", 
         " ", "\"\<LessThan\>\"", ",", " ", "10"}], "]"}]}], " ", "//", "\n", 
      "    ", "GEEMedian"}]}], ";"}], "\n", "\n", 
   RowBox[{"(*", " ", 
    RowBox[{"Compute", " ", 
     RowBox[{"NDWI", ":", " ", 
      RowBox[{
       RowBox[{"(", 
        RowBox[{"Green", " ", "-", " ", "NIR"}], ")"}], " ", "/", " ", 
       RowBox[{"(", 
        RowBox[{"Green", " ", "+", " ", "NIR"}], ")"}]}]}]}], " ", "*)"}], "\n", 
   RowBox[{
    RowBox[{"ndwi", " ", "=", " ", 
     RowBox[{"s2Composite", " ", "//", " ", 
      RowBox[{"GEENormalizedDifference", "[", 
       RowBox[{"{", 
        RowBox[{"\"\<B3\>\"", ",", " ", "\"\<B8\>\""}], "}"}], "]"}]}]}], 
    ";"}], "\n", "\n", 
   RowBox[{"(*", " ", 
    RowBox[{
     RowBox[{
      RowBox[{"Visualize", ":", " ", "blue"}], " ", "=", " ", 
      RowBox[{"water", " ", 
       RowBox[{"(", "positive", ")"}]}]}], ",", " ", 
     RowBox[{"brown", " ", "=", " ", 
      RowBox[{"land", " ", 
       RowBox[{"(", "negative", ")"}]}]}]}], " ", "*)"}], "\n", 
   RowBox[{"ndwiImage", " ", "=", " ", 
    RowBox[{"GEEComputePixels", "[", 
     RowBox[{"bbox", ",", " ", "ndwi", ",", "\n", "  ", 
      RowBox[{"\"\<VisParams\>\"", " ", "->", " ", 
       RowBox[{"<|", 
        RowBox[{
         RowBox[{"\"\<min\>\"", " ", "->", " ", 
          RowBox[{"-", "0.5"}]}], ",", " ", 
         RowBox[{"\"\<max\>\"", " ", "->", " ", "0.5"}], ",", "\n", "    ", 
         RowBox[{"\"\<palette\>\"", " ", "->", " ", 
          RowBox[{"{", 
           
           RowBox[{"\"\<#8B4513\>\"", ",", " ", "\"\<#FFFFFF\>\"", ",", 
            " ", "\"\<#0000FF\>\""}], "}"}]}]}], "|>"}]}]}], 
     "]"}]}]}]}]], "Input",ExpressionUUID->"866c4531-620e-ae47-9e4f-\
39bf0ba9b73d"],

Cell["\<\
To extract only water pixels, threshold at zero and apply a self-mask. Pixels \
where NDWI <= 0 are masked out, leaving only water.\
\>", "Text",ExpressionUUID->"f839c915-2511-d347-8923-87dc7af45494"],

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"waterMask", " ", "=", " ", 
    RowBox[{
     RowBox[{"ndwi", " ", "//", "\n", "  ", 
      RowBox[{"GEEGreaterThan", "[", "0", "]"}]}], " ", "//", "\n", "  ", 
     "GEESelfMask"}]}], ";"}], "\n"}], "\n", 
 RowBox[{"waterImage", " ", "=", " ", 
  RowBox[{"GEEComputePixels", "[", 
   RowBox[{"bbox", ",", " ", "waterMask", ",", "\n", "  ", 
    RowBox[{"\"\<VisParams\>\"", " ", "->", " ", 
     RowBox[{"<|", 
      RowBox[{
       RowBox[{"\"\<min\>\"", " ", "->", " ", "0"}], ",", " ", 
       RowBox[{"\"\<max\>\"", " ", "->", " ", "1"}], ",", "\n", "    ", 
       RowBox[{"\"\<palette\>\"", " ", "->", " ", 
        RowBox[{"{", "\"\<#0000FF\>\"", "}"}]}]}], "|>"}]}]}], 
   "]"}]}]}], "Input",ExpressionUUID->"55e1db0a-2219-f945-acd5-5423221adb3c"]
}, Open  ]],

Cell[CellGroupData[{

Cell["MNDWI -- Modified NDWI for Urban Areas", "Section",ExpressionUUID->"dcf8d4a4-bf19-7944-b309-bfbf541d23cb"],

Cell["\<\
In urban areas, built-up surfaces (concrete, asphalt) can produce false \
positives with standard NDWI because they also reflect in the NIR. The \
Modified NDWI substitutes SWIR (Band 11) for NIR, which better separates \
water from built-up surfaces because SWIR reflectance is higher for dry \
built-up materials and lower for water.\
\>", "Text",ExpressionUUID->"6c6b2904-edf0-754d-8622-8cc2d6eb7d00"],

Cell["\<\
Bangkok's dense mix of canals and buildings provides an ideal test case for \
MNDWI's ability to separate water from built-up surfaces.\
\>", "Text",ExpressionUUID->"18317470-d448-1b47-9dfd-ed34b834258b"],

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{
    RowBox[{"Region", ":", " ", "Bangkok"}], ",", " ", 
    RowBox[{
     RowBox[{"Thailand", " ", "--"}], " ", "urban", " ", "waterways", " ", 
     "mixed", " ", "with", " ", "buildings"}]}], " ", "*)"}], "\n", 
  RowBox[{
   RowBox[{
    RowBox[{"bkkBox", " ", "=", " ", 
     RowBox[{"{", 
      RowBox[{
      "100.45", ",", " ", "13.65", ",", " ", "100.65", ",", " ", "13.85"}], 
      "}"}]}], ";"}], "\n", "\n", 
   RowBox[{
    RowBox[{"s2Bangkok", " ", "=", "\n", "  ", 
     RowBox[{
      RowBox[{
       RowBox[{
        RowBox[{
         RowBox[{
         "GEECollection", "[", "\"\<COPERNICUS/S2_SR_HARMONIZED\>\"", "]"}], 
         " ", "//", "\n", "    ", 
         RowBox[{"GEEFilterDate", "[", 
          RowBox[{"\"\<2024-01-01\>\"", ",", " ", "\"\<2024-04-01\>\""}], 
          "]"}]}], " ", "//", "\n", "    ", 
        RowBox[{"GEEFilterBounds", "[", "bkkBox", "]"}]}], " ", "//", "\n", 
       "    ", 
       RowBox[{"GEEFilterProperty", "[", 
        RowBox[{"\"\<CLOUDY_PIXEL_PERCENTAGE\>\"", ",", 
         " ", "\"\<LessThan\>\"", ",", " ", "15"}], "]"}]}], " ", "//", "\n", 
      "    ", "GEEMedian"}]}], ";"}], "\n", "\n", 
   RowBox[{"(*", " ", 
    RowBox[{"Standard", " ", "NDWI"}], " ", "*)"}], "\n", 
   RowBox[{
    RowBox[{"ndwiBangkok", " ", "=", " ", 
     RowBox[{"s2Bangkok", " ", "//", " ", 
      RowBox[{"GEENormalizedDifference", "[", 
       RowBox[{"{", 
        RowBox[{"\"\<B3\>\"", ",", " ", "\"\<B8\>\""}], "}"}], "]"}]}]}], 
    ";"}], "\n", "\n", 
   RowBox[{"(*", " ", 
    RowBox[{"Modified", " ", 
     RowBox[{"NDWI", ":", " ", 
      RowBox[{
       RowBox[{"(", 
        RowBox[{"Green", " ", "-", " ", "SWIR"}], ")"}], " ", "/", " ", 
       RowBox[{"(", 
        RowBox[{"Green", " ", "+", " ", "SWIR"}], ")"}]}]}]}], " ", "*)"}], "\n", 
   RowBox[{
    RowBox[{"mndwiBangkok", " ", "=", " ", 
     RowBox[{"s2Bangkok", " ", "//", " ", 
      RowBox[{"GEENormalizedDifference", "[", 
       RowBox[{"{", 
        RowBox[{"\"\<B3\>\"", ",", " ", "\"\<B11\>\""}], "}"}], "]"}]}]}], 
    ";"}], "\n", "\n", 
   RowBox[{"(*", " ", 
    RowBox[{"Compare", " ", "side", " ", "by", " ", "side"}], " ", "*)"}], "\n", 
   RowBox[{
    RowBox[{"ndwiImg", " ", "=", " ", 
     RowBox[{"GEEComputePixels", "[", 
      RowBox[{"bkkBox", ",", " ", "ndwiBangkok", ",", "\n", "  ", 
       RowBox[{"\"\<VisParams\>\"", " ", "->", " ", 
        RowBox[{"<|", 
         RowBox[{
          RowBox[{"\"\<min\>\"", " ", "->", " ", 
           RowBox[{"-", "0.5"}]}], ",", " ", 
          RowBox[{"\"\<max\>\"", " ", "->", " ", "0.5"}], ",", "\n", "    ", 
          RowBox[{"\"\<palette\>\"", " ", "->", " ", 
           RowBox[{"{", 
            
            RowBox[{"\"\<#8B4513\>\"", ",", " ", "\"\<#FFFFFF\>\"", ",", 
             " ", "\"\<#0000FF\>\""}], "}"}]}]}], "|>"}]}]}], "]"}]}], ";"}], 
   "\n", "\n", 
   RowBox[{
    RowBox[{"mndwiImg", " ", "=", " ", 
     RowBox[{"GEEComputePixels", "[", 
      RowBox[{"bkkBox", ",", " ", "mndwiBangkok", ",", "\n", "  ", 
       RowBox[{"\"\<VisParams\>\"", " ", "->", " ", 
        RowBox[{"<|", 
         RowBox[{
          RowBox[{"\"\<min\>\"", " ", "->", " ", 
           RowBox[{"-", "0.5"}]}], ",", " ", 
          RowBox[{"\"\<max\>\"", " ", "->", " ", "0.5"}], ",", "\n", "    ", 
          RowBox[{"\"\<palette\>\"", " ", "->", " ", 
           RowBox[{"{", 
            
            RowBox[{"\"\<#8B4513\>\"", ",", " ", "\"\<#FFFFFF\>\"", ",", 
             " ", "\"\<#0000FF\>\""}], "}"}]}]}], "|>"}]}]}], "]"}]}], ";"}], 
   "\n", "\n", 
   RowBox[{"GraphicsRow", "[", 
    RowBox[{"{", "\n", "  ", 
     RowBox[{
      RowBox[{"Labeled", "[", 
       RowBox[{
        RowBox[{"Image", "[", 
         RowBox[{"ndwiImg", ",", " ", 
          RowBox[{"ImageSize", " ", "->", " ", "400"}]}], "]"}], ",", 
        " ", "\"\<NDWI\>\"", ",", " ", "Top"}], "]"}], ",", "\n", "  ", 
      RowBox[{"Labeled", "[", 
       RowBox[{
        RowBox[{"Image", "[", 
         RowBox[{"mndwiImg", ",", " ", 
          RowBox[{"ImageSize", " ", "->", " ", "400"}]}], "]"}], ",", 
        " ", "\"\<MNDWI\>\"", ",", " ", "Top"}], "]"}]}], "\n", "}"}], 
    "]"}]}]}]], "Input",ExpressionUUID->"95abe7d9-6827-5343-8b97-\
9acb966038fe"],

Cell["\<\
In the output, the MNDWI image will show cleaner water boundaries along the \
Chao Phraya River, with fewer false positives from adjacent buildings.\
\>", "Text",ExpressionUUID->"1b49e1d9-4a05-6040-88cb-7ec39d8d6ff2"]
}, Open  ]],

Cell[CellGroupData[{

Cell["JRC Global Surface Water -- 38 Years of Water History", "Section",ExpressionUUID->"5768e52e-b2f7-7945-b92b-be45e844a705"],

Cell[TextData[{
 "The JRC Global Surface Water dataset provides a pre-computed, pixel-level \
history of surface water occurrence from 1984 to present at 30-meter \
resolution. The ",
 Cell["occurrence", "InlineCode",ExpressionUUID->
  "049926f1-4241-a840-b00d-873d798d8b2e"],
 " band encodes the percentage of time each pixel was classified as water, \
making it straightforward to separate permanent water bodies from seasonal or \
ephemeral ones."
}], "Text",ExpressionUUID->"f7fa153c-ed9f-a947-8eba-c045814025e8"],

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{"JRC", " ", "Global", " ", "Surface", " ", "Water"}], " ", "*)"}], 
  "\n", 
  RowBox[{
   RowBox[{
    RowBox[{"jrcWater", " ", "=", " ", 
     RowBox[{
     "GEELoadImage", "[", "\"\<JRC/GSW1_4/GlobalSurfaceWater\>\"", "]"}]}], 
    ";"}], "\n", "\n", 
   RowBox[{"(*", " ", 
    RowBox[{"Lake", " ", "Chad", " ", 
     RowBox[{"region", " ", "--"}], " ", "dramatic", " ", "shrinkage", " ", 
     "over", " ", "decades"}], " ", "*)"}], "\n", 
   RowBox[{
    RowBox[{"chadBox", " ", "=", " ", 
     RowBox[{"{", 
      RowBox[{"13.5", ",", " ", "12.5", ",", " ", "15.5", ",", " ", "14.0"}], 
      "}"}]}], ";"}], "\n", "\n", 
   RowBox[{"(*", " ", 
    RowBox[{"Occurrence", " ", 
     RowBox[{"band", ":", " ", 
      RowBox[{"0", "-", 
       RowBox[{"100", " ", 
        RowBox[{"(", 
         RowBox[{
         "%", " ", "of", " ", "time", " ", "pixel", " ", "was", " ", 
          "water"}], ")"}]}]}]}]}], " ", "*)"}], "\n", 
   RowBox[{
    RowBox[{"occurrence", " ", "=", " ", 
     RowBox[{"jrcWater", " ", "//", " ", 
      RowBox[{"GEESelectBands", "[", 
       RowBox[{"{", "\"\<occurrence\>\"", "}"}], "]"}]}]}], ";"}], "\n", "\n", 
   RowBox[{"occurrenceImage", " ", "=", " ", 
    RowBox[{"GEEComputePixels", "[", 
     RowBox[{"chadBox", ",", " ", "occurrence", ",", "\n", "  ", 
      RowBox[{"\"\<VisParams\>\"", " ", "->", " ", 
       RowBox[{"<|", 
        RowBox[{
         RowBox[{"\"\<min\>\"", " ", "->", " ", "0"}], ",", " ", 
         RowBox[{"\"\<max\>\"", " ", "->", " ", "100"}], ",", "\n", "    ", 
         RowBox[{"\"\<palette\>\"", " ", "->", " ", 
          RowBox[{"{", 
           
           RowBox[{"\"\<#FFFFFF\>\"", ",", " ", "\"\<#ADD8E6\>\"", ",", 
            " ", "\"\<#0000FF\>\"", ",", " ", "\"\<#00008B\>\""}], "}"}]}]}], 
        "|>"}]}]}], "]"}]}]}]}]], "Input",ExpressionUUID->"08be6988-f420-4e47-\
87c8-ebb3ec899c40"],

Cell["\<\
Classify water into permanence categories using threshold logic.\
\>", "Text",ExpressionUUID->"a89c7e2d-0821-df44-93c1-a6ce2d4a8244"],

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{"Permanent", " ", 
    RowBox[{"water", ":", " ", 
     RowBox[{"present", " ", ">", " ", 
      RowBox[{"80", "%", " ", "of", " ", "the", " ", "time"}]}]}]}], " ", 
   "*)"}], "\n", 
  RowBox[{
   RowBox[{
    RowBox[{"permanentWater", " ", "=", " ", 
     RowBox[{
      RowBox[{"occurrence", " ", "//", "\n", "  ", 
       RowBox[{"GEEGreaterThan", "[", "80", "]"}]}], " ", "//", "\n", "  ", 
      "GEESelfMask"}]}], ";"}], "\n", "\n", 
   RowBox[{"(*", " ", 
    RowBox[{"Seasonal", " ", 
     RowBox[{"water", ":", " ", 
      RowBox[{
       RowBox[{"present", " ", "20"}], "-", 
       RowBox[{"80", "%", " ", "of", " ", "the", " ", "time"}]}]}]}], " ", 
    "*)"}], "\n", 
   RowBox[{
    RowBox[{"seasonalWater", " ", "=", " ", 
     RowBox[{
      RowBox[{
       RowBox[{"occurrence", " ", "//", "\n", "  ", 
        RowBox[{"GEEGreaterThan", "[", "20", "]"}]}], " ", "//", "\n", "  ", 
       RowBox[{"GEEAnd", "[", 
        RowBox[{"occurrence", " ", "//", " ", 
         RowBox[{"GEELessThan", "[", "80", "]"}]}], "]"}]}], " ", "//", "\n", 
      "  ", "GEESelfMask"}]}], ";"}], "\n", "\n", 
   RowBox[{"(*", " ", 
    RowBox[{"Seasonality", " ", 
     RowBox[{"band", ":", " ", 
      RowBox[{
      "number", " ", "of", " ", "months", " ", "water", " ", "is", " ", 
       "present", " ", "per", " ", "year"}]}]}], " ", "*)"}], "\n", 
   RowBox[{
    RowBox[{"seasonality", " ", "=", " ", 
     RowBox[{"jrcWater", " ", "//", " ", 
      RowBox[{"GEESelectBands", "[", 
       RowBox[{"{", "\"\<seasonality\>\"", "}"}], "]"}]}]}], ";"}], "\n", "\n", 
   RowBox[{"seasonalityImage", " ", "=", " ", 
    RowBox[{"GEEComputePixels", "[", 
     RowBox[{"chadBox", ",", " ", "seasonality", ",", "\n", "  ", 
      RowBox[{"\"\<VisParams\>\"", " ", "->", " ", 
       RowBox[{"<|", 
        RowBox[{
         RowBox[{"\"\<min\>\"", " ", "->", " ", "0"}], ",", " ", 
         RowBox[{"\"\<max\>\"", " ", "->", " ", "12"}], ",", "\n", "    ", 
         RowBox[{"\"\<palette\>\"", " ", "->", " ", 
          RowBox[{"{", 
           
           RowBox[{"\"\<#FFFFFF\>\"", ",", " ", "\"\<#87CEEB\>\"", ",", 
            " ", "\"\<#4169E1\>\"", ",", " ", "\"\<#00008B\>\""}], "}"}]}]}], 
        "|>"}]}]}], "]"}]}]}]}]], "Input",ExpressionUUID->"fac40e85-70e6-3e40-\
8b38-2f901f021ba4"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Extracting Water Statistics at a Point", "Section",ExpressionUUID->"f487d4e4-909b-3e41-a6b4-935796065891"],

Cell[TextData[{
 "Use ",
 Cell["GEEIdentify", "InlineCode",ExpressionUUID->
  "f532dfec-87a6-d74f-b98e-27cca7d85aad"],
 " to query the JRC dataset at a specific location and retrieve the \
occurrence value directly."
}], "Text",ExpressionUUID->"930e695f-ac91-e047-9c0c-32541653b73b"],

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{"Query", " ", "Lake", " ", "Chad", " ", "center"}], " ", "*)"}], 
  "\n", 
  RowBox[{
   RowBox[{"GEEIdentify", "[", 
    RowBox[{
     RowBox[{"GeoPosition", "[", 
      RowBox[{"{", 
       RowBox[{"13.2", ",", " ", "14.1"}], "}"}], "]"}], ",", " ", 
     "occurrence"}], "]"}], "\n", "\n", 
   RowBox[{"(*", " ", 
    RowBox[{"Returns", ":", " ", 
     RowBox[{"<|", 
      RowBox[{
       RowBox[{"\"\<Position\>\"", " ", "->", " ", "..."}], ",", " ", 
       RowBox[{"\"\<Values\>\"", " ", "->", " ", 
        RowBox[{"{", "42", "}"}]}], ",", " ", 
       RowBox[{"\"\<Bands\>\"", " ", "->", " ", 
        RowBox[{"{", "\"\<occurrence\>\"", "}"}]}], ",", " ", "..."}], 
      "|>"}]}], " ", "*)"}], "\n", 
   RowBox[{"(*", " ", 
    RowBox[{"42", "%", " ", "occurrence", " ", "indicates", " ", 
     RowBox[{"seasonal", "/", "declining"}], " ", "water"}], " ", 
    "*)"}]}]}]], "Input",ExpressionUUID->"ceac8083-d39a-2942-9878-\
2569fdafb196"],

Cell["", "Text",
 CellFrame->{{0, 0}, {0, 
  1}},ExpressionUUID->"5c748a3b-5057-1845-af23-b81d5ef87829"]
}, Open  ]]
}, Open  ]],

Cell[CellGroupData[{

Cell["6.2 Reservoir and Lake Monitoring", "Chapter",ExpressionUUID->"6aada422-f1aa-3f47-bb45-ca198aa34b4e"],

Cell[CellGroupData[{

Cell["Tracking Reservoir Surface Area Over Time", "Section",ExpressionUUID->"d9c2a107-04a3-3c47-be8b-43f1dffa5424"],

Cell["\<\
Reservoir surface area is a practical proxy for storage volume. By computing \
monthly NDWI composites and counting water pixels, you can build a time \
series of reservoir extent.\
\>", "Text",ExpressionUUID->"bc999ae0-1e08-6048-991b-f44496df2976"],

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{
    RowBox[{"Target", ":", " ", 
     RowBox[{"Lake", " ", "Mead"}]}], ",", " ", 
    RowBox[{"Nevada", "/", "Arizona"}], ",", " ", "USA"}], " ", "*)"}], "\n", 
  RowBox[{
   RowBox[{
    RowBox[{"meadBox", " ", "=", " ", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"-", "114.9"}], ",", " ", "35.9", ",", " ", 
       RowBox[{"-", "114.3"}], ",", " ", "36.4"}], "}"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"meadGeom", " ", "=", " ", 
     RowBox[{"GEEGeometry", "[", "meadBox", "]"}]}], ";"}], "\n", "\n", 
   RowBox[{"(*", " ", 
    RowBox[{
    "Function", " ", "to", " ", "compute", " ", "water", " ", "area", " ", 
     "for", " ", "a", " ", "single", " ", "month"}], " ", "*)"}], "\n", 
   RowBox[{
    RowBox[{"reservoirAreaForMonth", "[", 
     RowBox[{"year_Integer", ",", " ", "month_Integer"}], "]"}], " ", ":=", 
    " ", 
    RowBox[{"Module", "[", "\n", "  ", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{
       "startDate", ",", " ", "endDate", ",", " ", "composite", ",", " ", 
        "waterMask", ",", " ", "areaImage", ",", " ", "stats"}], "}"}], ",", 
      "\n", "\n", "  ", 
      RowBox[{
       RowBox[{"startDate", " ", "=", " ", 
        RowBox[{"DateString", "[", 
         RowBox[{
          RowBox[{"{", 
           RowBox[{"year", ",", " ", "month", ",", " ", "1"}], "}"}], ",", 
          " ", "\"\<ISODate\>\""}], "]"}]}], ";", "\n", "  ", 
       RowBox[{"endDate", " ", "=", " ", 
        RowBox[{"DateString", "[", 
         RowBox[{
          RowBox[{"DatePlus", "[", 
           RowBox[{
            RowBox[{"{", 
             RowBox[{"year", ",", " ", "month", ",", " ", "1"}], "}"}], ",", 
            " ", 
            RowBox[{"{", 
             RowBox[{"1", ",", " ", "\"\<Month\>\""}], "}"}]}], "]"}], ",", 
          " ", "\"\<ISODate\>\""}], "]"}]}], ";", "\n", "\n", "  ", 
       RowBox[{"(*", " ", 
        RowBox[{
         RowBox[{"Monthly", " ", "Sentinel"}], "-", 
         RowBox[{"2", " ", "composite"}]}], " ", "*)"}], "\n", "  ", 
       RowBox[{"composite", " ", "=", "\n", "    ", 
        RowBox[{
         RowBox[{
          RowBox[{
           RowBox[{
            RowBox[{
            "GEECollection", "[", "\"\<COPERNICUS/S2_SR_HARMONIZED\>\"", 
             "]"}], " ", "//", "\n", "      ", 
            RowBox[{"GEEFilterDate", "[", 
             RowBox[{"startDate", ",", " ", "endDate"}], "]"}]}], " ", "//", 
           "\n", "      ", 
           RowBox[{"GEEFilterBounds", "[", "meadBox", "]"}]}], " ", "//", 
          "\n", "      ", 
          RowBox[{"GEEFilterProperty", "[", 
           
           RowBox[{"\"\<CLOUDY_PIXEL_PERCENTAGE\>\"", ",", 
            " ", "\"\<LessThan\>\"", ",", " ", "30"}], "]"}]}], " ", "//", 
         "\n", "      ", "GEEMedian"}]}], ";", "\n", "\n", "  ", 
       RowBox[{"(*", " ", 
        RowBox[{"NDWI", " ", "water", " ", "mask"}], " ", "*)"}], "\n", "  ", 
       RowBox[{"waterMask", " ", "=", " ", 
        RowBox[{
         RowBox[{
          RowBox[{"composite", " ", "//", "\n", "    ", 
           RowBox[{"GEENormalizedDifference", "[", 
            RowBox[{"{", 
             RowBox[{"\"\<B3\>\"", ",", " ", "\"\<B8\>\""}], "}"}], "]"}]}], 
          " ", "//", "\n", "    ", 
          RowBox[{"GEEGreaterThan", "[", "0", "]"}]}], " ", "//", "\n", 
         "    ", "GEESelfMask"}]}], ";", "\n", "\n", "  ", 
       RowBox[{"(*", " ", 
        RowBox[{
         RowBox[{
         "Multiply", " ", "water", " ", "mask", " ", "by", " ", "pixel", " ", 
          "area"}], ",", " ", 
         RowBox[{"then", " ", "sum"}]}], " ", "*)"}], "\n", "  ", 
       RowBox[{"areaImage", " ", "=", " ", 
        RowBox[{"waterMask", " ", "//", " ", 
         RowBox[{"GEEMultiply", "[", 
          RowBox[{"GEEPixelArea", "[", "]"}], "]"}]}]}], ";", "\n", "\n", 
       "  ", 
       RowBox[{"stats", " ", "=", " ", 
        RowBox[{"GEECompute", "[", "\n", "    ", 
         RowBox[{"areaImage", " ", "//", " ", 
          RowBox[{"GEEReduceRegion", "[", 
           RowBox[{"meadGeom", ",", " ", "\"\<sum\>\"", ",", " ", "30"}], 
           "]"}]}], "\n", "  ", "]"}]}], ";", "\n", "\n", "  ", 
       RowBox[{"(*", " ", 
        RowBox[{"Return", " ", "date", " ", "and", " ", "area", " ", "in", " ", 
         RowBox[{"km", "^", "2."}], "\n", "     ", "The", " ", "band", " ", 
         "is", " ", "named", " ", "\"\<nd\>\"", " ", "because", " ", 
         "GEENormalizedDifference", " ", "outputs", "\n", "     ", "a", " ", 
         "single", " ", "band", " ", "with", " ", "that", " ", "name", " ", 
         "by", " ", 
         RowBox[{"default", "."}]}], " ", "*)"}], "\n", "  ", 
       RowBox[{"{", 
        RowBox[{
         RowBox[{"DateObject", "[", 
          RowBox[{"{", 
           RowBox[{"year", ",", " ", "month", ",", " ", "1"}], "}"}], "]"}], ",",
          "\n", "   ", 
         RowBox[{
          RowBox[{"Lookup", "[", 
           RowBox[{"stats", ",", " ", "\"\<nd\>\"", ",", " ", "0"}], "]"}], 
          " ", "/", " ", "1.0*^6"}]}], "}"}]}]}], "\n", "]"}]}]}]}]], "Input",\
ExpressionUUID->"c6ce7c2a-bd20-5743-b35a-b77051944aab"],

Cell["Build a multi-year time series and visualize.", "Text",ExpressionUUID->"e3c61fd7-aa3a-dc42-88e1-662662cba78d"],

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{
   "Compute", " ", "monthly", " ", "areas", " ", "from", " ", "2020", " ", 
    "through", " ", "2024"}], " ", "*)"}], "\n", 
  RowBox[{
   RowBox[{
    RowBox[{"monthlyData", " ", "=", " ", 
     RowBox[{"Flatten", "[", "\n", "  ", 
      RowBox[{
       RowBox[{
        RowBox[{"Table", "[", "\n", "    ", 
         RowBox[{
          RowBox[{"reservoirAreaForMonth", "[", 
           RowBox[{"y", ",", " ", "m"}], "]"}], ",", "\n", "    ", 
          RowBox[{"{", 
           RowBox[{"y", ",", " ", "2020", ",", " ", "2024"}], "}"}], ",", " ", 
          RowBox[{"{", 
           RowBox[{"m", ",", " ", "1", ",", " ", "12"}], "}"}]}], "\n", "  ", 
         "]"}], " ", "//", " ", 
        RowBox[{"DeleteCases", "[", 
         RowBox[{"{", 
          RowBox[{"_", ",", " ", 
           RowBox[{"0", " ", "|", " ", "0."}]}], "}"}], "]"}]}], ",", "\n", 
       "  ", "1"}], "\n", "]"}]}], ";"}], "\n", "\n", 
   RowBox[{"(*", " ", 
    RowBox[{"Build", " ", "a", " ", "TimeSeries", " ", "and", " ", "plot"}], 
    " ", "*)"}], "\n", 
   RowBox[{
    RowBox[{"areaSeries", " ", "=", " ", 
     RowBox[{"TimeSeries", "[", "monthlyData", "]"}]}], ";"}], "\n", "\n", 
   RowBox[{"DateListPlot", "[", 
    RowBox[{"areaSeries", ",", "\n", "  ", 
     RowBox[{
     "PlotLabel", " ", "->", 
      " ", "\"\<Lake Mead Surface Area (2020-2024)\>\""}], ",", "\n", "  ", 
     RowBox[{"FrameLabel", " ", "->", " ", 
      RowBox[{"{", 
       RowBox[{"\"\<Date\>\"", ",", 
        " ", "\"\<Surface Area (km\\[Superscript]2)\>\""}], "}"}]}], ",", 
     "\n", "  ", 
     RowBox[{"PlotStyle", " ", "->", " ", "Blue"}], ",", "\n", "  ", 
     RowBox[{"Filling", " ", "->", " ", "Axis"}], ",", "\n", "  ", 
     RowBox[{"FillingStyle", " ", "->", " ", 
      RowBox[{"Directive", "[", 
       RowBox[{
        RowBox[{"Opacity", "[", "0.2", "]"}], ",", " ", "Blue"}], "]"}]}], ",",
      "\n", "  ", 
     RowBox[{"GridLines", " ", "->", " ", "Automatic"}], ",", "\n", "  ", 
     RowBox[{"ImageSize", " ", "->", " ", "Large"}]}], "]"}]}]}]], "Input",Exp\
ressionUUID->"2411e203-67a7-7d41-afa7-a138c84b1449"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Before/After Drought Comparison", "Section",ExpressionUUID->"f34dcc9f-43da-cc4e-8e76-b0197b958a5e"],

Cell["\<\
A direct visual comparison between wet and dry periods can be more compelling \
than a time series chart. This example compares Lake Mead in a wet year \
versus a drought year.\
\>", "Text",ExpressionUUID->"da2f0a6e-9ea2-2045-97e0-1dc17a55f9c5"],

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{"Wet", " ", 
    RowBox[{"period", ":", " ", 
     RowBox[{"spring", " ", "2019"}]}]}], " ", "*)"}], "\n", 
  RowBox[{
   RowBox[{
    RowBox[{"wetComposite", " ", "=", "\n", "  ", 
     RowBox[{
      RowBox[{
       RowBox[{
        RowBox[{
         RowBox[{
         "GEECollection", "[", "\"\<COPERNICUS/S2_SR_HARMONIZED\>\"", "]"}], 
         " ", "//", "\n", "    ", 
         RowBox[{"GEEFilterDate", "[", 
          RowBox[{"\"\<2019-04-01\>\"", ",", " ", "\"\<2019-07-01\>\""}], 
          "]"}]}], " ", "//", "\n", "    ", 
        RowBox[{"GEEFilterBounds", "[", "meadBox", "]"}]}], " ", "//", "\n", 
       "    ", 
       RowBox[{"GEEFilterProperty", "[", 
        RowBox[{"\"\<CLOUDY_PIXEL_PERCENTAGE\>\"", ",", 
         " ", "\"\<LessThan\>\"", ",", " ", "20"}], "]"}]}], " ", "//", "\n", 
      "    ", "GEEMedian"}]}], ";"}], "\n", "\n", 
   RowBox[{
    RowBox[{"wetWater", " ", "=", " ", 
     RowBox[{
      RowBox[{
       RowBox[{"wetComposite", " ", "//", "\n", "  ", 
        RowBox[{"GEENormalizedDifference", "[", 
         RowBox[{"{", 
          RowBox[{"\"\<B3\>\"", ",", " ", "\"\<B8\>\""}], "}"}], "]"}]}], " ",
        "//", "\n", "  ", 
       RowBox[{"GEEGreaterThan", "[", "0", "]"}]}], " ", "//", "\n", "  ", 
      "GEESelfMask"}]}], ";"}], "\n", "\n", 
   RowBox[{"(*", " ", 
    RowBox[{"Dry", " ", 
     RowBox[{"period", ":", " ", 
      RowBox[{"summer", " ", "2022", " ", 
       RowBox[{"(", 
        RowBox[{"historic", " ", "low"}], ")"}]}]}]}], " ", "*)"}], "\n", 
   RowBox[{
    RowBox[{"dryComposite", " ", "=", "\n", "  ", 
     RowBox[{
      RowBox[{
       RowBox[{
        RowBox[{
         RowBox[{
         "GEECollection", "[", "\"\<COPERNICUS/S2_SR_HARMONIZED\>\"", "]"}], 
         " ", "//", "\n", "    ", 
         RowBox[{"GEEFilterDate", "[", 
          RowBox[{"\"\<2022-06-01\>\"", ",", " ", "\"\<2022-09-01\>\""}], 
          "]"}]}], " ", "//", "\n", "    ", 
        RowBox[{"GEEFilterBounds", "[", "meadBox", "]"}]}], " ", "//", "\n", 
       "    ", 
       RowBox[{"GEEFilterProperty", "[", 
        RowBox[{"\"\<CLOUDY_PIXEL_PERCENTAGE\>\"", ",", 
         " ", "\"\<LessThan\>\"", ",", " ", "20"}], "]"}]}], " ", "//", "\n", 
      "    ", "GEEMedian"}]}], ";"}], "\n", "\n", 
   RowBox[{
    RowBox[{"dryWater", " ", "=", " ", 
     RowBox[{
      RowBox[{
       RowBox[{"dryComposite", " ", "//", "\n", "  ", 
        RowBox[{"GEENormalizedDifference", "[", 
         RowBox[{"{", 
          RowBox[{"\"\<B3\>\"", ",", " ", "\"\<B8\>\""}], "}"}], "]"}]}], " ",
        "//", "\n", "  ", 
       RowBox[{"GEEGreaterThan", "[", "0", "]"}]}], " ", "//", "\n", "  ", 
      "GEESelfMask"}]}], ";"}], "\n", "\n", 
   RowBox[{"(*", " ", 
    RowBox[{"Render", " ", "both"}], " ", "*)"}], "\n", 
   RowBox[{
    RowBox[{"visPar", " ", "=", " ", 
     RowBox[{"<|", 
      RowBox[{
       RowBox[{"\"\<min\>\"", " ", "->", " ", "0"}], ",", " ", 
       RowBox[{"\"\<max\>\"", " ", "->", " ", "1"}], ",", " ", 
       RowBox[{"\"\<palette\>\"", " ", "->", " ", 
        RowBox[{"{", "\"\<#0000FF\>\"", "}"}]}]}], "|>"}]}], ";"}], "\n", "\n", 
   RowBox[{
    RowBox[{"wetImg", " ", "=", " ", 
     RowBox[{"GEEComputePixels", "[", 
      RowBox[{"meadBox", ",", " ", "wetWater", ",", " ", 
       RowBox[{"\"\<VisParams\>\"", " ", "->", " ", "visPar"}]}], "]"}]}], 
    ";"}], "\n", 
   RowBox[{
    RowBox[{"dryImg", " ", "=", " ", 
     RowBox[{"GEEComputePixels", "[", 
      RowBox[{"meadBox", ",", " ", "dryWater", ",", " ", 
       RowBox[{"\"\<VisParams\>\"", " ", "->", " ", "visPar"}]}], "]"}]}], 
    ";"}], "\n", "\n", 
   RowBox[{"GraphicsRow", "[", 
    RowBox[{
     RowBox[{"{", "\n", "  ", 
      RowBox[{
       RowBox[{"Labeled", "[", 
        RowBox[{
         RowBox[{"Image", "[", 
          RowBox[{"wetImg", ",", " ", 
           RowBox[{"ImageSize", " ", "->", " ", "400"}]}], "]"}], ",", 
         " ", "\"\<Spring 2019\>\"", ",", " ", "Top"}], "]"}], ",", "\n", 
       "  ", 
       RowBox[{"Labeled", "[", 
        RowBox[{
         RowBox[{"Image", "[", 
          RowBox[{"dryImg", ",", " ", 
           RowBox[{"ImageSize", " ", "->", " ", "400"}]}], "]"}], ",", 
         " ", "\"\<Summer 2022\>\"", ",", " ", "Top"}], "]"}]}], "\n", "}"}], 
     ",", " ", 
     RowBox[{"Spacings", " ", "->", " ", "20"}]}], "]"}]}]}]], "Input",Express\
ionUUID->"9819bd5e-35d2-6140-9213-6d7b3d91e670"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Overlay on a Basemap with GEEGeoGraphics", "Section",ExpressionUUID->"a8d03131-709f-1640-8646-8f826a8eed62"],

Cell[TextData[{
 Cell["GEEGeoGraphics", "InlineCode",ExpressionUUID->
  "d6e49a74-12b3-fb48-978e-ecf92bfc71f0"],
 " renders GEE imagery as a background layer with geographic primitives drawn \
on top, making it easy to annotate water features."
}], "Text",ExpressionUUID->"a39bcd47-c1f8-8f4f-be85-de0c2f9e6785"],

Cell[BoxData[
 RowBox[{"GEEGeoGraphics", "[", "\n", "  ", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{
     RowBox[{"EdgeForm", "[", "Red", "]"}], ",", " ", 
     RowBox[{"FaceForm", "[", "None", "]"}], ",", "\n", "   ", 
     RowBox[{"Rectangle", " ", "@@", " ", 
      RowBox[{"(", 
       RowBox[{"GeoPosition", " ", "/@", " ", 
        RowBox[{"{", 
         RowBox[{
          RowBox[{"{", 
           RowBox[{"35.9", ",", " ", 
            RowBox[{"-", "114.9"}]}], "}"}], ",", " ", 
          RowBox[{"{", 
           RowBox[{"36.4", ",", " ", 
            RowBox[{"-", "114.3"}]}], "}"}]}], "}"}]}], ")"}]}]}], "}"}], ",",
    "\n", "  ", "dryWater", ",", "\n", "  ", 
   RowBox[{"GeoRange", " ", "->", " ", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{"35.85", ",", " ", "36.45"}], "}"}], ",", " ", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"-", "114.95"}], ",", " ", 
        RowBox[{"-", "114.25"}]}], "}"}]}], "}"}]}], ",", "\n", "  ", 
   RowBox[{"\"\<VisParams\>\"", " ", "->", " ", 
    RowBox[{"<|", 
     RowBox[{
      RowBox[{"\"\<min\>\"", " ", "->", " ", "0"}], ",", " ", 
      RowBox[{"\"\<max\>\"", " ", "->", " ", "1"}], ",", "\n", "    ", 
      RowBox[{"\"\<palette\>\"", " ", "->", " ", 
       RowBox[{"{", "\"\<#0066CC\>\"", "}"}]}]}], "|>"}]}], ",", "\n", "  ", 
   RowBox[{"ImageSize", " ", "->", " ", "600"}]}], "]"}]], "Input",ExpressionU\
UID->"6a5aea4f-524b-6b44-a9ef-d6e1c9442c0e"],

Cell["", "Text",
 CellFrame->{{0, 0}, {0, 
  1}},ExpressionUUID->"95d2a9e1-123d-dc41-84c4-9d62b8c577ad"]
