Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{
   "Compile", " ", "all", " ", "results", " ", "into", " ", "a", " ", 
    "summary", " ", "Dataset"}], " ", "*)"}], "\n", 
  RowBox[{
   RowBox[{
    RowBox[{"summary", " ", "=", " ", 
     RowBox[{"Dataset", "[", 
      RowBox[{"<|", "\n", "  ", 
       RowBox[{
        RowBox[{"\"\<Water Body Area\>\"", " ", "->", " ", 
         RowBox[{"Quantity", "[", 
          RowBox[{"mekongWaterKm2", ",", " ", 
           RowBox[{"\"\<Kilometers\>\"", "^", "2"}]}], "]"}]}], ",", "\n", 
