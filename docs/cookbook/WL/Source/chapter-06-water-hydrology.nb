Cell[CellGroupData[{

Cell["6.6 Water Quality Indicators", "Chapter",ExpressionUUID->"ad377bbb-5526-d749-b32b-b0aa27525b2b"],

Cell[CellGroupData[{

Cell["Turbidity Estimation from Sentinel-2", "Section",ExpressionUUID->"885d98ab-b243-9444-8d35-3bc4fe984e23"],

Cell["\<\
Turbidity -- the cloudiness of water caused by suspended sediments -- \
correlates strongly with red-band reflectance. Clear water absorbs red light, \
while sediment-laden water reflects it. The red band (B4) of Sentinel-2 \
provides a simple but effective turbidity proxy at 10-meter resolution.\
\>", "Text",ExpressionUUID->"e8a925a8-2f65-df42-91fe-2b17173544a0"],

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{"Target", ":", " ", 
    RowBox[{
    "Chesapeake", " ", "Bay", " ", "after", " ", "a", " ", "storm", " ", 
     "event"}]}], " ", "*)"}], "\n", 
  RowBox[{
   RowBox[{
    RowBox[{"bayBox", " ", "=", " ", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"-", "76.5"}], ",", " ", "37.0", ",", " ", 
       RowBox[{"-", "75.8"}], ",", " ", "37.6"}], "}"}]}], ";"}], "\n", "\n", 
   RowBox[{
    RowBox[{"s2Bay", " ", "=", "\n", "  ", 
     RowBox[{
      RowBox[{
       RowBox[{
        RowBox[{
         RowBox[{
         "GEECollection", "[", "\"\<COPERNICUS/S2_SR_HARMONIZED\>\"", "]"}], 
         " ", "//", "\n", "    ", 
         RowBox[{"GEEFilterDate", "[", 
          RowBox[{"\"\<2024-09-01\>\"", ",", " ", "\"\<2024-10-01\>\""}], 
          "]"}]}], " ", "//", "\n", "    ", 
        RowBox[{"GEEFilterBounds", "[", "bayBox", "]"}]}], " ", "//", "\n", 
       "    ", 
       RowBox[{"GEEFilterProperty", "[", 
        RowBox[{"\"\<CLOUDY_PIXEL_PERCENTAGE\>\"", ",", 
         " ", "\"\<LessThan\>\"", ",", " ", "20"}], "]"}]}], " ", "//", "\n", 
      "    ", "GEEMedian"}]}], ";"}], "\n", "\n", 
   RowBox[{"(*", " ", 
    RowBox[{
    "Extract", " ", "red", " ", "band", " ", "as", " ", "turbidity", " ", 
     "proxy"}], " ", "*)"}], "\n", 
   RowBox[{
    RowBox[{"redBand", " ", "=", " ", 
     RowBox[{"s2Bay", " ", "//", " ", 
      RowBox[{"GEESelectBands", "[", 
       RowBox[{"{", "\"\<B4\>\"", "}"}], "]"}]}]}], ";"}], "\n", "\n", 
   RowBox[{"(*", " ", 
    RowBox[{"Mask", " ", "land", " ", "using", " ", "NDWI"}], " ", "*)"}], "\n", 
   RowBox[{
    RowBox[{"waterMask", " ", "=", " ", 
     RowBox[{
      RowBox[{"s2Bay", " ", "//", "\n", "  ", 
       RowBox[{"GEENormalizedDifference", "[", 
        RowBox[{"{", 
         RowBox[{"\"\<B3\>\"", ",", " ", "\"\<B8\>\""}], "}"}], "]"}]}], " ", 
      "//", "\n", "  ", 
      RowBox[{"GEEGreaterThan", "[", "0", "]"}]}]}], ";"}], "\n", "\n", 
   RowBox[{"(*", " ", 
    RowBox[{
    "Apply", " ", "water", " ", "mask", " ", "to", " ", "red", " ", "band"}], 
    " ", "*)"}], "\n", 
   RowBox[{
    RowBox[{"turbidity", " ", "=", " ", 
     RowBox[{"redBand", " ", "//", " ", 
      RowBox[{"GEEUpdateMask", "[", "waterMask", "]"}]}]}], ";"}], "\n", "\n", 
   RowBox[{"turbidityImage", " ", "=", " ", 
    RowBox[{"GEEComputePixels", "[", 
     RowBox[{"bayBox", ",", " ", "turbidity", ",", "\n", "  ", 
      RowBox[{"\"\<VisParams\>\"", " ", "->", " ", 
       RowBox[{"<|", 
        RowBox[{
         RowBox[{"\"\<min\>\"", " ", "->", " ", "0"}], ",", " ", 
         RowBox[{"\"\<max\>\"", " ", "->", " ", "1500"}], ",", "\n", "    ", 
         RowBox[{"\"\<palette\>\"", " ", "->", " ", 
          RowBox[{"{", 
           
           RowBox[{"\"\<#0000FF\>\"", ",", " ", "\"\<#00FF00\>\"", ",", 
            " ", "\"\<#FFFF00\>\"", ",", " ", "\"\<#FF0000\>\""}], "}"}]}]}], 
        "|>"}]}]}], "]"}]}]}]}]], "Input",ExpressionUUID->"30947aa0-31c2-4d4a-\
9fbe-798f2b603282"],

Cell[TextData[{
 StyleBox["Note:",
  FontWeight->Bold],
 " Red-band reflectance is a qualitative turbidity proxy. Quantitative \
turbidity estimation requires site-specific calibration with in-situ NTU \
measurements."
}], "Text",
 CellFrame->{{True, False}, {
   False, False}},ExpressionUUID->"378c44de-6425-0d4b-b9c0-1bd3e627a2bd"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Chlorophyll-a and Algal Bloom Detection", "Section",ExpressionUUID->"1fb1e1ef-ac2d-ef48-a5c6-b9ffd5950950"],

Cell["\<\
Chlorophyll-a concentration correlates with the ratio of green to blue \
reflectance. Elevated green-to-blue ratios indicate higher phytoplankton \
density, which can signal harmful algal blooms in lakes and reservoirs.\
\>", "Text",ExpressionUUID->"32d3fd63-0137-0444-8318-eed36dafb7b6"],

Cell[TextData[{
 StyleBox["Note:",
  FontWeight->Bold],
 " The green/blue ratio is a first-order approximation. Operational \
chlorophyll-a algorithms (e.g., OC3 for open ocean, CI for \
cyanobacteria-dominated systems) are more appropriate for quantitative work."
}], "Text",
 CellFrame->{{True, False}, {
   False, False}},ExpressionUUID->"95e7b517-abb7-2a4a-871c-387f3edaa179"],

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{"Target", ":", " ", 
    RowBox[{"Lake", " ", 
     RowBox[{"Erie", " ", "--"}], " ", "prone", " ", "to", " ", "harmful", " ",
      "algal", " ", "blooms"}]}], " ", "*)"}], "\n", 
  RowBox[{
   RowBox[{
    RowBox[{"erieBox", " ", "=", " ", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"-", "83.5"}], ",", " ", "41.3", ",", " ", 
       RowBox[{"-", "82.5"}], ",", " ", "42.0"}], "}"}]}], ";"}], "\n", "\n", 
   RowBox[{
    RowBox[{"s2Erie", " ", "=", "\n", "  ", 
     RowBox[{
      RowBox[{
       RowBox[{
        RowBox[{
         RowBox[{
         "GEECollection", "[", "\"\<COPERNICUS/S2_SR_HARMONIZED\>\"", "]"}], 
         " ", "//", "\n", "    ", 
         RowBox[{"GEEFilterDate", "[", 
          RowBox[{"\"\<2024-07-01\>\"", ",", " ", "\"\<2024-09-01\>\""}], 
          "]"}]}], " ", "//", "\n", "    ", 
        RowBox[{"GEEFilterBounds", "[", "erieBox", "]"}]}], " ", "//", "\n", 
       "    ", 
       RowBox[{"GEEFilterProperty", "[", 
        RowBox[{"\"\<CLOUDY_PIXEL_PERCENTAGE\>\"", ",", 
         " ", "\"\<LessThan\>\"", ",", " ", "15"}], "]"}]}], " ", "//", "\n", 
      "    ", "GEEMedian"}]}], ";"}], "\n", "\n", 
   RowBox[{"(*", " ", 
    RowBox[{
     RowBox[{
      RowBox[{"Green", "/", "Blue"}], " ", "band", " ", "ratio", " ", "as", " ",
       "chlorophyll"}], "-", 
     RowBox[{"a", " ", "proxy"}]}], " ", "*)"}], "\n", 
   RowBox[{
    RowBox[{"greenBand", " ", "=", " ", 
     RowBox[{"s2Erie", " ", "//", " ", 
      RowBox[{"GEESelectBands", "[", 
       RowBox[{"{", "\"\<B3\>\"", "}"}], "]"}]}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"blueBand", " ", "=", " ", 
     RowBox[{"s2Erie", " ", "//", " ", 
      RowBox[{"GEESelectBands", "[", 
       RowBox[{"{", "\"\<B2\>\"", "}"}], "]"}]}]}], ";"}], "\n", "\n", 
   RowBox[{
    RowBox[{"chlRatio", " ", "=", " ", 
     RowBox[{"GEEDivide", "[", 
      RowBox[{"greenBand", ",", " ", "blueBand"}], "]"}]}], ";"}], "\n", "\n", 
   RowBox[{"(*", " ", 
    RowBox[{"Mask", " ", "to", " ", "water", " ", "only"}], " ", "*)"}], "\n", 
   RowBox[{
    RowBox[{"erieWaterMask", " ", "=", " ", 
     RowBox[{
      RowBox[{"s2Erie", " ", "//", "\n", "  ", 
       RowBox[{"GEENormalizedDifference", "[", 
        RowBox[{"{", 
         RowBox[{"\"\<B3\>\"", ",", " ", "\"\<B8\>\""}], "}"}], "]"}]}], " ", 
      "//", "\n", "  ", 
      RowBox[{"GEEGreaterThan", "[", "0", "]"}]}]}], ";"}], "\n", "\n", 
   RowBox[{
    RowBox[{"chlWater", " ", "=", " ", 
     RowBox[{"chlRatio", " ", "//", " ", 
      RowBox[{"GEEUpdateMask", "[", "erieWaterMask", "]"}]}]}], ";"}], "\n", "\n", 
   RowBox[{"chlImage", " ", "=", " ", 
    RowBox[{"GEEComputePixels", "[", 
     RowBox[{"erieBox", ",", " ", "chlWater", ",", "\n", "  ", 
      RowBox[{"\"\<VisParams\>\"", " ", "->", " ", 
       RowBox[{"<|", 
        RowBox[{
         RowBox[{"\"\<min\>\"", " ", "->", " ", "0.8"}], ",", " ", 
         RowBox[{"\"\<max\>\"", " ", "->", " ", "2.5"}], ",", "\n", "    ", 
         RowBox[{"\"\<palette\>\"", " ", "->", " ", 
          RowBox[{"{", 
           
           RowBox[{"\"\<#0000FF\>\"", ",", " ", "\"\<#00FF00\>\"", ",", 
            " ", "\"\<#FFFF00\>\"", ",", " ", "\"\<#FF0000\>\""}], "}"}]}]}], 
        "|>"}]}]}], "]"}]}]}]}]], "Input",ExpressionUUID->"0ffbad8d-1cc1-8948-\
944c-5caf04e030de"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Algal Bloom Area Estimation", "Section",ExpressionUUID->"d803eede-9d5f-394f-a82d-8046f6f96fdc"],

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{"Define", " ", "bloom", " ", 
    RowBox[{"threshold", ":", " ", 
     RowBox[{
      RowBox[{
       RowBox[{"green", "/", "blue"}], " ", "ratio"}], " ", ">", " ", 
      "1.5"}]}]}], " ", "*)"}], "\n", 
  RowBox[{
   RowBox[{
    RowBox[{"bloomMask", " ", "=", " ", 
     RowBox[{
      RowBox[{"chlWater", " ", "//", "\n", "  ", 
       RowBox[{"GEEGreaterThan", "[", "1.5", "]"}]}], " ", "//", "\n", "  ", 
      "GEESelfMask"}]}], ";"}], "\n", "\n", 
   RowBox[{
    RowBox[{"bloomArea", " ", "=", " ", 
     RowBox[{"bloomMask", " ", "//", " ", 
      RowBox[{"GEEMultiply", "[", 
       RowBox[{"GEEPixelArea", "[", "]"}], "]"}]}]}], ";"}], "\n", "\n", 
   RowBox[{
    RowBox[{"erieGeom", " ", "=", " ", 
     RowBox[{"GEEGeometry", "[", "erieBox", "]"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"bloomStats", " ", "=", " ", 
     RowBox[{"GEECompute", "[", "\n", "  ", 
      RowBox[{"bloomArea", " ", "//", " ", 
       RowBox[{"GEEReduceRegion", "[", 
        RowBox[{"erieGeom", ",", " ", "\"\<sum\>\"", ",", " ", "20"}], 
        "]"}]}], "\n", "]"}]}], ";"}], "\n", "\n", 
   RowBox[{
    RowBox[{"bloomAreaKm2", " ", "=", " ", 
     RowBox[{
      RowBox[{"Lookup", "[", 
       RowBox[{"bloomStats", ",", " ", "\"\<B3\>\"", ",", " ", "0"}], "]"}], 
      " ", "/", " ", "1.0*^6"}]}], ";"}], "\n", 
   RowBox[{"Print", "[", 
    RowBox[{"\"\<Estimated bloom area: \>\"", ",", " ", 
     RowBox[{"Quantity", "[", 
      RowBox[{"bloomAreaKm2", ",", " ", 
       RowBox[{"\"\<Kilometers\>\"", "^", "2"}]}], "]"}]}], 
    "]"}]}]}]], "Input",ExpressionUUID->"8f45f215-943d-ff4f-a5b4-\
beaa353f1f66"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Color Analysis of Retrieved Water Imagery", "Section",ExpressionUUID->"213a8bbe-3940-4846-a9f2-eae7d7045f47"],

Cell["\<\
Wolfram Language's image processing functions can extract additional \
information from the retrieved satellite imagery on the client side.\
\>", "Text",ExpressionUUID->"32828e65-2143-ff47-9400-5df6ead1a268"],

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{
    RowBox[{"Retrieve", " ", "true"}], "-", 
    RowBox[{"color", " ", "image", " ", "of", " ", "Lake", " ", "Erie"}]}], 
   " ", "*)"}], "\n", 
  RowBox[{
   RowBox[{
    RowBox[{"erieRGB", " ", "=", " ", 
     RowBox[{"GEEImage", "[", "\n", "  ", 
      RowBox[{
       RowBox[{"GeoPosition", "[", 
        RowBox[{"{", 
         RowBox[{"41.7", ",", " ", 
          RowBox[{"-", "83.0"}]}], "}"}], "]"}], ",", "\n", "  ", 
       RowBox[{"s2Erie", " ", "//", " ", 
        RowBox[{"GEESelectBands", "[", 
         RowBox[{"{", 
          
          RowBox[{"\"\<B4\>\"", ",", " ", "\"\<B3\>\"", ",", 
           " ", "\"\<B2\>\""}], "}"}], "]"}]}], ",", "\n", "  ", 
       RowBox[{"GeoRange", " ", "->", " ", 
        RowBox[{"Quantity", "[", 
         RowBox[{"50", ",", " ", "\"\<Kilometers\>\""}], "]"}]}], ",", "\n", 
       "  ", 
       RowBox[{"\"\<VisParams\>\"", " ", "->", " ", 
        RowBox[{"<|", 
         RowBox[{
          RowBox[{"\"\<min\>\"", " ", "->", " ", "0"}], ",", " ", 
          RowBox[{"\"\<max\>\"", " ", "->", " ", "3000"}]}], "|>"}]}]}], 
      "]"}]}], ";"}], "\n", "\n", 
   RowBox[{"(*", " ", 
    RowBox[{"Extract", " ", "dominant", " ", 
     RowBox[{"colors", " ", "--"}], " ", "green", " ", "tints", " ", 
     "indicate", " ", "algae"}], " ", "*)"}], "\n", 
   RowBox[{"DominantColors", "[", 
    RowBox[{"erieRGB", ",", " ", "5"}], "]"}], "\n", "\n", 
   RowBox[{"(*", " ", 
    RowBox[{
    "Measure", " ", "how", " ", "\"\<green\>\"", " ", "the", " ", "water", " ",
      "is", " ", "using", " ", "color", " ", "distance"}], " ", "*)"}], "\n", 
   RowBox[{
    RowBox[{"greenRef", " ", "=", " ", 
     RowBox[{"RGBColor", "[", 
      RowBox[{"0.2", ",", " ", "0.5", ",", " ", "0.2"}], "]"}]}], ";"}], " ", 
   RowBox[{"(*", " ", 
    RowBox[{"algal", " ", "green"}], " ", "*)"}], "\n", 
   RowBox[{
    RowBox[{"blueRef", " ", "=", " ", 
     RowBox[{"RGBColor", "[", 
      RowBox[{"0.1", ",", " ", "0.2", ",", " ", "0.5"}], "]"}]}], ";"}], " ", 
   RowBox[{"(*", " ", 
    RowBox[{"clean", " ", "water", " ", "blue"}], " ", "*)"}], "\n", "\n", 
   RowBox[{
    RowBox[{"pixels", " ", "=", " ", 
     RowBox[{"ImageData", "[", "erieRGB", "]"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"greenDist", " ", "=", " ", 
     RowBox[{"Map", "[", 
      RowBox[{
       RowBox[{
        RowBox[{"ColorDistance", "[", 
         RowBox[{
          RowBox[{"RGBColor", " ", "@@", " ", "#"}], ",", " ", "greenRef"}], 
         "]"}], " ", "&"}], ",", " ", "pixels", ",", " ", 
       RowBox[{"{", "2", "}"}]}], "]"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"blueDist", " ", "=", " ", 
     RowBox[{"Map", "[", 
      RowBox[{
       RowBox[{
        RowBox[{"ColorDistance", "[", 
         RowBox[{
          RowBox[{"RGBColor", " ", "@@", " ", "#"}], ",", " ", "blueRef"}], 
         "]"}], " ", "&"}], ",", " ", "pixels", ",", " ", 
       RowBox[{"{", "2", "}"}]}], "]"}]}], ";"}], "\n", "\n", 
   RowBox[{"(*", " ", 
    RowBox[{
     RowBox[{"Ratio", " ", 
      RowBox[{"image", ":", " ", 
       RowBox[{"low", " ", "values"}]}]}], " ", "=", " ", 
     RowBox[{"more", " ", "green", " ", 
      RowBox[{"(", 
       RowBox[{"potential", " ", "algae"}], ")"}]}]}], " ", "*)"}], "\n", 
   RowBox[{
    RowBox[{"ratioImg", " ", "=", " ", 
     RowBox[{"Image", "[", 
      RowBox[{"greenDist", " ", "/", " ", 
       RowBox[{"(", 
        RowBox[{"blueDist", " ", "+", " ", "0.01"}], ")"}]}], "]"}]}], ";"}], 
   "\n", 
   RowBox[{"Labeled", "[", 
    RowBox[{"ratioImg", ",", " ", "\"\<Green/Blue Color Distance Ratio\>\""}],
     "]"}]}]}]], "Input",ExpressionUUID->"6fd0d3d1-7453-014e-9d57-\
b45264b6cd32"],

Cell["", "Text",
 CellFrame->{{0, 0}, {0, 
  1}},ExpressionUUID->"031370a0-c9e1-d742-b965-108fac2250c1"]
}, Open  ]]
}, Open  ]],

Cell[CellGroupData[{

Cell["6.7 Wetland Mapping", "Chapter",ExpressionUUID->"99553172-9860-264e-b266-135c2f23ab66"],

Cell[CellGroupData[{

Cell["Multi-Index Wetland Classification", "Section",ExpressionUUID->"78a26089-5ea2-aa48-8d37-8cb872dcf5c0"],

Cell["\<\
Wetlands occupy the boundary between terrestrial and aquatic systems. They \
support dense vegetation (high NDVI) while maintaining high soil moisture or \
standing water (moderate NDWI). A combination of spectral indices can \
distinguish wetlands from pure water bodies and dry land.\
\>", "Text",ExpressionUUID->"ee7e17f8-a839-c44e-96a5-b3efd9451b2c"],

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{
    RowBox[{"Target", ":", " ", 
     RowBox[{"Okavango", " ", "Delta"}]}], ",", " ", "Botswana"}], " ", 
   "*)"}], "\n", 
  RowBox[{
   RowBox[{
    RowBox[{"okBox", " ", "=", " ", 
     RowBox[{"{", 
      RowBox[{"22.0", ",", " ", 
       RowBox[{"-", "20.0"}], ",", " ", "24.0", ",", " ", 
       RowBox[{"-", "18.5"}]}], "}"}]}], ";"}], "\n", "\n", 
   RowBox[{
    RowBox[{"s2Okavango", " ", "=", "\n", "  ", 
     RowBox[{
      RowBox[{
       RowBox[{
        RowBox[{
         RowBox[{
         "GEECollection", "[", "\"\<COPERNICUS/S2_SR_HARMONIZED\>\"", "]"}], 
         " ", "//", "\n", "    ", 
         RowBox[{"GEEFilterDate", "[", 
          RowBox[{"\"\<2024-03-01\>\"", ",", " ", "\"\<2024-06-01\>\""}], 
          "]"}]}], " ", "//", "\n", "    ", 
        RowBox[{"GEEFilterBounds", "[", "okBox", "]"}]}], " ", "//", "\n", 
       "    ", 
       RowBox[{"GEEFilterProperty", "[", 
        RowBox[{"\"\<CLOUDY_PIXEL_PERCENTAGE\>\"", ",", 
         " ", "\"\<LessThan\>\"", ",", " ", "15"}], "]"}]}], " ", "//", "\n", 
      "    ", "GEEMedian"}]}], ";"}], "\n", "\n", 
   RowBox[{"(*", " ", 
    RowBox[{"Compute", " ", "indices"}], " ", "*)"}], "\n", 
   RowBox[{
    RowBox[{"ndvi", " ", "=", " ", 
     RowBox[{"s2Okavango", " ", "//", " ", 
      RowBox[{"GEENormalizedDifference", "[", 
       RowBox[{"{", 
        RowBox[{"\"\<B8\>\"", ",", " ", "\"\<B4\>\""}], "}"}], "]"}]}]}], 
    ";"}], "\n", 
   RowBox[{
    RowBox[{"ndwi", " ", "=", " ", 
     RowBox[{"s2Okavango", " ", "//", " ", 
      RowBox[{"GEENormalizedDifference", "[", 
       RowBox[{"{", 
        RowBox[{"\"\<B3\>\"", ",", " ", "\"\<B8\>\""}], "}"}], "]"}]}]}], 
    ";"}], "\n", 
   RowBox[{
    RowBox[{"mndwi", " ", "=", " ", 
     RowBox[{"s2Okavango", " ", "//", " ", 
      RowBox[{"GEENormalizedDifference", "[", 
       RowBox[{"{", 
        RowBox[{"\"\<B3\>\"", ",", " ", "\"\<B11\>\""}], "}"}], "]"}]}]}], 
    ";"}]}]}]], "Input",ExpressionUUID->"ab53efe6-4d87-734d-98f7-\
4fa2deaef228"],

Cell["\<\
Apply classification rules to separate water, wetland, and dryland.\
\>", "Text",ExpressionUUID->"88efcf57-e015-cc40-a72c-6bd57f26e078"],

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{"Open", " ", 
    RowBox[{"water", ":", " ", 
     RowBox[{"NDWI", " ", ">", " ", "0.3"}]}]}], " ", "*)"}], "\n", 
  RowBox[{
   RowBox[{
    RowBox[{"openWater", " ", "=", " ", 
     RowBox[{
      RowBox[{"ndwi", " ", "//", "\n", "  ", 
       RowBox[{"GEEGreaterThan", "[", "0.3", "]"}]}], " ", "//", "\n", "  ", 
      "GEESelfMask"}]}], ";"}], "\n", "\n", 
   RowBox[{"(*", " ", 
    RowBox[{"Wetland", " ", 
     RowBox[{"vegetation", ":", " ", 
      RowBox[{"NDVI", " ", ">", " ", 
       RowBox[{"0.2", " ", "AND", " ", "NDWI"}], " ", ">", " ", 
       RowBox[{"-", "0.1"}]}]}]}], " ", "*)"}], "\n", 
   RowBox[{
    RowBox[{"wetlandVeg", " ", "=", " ", 
     RowBox[{
      RowBox[{"GEEAnd", "[", "\n", "  ", 
       RowBox[{
        RowBox[{"ndvi", " ", "//", " ", 
         RowBox[{"GEEGreaterThan", "[", "0.2", "]"}]}], ",", "\n", "  ", 
        RowBox[{"ndwi", " ", "//", " ", 
         RowBox[{"GEEGreaterThan", "[", 
          RowBox[{"-", "0.1"}], "]"}]}]}], "\n", "]"}], " ", "//", " ", 
      "GEESelfMask"}]}], ";"}], "\n", "\n", 
   RowBox[{"(*", " ", 
    RowBox[{
    "Build", " ", "a", " ", "classified", " ", "image", " ", "using", " ", 
     "GEEWhere"}], " ", "*)"}], "\n", 
   RowBox[{"(*", " ", 
    RowBox[{
    "Start", " ", "with", " ", "a", " ", "constant", " ", "image", " ", "of", 
     " ", "0", " ", 
     RowBox[{"(", "unclassified", ")"}]}], " ", "*)"}], "\n", 
   RowBox[{
    RowBox[{"classified", " ", "=", " ", 
     RowBox[{
      RowBox[{
       RowBox[{
        RowBox[{"GEEConstant", "[", "0", "]"}], " ", "//", "\n", "  ", 
        RowBox[{"GEEWhere", "[", 
         RowBox[{
          RowBox[{"ndwi", " ", "//", " ", 
           RowBox[{"GEEGreaterThan", "[", 
            RowBox[{"-", "0.1"}], "]"}]}], ",", " ", "1"}], "]"}]}], " ", "//",
        "   ", 
       RowBox[{"(*", " ", 
        RowBox[{"moist", " ", "soil"}], " ", "*)"}], "\n", "  ", 
       RowBox[{"GEEWhere", "[", 
        RowBox[{"wetlandVeg", ",", " ", "2"}], "]"}]}], " ", "//", 
      "                       ", 
      RowBox[{"(*", " ", "wetland", " ", "*)"}], "\n", "  ", 
      RowBox[{"GEEWhere", "[", 
       RowBox[{"openWater", ",", " ", "3"}], "]"}]}]}], ";"}], 
   "                          ", 
   RowBox[{"(*", " ", 
    RowBox[{"open", " ", "water"}], " ", "*)"}], "\n", "\n", 
   RowBox[{"classImage", " ", "=", " ", 
    RowBox[{"GEEComputePixels", "[", 
     RowBox[{"okBox", ",", " ", "classified", ",", "\n", "  ", 
      RowBox[{"\"\<VisParams\>\"", " ", "->", " ", 
       RowBox[{"<|", 
        RowBox[{
         RowBox[{"\"\<min\>\"", " ", "->", " ", "0"}], ",", " ", 
         RowBox[{"\"\<max\>\"", " ", "->", " ", "3"}], ",", "\n", "    ", 
         RowBox[{"\"\<palette\>\"", " ", "->", " ", 
          RowBox[{"{", 
           
           RowBox[{"\"\<#D2B48C\>\"", ",", " ", "\"\<#90EE90\>\"", ",", 
            " ", "\"\<#006400\>\"", ",", " ", "\"\<#0000FF\>\""}], "}"}]}]}], 
        "|>"}]}]}], "]"}]}]}]}]], "Input",ExpressionUUID->"40f41619-94e0-a640-\
9bbc-31ba7155db90"],

Cell["\<\
The resulting image shows four classes: dry land (tan), moist soil (light \
green), wetland vegetation (dark green), and open water (blue).\
\>", "Text",ExpressionUUID->"794ad034-7be2-c042-9ff7-b0ee210c10f1"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Wetland Area by Class", "Section",ExpressionUUID->"ef256f2b-e157-3047-8a57-c820e74eedc9"],

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"okGeom", " ", "=", " ", 
    RowBox[{"GEEGeometry", "[", "okBox", "]"}]}], ";"}], "\n", "\n", 
  RowBox[{"(*", " ", 
   RowBox[{"Area", " ", "for", " ", "each", " ", "class"}], " ", "*)"}]}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"wetlandClasses", " ", "=", " ", 
    RowBox[{"Association", " ", "@@", " ", 
     RowBox[{"Table", "[", "\n", "  ", 
      RowBox[{
       RowBox[{"Module", "[", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{"mask", ",", " ", "areaImg", ",", " ", "stats"}], "}"}], ",",
          "\n", "    ", 
         RowBox[{
          RowBox[{"mask", " ", "=", " ", 
           RowBox[{
            RowBox[{"classified", " ", "//", " ", 
             RowBox[{"GEEEquals", "[", "classVal", "]"}]}], " ", "//", " ", 
            "GEESelfMask"}]}], ";", "\n", "    ", 
          RowBox[{"areaImg", " ", "=", " ", 
           RowBox[{"mask", " ", "//", " ", 
            RowBox[{"GEEMultiply", "[", 
             RowBox[{"GEEPixelArea", "[", "]"}], "]"}]}]}], ";", "\n", "    ", 
          RowBox[{"stats", " ", "=", " ", 
           RowBox[{"GEECompute", "[", "\n", "      ", 
            RowBox[{"areaImg", " ", "//", " ", 
             RowBox[{"GEEReduceRegion", "[", 
              RowBox[{"okGeom", ",", " ", "\"\<sum\>\"", ",", " ", "30"}], 
              "]"}]}], "\n", "    ", "]"}]}], ";", "\n", "    ", 
          RowBox[{"className", " ", "->", " ", 
           RowBox[{
            RowBox[{"Lookup", "[", 
             RowBox[{"stats", ",", " ", "\"\<constant\>\"", ",", " ", "0"}], 
             "]"}], " ", "/", " ", "1.0*^6"}]}]}]}], "\n", "  ", "]"}], ",", 
       "\n", "  ", 
       RowBox[{"{", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{"classVal", ",", " ", "className"}], "}"}], ",", "\n", 
         "   ", 
         RowBox[{"{", 
          RowBox[{
           RowBox[{"{", 
            RowBox[{"1", ",", " ", "\"\<Moist Soil\>\""}], "}"}], ",", " ", 
           RowBox[{"{", 
            RowBox[{"2", ",", " ", "\"\<Wetland\>\""}], "}"}], ",", " ", 
           RowBox[{"{", 
            RowBox[{"3", ",", " ", "\"\<Open Water\>\""}], "}"}]}], "}"}]}], 
        "}"}]}], "\n", "]"}]}]}], ";"}], "\n", "\n", 
  RowBox[{"(*", " ", 
   RowBox[{"Display", " ", "as", " ", "a", " ", "Dataset"}], " ", "*)"}]}], "\n", 
 RowBox[{
  RowBox[{"Dataset", "[", "wetlandClasses", "]"}], "\n", "\n", 
  RowBox[{"(*", " ", 
   RowBox[{"Pie", " ", "chart"}], " ", "*)"}]}], "\n", 
 RowBox[{"PieChart", "[", 
  RowBox[{
   RowBox[{"Values", "[", "wetlandClasses", "]"}], ",", "\n", "  ", 
   RowBox[{"ChartLabels", " ", "->", " ", 
    RowBox[{"Keys", "[", "wetlandClasses", "]"}]}], ",", "\n", "  ", 
   RowBox[{"ChartStyle", " ", "->", " ", 
    RowBox[{"{", 
     RowBox[{"\"\<LightGreen\>\"", ",", " ", "\"\<DarkGreen\>\"", ",", 
      " ", "\"\<Blue\>\""}], "}"}]}], ",", "\n", "  ", 
   RowBox[{
   "PlotLabel", " ", "->", 
    " ", "\"\<Okavango Delta Land Cover (km\\[Superscript]2)\>\""}], ",", 
   "\n", "  ", 
   RowBox[{"ImageSize", " ", "->", " ", "400"}]}], "]"}]}], "Input",Expression\
UUID->"54973a3b-53a3-bf46-8880-c84451ac2c13"]
}, Open  ]],

Cell[CellGroupData[{

Cell["ESA WorldCover Wetland Extraction", "Section",ExpressionUUID->"f75b2413-6280-9143-b428-d3ec8be915b4"],

Cell["\<\
The ESA WorldCover product provides a global land cover map at 10-meter \
resolution. Class 90 corresponds to herbaceous wetlands.\
\>", "Text",ExpressionUUID->"3fe3bbd0-123e-9a44-8245-fe779add6c21"],

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{
   "ESA", " ", "WorldCover", " ", "v200", " ", "is", " ", "an", " ", 
    "IMAGE_COLLECTION"}], " ", "*)"}], "\n", 
  RowBox[{
   RowBox[{
    RowBox[{"worldCover", " ", "=", " ", 
     RowBox[{
      RowBox[{
       RowBox[{"GEECollection", "[", "\"\<ESA/WorldCover/v200\>\"", "]"}], 
       " ", "//", "\n", "  ", 
       RowBox[{"GEEFilterDate", "[", 
        RowBox[{"\"\<2021-01-01\>\"", ",", " ", "\"\<2022-01-01\>\""}], 
        "]"}]}], " ", "//", "\n", "  ", "GEEMosaic"}]}], ";"}], "\n", "\n", 
   RowBox[{"(*", " ", 
    RowBox[{"Extract", " ", "wetland", " ", "class", " ", 
     RowBox[{"(", 
      RowBox[{"value", " ", "=", " ", "90"}], ")"}]}], " ", "*)"}], "\n", 
   RowBox[{
    RowBox[{"wetlands", " ", "=", " ", 
     RowBox[{
      RowBox[{
       RowBox[{"worldCover", " ", "//", "\n", "  ", 
        RowBox[{"GEESelectBands", "[", 
         RowBox[{"{", "\"\<Map\>\"", "}"}], "]"}]}], " ", "//", "\n", "  ", 
       RowBox[{"GEEEquals", "[", "90", "]"}]}], " ", "//", "\n", "  ", 
      "GEESelfMask"}]}], ";"}], "\n", "\n", 
   RowBox[{"wetlandImg", " ", "=", " ", 
    RowBox[{"GEEComputePixels", "[", 
     RowBox[{"okBox", ",", " ", "wetlands", ",", "\n", "  ", 
      RowBox[{"\"\<VisParams\>\"", " ", "->", " ", 
       RowBox[{"<|", 
        RowBox[{
         RowBox[{"\"\<min\>\"", " ", "->", " ", "0"}], ",", " ", 
         RowBox[{"\"\<max\>\"", " ", "->", " ", "1"}], ",", "\n", "    ", 
         RowBox[{"\"\<palette\>\"", " ", "->", " ", 
          RowBox[{"{", "\"\<#006400\>\"", "}"}]}]}], "|>"}]}]}], "]"}]}], 
   "\n", "\n", 
   RowBox[{"(*", " ", 
    RowBox[{"Compute", " ", "wetland", " ", "area"}], " ", "*)"}], "\n", 
   RowBox[{
    RowBox[{"wetlandArea", " ", "=", " ", 
     RowBox[{"wetlands", " ", "//", " ", 
      RowBox[{"GEEMultiply", "[", 
       RowBox[{"GEEPixelArea", "[", "]"}], "]"}]}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"wetlandStats", " ", "=", " ", 
     RowBox[{"GEECompute", "[", "\n", "  ", 
      RowBox[{"wetlandArea", " ", "//", " ", 
       RowBox[{"GEEReduceRegion", "[", 
        RowBox[{"okGeom", ",", " ", "\"\<sum\>\"", ",", " ", "10"}], "]"}]}], 
      "\n", "]"}]}], ";"}], "\n", "\n", 
   RowBox[{"Quantity", "[", 
    RowBox[{
     RowBox[{
      RowBox[{"Lookup", "[", 
       RowBox[{"wetlandStats", ",", " ", "\"\<Map\>\"", ",", " ", "0"}], 
       "]"}], " ", "/", " ", "1.0*^6"}], ",", " ", 
     RowBox[{"\"\<Kilometers\>\"", "^", "2"}]}], "]"}]}]}]], "Input",Expressio\
nUUID->"5d203c71-2bdc-da49-8b08-83b611d95d8f"],

Cell["", "Text",
 CellFrame->{{0, 0}, {0, 
  1}},ExpressionUUID->"28d0a2fc-0cbe-0a45-8e75-4996b3774cb3"]
}, Open  ]]
}, Open  ]],

Cell[CellGroupData[{

Cell["6.8 Watershed-Scale Analysis", "Chapter",ExpressionUUID->"03c6add3-ad9b-3144-8a4e-024f613582cb"],

Cell[CellGroupData[{

Cell["Building a Water Budget", "Section",ExpressionUUID->"fd711b3c-417e-f84b-914f-e09f4f49fb07"],

Cell["\<\
A watershed water budget balances inputs (precipitation) against outputs \
(evapotranspiration, runoff, groundwater recharge). At the simplest level:\
\>", "Text",ExpressionUUID->"1dbcdf41-e640-ac44-ad87-e5615be94e23"],

Cell["Net Water = Precipitation - Evapotranspiration", "Program",ExpressionUUID->"c8922978-5dcd-714f-b667-a180d299d67e"],

Cell["\<\
Both terms come from satellite data: CHIRPS for precipitation and MODIS \
MOD16A2 for evapotranspiration (ET).\
\>", "Text",ExpressionUUID->"6f9871ab-454e-ec40-9776-2d2d7f57953f"],

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{
    RowBox[{"Define", " ", "a", " ", 
     RowBox[{"watershed", ":", " ", 
      RowBox[{"Upper", " ", "Blue", " ", "Nile", " ", "Basin"}]}]}], ",", " ",
     "Ethiopia"}], " ", "*)"}], "\n", 
  RowBox[{
   RowBox[{
    RowBox[{"nileCoords", " ", "=", " ", 
     RowBox[{"{", "\n", "  ", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{"37.0", ",", " ", "8.0"}], "}"}], ",", " ", 
       RowBox[{"{", 
        RowBox[{"40.0", ",", " ", "8.0"}], "}"}], ",", " ", 
       RowBox[{"{", 
        RowBox[{"40.0", ",", " ", "12.0"}], "}"}], ",", "\n", "  ", 
       RowBox[{"{", 
        RowBox[{"37.5", ",", " ", "13.0"}], "}"}], ",", " ", 
       RowBox[{"{", 
        RowBox[{"35.5", ",", " ", "12.0"}], "}"}], ",", " ", 
       RowBox[{"{", 
        RowBox[{"35.5", ",", " ", "9.0"}], "}"}], ",", " ", 
       RowBox[{"{", 
        RowBox[{"37.0", ",", " ", "8.0"}], "}"}]}], "\n", "}"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"nilePolygon", " ", "=", " ", 
     RowBox[{"GEEPolygon", "[", "nileCoords", "]"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"nileBbox", " ", "=", " ", 
     RowBox[{"{", 
      RowBox[{"35.5", ",", " ", "8.0", ",", " ", "40.0", ",", " ", "13.0"}], 
      "}"}]}], ";"}], "\n", "\n", 
   RowBox[{"(*", " ", 
    RowBox[{"Monthly", " ", "water", " ", "budget", " ", "for", " ", "2023"}],
     " ", "*)"}], "\n", 
   RowBox[{
    RowBox[{"waterBudgetMonth", "[", 
     RowBox[{"year_Integer", ",", " ", "month_Integer"}], "]"}], " ", ":=", 
    " ", 
    RowBox[{"Module", "[", "\n", "  ", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{
       "startDate", ",", " ", "endDate", ",", " ", "precip", ",", " ", "et", ",",
         " ", "precipStats", ",", " ", "etStats", ",", " ", "pMm", ",", " ", 
        "etMm"}], "}"}], ",", "\n", "\n", "  ", 
      RowBox[{
       RowBox[{"startDate", " ", "=", " ", 
        RowBox[{"DateString", "[", 
         RowBox[{
          RowBox[{"{", 
           RowBox[{"year", ",", " ", "month", ",", " ", "1"}], "}"}], ",", 
          " ", "\"\<ISODate\>\""}], "]"}]}], ";", "\n", "  ", 
       RowBox[{"endDate", " ", "=", " ", 
        RowBox[{"DateString", "[", 
         RowBox[{
          RowBox[{"DatePlus", "[", 
           RowBox[{
            RowBox[{"{", 
             RowBox[{"year", ",", " ", "month", ",", " ", "1"}], "}"}], ",", 
            " ", 
            RowBox[{"{", 
             RowBox[{"1", ",", " ", "\"\<Month\>\""}], "}"}]}], "]"}], ",", 
          " ", "\"\<ISODate\>\""}], "]"}]}], ";", "\n", "\n", "  ", 
       RowBox[{"(*", " ", 
        RowBox[{"CHIRPS", " ", "precipitation", " ", 
         RowBox[{"(", 
          RowBox[{
           RowBox[{"mm", "/", "day"}], " ", "->", " ", 
           RowBox[{
            RowBox[{"mm", "/", "month"}], " ", "via", " ", "sum"}]}], ")"}]}],
         " ", "*)"}], "\n", "  ", 
       RowBox[{"precip", " ", "=", "\n", "    ", 
        RowBox[{
         RowBox[{
          RowBox[{
           RowBox[{
            RowBox[{
            "GEECollection", "[", "\"\<UCSB-CHG/CHIRPS/DAILY\>\"", "]"}], " ",
             "//", "\n", "      ", 
            RowBox[{"GEEFilterDate", "[", 
             RowBox[{"startDate", ",", " ", "endDate"}], "]"}]}], " ", "//", 
           "\n", "      ", 
           RowBox[{"GEEFilterBounds", "[", "nileBbox", "]"}]}], " ", "//", 
          "\n", "      ", "GEECollectionSum"}], " ", "//", "\n", "      ", 
         RowBox[{"GEEClip", "[", "nilePolygon", "]"}]}]}], ";", "\n", "\n", 
       "  ", 
       RowBox[{"precipStats", " ", "=", " ", 
        RowBox[{"GEECompute", "[", "\n", "    ", 
         RowBox[{"precip", " ", "//", " ", 
          RowBox[{"GEEReduceRegion", "[", 
           RowBox[{
           "nilePolygon", ",", " ", "\"\<mean\>\"", ",", " ", "5000"}], 
           "]"}]}], "\n", "  ", "]"}]}], ";", "\n", "\n", "  ", 
       RowBox[{"(*", " ", 
        RowBox[{"MODIS", " ", "ET", " ", 
         RowBox[{"(", 
          RowBox[{
           RowBox[{
            RowBox[{
             RowBox[{"kg", "/", 
              RowBox[{"m", "^", "2"}]}], "/", "8"}], "day"}], " ", "->", " ", 
           RowBox[{"sum", " ", "and", " ", "scale"}]}], ")"}]}], " ", "*)"}], 
       "\n", "  ", 
       RowBox[{"et", " ", "=", "\n", "    ", 
        RowBox[{
         RowBox[{
          RowBox[{
           RowBox[{
            RowBox[{
             RowBox[{
              RowBox[{
              "GEECollection", "[", "\"\<MODIS/061/MOD16A2GF\>\"", "]"}], " ",
               "//", "\n", "      ", 
              RowBox[{"GEEFilterDate", "[", 
               RowBox[{"startDate", ",", " ", "endDate"}], "]"}]}], " ", "//",
              "\n", "      ", 
             RowBox[{"GEEFilterBounds", "[", "nileBbox", "]"}]}], " ", "//", 
            "\n", "      ", 
            RowBox[{"GEESelectBands", "[", 
             RowBox[{"{", "\"\<ET\>\"", "}"}], "]"}]}], " ", "//", "\n", 
           "      ", "GEECollectionSum"}], " ", "//", "\n", "      ", 
          RowBox[{"GEEMultiply", "[", "0.1", "]"}]}], " ", "//", "   ", 
         RowBox[{"(*", " ", 
          RowBox[{
           RowBox[{"Scale", " ", 
            RowBox[{"factor", ":", " ", 
             RowBox[{"0.1", " ", 
              RowBox[{"kg", "/", 
               RowBox[{"m", "^", "2"}]}]}]}]}], " ", "=", " ", 
           RowBox[{"0.1", " ", "mm"}]}], " ", "*)"}], "\n", "      ", 
         RowBox[{"GEEClip", "[", "nilePolygon", "]"}]}]}], ";", "\n", "\n", 
       "  ", 
       RowBox[{"etStats", " ", "=", " ", 
        RowBox[{"GEECompute", "[", "\n", "    ", 
         RowBox[{"et", " ", "//", " ", 
          RowBox[{"GEEReduceRegion", "[", 
           RowBox[{"nilePolygon", ",", " ", "\"\<mean\>\"", ",", " ", "500"}],
            "]"}]}], "\n", "  ", "]"}]}], ";", "\n", "\n", "  ", 
       RowBox[{"pMm", " ", "=", " ", 
        RowBox[{"Lookup", "[", 
         RowBox[{
         "precipStats", ",", " ", "\"\<precipitation\>\"", ",", " ", "0"}], 
         "]"}]}], ";", "\n", "  ", 
       RowBox[{"etMm", " ", "=", " ", 
        RowBox[{"Lookup", "[", 
         RowBox[{"etStats", ",", " ", "\"\<ET\>\"", ",", " ", "0"}], "]"}]}], 
       ";", "\n", "\n", "  ", 
       RowBox[{"<|", "\n", "    ", 
        RowBox[{
         RowBox[{"\"\<Month\>\"", " ", "->", " ", 
          RowBox[{"DateObject", "[", 
           RowBox[{
            RowBox[{"{", 
             RowBox[{"year", ",", " ", "month", ",", " ", "1"}], "}"}], ",", 
            " ", "\"\<Month\>\""}], "]"}]}], ",", "\n", "    ", 
         RowBox[{"\"\<Precipitation_mm\>\"", " ", "->", " ", "pMm"}], ",", 
         "\n", "    ", 
         RowBox[{"\"\<ET_mm\>\"", " ", "->", " ", "etMm"}], ",", "\n", "    ", 
         RowBox[{"\"\<NetWater_mm\>\"", " ", "->", " ", 
          RowBox[{"pMm", " ", "-", " ", "etMm"}]}]}], "\n", "  ", "|>"}]}]}], 
     "\n", "]"}]}]}]}]], "Input",ExpressionUUID->"984c27d0-b0b7-5d4e-b13f-\
0bf275ffba3e"],

Cell["Build the full annual water budget.", "Text",ExpressionUUID->"129afdc6-73e6-0740-bb3c-8fc9a7153312"],

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"budgetData", " ", "=", " ", 
    RowBox[{"Table", "[", "\n", "  ", 
     RowBox[{
      RowBox[{"waterBudgetMonth", "[", 
       RowBox[{"2023", ",", " ", "m"}], "]"}], ",", "\n", "  ", 
      RowBox[{"{", 
       RowBox[{"m", ",", " ", "1", ",", " ", "12"}], "}"}]}], "\n", "]"}]}], 
   ";"}], "\n"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"budgetDS", " ", "=", " ", 
    RowBox[{"Dataset", "[", "budgetData", "]"}]}], ";"}], "\n", "\n", 
  RowBox[{"(*", " ", 
   RowBox[{"Display", " ", "the", " ", "table"}], " ", "*)"}]}], "\n", 
 RowBox[{"budgetDS", "[", 
  RowBox[{"All", ",", " ", 
   RowBox[{"{", 
    RowBox[{"\"\<Month\>\"", ",", " ", "\"\<Precipitation_mm\>\"", ",", 
     " ", "\"\<ET_mm\>\"", ",", " ", "\"\<NetWater_mm\>\""}], "}"}]}], 
  "]"}]}], "Input",ExpressionUUID->"a2b0dfb2-0b36-6840-84b7-378cd3508b01"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Visualizing the Water Budget", "Section",ExpressionUUID->"e25530bc-0297-034a-bd85-1f798966bfa9"],

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{"Extract", " ", "columns", " ", "for", " ", "plotting"}], " ", 
   "*)"}], "\n", 
  RowBox[{
   RowBox[{
    RowBox[{"months", " ", "=", " ", 
     RowBox[{"Normal", "[", 
      RowBox[{"budgetDS", "[", 
       RowBox[{"All", ",", " ", "\"\<Month\>\""}], "]"}], "]"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"precip", " ", "=", " ", 
     RowBox[{"Normal", "[", 
      RowBox[{"budgetDS", "[", 
       RowBox[{"All", ",", " ", "\"\<Precipitation_mm\>\""}], "]"}], "]"}]}], 
    ";"}], "\n", 
   RowBox[{
    RowBox[{"et", " ", "=", " ", 
     RowBox[{"Normal", "[", 
      RowBox[{"budgetDS", "[", 
       RowBox[{"All", ",", " ", "\"\<ET_mm\>\""}], "]"}], "]"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"netWater", " ", "=", " ", 
     RowBox[{"Normal", "[", 
      RowBox[{"budgetDS", "[", 
       RowBox[{"All", ",", " ", "\"\<NetWater_mm\>\""}], "]"}], "]"}]}], 
    ";"}], "\n", "\n", 
   RowBox[{"DateListPlot", "[", "\n", "  ", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
       RowBox[{"TimeSeries", "[", 
        RowBox[{"Transpose", "[", 
         RowBox[{"{", 
          RowBox[{"months", ",", " ", "precip"}], "}"}], "]"}], "]"}], ",", 
       "\n", "   ", 
       RowBox[{"TimeSeries", "[", 
        RowBox[{"Transpose", "[", 
         RowBox[{"{", 
          RowBox[{"months", ",", " ", "et"}], "}"}], "]"}], "]"}], ",", "\n", 
       "   ", 
       RowBox[{"TimeSeries", "[", 
        RowBox[{"Transpose", "[", 
         RowBox[{"{", 
          RowBox[{"months", ",", " ", "netWater"}], "}"}], "]"}], "]"}]}], 
      "}"}], ",", "\n", "  ", 
     RowBox[{"PlotLegends", " ", "->", " ", 
      RowBox[{"{", 
       RowBox[{"\"\<Precipitation\>\"", ",", " ", "\"\<ET\>\"", ",", 
        " ", "\"\<Net (P - ET)\>\""}], "}"}]}], ",", "\n", "  ", 
     RowBox[{
     "PlotLabel", " ", "->", 
      " ", "\"\<Upper Blue Nile Water Budget (2023)\>\""}], ",", "\n", "  ", 
     RowBox[{"FrameLabel", " ", "->", " ", 
      RowBox[{"{", 
       RowBox[{"\"\<Month\>\"", ",", " ", "\"\<Water Depth (mm)\>\""}], 
       "}"}]}], ",", "\n", "  ", 
     RowBox[{"PlotStyle", " ", "->", " ", 
      RowBox[{"{", 
       RowBox[{"Blue", ",", " ", "Red", ",", " ", 
        RowBox[{"Directive", "[", 
         RowBox[{"Thick", ",", " ", 
          RowBox[{"Darker", "[", "Green", "]"}]}], "]"}]}], "}"}]}], ",", 
     "\n", "  ", 
     RowBox[{"Filling", " ", "->", " ", 
      RowBox[{"{", 
       RowBox[{"3", " ", "->", " ", "Axis"}], "}"}]}], ",", "\n", "  ", 
     RowBox[{"FillingStyle", " ", "->", " ", 
      RowBox[{"Directive", "[", 
       RowBox[{
        RowBox[{"Opacity", "[", "0.1", "]"}], ",", " ", "Green"}], "]"}]}], ",",
      "\n", "  ", 
     RowBox[{"GridLines", " ", "->", " ", "Automatic"}], ",", "\n", "  ", 
     RowBox[{"ImageSize", " ", "->", " ", "Large"}]}], "]"}]}]}]], "Input",Exp\
ressionUUID->"508b7430-124f-fb46-8b81-985a1b1f6978"]
