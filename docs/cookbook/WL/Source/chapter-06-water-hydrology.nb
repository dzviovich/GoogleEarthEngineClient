Cell[CellGroupData[{

Cell["6.5 Precipitation and Runoff", "Chapter",ExpressionUUID->"ac980d18-d42a-9a4c-bd84-cf1a2c18876a"],

Cell[CellGroupData[{

Cell["CHIRPS Daily Rainfall", "Section",ExpressionUUID->"080b3cb3-c5ef-624c-8cc5-6a0406012373"],

Cell["\<\
CHIRPS (Climate Hazards Group InfraRed Precipitation with Station data) \
provides daily rainfall estimates at ~5.5 km resolution from 1981 to \
near-present. It combines satellite infrared data with station observations, \
making it one of the most widely used precipitation products for hydrological \
modeling. For a broader treatment of CHIRPS including rainfall anomalies, \
trend analysis, and comparison with GPM IMERG, see Section 3.2.\
\>", "Text",ExpressionUUID->"dbc1c9a7-a958-4441-9a63-2595682c8718"],

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{
    RowBox[{"Define", " ", "a", " ", 
     RowBox[{"watershed", ":", " ", 
      RowBox[{"Tana", " ", "River", " ", "basin"}]}]}], ",", " ", "Kenya"}], 
   " ", "*)"}], "\n", 
  RowBox[{
   RowBox[{
    RowBox[{"tanaCoords", " ", "=", " ", 
     RowBox[{"{", "\n", "  ", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{"39.5", ",", " ", 
         RowBox[{"-", "1.0"}]}], "}"}], ",", " ", 
       RowBox[{"{", 
        RowBox[{"40.5", ",", " ", 
         RowBox[{"-", "1.0"}]}], "}"}], ",", " ", 
       RowBox[{"{", 
        RowBox[{"40.5", ",", " ", 
         RowBox[{"-", "2.5"}]}], "}"}], ",", "\n", "  ", 
       RowBox[{"{", 
        RowBox[{"39.0", ",", " ", 
         RowBox[{"-", "3.5"}]}], "}"}], ",", " ", 
       RowBox[{"{", 
        RowBox[{"38.0", ",", " ", 
         RowBox[{"-", "2.0"}]}], "}"}], ",", " ", 
       RowBox[{"{", 
        RowBox[{"39.5", ",", " ", 
         RowBox[{"-", "1.0"}]}], "}"}]}], "\n", "}"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"tanaPolygon", " ", "=", " ", 
     RowBox[{"GEEPolygon", "[", "tanaCoords", "]"}]}], ";"}], "\n", "\n", 
   RowBox[{"(*", " ", 
    RowBox[{
    "Monthly", " ", "rainfall", " ", "accumulation", " ", "for", " ", 
     "January", " ", "2024"}], " ", "*)"}], "\n", 
   RowBox[{
    RowBox[{"janRain", " ", "=", "\n", "  ", 
     RowBox[{
      RowBox[{
       RowBox[{
        RowBox[{
         RowBox[{"GEECollection", "[", "\"\<UCSB-CHG/CHIRPS/DAILY\>\"", "]"}],
          " ", "//", "\n", "    ", 
         RowBox[{"GEEFilterDate", "[", 
          RowBox[{"\"\<2024-01-01\>\"", ",", " ", "\"\<2024-02-01\>\""}], 
          "]"}]}], " ", "//", "\n", "    ", 
        RowBox[{"GEEFilterBounds", "[", 
         RowBox[{"{", 
          RowBox[{"38.0", ",", " ", 
           RowBox[{"-", "3.5"}], ",", " ", "40.5", ",", " ", 
           RowBox[{"-", "1.0"}]}], "}"}], "]"}]}], " ", "//", "\n", "    ", 
       "GEECollectionSum"}], " ", "//", "\n", "    ", 
      RowBox[{"GEEClip", "[", "tanaPolygon", "]"}]}]}], ";"}], "\n", "\n", 
   RowBox[{"rainImage", " ", "=", " ", 
    RowBox[{"GEEComputePixels", "[", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{"38.0", ",", " ", 
        RowBox[{"-", "3.5"}], ",", " ", "40.5", ",", " ", 
        RowBox[{"-", "1.0"}]}], "}"}], ",", " ", "janRain", ",", "\n", "  ", 
      RowBox[{"\"\<VisParams\>\"", " ", "->", " ", 
       RowBox[{"<|", 
        RowBox[{
         RowBox[{"\"\<min\>\"", " ", "->", " ", "0"}], ",", " ", 
         RowBox[{"\"\<max\>\"", " ", "->", " ", "200"}], ",", "\n", "    ", 
         RowBox[{"\"\<palette\>\"", " ", "->", " ", 
          RowBox[{"{", 
           
           RowBox[{"\"\<#FFFFCC\>\"", ",", " ", "\"\<#41B6C4\>\"", ",", 
            " ", "\"\<#0C2C84\>\""}], "}"}]}]}], "|>"}]}]}], 
     "]"}]}]}]}]], "Input",ExpressionUUID->"a95988d5-07d8-fb43-b80b-\
b53c482937cd"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Annual Rainfall Accumulation", "Section",ExpressionUUID->"895b98dd-7bff-5341-b80a-ab2341d57246"],

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{"Annual", " ", "rainfall", " ", "for", " ", "2023"}], " ", "*)"}], 
  "\n", 
  RowBox[{
   RowBox[{
    RowBox[{"annualRain", " ", "=", "\n", "  ", 
     RowBox[{
      RowBox[{
       RowBox[{
        RowBox[{
         RowBox[{"GEECollection", "[", "\"\<UCSB-CHG/CHIRPS/DAILY\>\"", "]"}],
          " ", "//", "\n", "    ", 
         RowBox[{"GEEFilterDate", "[", 
          RowBox[{"\"\<2023-01-01\>\"", ",", " ", "\"\<2024-01-01\>\""}], 
          "]"}]}], " ", "//", "\n", "    ", 
        RowBox[{"GEEFilterBounds", "[", 
         RowBox[{"{", 
          RowBox[{"38.0", ",", " ", 
           RowBox[{"-", "3.5"}], ",", " ", "40.5", ",", " ", 
           RowBox[{"-", "1.0"}]}], "}"}], "]"}]}], " ", "//", "\n", "    ", 
       "GEECollectionSum"}], " ", "//", "\n", "    ", 
      RowBox[{"GEEClip", "[", "tanaPolygon", "]"}]}]}], ";"}], "\n", "\n", 
   RowBox[{"(*", " ", 
    RowBox[{
    "Mean", " ", "rainfall", " ", "over", " ", "the", " ", "watershed"}], " ",
     "*)"}], "\n", 
   RowBox[{
    RowBox[{"meanRainfall", " ", "=", " ", 
     RowBox[{"GEECompute", "[", "\n", "  ", 
      RowBox[{"annualRain", " ", "//", " ", 
       RowBox[{"GEEReduceRegion", "[", 
        RowBox[{"tanaPolygon", ",", " ", "\"\<mean\>\"", ",", " ", "5000"}], 
        "]"}]}], "\n", "]"}]}], ";"}], "\n", "\n", 
   RowBox[{"(*", " ", 
    RowBox[{"Result", " ", "in", " ", "mm"}], " ", "*)"}], "\n", 
   RowBox[{
    RowBox[{"annualMeanMm", " ", "=", " ", 
     RowBox[{"Lookup", "[", 
      RowBox[{"meanRainfall", ",", " ", "\"\<precipitation\>\"", ",", " ", 
       RowBox[{"Missing", "[", "]"}]}], "]"}]}], ";"}], "\n", "\n", 
   RowBox[{"(*", " ", 
    RowBox[{
    "Convert", " ", "to", " ", "total", " ", "volume", " ", "over", " ", 
     "watershed"}], " ", "*)"}], "\n", 
   RowBox[{"(*", " ", 
    RowBox[{"First", " ", "compute", " ", "watershed", " ", 
     RowBox[{"area", " ", "--"}], " ", "GEECompute", " ", "returns", " ", 
     "an", " ", "Association"}], " ", "*)"}], "\n", 
   RowBox[{
    RowBox[{"watershedAreaM2", " ", "=", " ", 
     RowBox[{"First", "[", 
      RowBox[{"Values", "[", 
       RowBox[{"GEECompute", "[", 
        RowBox[{"GEEArea", "[", "tanaPolygon", "]"}], "]"}], "]"}], "]"}]}], 
    ";"}], "\n", "\n", 
   RowBox[{"(*", " ", 
    RowBox[{
     RowBox[{"Rainfall", " ", "depth", " ", 
      RowBox[{"(", "mm", ")"}]}], " ", "->", " ", 
     RowBox[{"volume", " ", 
      RowBox[{"(", 
       RowBox[{"m", "^", "3"}], ")"}]}]}], " ", "*)"}], "\n", 
   RowBox[{"totalVolumeM3", " ", "=", " ", 
    RowBox[{
     RowBox[{
      RowBox[{"Quantity", "[", 
       RowBox[{"annualMeanMm", ",", " ", "\"\<Millimeters\>\""}], "]"}], " ", 
      "*", "\n", "  ", 
      RowBox[{"Quantity", "[", 
       RowBox[{"watershedAreaM2", ",", " ", 
        RowBox[{"\"\<Meters\>\"", "^", "2"}]}], "]"}]}], " ", "//", "\n", 
     "  ", 
     RowBox[{
      RowBox[{"UnitConvert", "[", 
       RowBox[{"#", ",", " ", 
        RowBox[{"\"\<Meters\>\"", "^", "3"}]}], "]"}], " ", 
      "&"}]}]}]}]}]], "Input",ExpressionUUID->"27e2dc74-ff45-4242-8d32-\
6db6a7d969b6"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Monthly Rainfall Time Series", "Section",ExpressionUUID->"fe9dd4c7-9938-3742-af08-9b49da0aa7f5"],

Cell["\<\
Extract a multi-year monthly rainfall series for trend analysis.\
\>", "Text",ExpressionUUID->"6fa4c93c-868a-9e43-ba6e-a69a639655c6"],

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"monthlyRainfall", "[", 
    RowBox[{"year_Integer", ",", " ", "month_Integer"}], "]"}], " ", ":=", 
   " ", 
   RowBox[{"Module", "[", "\n", "  ", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
      "startDate", ",", " ", "endDate", ",", " ", "monthlySum", ",", " ", 
       "stats"}], "}"}], ",", "\n", "\n", "  ", 
     RowBox[{
      RowBox[{"startDate", " ", "=", " ", 
       RowBox[{"DateString", "[", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{"year", ",", " ", "month", ",", " ", "1"}], "}"}], ",", 
         " ", "\"\<ISODate\>\""}], "]"}]}], ";", "\n", "  ", 
      RowBox[{"endDate", " ", "=", " ", 
       RowBox[{"DateString", "[", 
        RowBox[{
         RowBox[{"DatePlus", "[", 
          RowBox[{
           RowBox[{"{", 
            RowBox[{"year", ",", " ", "month", ",", " ", "1"}], "}"}], ",", 
           " ", 
           RowBox[{"{", 
            RowBox[{"1", ",", " ", "\"\<Month\>\""}], "}"}]}], "]"}], ",", 
         " ", "\"\<ISODate\>\""}], "]"}]}], ";", "\n", "\n", "  ", 
      RowBox[{"monthlySum", " ", "=", "\n", "    ", 
       RowBox[{
        RowBox[{
         RowBox[{
          RowBox[{
           RowBox[{
           "GEECollection", "[", "\"\<UCSB-CHG/CHIRPS/DAILY\>\"", "]"}], " ", 
           "//", "\n", "      ", 
           RowBox[{"GEEFilterDate", "[", 
            RowBox[{"startDate", ",", " ", "endDate"}], "]"}]}], " ", "//", 
          "\n", "      ", 
          RowBox[{"GEEFilterBounds", "[", 
           RowBox[{"{", 
            RowBox[{"38.0", ",", " ", 
             RowBox[{"-", "3.5"}], ",", " ", "40.5", ",", " ", 
             RowBox[{"-", "1.0"}]}], "}"}], "]"}]}], " ", "//", "\n", 
         "      ", "GEECollectionSum"}], " ", "//", "\n", "      ", 
        RowBox[{"GEEClip", "[", "tanaPolygon", "]"}]}]}], ";", "\n", "\n", 
      "  ", 
      RowBox[{"stats", " ", "=", " ", 
       RowBox[{"GEECompute", "[", "\n", "    ", 
        RowBox[{"monthlySum", " ", "//", " ", 
         RowBox[{"GEEReduceRegion", "[", 
          RowBox[{"tanaPolygon", ",", " ", "\"\<mean\>\"", ",", " ", "5000"}],
           "]"}]}], "\n", "  ", "]"}]}], ";", "\n", "\n", "  ", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"DateObject", "[", 
         RowBox[{"{", 
          RowBox[{"year", ",", " ", "month", ",", " ", "15"}], "}"}], "]"}], ",",
         "\n", "   ", 
        RowBox[{"Lookup", "[", 
         RowBox[{"stats", ",", " ", "\"\<precipitation\>\"", ",", " ", "0"}], 
         "]"}]}], "}"}]}]}], "\n", "]"}]}], "\n", "\n", 
  RowBox[{"(*", " ", 
   RowBox[{
    RowBox[{"Build", " ", "5"}], "-", 
    RowBox[{"year", " ", "series"}]}], " ", "*)"}]}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"rainData", " ", "=", " ", 
    RowBox[{"Flatten", "[", "\n", "  ", 
     RowBox[{
      RowBox[{"Table", "[", 
       RowBox[{
        RowBox[{"monthlyRainfall", "[", 
         RowBox[{"y", ",", " ", "m"}], "]"}], ",", " ", 
        RowBox[{"{", 
         RowBox[{"y", ",", " ", "2019", ",", " ", "2023"}], "}"}], ",", " ", 
        RowBox[{"{", 
         RowBox[{"m", ",", " ", "1", ",", " ", "12"}], "}"}]}], "]"}], ",", 
      "\n", "  ", "1"}], "\n", "]"}]}], ";"}], "\n"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"rainSeries", " ", "=", " ", 
    RowBox[{"TimeSeries", "[", "rainData", "]"}]}], ";"}], "\n"}], "\n", 
 RowBox[{"DateListPlot", "[", 
  RowBox[{"rainSeries", ",", "\n", "  ", 
   RowBox[{
   "PlotLabel", " ", "->", 
    " ", "\"\<Tana River Basin Monthly Rainfall (2019-2023)\>\""}], ",", "\n",
    "  ", 
   RowBox[{"FrameLabel", " ", "->", " ", 
    RowBox[{"{", 
     RowBox[{"\"\<Date\>\"", ",", " ", "\"\<Rainfall (mm)\>\""}], "}"}]}], ",",
    "\n", "  ", 
   RowBox[{"Filling", " ", "->", " ", "Axis"}], ",", "\n", "  ", 
   RowBox[{"PlotStyle", " ", "->", " ", 
    RowBox[{"Directive", "[", 
     RowBox[{"Thick", ",", " ", 
      RowBox[{"RGBColor", "[", 
       RowBox[{"0.2", ",", " ", "0.4", ",", " ", "0.8"}], "]"}]}], "]"}]}], ",",
    "\n", "  ", 
   RowBox[{"FillingStyle", " ", "->", " ", 
    RowBox[{"Directive", "[", 
     RowBox[{
      RowBox[{"Opacity", "[", "0.2", "]"}], ",", " ", "Blue"}], "]"}]}], ",", 
   "\n", "  ", 
   RowBox[{"ImageSize", " ", "->", " ", "Large"}]}], "]"}]}], "Input",Expressi\
onUUID->"6a72ff31-42e1-5a44-9785-98ed3953db94"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Rainfall-Runoff Relationship", "Section",ExpressionUUID->"78137b86-8124-c249-a4d7-fb4eb4ee9e06"],

Cell["\<\
Compare satellite-derived rainfall with observed streamflow to build a simple \
rainfall-runoff model. Streamflow data can be imported from a CSV file (e.g., \
from a national hydrological service).\
\>", "Text",ExpressionUUID->"1e8a3e11-f0cd-ac43-8a33-a03052151234"],

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{"Import", " ", "observed", " ", "monthly", " ", "streamflow", " ", 
    RowBox[{"(", 
     RowBox[{
      RowBox[{"m", "^", "3"}], "/", "s"}], ")"}]}], " ", "*)"}], "\n", 
  RowBox[{
   RowBox[{
    RowBox[{"streamflowData", " ", "=", " ", 
     RowBox[{"Import", "[", "\n", "  ", 
      RowBox[{"\"\<data/tana_streamflow_monthly.csv\>\"", ",", 
       " ", "\"\<Dataset\>\"", ",", "\n", "  ", 
       RowBox[{"HeaderLines", " ", "->", " ", "1"}]}], "\n", "]"}]}], ";"}], 
   "\n", "\n", 
   RowBox[{"(*", " ", 
    RowBox[{
    "Extract", " ", "matching", " ", "monthly", " ", "rainfall", " ", "from", 
     " ", "our", " ", "series"}], " ", "*)"}], "\n", 
   RowBox[{
    RowBox[{"rainfallValues", " ", "=", " ", 
     RowBox[{"rainSeries", "[", "\"\<Values\>\"", "]"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"streamflowValues", " ", "=", " ", 
     RowBox[{"Normal", "[", 
      RowBox[{"streamflowData", "[", 
       RowBox[{"All", ",", " ", "\"\<Discharge_m3s\>\""}], "]"}], "]"}]}], 
    ";"}], "\n", "\n", 
   RowBox[{"(*", " ", 
    RowBox[{"Ensure", " ", "same", " ", "length"}], " ", "*)"}], "\n", 
   RowBox[{
    RowBox[{"nMonths", " ", "=", " ", 
     RowBox[{"Min", "[", 
      RowBox[{
       RowBox[{"Length", "[", "rainfallValues", "]"}], ",", " ", 
       RowBox[{"Length", "[", "streamflowValues", "]"}]}], "]"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"rain", " ", "=", " ", 
     RowBox[{"rainfallValues", "[", 
      RowBox[{"[", 
       RowBox[{";;", "nMonths"}], "]"}], "]"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"flow", " ", "=", " ", 
     RowBox[{"streamflowValues", "[", 
      RowBox[{"[", 
       RowBox[{";;", "nMonths"}], "]"}], "]"}]}], ";"}], "\n", "\n", 
   RowBox[{"(*", " ", 
    RowBox[{
     RowBox[{"Fit", " ", "a", " ", "linear", " ", 
      RowBox[{"model", ":", " ", "Q"}]}], " ", "=", " ", 
     RowBox[{
      RowBox[{"a", " ", "*", " ", "P"}], " ", "+", " ", "b"}]}], " ", "*)"}], 
   "\n", 
   RowBox[{
    RowBox[{"model", " ", "=", " ", 
     RowBox[{"LinearModelFit", "[", "\n", "  ", 
      RowBox[{
       RowBox[{"Transpose", "[", 
        RowBox[{"{", 
         RowBox[{"rain", ",", " ", "flow"}], "}"}], "]"}], ",", "\n", "  ", 
       "x", ",", " ", "x"}], "\n", "]"}]}], ";"}], "\n", "\n", 
   RowBox[{"(*", " ", 
    RowBox[{"Display", " ", "the", " ", "model"}], " ", "*)"}], "\n", 
   RowBox[{"model", "[", "\"\<BestFit\>\"", "]"}], "\n", 
   RowBox[{"model", "[", "\"\<RSquared\>\"", "]"}], "\n", "\n", 
   RowBox[{"(*", " ", 
    RowBox[{
    "Scatter", " ", "plot", " ", "with", " ", "regression", " ", "line"}], 
    " ", "*)"}], "\n", 
   RowBox[{"Show", "[", "\n", "  ", 
    RowBox[{
     RowBox[{"ListPlot", "[", 
      RowBox[{
       RowBox[{"Transpose", "[", 
        RowBox[{"{", 
         RowBox[{"rain", ",", " ", "flow"}], "}"}], "]"}], ",", "\n", "    ", 
       RowBox[{"PlotStyle", " ", "->", " ", 
        RowBox[{"PointSize", "[", "0.015", "]"}]}], ",", "\n", "    ", 
       RowBox[{"AxesLabel", " ", "->", " ", 
        RowBox[{"{", 
         RowBox[{"\"\<Monthly Rainfall (mm)\>\"", ",", 
          " ", "\"\<Streamflow (m\\[Superscript]3/s)\>\""}], "}"}]}], ",", 
       "\n", "    ", 
       RowBox[{
       "PlotLabel", " ", "->", 
        " ", "\"\<Rainfall-Runoff Relationship\>\""}]}], "]"}], ",", "\n", 
     "  ", 
     RowBox[{"Plot", "[", 
      RowBox[{
       RowBox[{"model", "[", "x", "]"}], ",", " ", 
       RowBox[{"{", 
        RowBox[{"x", ",", " ", "0", ",", " ", 
         RowBox[{"Max", "[", "rain", "]"}]}], "}"}], ",", "\n", "    ", 
       RowBox[{"PlotStyle", " ", "->", " ", 
        RowBox[{"Directive", "[", 
         RowBox[{"Red", ",", " ", "Thick"}], "]"}]}]}], "]"}]}], "\n", 
    "]"}]}]}]], "Input",ExpressionUUID->"d8035921-2f0c-3b49-b133-\
4ace75bdfec5"],

Cell["", "Text",
 CellFrame->{{0, 0}, {0, 
  1}},ExpressionUUID->"7cf4e51c-e359-7948-bbe2-1d592bca2901"]
