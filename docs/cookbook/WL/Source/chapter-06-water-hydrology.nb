Cell[CellGroupData[{

Cell["Volume Conversion with Wolfram Units", "Section",ExpressionUUID->"eb5ca139-b0eb-d346-b7af-63745dce911d"],

Cell["\<\
Convert the water budget from depth (mm) to volume (cubic meters) using the \
watershed area and Wolfram Language's unit system.\
\>", "Text",ExpressionUUID->"08dd2cf0-b586-f64d-ada1-bd05f7ec448b"],

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{"Compute", " ", "watershed", " ", "area"}], " ", "*)"}], "\n", 
  RowBox[{
   RowBox[{
    RowBox[{"watershedAreaM2", " ", "=", " ", 
     RowBox[{"GEECompute", "[", 
      RowBox[{"GEEArea", "[", "nilePolygon", "]"}], "]"}]}], ";"}], "\n", 
   "\n", 
   RowBox[{"(*", " ", 
    RowBox[{"Annual", " ", "totals"}], " ", "*)"}], "\n", 
   RowBox[{
    RowBox[{"annualPrecipMm", " ", "=", " ", 
     RowBox[{"Total", "[", "precip", "]"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"annualETMm", " ", "=", " ", 
     RowBox[{"Total", "[", "et", "]"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"annualNetMm", " ", "=", " ", 
     RowBox[{"annualPrecipMm", " ", "-", " ", "annualETMm"}]}], ";"}], "\n", 
   "\n", 
   RowBox[{"(*", " ", 
    RowBox[{
     RowBox[{"Convert", ":", " ", 
      RowBox[{"mm", " ", "over", " ", "area"}]}], " ", "->", " ", 
     RowBox[{"m", "^", "3"}]}], " ", "*)"}], "\n", 
   RowBox[{
    RowBox[{"volumeConvert", "[", 
     RowBox[{"depthMm_", ",", " ", "areaM2_"}], "]"}], " ", ":=", "\n", "  ", 
    RowBox[{"UnitConvert", "[", "\n", "    ", 
     RowBox[{
      RowBox[{
       RowBox[{"Quantity", "[", 
        RowBox[{"depthMm", ",", " ", "\"\<Millimeters\>\""}], "]"}], " ", "*",
        " ", 
       RowBox[{"Quantity", "[", 
        RowBox[{"areaM2", ",", " ", 
         RowBox[{"\"\<Meters\>\"", "^", "2"}]}], "]"}]}], ",", "\n", "    ", 
      RowBox[{"\"\<Meters\>\"", "^", "3"}]}], "\n", "  ", "]"}]}], "\n", "\n", 
   RowBox[{
    RowBox[{"annualPrecipVol", " ", "=", " ", 
     RowBox[{"volumeConvert", "[", 
      RowBox[{"annualPrecipMm", ",", " ", "watershedAreaM2"}], "]"}]}], ";"}],
    "\n", 
   RowBox[{
    RowBox[{"annualETVol", " ", "=", " ", 
     RowBox[{"volumeConvert", "[", 
      RowBox[{"annualETMm", ",", " ", "watershedAreaM2"}], "]"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"annualNetVol", " ", "=", " ", 
     RowBox[{"volumeConvert", "[", 
      RowBox[{"annualNetMm", ",", " ", "watershedAreaM2"}], "]"}]}], ";"}], 
   "\n", "\n", 
   RowBox[{"(*", " ", "Summary", " ", "*)"}], "\n", 
   RowBox[{"Dataset", "[", 
    RowBox[{"<|", "\n", "  ", 
     RowBox[{
      RowBox[{"\"\<Annual Precipitation\>\"", " ", "->", " ", 
       RowBox[{"UnitConvert", "[", 
        RowBox[{"annualPrecipVol", ",", " ", 
         RowBox[{"\"\<Kilometers\>\"", "^", "3"}]}], "]"}]}], ",", "\n", "  ", 
      RowBox[{"\"\<Annual ET\>\"", " ", "->", " ", 
       RowBox[{"UnitConvert", "[", 
        RowBox[{"annualETVol", ",", " ", 
         RowBox[{"\"\<Kilometers\>\"", "^", "3"}]}], "]"}]}], ",", "\n", "  ", 
      RowBox[{"\"\<Net Water Availability\>\"", " ", "->", " ", 
       RowBox[{"UnitConvert", "[", 
        RowBox[{"annualNetVol", ",", " ", 
         RowBox[{"\"\<Kilometers\>\"", "^", "3"}]}], "]"}]}]}], "\n", "|>"}], 
    "]"}]}]}]], "Input",ExpressionUUID->"a54bc603-78bb-c54a-8d00-\
7a4394e4b738"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Spatial P-ET Map", "Section",ExpressionUUID->"cecff218-5909-074a-9298-5d49b9cef037"],

Cell["\<\
Instead of basin-average values, compute the spatial pattern of P - ET to \
identify which sub-regions generate the most runoff.\
\>", "Text",ExpressionUUID->"4d9c4f0d-f8f0-6b49-b035-56aed9d9ed1f"],

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{"Annual", " ", "precipitation"}], " ", "*)"}], "\n", 
  RowBox[{
   RowBox[{
    RowBox[{"annualP", " ", "=", "\n", "  ", 
     RowBox[{
      RowBox[{
       RowBox[{
        RowBox[{
         RowBox[{"GEECollection", "[", "\"\<UCSB-CHG/CHIRPS/DAILY\>\"", "]"}],
          " ", "//", "\n", "    ", 
         RowBox[{"GEEFilterDate", "[", 
          RowBox[{"\"\<2023-01-01\>\"", ",", " ", "\"\<2024-01-01\>\""}], 
          "]"}]}], " ", "//", "\n", "    ", 
        RowBox[{"GEEFilterBounds", "[", "nileBbox", "]"}]}], " ", "//", "\n", 
       "    ", "GEECollectionSum"}], " ", "//", "\n", "    ", 
      RowBox[{"GEEClip", "[", "nilePolygon", "]"}]}]}], ";"}], "\n", "\n", 
   RowBox[{"(*", " ", 
    RowBox[{"Annual", " ", "ET"}], " ", "*)"}], "\n", 
   RowBox[{
    RowBox[{"annualET", " ", "=", "\n", "  ", 
     RowBox[{
      RowBox[{
       RowBox[{
        RowBox[{
         RowBox[{
          RowBox[{
           RowBox[{"GEECollection", "[", "\"\<MODIS/061/MOD16A2GF\>\"", "]"}],
            " ", "//", "\n", "    ", 
           RowBox[{"GEEFilterDate", "[", 
            RowBox[{"\"\<2023-01-01\>\"", ",", " ", "\"\<2024-01-01\>\""}], 
            "]"}]}], " ", "//", "\n", "    ", 
          RowBox[{"GEEFilterBounds", "[", "nileBbox", "]"}]}], " ", "//", 
         "\n", "    ", 
         RowBox[{"GEESelectBands", "[", 
          RowBox[{"{", "\"\<ET\>\"", "}"}], "]"}]}], " ", "//", "\n", "    ", 
        "GEECollectionSum"}], " ", "//", "\n", "    ", 
       RowBox[{"GEEMultiply", "[", "0.1", "]"}]}], " ", "//", "\n", "    ", 
      RowBox[{"GEEClip", "[", "nilePolygon", "]"}]}]}], ";"}], "\n", "\n", 
   RowBox[{"(*", " ", 
    RowBox[{
     RowBox[{"Spatial", " ", "net", " ", "water"}], " ", "=", " ", 
     RowBox[{"P", " ", "-", " ", "ET"}]}], " ", "*)"}], "\n", 
   RowBox[{
    RowBox[{"netWaterMap", " ", "=", " ", 
     RowBox[{"GEESubtract", "[", 
      RowBox[{"annualP", ",", " ", "annualET"}], "]"}]}], ";"}], "\n", "\n", 
   RowBox[{"netWaterImage", " ", "=", " ", 
    RowBox[{"GEEComputePixels", "[", 
     RowBox[{"nileBbox", ",", " ", "netWaterMap", ",", "\n", "  ", 
      RowBox[{"\"\<VisParams\>\"", " ", "->", " ", 
       RowBox[{"<|", 
        RowBox[{
         RowBox[{"\"\<min\>\"", " ", "->", " ", 
          RowBox[{"-", "200"}]}], ",", " ", 
         RowBox[{"\"\<max\>\"", " ", "->", " ", "1000"}], ",", "\n", "    ", 
         RowBox[{"\"\<palette\>\"", " ", "->", " ", 
          RowBox[{"{", 
           
           RowBox[{"\"\<#FF0000\>\"", ",", " ", "\"\<#FFFF00\>\"", ",", 
            " ", "\"\<#00FF00\>\"", ",", " ", "\"\<#0000FF\>\""}], "}"}]}]}], 
        "|>"}]}]}], "]"}]}]}]}]], "Input",ExpressionUUID->"4c279a30-de46-7149-\
aa8a-52b0923f63b0"],

Cell["\<\
Red areas experience water deficit (ET exceeds P); blue areas produce surplus \
water that becomes runoff or groundwater recharge.\
\>", "Text",ExpressionUUID->"8cbe59d8-dce0-fe4a-9296-0ab7ce34e423"],

Cell["", "Text",
 CellFrame->{{0, 0}, {0, 
  1}},ExpressionUUID->"64326095-c932-bc46-95f9-b1cf364606ce"]
}, Open  ]]
}, Open  ]],

Cell[CellGroupData[{

Cell["6.9 Putting It All Together: Integrated Watershed Assessment", "Chapter",ExpressionUUID->"d10f09fe-1b18-a64f-ab15-117a8a3107e8"],

Cell["\<\
This section combines techniques from throughout the chapter into a single \
watershed assessment workflow.\
\>", "Text",ExpressionUUID->"cbea11db-38e7-934b-80b6-702c551898e3"],

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{
    RowBox[{"Target", ":", " ", 
     RowBox[{"Mekong", " ", "Delta"}]}], ",", " ", "Vietnam"}], " ", "*)"}], 
  "\n", 
  RowBox[{
   RowBox[{
    RowBox[{"mekongBox", " ", "=", " ", 
     RowBox[{"{", 
      RowBox[{"105.0", ",", " ", "9.0", ",", " ", "107.0", ",", " ", "11.0"}],
       "}"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"mekongCoords", " ", "=", " ", 
     RowBox[{"{", "\n", "  ", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{"105.0", ",", " ", "9.0"}], "}"}], ",", " ", 
       RowBox[{"{", 
        RowBox[{"107.0", ",", " ", "9.0"}], "}"}], ",", " ", 
       RowBox[{"{", 
        RowBox[{"107.0", ",", " ", "11.0"}], "}"}], ",", "\n", "  ", 
       RowBox[{"{", 
        RowBox[{"105.0", ",", " ", "11.0"}], "}"}], ",", " ", 
       RowBox[{"{", 
        RowBox[{"105.0", ",", " ", "9.0"}], "}"}]}], "\n", "}"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"mekongPoly", " ", "=", " ", 
     RowBox[{"GEEPolygon", "[", "mekongCoords", "]"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"mekongGeom", " ", "=", " ", 
     RowBox[{"GEEGeometry", "[", "mekongBox", "]"}]}], ";"}]}]}]], "Input",Exp\
ressionUUID->"67cef7af-5142-524f-8a17-a0c6b8216bdb"],

Cell[CellGroupData[{

Cell["Step 1: Map Current Water Bodies", "Section",ExpressionUUID->"42813b20-4a4d-7d4d-81eb-835e59e77e5c"],

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"s2Mekong", " ", "=", "\n", "  ", 
    RowBox[{
     RowBox[{
      RowBox[{
       RowBox[{
        RowBox[{
        "GEECollection", "[", "\"\<COPERNICUS/S2_SR_HARMONIZED\>\"", "]"}], 
        " ", "//", "\n", "    ", 
        RowBox[{"GEEFilterDate", "[", 
         RowBox[{"\"\<2024-01-01\>\"", ",", " ", "\"\<2024-04-01\>\""}], 
         "]"}]}], " ", "//", "\n", "    ", 
       RowBox[{"GEEFilterBounds", "[", "mekongBox", "]"}]}], " ", "//", "\n", 
      "    ", 
      RowBox[{"GEEFilterProperty", "[", 
       RowBox[{"\"\<CLOUDY_PIXEL_PERCENTAGE\>\"", ",", " ", "\"\<LessThan\>\"",
         ",", " ", "15"}], "]"}]}], " ", "//", "\n", "    ", "GEEMedian"}]}], 
   ";"}], "\n"}], "\n", 
 RowBox[{
  RowBox[{"mekongNDWI", " ", "=", " ", 
   RowBox[{"s2Mekong", " ", "//", " ", 
    RowBox[{"GEENormalizedDifference", "[", 
     RowBox[{"{", 
      RowBox[{"\"\<B3\>\"", ",", " ", "\"\<B8\>\""}], "}"}], "]"}]}]}], 
  ";"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"mekongWater", " ", "=", " ", 
    RowBox[{
     RowBox[{"mekongNDWI", " ", "//", " ", 
      RowBox[{"GEEGreaterThan", "[", "0", "]"}]}], " ", "//", " ", 
     "GEESelfMask"}]}], ";"}], "\n", "\n", 
  RowBox[{"(*", " ", 
   RowBox[{"Water", " ", "area"}], " ", "*)"}]}], "\n", 
 RowBox[{
  RowBox[{"waterAreaImg", " ", "=", " ", 
   RowBox[{"mekongWater", " ", "//", " ", 
    RowBox[{"GEEMultiply", "[", 
     RowBox[{"GEEPixelArea", "[", "]"}], "]"}]}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"waterStats", " ", "=", " ", 
    RowBox[{"GEECompute", "[", "\n", "  ", 
     RowBox[{"waterAreaImg", " ", "//", " ", 
      RowBox[{"GEEReduceRegion", "[", 
       RowBox[{"mekongGeom", ",", " ", "\"\<sum\>\"", ",", " ", "10"}], 
       "]"}]}], "\n", "]"}]}], ";"}], "\n"}], "\n", 
 RowBox[{
  RowBox[{"mekongWaterKm2", " ", "=", " ", 
   RowBox[{
    RowBox[{"Lookup", "[", 
     RowBox[{"waterStats", ",", " ", "\"\<nd\>\"", ",", " ", "0"}], "]"}], 
    " ", "/", " ", "1.0*^6"}]}], ";"}]}], "Input",ExpressionUUID->"428d0e11-\
4472-4246-8638-bc3bb8236fa3"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Step 2: Seasonal Precipitation", "Section",ExpressionUUID->"15e196af-f96d-0045-b8a8-7aaf8a262206"],

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"mekongPrecip", " ", "=", "\n", "  ", 
    RowBox[{
     RowBox[{
      RowBox[{
       RowBox[{
        RowBox[{"GEECollection", "[", "\"\<UCSB-CHG/CHIRPS/DAILY\>\"", "]"}], 
        " ", "//", "\n", "    ", 
        RowBox[{"GEEFilterDate", "[", 
         RowBox[{"\"\<2023-01-01\>\"", ",", " ", "\"\<2024-01-01\>\""}], 
         "]"}]}], " ", "//", "\n", "    ", 
       RowBox[{"GEEFilterBounds", "[", "mekongBox", "]"}]}], " ", "//", "\n", 
      "    ", "GEECollectionSum"}], " ", "//", "\n", "    ", 
     RowBox[{"GEEClip", "[", "mekongPoly", "]"}]}]}], ";"}], "\n"}], "\n", 
 RowBox[{
  RowBox[{"precipMean", " ", "=", " ", 
   RowBox[{"GEECompute", "[", "\n", "  ", 
    RowBox[{"mekongPrecip", " ", "//", " ", 
     RowBox[{"GEEReduceRegion", "[", 
      RowBox[{"mekongPoly", ",", " ", "\"\<mean\>\"", ",", " ", "5000"}], 
      "]"}]}], "\n", "]"}]}], ";"}]}], "Input",ExpressionUUID->"9fd99cc1-93e2-\
3d4e-b76b-0b8d1a5ad671"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Step 3: Land Cover Composition", "Section",ExpressionUUID->"04c43a92-f0e6-5743-bbd5-19052fdccbcd"],

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"mekongLC", " ", "=", " ", 
    RowBox[{
     RowBox[{
      RowBox[{
       RowBox[{
        RowBox[{"GEECollection", "[", "\"\<ESA/WorldCover/v200\>\"", "]"}], 
        " ", "//", "\n", "  ", 
        RowBox[{"GEEFilterDate", "[", 
         RowBox[{"\"\<2021-01-01\>\"", ",", " ", "\"\<2022-01-01\>\""}], 
         "]"}]}], " ", "//", "\n", "  ", "GEEMosaic"}], " ", "//", "\n", "  ", 
      RowBox[{"GEESelectBands", "[", 
       RowBox[{"{", "\"\<Map\>\"", "}"}], "]"}]}], " ", "//", "\n", "  ", 
     RowBox[{"GEEClip", "[", "mekongPoly", "]"}]}]}], ";"}], "\n", "\n", 
  RowBox[{"(*", " ", 
   RowBox[{"Extract", " ", "specific", " ", "classes"}], " ", "*)"}]}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"classAreas", " ", "=", " ", 
    RowBox[{"Association", " ", "@@", " ", 
     RowBox[{"Table", "[", "\n", "  ", 
      RowBox[{
       RowBox[{"Module", "[", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{"mask", ",", " ", "areaImg", ",", " ", "stats"}], "}"}], ",",
          "\n", "    ", 
         RowBox[{
          RowBox[{"mask", " ", "=", " ", 
           RowBox[{
            RowBox[{"mekongLC", " ", "//", " ", 
             RowBox[{"GEEEquals", "[", "classVal", "]"}]}], " ", "//", " ", 
            "GEESelfMask"}]}], ";", "\n", "    ", 
          RowBox[{"areaImg", " ", "=", " ", 
           RowBox[{"mask", " ", "//", " ", 
            RowBox[{"GEEMultiply", "[", 
             RowBox[{"GEEPixelArea", "[", "]"}], "]"}]}]}], ";", "\n", "    ", 
          RowBox[{"stats", " ", "=", " ", 
           RowBox[{"GEECompute", "[", "\n", "      ", 
            RowBox[{"areaImg", " ", "//", " ", 
             RowBox[{"GEEReduceRegion", "[", 
              RowBox[{"mekongGeom", ",", " ", "\"\<sum\>\"", ",", " ", "10"}],
               "]"}]}], "\n", "    ", "]"}]}], ";", "\n", "    ", 
          RowBox[{"className", " ", "->", " ", 
           RowBox[{
            RowBox[{"Lookup", "[", 
             RowBox[{"stats", ",", " ", "\"\<Map\>\"", ",", " ", "0"}], "]"}],
             " ", "/", " ", "1.0*^6"}]}]}]}], "\n", "  ", "]"}], ",", "\n", 
       "  ", 
       RowBox[{"{", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{"classVal", ",", " ", "className"}], "}"}], ",", " ", 
         RowBox[{"{", "\n", "    ", 
          RowBox[{
           RowBox[{"{", 
            RowBox[{"10", ",", " ", "\"\<Tree Cover\>\""}], "}"}], ",", " ", 
           RowBox[{"{", 
            RowBox[{"20", ",", " ", "\"\<Shrubland\>\""}], "}"}], ",", " ", 
           RowBox[{"{", 
            RowBox[{"30", ",", " ", "\"\<Grassland\>\""}], "}"}], ",", "\n", 
           "    ", 
           RowBox[{"{", 
            RowBox[{"40", ",", " ", "\"\<Cropland\>\""}], "}"}], ",", " ", 
           RowBox[{"{", 
            RowBox[{"50", ",", " ", "\"\<Built-up\>\""}], "}"}], ",", " ", 
           RowBox[{"{", 
            RowBox[{"60", ",", " ", "\"\<Bare\>\""}], "}"}], ",", "\n", 
           "    ", 
           RowBox[{"{", 
            RowBox[{"80", ",", " ", "\"\<Water\>\""}], "}"}], ",", " ", 
           RowBox[{"{", 
            RowBox[{"90", ",", " ", "\"\<Wetland\>\""}], "}"}], ",", " ", 
           RowBox[{"{", 
            RowBox[{"95", ",", " ", "\"\<Mangroves\>\""}], "}"}]}], "\n", 
          "  ", "}"}]}], "}"}]}], "\n", "]"}]}]}], ";"}], "\n"}], "\n", 
 RowBox[{"Dataset", "[", "classAreas", "]"}]}], "Input",ExpressionUUID->\
"61575b45-8bf5-0143-a13d-1670237ec83f"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Step 4: Water Quality Assessment", "Section",ExpressionUUID->"a21291a4-f9fd-6c47-a3cf-c2132733a343"],

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{
   "Turbidity", " ", "proxy", " ", "across", " ", "the", " ", "delta", " ", 
    "waterways"}], " ", "*)"}], "\n", 
  RowBox[{
   RowBox[{
    RowBox[{"mekongRedBand", " ", "=", " ", 
     RowBox[{"s2Mekong", " ", "//", " ", 
      RowBox[{"GEESelectBands", "[", 
       RowBox[{"{", "\"\<B4\>\"", "}"}], "]"}]}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"mekongTurbidity", " ", "=", " ", 
     RowBox[{"mekongRedBand", " ", "//", " ", 
      RowBox[{"GEEUpdateMask", "[", "mekongWater", "]"}]}]}], ";"}], "\n", 
   "\n", 
   RowBox[{"(*", " ", 
    RowBox[{
    "Sample", " ", "turbidity", " ", "at", " ", "key", " ", "locations"}], 
    " ", "*)"}], "\n", 
   RowBox[{
    RowBox[{"samplePoints", " ", "=", " ", 
     RowBox[{"{", "\n", "  ", 
      RowBox[{
       RowBox[{"GeoPosition", "[", 
        RowBox[{"{", 
         RowBox[{"10.0", ",", " ", "106.7"}], "}"}], "]"}], ",", "   ", 
       RowBox[{"(*", " ", 
        RowBox[{"Ho", " ", "Chi", " ", "Minh", " ", "City"}], " ", "*)"}], 
       "\n", "  ", 
       RowBox[{"GeoPosition", "[", 
        RowBox[{"{", 
         RowBox[{"10.3", ",", " ", "106.1"}], "}"}], "]"}], ",", "   ", 
       RowBox[{"(*", " ", 
        RowBox[{"Upper", " ", "delta"}], " ", "*)"}], "\n", "  ", 
       RowBox[{"GeoPosition", "[", 
        RowBox[{"{", 
         RowBox[{"9.5", ",", " ", "106.3"}], "}"}], "]"}], ",", "    ", 
       RowBox[{"(*", " ", 
        RowBox[{"Lower", " ", "delta"}], " ", "*)"}], "\n", "  ", 
