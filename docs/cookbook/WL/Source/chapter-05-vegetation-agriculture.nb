Cell[CellGroupData[{

Cell["5.8 Evapotranspiration and Irrigation Scheduling", "Chapter",ExpressionUUID->"af1f007a-3e45-934b-a31c-9e46771d7781"],

Cell["\<\
Evapotranspiration (ET) measures the total water lost from the land surface \
through soil evaporation and plant transpiration. It is the single most \
important variable for irrigation scheduling because it quantifies actual \
crop water consumption.\
\>", "Text",ExpressionUUID->"9a41a9de-97b1-6441-aa37-c0caef12b45d"],

Cell[CellGroupData[{

Cell["5.8.1 MODIS ET Product", "Section",ExpressionUUID->"517030b2-3438-a946-a730-ac748c33eacc"],

Cell["\<\
The MODIS MOD16A2 product provides 8-day composite ET at 500 m resolution, \
derived from the Penman-Monteith equation using MODIS LAI, albedo, and \
meteorological inputs.\
\>", "Text",ExpressionUUID->"5daca2f6-53eb-5e4a-993c-8b43421a0d50"],

Cell[BoxData[{
 RowBox[{
  RowBox[{"irrigatedRegion", " ", "=", " ", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"-", "93.5"}], ",", " ", "41.7", ",", " ", 
     RowBox[{"-", "93.2"}], ",", " ", "41.9"}], "}"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"irrigatedGeom", " ", "=", " ", 
    RowBox[{"GEEGeometry", "[", "irrigatedRegion", "]"}]}], ";"}], "\n"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"etData", " ", "=", " ", 
    RowBox[{"Table", "[", "\n", "  ", 
     RowBox[{
      RowBox[{"Module", "[", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{
         "start", ",", " ", "end", ",", " ", "et", ",", " ", "stats"}], "}"}],
         ",", "\n", "    ", 
        RowBox[{
         RowBox[{"start", " ", "=", " ", 
          RowBox[{"DateString", "[", 
           RowBox[{
            RowBox[{
             RowBox[{"DateObject", "[", 
              RowBox[{"{", 
               RowBox[{"2024", ",", " ", "1", ",", " ", "1"}], "}"}], "]"}], 
             " ", "~", "DatePlus", "~", " ", 
             RowBox[{"{", 
              RowBox[{
               RowBox[{
                RowBox[{"(", 
                 RowBox[{"i", " ", "-", " ", "1"}], ")"}], " ", "*", " ", 
                "8"}], ",", " ", "\"\<Day\>\""}], "}"}]}], ",", "\n", 
            "      ", 
            RowBox[{"{", 
             
             RowBox[{"\"\<Year\>\"", ",", " ", "\"\<-\>\"", ",", 
              " ", "\"\<Month\>\"", ",", " ", "\"\<-\>\"", ",", 
              " ", "\"\<Day\>\""}], "}"}]}], "]"}]}], ";", "\n", "    ", 
         RowBox[{"end", " ", "=", " ", 
          RowBox[{"DateString", "[", 
           RowBox[{
            RowBox[{
             RowBox[{"DateObject", "[", 
              RowBox[{"{", 
               RowBox[{"2024", ",", " ", "1", ",", " ", "1"}], "}"}], "]"}], 
             " ", "~", "DatePlus", "~", " ", 
             RowBox[{"{", 
              RowBox[{
               RowBox[{"i", " ", "*", " ", "8"}], ",", " ", "\"\<Day\>\""}], 
              "}"}]}], ",", "\n", "      ", 
            RowBox[{"{", 
             
             RowBox[{"\"\<Year\>\"", ",", " ", "\"\<-\>\"", ",", 
              " ", "\"\<Month\>\"", ",", " ", "\"\<-\>\"", ",", 
              " ", "\"\<Day\>\""}], "}"}]}], "]"}]}], ";", "\n", "\n", "    ", 
         RowBox[{"et", " ", "=", "\n", "      ", 
          RowBox[{
           RowBox[{
            RowBox[{
             RowBox[{
              RowBox[{
               RowBox[{
               "GEECollection", "[", "\"\<MODIS/061/MOD16A2\>\"", "]"}], " ", 
               "//", "\n", "        ", 
               RowBox[{"GEEFilterDate", "[", 
                RowBox[{"start", ",", " ", "end"}], "]"}]}], " ", "//", "\n", 
              "        ", 
              RowBox[{"GEEFilterBounds", "[", "irrigatedRegion", "]"}]}], " ",
              "//", "\n", "        ", "GEEMean"}], " ", "//", "\n", 
            "        ", 
            RowBox[{"GEESelectBands", "[", 
             RowBox[{"{", "\"\<ET\>\"", "}"}], "]"}]}], " ", "//", "\n", 
           "        ", 
           RowBox[{"GEEMultiply", "[", "0.1", "]"}]}]}], ";", "  ", 
         RowBox[{"(*", " ", 
          RowBox[{"Scale", " ", 
           RowBox[{"factor", ":", " ", 
            RowBox[{"0.1", " ", 
             RowBox[{
              RowBox[{"kg", "/", 
               RowBox[{"m", "^", "2"}]}], "/", "8"}], "day"}]}]}], " ", 
          "*)"}], "\n", "\n", "    ", 
         RowBox[{"stats", " ", "=", " ", 
          RowBox[{"GEECompute", "[", "\n", "      ", 
           RowBox[{"et", " ", "//", " ", 
            RowBox[{"GEEReduceRegion", "[", 
             RowBox[{
             "irrigatedGeom", ",", " ", "\"\<mean\>\"", ",", " ", "500"}], 
             "]"}]}], "\n", "    ", "]"}]}], ";", "\n", "    ", 
         RowBox[{"{", 
          RowBox[{
           RowBox[{
            RowBox[{"DateObject", "[", 
             RowBox[{"{", 
              RowBox[{"2024", ",", " ", "1", ",", " ", "1"}], "}"}], "]"}], 
            " ", "~", "DatePlus", "~", " ", 
            RowBox[{"{", 
             RowBox[{
              RowBox[{
               RowBox[{
                RowBox[{"(", 
                 RowBox[{"i", " ", "-", " ", "1"}], ")"}], " ", "*", " ", 
                "8"}], " ", "+", " ", "4"}], ",", " ", "\"\<Day\>\""}], 
             "}"}]}], ",", "\n", "     ", 
           RowBox[{"stats", "[", "\"\<ET\>\"", "]"}]}], "}"}]}]}], "\n", "  ",
        "]"}], ",", "\n", "  ", 
      RowBox[{"{", 
       RowBox[{"i", ",", " ", "1", ",", " ", "46"}], "}"}]}], "\n", "]"}]}], 
   ";"}], "\n"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"etTS", " ", "=", " ", 
    RowBox[{"TimeSeries", "[", 
     RowBox[{
      RowBox[{"etData", "[", 
       RowBox[{"[", 
        RowBox[{"All", ",", " ", "2"}], "]"}], "]"}], ",", " ", 
      RowBox[{"{", 
       RowBox[{"etData", "[", 
        RowBox[{"[", 
         RowBox[{"All", ",", " ", "1"}], "]"}], "]"}], "}"}]}], "]"}]}], 
   ";"}], "\n"}], "\n", 
 RowBox[{"DateListPlot", "[", 
  RowBox[{"etTS", ",", "\n", "  ", 
   RowBox[{
   "PlotLabel", " ", "->", 
    " ", "\"\<8-Day Evapotranspiration -- Irrigated Field\>\""}], ",", "\n", 
   "  ", 
   RowBox[{"FrameLabel", " ", "->", " ", 
    RowBox[{"{", 
     RowBox[{"\"\<Date\>\"", ",", 
      " ", "\"\<ET (kg/m\\[Superscript]2/8-day)\>\""}], "}"}]}], ",", "\n", 
   "  ", 
   RowBox[{"Filling", " ", "->", " ", "Axis"}], ",", "\n", "  ", 
   RowBox[{"PlotTheme", " ", "->", " ", "\"\<Scientific\>\""}]}], 
  "]"}]}], "Input",ExpressionUUID->"8a218498-4119-7f46-a03a-b5b699aba344"]
}, Open  ]],

Cell[CellGroupData[{

Cell["5.8.2 Irrigation Scheduling Decision Support", "Section",ExpressionUUID->"f2aa0698-bd97-3a4d-a33c-ef50131b8b43"],

Cell["\<\
A practical irrigation scheduling rule triggers watering when cumulative ET \
since the last irrigation event exceeds the soil's readily available water \
(RAW), which depends on soil type and root depth.\
\>", "Text",ExpressionUUID->"e1f5d008-76e7-c94a-8e60-0dca83fd83b6"],

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{
   "Parameters", " ", "for", " ", "a", " ", "silt", " ", "loam", " ", "soil", 
    " ", "with", " ", "corn"}], " ", "*)"}], "\n", 
  RowBox[{
   RowBox[{
    RowBox[{"fieldCapacity", " ", "=", " ", "0.33"}], ";"}], "        ", 
   RowBox[{"(*", " ", 
    RowBox[{
     RowBox[{"m", "^", "3"}], "/", 
     RowBox[{"m", "^", "3"}]}], " ", "*)"}], "\n", 
   RowBox[{
    RowBox[{"wiltingPoint", " ", "=", " ", "0.13"}], ";"}], "         ", 
   RowBox[{"(*", " ", 
    RowBox[{
     RowBox[{"m", "^", "3"}], "/", 
     RowBox[{"m", "^", "3"}]}], " ", "*)"}], "\n", 
   RowBox[{
    RowBox[{"rootDepth", " ", "=", " ", "1.0"}], ";"}], "             ", 
   RowBox[{"(*", " ", "meters", " ", "*)"}], "\n", 
   RowBox[{
    RowBox[{"managementAllowableDepletion", " ", "=", " ", "0.5"}], ";"}], 
   "\n", "\n", 
   RowBox[{
    RowBox[{"totalAvailableWater", " ", "=", " ", 
     RowBox[{
      RowBox[{"(", 
       RowBox[{"fieldCapacity", " ", "-", " ", "wiltingPoint"}], ")"}], " ", "*",
       " ", "rootDepth", " ", "*", " ", "1000"}]}], ";"}], "\n", "  ", 
   RowBox[{"(*", " ", "mm", " ", "*)"}], "\n", 
   RowBox[{
    RowBox[{"readilyAvailableWater", " ", "=", " ", 
     RowBox[{
     "totalAvailableWater", " ", "*", " ", "managementAllowableDepletion"}]}],
     ";"}], "\n", "  ", 
   RowBox[{"(*", " ", "mm", " ", "*)"}], "\n", "\n", 
   RowBox[{"(*", " ", 
    RowBox[{
     RowBox[{"Convert", " ", "8"}], "-", 
     RowBox[{"day", " ", "ET", " ", "to", " ", "daily", " ", "ET", " ", 
      RowBox[{"(", "approximate", ")"}], " ", "and", " ", "accumulate"}]}], 
    " ", "*)"}], "\n", 
   RowBox[{
    RowBox[{"dailyET", " ", "=", " ", 
     RowBox[{
      RowBox[{"etData", "[", 
       RowBox[{"[", 
        RowBox[{"All", ",", " ", "2"}], "]"}], "]"}], " ", "/", " ", 
      "8.0"}]}], ";"}], "  ", 
   RowBox[{"(*", " ", 
    RowBox[{
     RowBox[{"mm", "/", "day"}], " ", "approximation"}], " ", "*)"}], "\n", 
   RowBox[{
    RowBox[{"cumulativeET", " ", "=", " ", 
     RowBox[{"Accumulate", "[", 
      RowBox[{"Flatten", " ", "@", " ", 
       RowBox[{"Table", "[", "\n", "  ", 
        RowBox[{
         RowBox[{"ConstantArray", "[", 
          RowBox[{
           RowBox[{"dailyET", "[", 
            RowBox[{"[", "i", "]"}], "]"}], ",", " ", "8"}], "]"}], ",", "\n",
          "  ", 
         RowBox[{"{", 
          RowBox[{"i", ",", " ", 
           RowBox[{"Length", "[", "dailyET", "]"}]}], "}"}]}], "\n", "]"}]}], 
      "]"}]}], ";"}], "\n", "\n", 
   RowBox[{"(*", " ", 
    RowBox[{
    "Find", " ", "dates", " ", "when", " ", "cumulative", " ", "ET", " ", 
     "exceeds", " ", "RAW", " ", "since", " ", "last", " ", "reset"}], " ", 
    "*)"}], "\n", 
   RowBox[{
    RowBox[{"irrigationDates", " ", "=", " ", 
     RowBox[{"{", "}"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"runningET", " ", "=", " ", "0.0"}], ";"}], "\n", 
   RowBox[{
    RowBox[{"dayIndex", " ", "=", " ", "0"}], ";"}], "\n", "\n", 
   RowBox[{
    RowBox[{"Do", "[", "\n", "  ", 
     RowBox[{
      RowBox[{
       RowBox[{"runningET", " ", "+=", " ", 
        RowBox[{
         RowBox[{"dailyET", "[", 
          RowBox[{"[", "i", "]"}], "]"}], " ", "*", " ", "8"}]}], ";", "  ", 
       RowBox[{"(*", " ", 
        RowBox[{"8", "-", 
         RowBox[{"day", " ", "block"}]}], " ", "*)"}], "\n", "  ", 
       RowBox[{"dayIndex", " ", "+=", " ", "8"}], ";", "\n", "  ", 
       RowBox[{"If", "[", 
        RowBox[{
         RowBox[{"runningET", " ", ">=", " ", "readilyAvailableWater"}], ",", 
         "\n", "    ", 
         RowBox[{
          RowBox[{"AppendTo", "[", 
           RowBox[{"irrigationDates", ",", "\n", "      ", 
            RowBox[{
             RowBox[{"DateObject", "[", 
              RowBox[{"{", 
               RowBox[{"2024", ",", " ", "1", ",", " ", "1"}], "}"}], "]"}], 
             " ", "~", "DatePlus", "~", " ", 
             RowBox[{"{", 
              RowBox[{"dayIndex", ",", " ", "\"\<Day\>\""}], "}"}]}]}], "]"}],
           ";", "\n", "    ", 
          RowBox[{"runningET", " ", "=", " ", "0.0"}], ";"}]}], "\n", "  ", 
        "]"}]}], ",", "\n", "  ", 
      RowBox[{"{", 
       RowBox[{"i", ",", " ", 
        RowBox[{"Length", "[", "dailyET", "]"}]}], "}"}]}], "\n", "]"}], 
    ";"}], "\n", "\n", 
   RowBox[{"(*", " ", 
    RowBox[{"Display", " ", "recommended", " ", "irrigation", " ", "dates"}], 
    " ", "*)"}], "\n", 
   RowBox[{"Column", "[", 
    RowBox[{"{", "\n", "  ", 
     RowBox[{
      RowBox[{
       RowBox[{
       "StringTemplate", "[", "\"\<Readily Available Water: `` mm\>\"", "]"}],
        "[", "\n", "    ", 
       RowBox[{"NumberForm", "[", 
        RowBox[{"readilyAvailableWater", ",", " ", "3"}], "]"}], "]"}], ",", 
      "\n", "  ", 
      RowBox[{
       RowBox[{
       "StringTemplate", "[", "\"\<Number of irrigation events: ``\>\"", 
        "]"}], "[", "\n", "    ", 
       RowBox[{"Length", "[", "irrigationDates", "]"}], "]"}], ",", "\n", 
      "  ", 
      RowBox[{"Grid", "[", 
       RowBox[{
        RowBox[{
         RowBox[{"{", 
          RowBox[{"{", 
           RowBox[{"\"\<Event\>\"", ",", " ", "\"\<Recommended Date\>\""}], 
           "}"}], "}"}], " ", "~", "Join", "~", "\n", "    ", 
         RowBox[{"MapIndexed", "[", 
          RowBox[{
           RowBox[{
            RowBox[{"{", 
             RowBox[{
              RowBox[{"First", "[", "#2", "]"}], ",", " ", 
              RowBox[{"DateString", "[", 
               RowBox[{"#1", ",", " ", 
                RowBox[{"{", 
                 
                 RowBox[{"\"\<Month\>\"", ",", " ", "\"\</\>\"", ",", 
                  " ", "\"\<Day\>\""}], "}"}]}], "]"}]}], "}"}], " ", "&"}], ",",
            "\n", "      ", "irrigationDates"}], "]"}]}], ",", "\n", "    ", 
        RowBox[{"Frame", " ", "->", " ", "All"}], ",", " ", 
        RowBox[{"Background", " ", "->", " ", 
         RowBox[{"{", 
          RowBox[{"None", ",", " ", 
           RowBox[{"{", 
            RowBox[{"LightBlue", ",", " ", "None"}], "}"}]}], "}"}]}]}], 
       "]"}]}], "\n", "}"}], "]"}]}]}]], "Input",ExpressionUUID->"81f2615c-\
2ecf-1042-9fe7-4a227f94057c"]
}, Open  ]],

Cell[CellGroupData[{

Cell["\<\
5.8.3 Crop Water Stress Index from Thermal and Vegetation Data\
\>", "Section",ExpressionUUID->"ca8f3e7f-4644-ac41-90b0-81517c92cf96"],

Cell["\<\
The Crop Water Stress Index (CWSI) combines canopy temperature (from Landsat \
thermal bands) with vegetation cover (NDVI) to detect water stress. Stressed \
crops close their stomata, reducing transpiration and raising canopy \
temperature.\
\>", "Text",ExpressionUUID->"ce750d3a-e05e-d549-b139-beb275d3f753"],

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{
   "Landsat", " ", "9", " ", "thermal", " ", "band", " ", "and", " ", 
    "NDVI"}], " ", "*)"}], "\n", 
  RowBox[{
   RowBox[{
    RowBox[{"landsatComposite", " ", "=", "\n", "  ", 
     RowBox[{
      RowBox[{
       RowBox[{
        RowBox[{
         RowBox[{
         "GEECollection", "[", "\"\<LANDSAT/LC09/C02/T1_L2\>\"", "]"}], " ", "//",
          "\n", "    ", 
         RowBox[{"GEEFilterDate", "[", 
          RowBox[{"\"\<2024-07-01\>\"", ",", " ", "\"\<2024-08-01\>\""}], 
          "]"}]}], " ", "//", "\n", "    ", 
        RowBox[{"GEEFilterBounds", "[", "irrigatedRegion", "]"}]}], " ", "//",
        "\n", "    ", 
       RowBox[{"GEEFilterProperty", "[", 
        RowBox[{"\"\<CLOUD_COVER\>\"", ",", " ", "\"\<LessThan\>\"", ",", " ",
          "15"}], "]"}]}], " ", "//", "\n", "    ", "GEEMedian"}]}], ";"}], 
   "\n", "\n", 
   RowBox[{"(*", " ", "NDVI", " ", "*)"}], "\n", 
   RowBox[{
    RowBox[{"landsatNDVI", " ", "=", " ", 
     RowBox[{"landsatComposite", " ", "//", " ", 
      RowBox[{"GEENormalizedDifference", "[", 
       RowBox[{"{", 
        RowBox[{"\"\<SR_B5\>\"", ",", " ", "\"\<SR_B4\>\""}], "}"}], 
       "]"}]}]}], ";"}], "\n", "\n", 
   RowBox[{"(*", " ", 
    RowBox[{"Land", " ", "surface", " ", "temperature", " ", 
     RowBox[{"(", 
      RowBox[{"ST_B10", ",", " ", 
       RowBox[{"scale", " ", "factor", " ", "0.00341802"}], ",", " ", 
       RowBox[{"offset", " ", "149.0"}]}], ")"}]}], " ", "*)"}], "\n", 
   RowBox[{
    RowBox[{"lst", " ", "=", " ", 
     RowBox[{
      RowBox[{
       RowBox[{
        RowBox[{"landsatComposite", " ", "//", "\n", "  ", 
         RowBox[{"GEESelectBands", "[", 
          RowBox[{"{", "\"\<ST_B10\>\"", "}"}], "]"}]}], " ", "//", "\n", 
        "  ", 
        RowBox[{"GEEMultiply", "[", "0.00341802", "]"}]}], " ", "//", "\n", 
       "  ", 
       RowBox[{"GEEAdd", "[", "149.0", "]"}]}], " ", "//", "\n", "  ", 
      RowBox[{"GEESubtract", "[", "273.15", "]"}]}]}], ";"}], "  ", 
   RowBox[{"(*", " ", 
    RowBox[{"Convert", " ", "Kelvin", " ", "to", " ", "Celsius"}], " ", 
    "*)"}], "\n", "\n", 
   RowBox[{"(*", " ", 
    RowBox[{
    "Combine", " ", "NDVI", " ", "and", " ", "LST", " ", "into", " ", "a", " ",
      "single", " ", "image"}], " ", "*)"}], "\n", 
   RowBox[{
    RowBox[{"ndviLST", " ", "=", " ", 
     RowBox[{
      RowBox[{"landsatNDVI", " ", "//", "\n", "  ", 
       RowBox[{"GEERename", "[", 
        RowBox[{"{", "\"\<NDVI\>\"", "}"}], "]"}]}], " ", "//", "\n", "  ", 
      RowBox[{"GEEAddBands", "[", 
       RowBox[{"lst", " ", "//", " ", 
        RowBox[{"GEERename", "[", 
         RowBox[{"{", "\"\<LST\>\"", "}"}], "]"}]}], "]"}]}]}], ";"}], "\n", 
   "\n", 
   RowBox[{"(*", " ", 
    RowBox[{
     RowBox[{"Extract", " ", "paired", " ", "NDVI"}], "-", 
     RowBox[{
     "LST", " ", "values", " ", "at", " ", "sample", " ", "points"}]}], " ", 
    "*)"}], "\n", 
   RowBox[{
    RowBox[{"sampleGrid", " ", "=", " ", 
     RowBox[{"Flatten", "[", "\n", "  ", 
      RowBox[{
       RowBox[{"Table", "[", 
        RowBox[{
         RowBox[{"GeoPosition", "[", 
          RowBox[{"{", 
           RowBox[{"lat", ",", " ", "lon"}], "}"}], "]"}], ",", "\n", "    ", 
         RowBox[{"{", 
          RowBox[{
          "lat", ",", " ", "41.7", ",", " ", "41.9", ",", " ", "0.01"}], 
          "}"}], ",", "\n", "    ", 
         RowBox[{"{", 
          RowBox[{"lon", ",", " ", 
           RowBox[{"-", "93.5"}], ",", " ", 
           RowBox[{"-", "93.2"}], ",", " ", "0.01"}], "}"}]}], "]"}], ",", 
       "\n", "  ", "1"}], "]"}]}], ";"}], "\n", "\n", 
   RowBox[{
    RowBox[{"ndviLSTSamples", " ", "=", " ", 
     RowBox[{"GEEGetSamples", "[", 
      RowBox[{"sampleGrid", ",", " ", "ndviLST"}], "]"}]}], ";"}], "\n", "\n", 
   RowBox[{
    RowBox[{"ndviVals", " ", "=", " ", 
     RowBox[{
      RowBox[{
       RowBox[{
        RowBox[{"#", "[", "\"\<Values\>\"", "]"}], "[", 
        RowBox[{"[", "1", "]"}], "]"}], " ", "&"}], " ", "/@", " ", 
      "ndviLSTSamples"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"lstVals", " ", "=", " ", 
     RowBox[{
      RowBox[{
       RowBox[{
        RowBox[{"#", "[", "\"\<Values\>\"", "]"}], "[", 
        RowBox[{"[", "2", "]"}], "]"}], " ", "&"}], " ", "/@", " ", 
      "ndviLSTSamples"}]}], ";"}], "\n", "\n", 
   RowBox[{"(*", " ", 
    RowBox[{"NDVI", "-", 
     RowBox[{"LST", " ", "scatter", " ", 
      RowBox[{"plot", ":", " ", 
       RowBox[{"the", " ", "\"\<triangle\>\"", " ", "method"}]}]}]}], " ", 
    "*)"}], "\n", 
   RowBox[{"ListPlot", "[", 
    RowBox[{
     RowBox[{"Transpose", "[", 
      RowBox[{"{", 
       RowBox[{"ndviVals", ",", " ", "lstVals"}], "}"}], "]"}], ",", "\n", 
     "  ", 
     RowBox[{"FrameLabel", " ", "->", " ", 
      RowBox[{"{", 
       RowBox[{"\"\<NDVI\>\"", ",", " ", "\"\<LST (\[Degree]C)\>\""}], 
       "}"}]}], ",", "\n", "  ", 
     RowBox[{
     "PlotLabel", " ", "->", 
      " ", "\"\<NDVI-LST Triangle for Water Stress Detection\>\""}], ",", 
     "\n", "  ", 
     RowBox[{"PlotStyle", " ", "->", " ", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"PointSize", "[", "0.008", "]"}], ",", " ", 
        RowBox[{"Opacity", "[", "0.5", "]"}]}], "}"}]}], ",", "\n", "  ", 
     RowBox[{"PlotTheme", " ", "->", " ", "\"\<Scientific\>\""}], ",", "\n", 
     "  ", 
     RowBox[{"AspectRatio", " ", "->", " ", "1"}]}], "]"}]}]}]], "Input",Expre\
ssionUUID->"183e52c6-2e5d-6e4b-9034-e946d68839b6"],

Cell["\<\
In the NDVI-LST scatter plot, points form a triangular envelope. The upper \
edge (hot, vegetated) represents maximum water stress. The lower edge (cool, \
vegetated) represents well-watered conditions. Points near the upper edge \
indicate fields that need irrigation.\
\>", "Text",ExpressionUUID->"a942cb94-ef43-564a-a8cd-119ba632cf09"],

Cell[TextData[StyleBox["Computing a pixel-level stress index.",
 FontWeight->Bold]], "Text",ExpressionUUID->"6a38dbf9-ecd7-e444-9051-\
134636540eb5"],

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{"Fit", " ", "the", " ", "dry", " ", "edge", " ", 
    RowBox[{"(", 
     RowBox[{"upper", " ", "boundary"}], ")"}], " ", "and", " ", "wet", " ", 
    "edge", " ", 
    RowBox[{"(", 
     RowBox[{"lower", " ", "boundary"}], ")"}]}], " ", "*)"}], "\n", 
  RowBox[{"(*", " ", 
   RowBox[{"For", " ", "a", " ", "simplified", " ", 
    RowBox[{"CWSI", ":", " ", 
     RowBox[{
     "normalize", " ", "LST", " ", "between", " ", "wet", " ", "and", " ", 
      "dry", " ", "edges"}]}]}], " ", "*)"}], "\n", "\n", 
  RowBox[{"(*", " ", 
   RowBox[{
   "Approximate", " ", "wet", " ", "and", " ", "dry", " ", "edge", " ", 
    "temperatures", " ", "for", " ", "a", " ", "given", " ", "NDVI"}], " ", 
   "*)"}], "\n", 
  RowBox[{
   RowBox[{
    RowBox[{"dryEdgeModel", " ", "=", " ", 
     RowBox[{"LinearModelFit", "[", "\n", "  ", 
      RowBox[{
       RowBox[{"Select", "[", 
        RowBox[{
         RowBox[{"Transpose", "[", 
          RowBox[{"{", 
           RowBox[{"ndviVals", ",", " ", "lstVals"}], "}"}], "]"}], ",", " ", 
         RowBox[{
          RowBox[{
           RowBox[{"#", "[", 
            RowBox[{"[", "2", "]"}], "]"}], " ", ">", " ", 
           RowBox[{"Quantile", "[", 
            RowBox[{"lstVals", ",", " ", "0.9"}], "]"}]}], " ", "&"}]}], 
        "]"}], ",", "\n", "  ", "x", ",", " ", "x"}], "]"}]}], ";"}], "\n", "\n", 
   RowBox[{
    RowBox[{"wetEdgeModel", " ", "=", " ", 
     RowBox[{"LinearModelFit", "[", "\n", "  ", 
      RowBox[{
       RowBox[{"Select", "[", 
        RowBox[{
         RowBox[{"Transpose", "[", 
          RowBox[{"{", 
           RowBox[{"ndviVals", ",", " ", "lstVals"}], "}"}], "]"}], ",", " ", 
         RowBox[{
          RowBox[{
           RowBox[{"#", "[", 
            RowBox[{"[", "2", "]"}], "]"}], " ", "<", " ", 
           RowBox[{"Quantile", "[", 
            RowBox[{"lstVals", ",", " ", "0.1"}], "]"}]}], " ", "&"}]}], 
        "]"}], ",", "\n", "  ", "x", ",", " ", "x"}], "]"}]}], ";"}], "\n", 
   "\n", 
   RowBox[{"(*", " ", 
    RowBox[{"CWSI", " ", "=", " ", 
     RowBox[{
      RowBox[{"(", 
       RowBox[{"T_observed", " ", "-", " ", "T_wet"}], ")"}], " ", "/", " ", 
      RowBox[{"(", 
       RowBox[{"T_dry", " ", "-", " ", "T_wet"}], ")"}]}]}], " ", "*)"}], 
   "\n", 
   RowBox[{"(*", " ", 
    RowBox[{
     RowBox[{
      RowBox[{"Values", " ", "near", " ", "0"}], " ", "=", " ", 
      RowBox[{"no", " ", "stress"}]}], ",", " ", 
     RowBox[{
      RowBox[{"near", " ", "1"}], " ", "=", " ", 
      RowBox[{"severe", " ", "stress"}]}]}], " ", "*)"}], "\n", 
   RowBox[{
    RowBox[{"cwsiValues", " ", "=", " ", 
     RowBox[{"Table", "[", "\n", "  ", 
      RowBox[{
       RowBox[{"Module", "[", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{"tDry", ",", " ", "tWet"}], "}"}], ",", "\n", "    ", 
         RowBox[{
          RowBox[{"tDry", " ", "=", " ", 
           RowBox[{"dryEdgeModel", "[", 
            RowBox[{"ndviVals", "[", 
             RowBox[{"[", "i", "]"}], "]"}], "]"}]}], ";", "\n", "    ", 
          RowBox[{"tWet", " ", "=", " ", 
           RowBox[{"wetEdgeModel", "[", 
            RowBox[{"ndviVals", "[", 
             RowBox[{"[", "i", "]"}], "]"}], "]"}]}], ";", "\n", "    ", 
          RowBox[{"Clip", "[", 
           RowBox[{
            RowBox[{
             RowBox[{"(", 
              RowBox[{
               RowBox[{"lstVals", "[", 
                RowBox[{"[", "i", "]"}], "]"}], " ", "-", " ", "tWet"}], 
              ")"}], " ", "/", " ", 
             RowBox[{"(", 
              RowBox[{"tDry", " ", "-", " ", "tWet"}], ")"}]}], ",", " ", 
            RowBox[{"{", 
             RowBox[{"0", ",", " ", "1"}], "}"}]}], "]"}]}]}], "\n", "  ", 
        "]"}], ",", "\n", "  ", 
       RowBox[{"{", 
        RowBox[{"i", ",", " ", 
         RowBox[{"Length", "[", "ndviVals", "]"}]}], "}"}]}], "\n", "]"}]}], 
    ";"}], "\n", "\n", 
   RowBox[{"(*", " ", 
    RowBox[{
    "Map", " ", "CWSI", " ", "values", " ", "back", " ", "to", " ", 
     "geographic", " ", "positions"}], " ", "*)"}], "\n", 
   RowBox[{"GeoListPlot", "[", "\n", "  ", 
    RowBox[{
     RowBox[{"Table", "[", "\n", "    ", 
      RowBox[{
       RowBox[{"Style", "[", 
        RowBox[{
         RowBox[{"sampleGrid", "[", 
          RowBox[{"[", "i", "]"}], "]"}], ",", "\n", "      ", 
         RowBox[{"Blend", "[", 
          RowBox[{
           RowBox[{"{", 
            RowBox[{
             RowBox[{"Darker", "[", "Green", "]"}], ",", " ", "Yellow", ",", 
             " ", "Red"}], "}"}], ",", " ", 
           RowBox[{"cwsiValues", "[", 
            RowBox[{"[", "i", "]"}], "]"}]}], "]"}]}], "]"}], ",", "\n", 
       "    ", 
       RowBox[{"{", 
        RowBox[{"i", ",", " ", 
         RowBox[{"Length", "[", "sampleGrid", "]"}]}], "}"}]}], "\n", "  ", 
      "]"}], ",", "\n", "  ", 
     RowBox[{"PlotLabel", " ", "->", " ", "\"\<Crop Water Stress Index\>\""}],
      ",", "\n", "  ", 
     RowBox[{"PlotLegends", " ", "->", " ", 
      RowBox[{"BarLegend", "[", 
       RowBox[{
        RowBox[{"{", "\n", "    ", 
         RowBox[{
          RowBox[{"(", 
           RowBox[{
            RowBox[{"Blend", "[", 
             RowBox[{
              RowBox[{"{", 
               RowBox[{
                RowBox[{"Darker", "[", "Green", "]"}], ",", " ", "Yellow", ",",
                 " ", "Red"}], "}"}], ",", " ", "#"}], "]"}], " ", "&"}], 
           ")"}], ",", "\n", "    ", 
          RowBox[{"{", 
           RowBox[{"0", ",", " ", "1"}], "}"}]}], "}"}], ",", " ", 
        RowBox[{"LegendLabel", " ", "->", " ", "\"\<CWSI\>\""}]}], "]"}]}], ",",
      "\n", "  ", 
     RowBox[{"GeoRange", " ", "->", " ", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{"41.69", ",", " ", "41.91"}], "}"}], ",", " ", 
        RowBox[{"{", 
         RowBox[{
          RowBox[{"-", "93.51"}], ",", " ", 
          RowBox[{"-", "93.19"}]}], "}"}]}], "}"}]}]}], "]"}]}]}]], "Input",Ex\
pressionUUID->"83ec6a48-f535-8f47-8211-4b8956d02026"],

