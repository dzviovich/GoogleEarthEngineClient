Notebook[{

Cell[CellGroupData[{
Cell["Chapter 5: Vegetation and Agricultural Monitoring", "Title",ExpressionUUID->"f43e23fb-123f-7b4d-b294-38bea8848308"],

Cell["\<\
Vegetation monitoring from space is one of the most mature applications of \
remote sensing. Satellites measure how plants interact with sunlight -- \
absorbing red wavelengths for photosynthesis while reflecting near-infrared \
-- and this spectral signature lets us quantify crop health, detect water \
stress, estimate yields, and guide precision agriculture decisions. This \
chapter brings together Google Earth Engine imagery, Wolfram Language \
analysis, and ground-sensor integration into end-to-end workflows for \
agricultural scientists and engineers.\
\>", "Text",ExpressionUUID->"658d981b-c3ef-4f40-92e5-41f7cd86bad2"],

Cell[TextData[{
 StyleBox["Prerequisite:",
  FontWeight->Bold],
 " Authenticate per Section 1.3 and load the paclet with ",
 Cell["Needs[\"GoogleEarthEngineClient`\"]", "InlineCode",ExpressionUUID->
  "3078d5b7-d681-e541-a04b-628abc10b39d"],
 "."
}], "Text",ExpressionUUID->"c2aef2ac-9e89-104e-828b-4a3d543cd053"],

Cell["", "Text",
 CellFrame->{{0, 0}, {0, 
  1}},ExpressionUUID->"2f797e13-e8dc-9544-9202-ea2433786ca7"],

Cell[CellGroupData[{

Cell["5.1 Vegetation Indices", "Chapter",ExpressionUUID->"fb1d5a9e-47b4-be4a-9c12-15457df714d6"],

Cell["\<\
Vegetation indices transform multi-band reflectance into single numbers that \
correlate with plant properties such as chlorophyll content, canopy cover, \
and leaf water content. The most widely used index is NDVI, but several \
alternatives address its known limitations.\
\>", "Text",ExpressionUUID->"46d2d6f0-5ba3-6649-ba76-1e678c15432c"],

Cell[CellGroupData[{

Cell["5.1.1 NDVI -- Normalized Difference Vegetation Index", "Section",ExpressionUUID->"de5df832-d99b-3947-b3b2-2f305de530f0"],

Cell[TextData[{
 StyleBox["Physical basis.",
  FontWeight->Bold],
 " Healthy green vegetation absorbs strongly in the red band (~660 nm) \
because chlorophyll uses red photons for photosynthesis, while reflecting \
strongly in the near-infrared (~850 nm) because the internal cell structure \
of leaves scatters NIR light. NDVI captures this contrast:"
}], "Text",ExpressionUUID->"ded9d44b-8c0a-dc4b-ba2c-85d6821a9871"],

Cell["NDVI = (NIR - Red) / (NIR + Red)", "Program",ExpressionUUID->"e2afff06-4bcc-744e-a39a-2b27d1781c3a"],

Cell["\<\
Values range from -1 to +1. Bare soil typically falls between 0.1 and 0.2, \
sparse vegetation between 0.2 and 0.5, and dense healthy crops above 0.6.\
\>", "Text",ExpressionUUID->"7a966393-2a56-0444-9263-05c621ff2234"],

Cell[TextData[StyleBox["NDVI map of California's Central Valley (Sentinel-2).",
 FontWeight->Bold]], "Text",ExpressionUUID->"b6d3ea66-0525-7b48-ae3b-\
3e92851d420b"],

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"centralValley", " ", "=", " ", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{"-", "121.5"}], ",", " ", "36.0", ",", " ", 
      RowBox[{"-", "119.5"}], ",", " ", "37.5"}], "}"}]}], ";"}], "\n"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"ndviImage", " ", "=", "\n", "  ", 
    RowBox[{
     RowBox[{
      RowBox[{
       RowBox[{
        RowBox[{
         RowBox[{
         "GEECollection", "[", "\"\<COPERNICUS/S2_SR_HARMONIZED\>\"", "]"}], 
         " ", "//", "\n", "    ", 
         RowBox[{"GEEFilterDate", "[", 
          RowBox[{"\"\<2024-07-01\>\"", ",", " ", "\"\<2024-08-01\>\""}], 
          "]"}]}], " ", "//", "\n", "    ", 
        RowBox[{"GEEFilterBounds", "[", "centralValley", "]"}]}], " ", "//", 
       "\n", "    ", 
       RowBox[{"GEEFilterProperty", "[", 
        RowBox[{"\"\<CLOUDY_PIXEL_PERCENTAGE\>\"", ",", 
         " ", "\"\<LessThan\>\"", ",", " ", "10"}], "]"}]}], " ", "//", "\n", 
      "    ", "GEEMedian"}], " ", "//", "\n", "    ", 
     RowBox[{"GEENormalizedDifference", "[", 
      RowBox[{"{", 
       RowBox[{"\"\<B8\>\"", ",", " ", "\"\<B4\>\""}], "}"}], "]"}]}]}], 
   ";"}], "\n", "\n", 
  RowBox[{"(*", " ", 
   RowBox[{
    RowBox[{"Visualize", " ", "with", " ", "a", " ", "green"}], "-", "to", "-", 
    RowBox[{"brown", " ", "palette"}]}], " ", "*)"}]}], "\n", 
 RowBox[{"GEEComputePixels", "[", 
  RowBox[{"centralValley", ",", "\n", "  ", 
   RowBox[{"ndviImage", " ", "//", "\n", "    ", 
    RowBox[{"GEEVisualize", "[", 
     RowBox[{"<|", "\n", "      ", 
      RowBox[{
       RowBox[{"\"\<min\>\"", " ", "->", " ", 
        RowBox[{"-", "0.1"}]}], ",", "\n", "      ", 
       RowBox[{"\"\<max\>\"", " ", "->", " ", "0.9"}], ",", "\n", "      ", 
       RowBox[{"\"\<palette\>\"", " ", "->", " ", 
        RowBox[{"{", 
         RowBox[{"\"\<#8B4513\>\"", ",", " ", "\"\<#D2B48C\>\"", ",", 
          " ", "\"\<#F5F5DC\>\"", ",", " ", "\"\<#ADFF2F\>\"", ",", 
          " ", "\"\<#006400\>\""}], "}"}]}]}], "\n", "    ", "|>"}], "]"}]}], 
   ",", "\n", "  ", 
   RowBox[{"\"\<ImageSize\>\"", " ", "->", " ", "1024"}]}], "]"}]}], "Input",E\
xpressionUUID->"4f6df383-6a78-a84c-a0b9-2acc8d509dca"],

Cell["\<\
The palette runs from brown (bare soil, low NDVI) through tan and beige \
(sparse cover) to bright green and dark green (vigorous crops). July is peak \
growing season in the Central Valley, so irrigated fields appear dark green \
while fallowed parcels remain brown.\
\>", "Text",ExpressionUUID->"220f073d-5340-7242-8f99-448e609c5222"],

Cell[TextData[StyleBox["NDVI time series -- monthly composites.",
 FontWeight->Bold]], "Text",ExpressionUUID->"6ac535fc-de8b-5f45-be9c-\
2138d5c5ff34"],

Cell["\<\
Extracting mean NDVI over a region for each month builds a phenology curve \
that reveals green-up, peak, and senescence dates.\
\>", "Text",ExpressionUUID->"97304367-a03c-b542-bc78-bc52d24b7a9e"],

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"field", " ", "=", " ", 
    RowBox[{"GEEGeometry", "[", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"-", "120.5"}], ",", " ", "36.8", ",", " ", 
       RowBox[{"-", "120.3"}], ",", " ", "37.0"}], "}"}], "]"}]}], ";"}], 
  "\n"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"monthlyNDVI", " ", "=", " ", 
    RowBox[{"Table", "[", "\n", "  ", 
     RowBox[{
      RowBox[{"Module", "[", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{
         "start", ",", " ", "end", ",", " ", "composite", ",", " ", "ndvi", ",",
           " ", "stats"}], "}"}], ",", "\n", "    ", 
        RowBox[{
         RowBox[{"start", " ", "=", " ", 
          RowBox[{"DateString", "[", 
           RowBox[{
            RowBox[{"DateObject", "[", 
             RowBox[{"{", 
              RowBox[{"2024", ",", " ", "m", ",", " ", "1"}], "}"}], "]"}], ",",
             " ", 
            RowBox[{"{", 
             
             RowBox[{"\"\<Year\>\"", ",", " ", "\"\<-\>\"", ",", 
              " ", "\"\<Month\>\"", ",", " ", "\"\<-\>\"", ",", 
              " ", "\"\<Day\>\""}], "}"}]}], "]"}]}], ";", "\n", "    ", 
         RowBox[{"end", " ", "=", " ", 
          RowBox[{"DateString", "[", 
           RowBox[{
            RowBox[{"DatePlus", "[", 
             RowBox[{
              RowBox[{"DateObject", "[", 
               RowBox[{"{", 
                RowBox[{"2024", ",", " ", "m", ",", " ", "1"}], "}"}], "]"}], 
              ",", " ", 
              RowBox[{"{", 
               RowBox[{"1", ",", " ", "\"\<Month\>\""}], "}"}]}], "]"}], ",", 
            "\n", "      ", 
            RowBox[{"{", 
             
             RowBox[{"\"\<Year\>\"", ",", " ", "\"\<-\>\"", ",", 
              " ", "\"\<Month\>\"", ",", " ", "\"\<-\>\"", ",", 
              " ", "\"\<Day\>\""}], "}"}]}], "]"}]}], ";", "\n", "\n", "    ", 
         RowBox[{"composite", " ", "=", "\n", "      ", 
          RowBox[{
           RowBox[{
            RowBox[{
             RowBox[{
              RowBox[{
              "GEECollection", "[", "\"\<COPERNICUS/S2_SR_HARMONIZED\>\"", 
               "]"}], " ", "//", "\n", "        ", 
              RowBox[{"GEEFilterDate", "[", 
               RowBox[{"start", ",", " ", "end"}], "]"}]}], " ", "//", "\n", 
             "        ", 
             RowBox[{"GEEFilterBounds", "[", 
              RowBox[{"{", 
               RowBox[{
                RowBox[{"-", "120.5"}], ",", " ", "36.8", ",", " ", 
                RowBox[{"-", "120.3"}], ",", " ", "37.0"}], "}"}], "]"}]}], 
            " ", "//", "\n", "        ", 
            RowBox[{"GEEFilterProperty", "[", 
             
             RowBox[{"\"\<CLOUDY_PIXEL_PERCENTAGE\>\"", ",", 
              " ", "\"\<LessThan\>\"", ",", " ", "20"}], "]"}]}], " ", "//", 
           "\n", "        ", "GEEMedian"}]}], ";", "\n", "\n", "    ", 
         RowBox[{"ndvi", " ", "=", " ", 
          RowBox[{"composite", " ", "//", " ", 
           RowBox[{"GEENormalizedDifference", "[", 
            RowBox[{"{", 
             RowBox[{"\"\<B8\>\"", ",", " ", "\"\<B4\>\""}], "}"}], "]"}]}]}],
          ";", "\n", "\n", "    ", 
         RowBox[{"stats", " ", "=", " ", 
          RowBox[{"GEECompute", "[", "\n", "      ", 
           RowBox[{"ndvi", " ", "//", " ", 
            RowBox[{"GEEReduceRegion", "[", 
             RowBox[{"field", ",", " ", "\"\<mean\>\"", ",", " ", "30"}], 
             "]"}]}], "\n", "    ", "]"}]}], ";", "\n", "\n", "    ", 
         RowBox[{"(*", " ", 
          RowBox[{
          "GEENormalizedDifference", " ", "outputs", " ", "a", " ", "single", 
           " ", "band", " ", "named", " ", "\"\<nd\>\"", " ", "by", " ", 
           "default"}], " ", "*)"}], "\n", "    ", 
         RowBox[{"{", 
          RowBox[{
           RowBox[{"DateObject", "[", 
            RowBox[{"{", 
             RowBox[{"2024", ",", " ", "m", ",", " ", "15"}], "}"}], "]"}], ",",
            " ", 
           RowBox[{"stats", "[", "\"\<nd\>\"", "]"}]}], "}"}]}]}], "\n", "  ",
        "]"}], ",", "\n", "  ", 
      RowBox[{"{", 
       RowBox[{"m", ",", " ", "1", ",", " ", "12"}], "}"}]}], "\n", "]"}]}], 
   ";"}], "\n", "\n", 
  RowBox[{"(*", " ", 
   RowBox[{"Build", " ", "a", " ", "TimeSeries", " ", "and", " ", "plot"}], 
   " ", "*)"}]}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"ndviTS", " ", "=", " ", 
    RowBox[{"TimeSeries", "[", 
     RowBox[{
      RowBox[{"monthlyNDVI", "[", 
       RowBox[{"[", 
        RowBox[{"All", ",", " ", "2"}], "]"}], "]"}], ",", " ", 
      RowBox[{"{", 
       RowBox[{"monthlyNDVI", "[", 
        RowBox[{"[", 
         RowBox[{"All", ",", " ", "1"}], "]"}], "]"}], "}"}]}], "]"}]}], 
   ";"}], "\n"}], "\n", 
 RowBox[{"DateListPlot", "[", 
  RowBox[{"ndviTS", ",", "\n", "  ", 
   RowBox[{
   "PlotLabel", " ", "->", 
    " ", "\"\<Monthly Mean NDVI -- Central Valley Field\>\""}], ",", "\n", 
   "  ", 
   RowBox[{"FrameLabel", " ", "->", " ", 
    RowBox[{"{", 
     RowBox[{"\"\<Date\>\"", ",", " ", "\"\<NDVI\>\""}], "}"}]}], ",", "\n", 
   "  ", 
   RowBox[{"Filling", " ", "->", " ", "Axis"}], ",", "\n", "  ", 
   RowBox[{"PlotRange", " ", "->", " ", 
    RowBox[{"{", 
     RowBox[{"0", ",", " ", "1"}], "}"}]}], ",", "\n", "  ", 
   RowBox[{"PlotTheme", " ", "->", " ", "\"\<Scientific\>\""}]}], 
  "]"}]}], "Input",ExpressionUUID->"674783c8-8ae6-2d4d-8c75-be70f57db913"],

Cell[TextData[{
 StyleBox["NDVI from Landsat 8/9.",
  FontWeight->Bold],
 " The band names differ from Sentinel-2. Landsat Collection 2 surface \
reflectance uses ",
 Cell["SR_B5", "InlineCode",ExpressionUUID->
  "34586480-a3dc-b246-a9f7-f97188dff616"],
 " (NIR) and ",
 Cell["SR_B4", "InlineCode",ExpressionUUID->
  "3f1c27b2-84aa-7843-b965-2899473c396e"],
 " (red):"
}], "Text",ExpressionUUID->"19505c01-4782-9644-9626-2e05a9f6ee50"],

Cell[BoxData[
 RowBox[{
  RowBox[{"landsatNDVI", " ", "=", "\n", "  ", 
   RowBox[{
    RowBox[{
     RowBox[{
      RowBox[{
       RowBox[{
        RowBox[{"GEECollection", "[", "\"\<LANDSAT/LC09/C02/T1_L2\>\"", "]"}],
         " ", "//", "\n", "    ", 
        RowBox[{"GEEFilterDate", "[", 
         RowBox[{"\"\<2024-06-01\>\"", ",", " ", "\"\<2024-09-01\>\""}], 
         "]"}]}], " ", "//", "\n", "    ", 
       RowBox[{"GEEFilterBounds", "[", "centralValley", "]"}]}], " ", "//", 
      "\n", "    ", 
      RowBox[{"GEEFilterProperty", "[", 
       RowBox[{"\"\<CLOUD_COVER\>\"", ",", " ", "\"\<LessThan\>\"", ",", " ", 
        "15"}], "]"}]}], " ", "//", "\n", "    ", "GEEMedian"}], " ", "//", 
    "\n", "    ", 
    RowBox[{"GEENormalizedDifference", "[", 
     RowBox[{"{", 
      RowBox[{"\"\<SR_B5\>\"", ",", " ", "\"\<SR_B4\>\""}], "}"}], "]"}]}]}], 
  ";"}]], "Input",ExpressionUUID->"3c91283c-8e52-fd4b-866a-554f2fdb8acb"]
}, Open  ]],

Cell[CellGroupData[{

Cell["5.1.2 EVI -- Enhanced Vegetation Index", "Section",ExpressionUUID->"48806bfa-b19a-d746-9233-4742415b52a9"],

Cell["\<\
NDVI saturates in dense canopies where Leaf Area Index (LAI) exceeds roughly \
3. EVI was designed for the MODIS sensor to remain sensitive in high-biomass \
regions by incorporating a blue band to correct for atmospheric aerosol \
scattering and a soil adjustment factor:\
\>", "Text",ExpressionUUID->"e6aa76ff-2ba4-1b4a-a0b6-a27a6d362f84"],

Cell["EVI = 2.5 * ((NIR - Red) / (NIR + 6*Red - 7.5*Blue + 1))", "Program",ExpressionUUID->"b2af720c-7622-ba4e-85d9-96ca715fb9a1"],

Cell[TextData[{
 StyleBox["Computing EVI with ",
  FontWeight->Bold],
 Cell["GEEExpression", "InlineCode",ExpressionUUID->
  "13e67feb-48da-b54a-b4b2-2e198aa86513"],
 StyleBox[".",
  FontWeight->Bold]
}], "Text",ExpressionUUID->"feedeac0-3956-1748-b1df-ec713c893438"],

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"sentinel2Composite", " ", "=", "\n", "  ", 
    RowBox[{
     RowBox[{
      RowBox[{
       RowBox[{
        RowBox[{
         RowBox[{
         "GEECollection", "[", "\"\<COPERNICUS/S2_SR_HARMONIZED\>\"", "]"}], 
         " ", "//", "\n", "    ", 
         RowBox[{"GEEFilterDate", "[", 
          RowBox[{"\"\<2024-07-01\>\"", ",", " ", "\"\<2024-08-01\>\""}], 
          "]"}]}], " ", "//", "\n", "    ", 
        RowBox[{"GEEFilterBounds", "[", "centralValley", "]"}]}], " ", "//", 
       "\n", "    ", 
       RowBox[{"GEEFilterProperty", "[", 
        RowBox[{"\"\<CLOUDY_PIXEL_PERCENTAGE\>\"", ",", 
         " ", "\"\<LessThan\>\"", ",", " ", "10"}], "]"}]}], " ", "//", "\n", 
      "    ", "GEEMedian"}], " ", "//", "\n", "    ", 
     RowBox[{"GEESelectBands", "[", 
      RowBox[{"{", 
       RowBox[{"\"\<B8\>\"", ",", " ", "\"\<B4\>\"", ",", " ", "\"\<B2\>\""}],
        "}"}], "]"}]}]}], ";"}], "\n", "\n", 
  RowBox[{"(*", " ", 
   RowBox[{
    RowBox[{"After", " ", "GEEMedian"}], ",", " ", 
    RowBox[{
    "band", " ", "names", " ", "gain", " ", "a", " ", "_median", " ", 
     "suffix"}]}], " ", "*)"}]}], "\n", 
 RowBox[{
  RowBox[{"eviImage", " ", "=", "\n", "  ", 
   RowBox[{"sentinel2Composite", " ", "//", "\n", "    ", 
    RowBox[{"GEEExpression", "[", "\n", "      ", 
     RowBox[{"\"\<2.5 * ((nir - red) / (nir + 6 * red - 7.5 * blue + 1))\>\"",
       ",", "\n", "      ", 
      RowBox[{"<|", 
       RowBox[{
        RowBox[{"\"\<nir\>\"", " ", "->", " ", "\"\<B8_median\>\""}], ",", 
        " ", 
        RowBox[{"\"\<red\>\"", " ", "->", " ", "\"\<B4_median\>\""}], ",", 
        " ", 
        RowBox[{"\"\<blue\>\"", " ", "->", " ", "\"\<B2_median\>\""}]}], 
       "|>"}]}], "\n", "    ", "]"}]}]}], ";"}]}], "Input",ExpressionUUID->\
"564a3e1a-2963-484e-83dd-39930b30c9c8"],

Cell[TextData[StyleBox["Side-by-side comparison of NDVI and EVI.",
 FontWeight->Bold]], "Text",ExpressionUUID->"9c7ac351-a17c-5846-832b-\
e12fff231936"],

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"ndviVis", " ", "=", " ", 
    RowBox[{"ndviImage", " ", "//", " ", 
     RowBox[{"GEEVisualize", "[", 
      RowBox[{"<|", 
       RowBox[{
        RowBox[{"\"\<min\>\"", " ", "->", " ", "0"}], ",", " ", 
        RowBox[{"\"\<max\>\"", " ", "->", " ", "1"}], ",", "\n", "  ", 
        RowBox[{"\"\<palette\>\"", " ", "->", " ", 
         RowBox[{"{", 
          
          RowBox[{"\"\<white\>\"", ",", " ", "\"\<green\>\"", ",", 
           " ", "\"\<darkgreen\>\""}], "}"}]}]}], "|>"}], "]"}]}]}], ";"}], 
  "\n"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"eviVis", " ", "=", " ", 
    RowBox[{"eviImage", " ", "//", " ", 
     RowBox[{"GEEVisualize", "[", 
      RowBox[{"<|", 
       RowBox[{
        RowBox[{"\"\<min\>\"", " ", "->", " ", "0"}], ",", " ", 
        RowBox[{"\"\<max\>\"", " ", "->", " ", "0.8"}], ",", "\n", "  ", 
        RowBox[{"\"\<palette\>\"", " ", "->", " ", 
         RowBox[{"{", 
          
          RowBox[{"\"\<white\>\"", ",", " ", "\"\<green\>\"", ",", 
           " ", "\"\<darkgreen\>\""}], "}"}]}]}], "|>"}], "]"}]}]}], ";"}], 
  "\n"}], "\n", 
 RowBox[{"GraphicsRow", "[", 
  RowBox[{
   RowBox[{"{", "\n", "  ", 
    RowBox[{
     RowBox[{"GEEComputePixels", "[", 
      RowBox[{"centralValley", ",", " ", "ndviVis", ",", " ", 
       RowBox[{"\"\<ImageSize\>\"", " ", "->", " ", "512"}]}], "]"}], ",", 
     "\n", "  ", 
     RowBox[{"GEEComputePixels", "[", 
      RowBox[{"centralValley", ",", " ", "eviVis", ",", " ", 
       RowBox[{"\"\<ImageSize\>\"", " ", "->", " ", "512"}]}], "]"}]}], "\n", 
    "}"}], ",", " ", 
   RowBox[{"ImageSize", " ", "->", " ", "1100"}], ",", "\n", "  ", 
   RowBox[{
   "PlotLabel", " ", "->", 
    " ", "\"\<NDVI (left) vs EVI (right) -- July 2024\>\""}]}], 
  "]"}]}], "Input",ExpressionUUID->"fd1899ff-bb62-c24a-b896-30f7608b1e28"],

Cell["\<\
In densely vegetated fields (rice paddies, orchards), EVI retains more \
contrast than NDVI, which compresses toward 0.8-0.9.\
\>", "Text",ExpressionUUID->"8bc988c2-9554-d54a-a73a-567ad211de0d"]
}, Open  ]],

Cell[CellGroupData[{

Cell["\<\
5.1.3 NDWI -- Normalized Difference Water Index (Vegetation Moisture)\
\>", "Section",ExpressionUUID->"058bb736-3f20-bd4b-bb0e-c4fc568ba448"],

Cell[TextData[{
 "The Gao NDWI for vegetation water content uses NIR and SWIR bands: ",
 Cell["(NIR - SWIR) / (NIR + SWIR)", "InlineCode",ExpressionUUID->
  "de43efa5-1c3b-ae44-b172-b11a91248608"],
 ". This differs from the McFeeters NDWI (",
 Cell["(Green - NIR) / (Green + NIR)", "InlineCode",ExpressionUUID->
  "57463061-0222-b24f-b2d1-3a5f78ad1db3"],
 ") used for surface water detection in Section 6.1. The Gao variant is \
sensitive to leaf and canopy water content, making it useful for identifying \
crop water stress before it becomes visible in NDVI."
}], "Text",ExpressionUUID->"6dcb4fd3-df67-b842-987e-958013570021"],

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{
    RowBox[{
     RowBox[{
      RowBox[{"Sentinel", "-", "2"}], ":", " ", "B8"}], " ", "=", " ", 
     "NIR"}], ",", " ", 
    RowBox[{"B11", " ", "=", " ", 
     RowBox[{
      RowBox[{"SWIR", " ", "--"}], " ", "Gao", " ", "NDWI", " ", "for", " ", 
      "vegetation", " ", "moisture"}]}]}], " ", "*)"}], "\n", 
  RowBox[{
   RowBox[{
    RowBox[{"ndwiImage", " ", "=", "\n", "  ", 
     RowBox[{
      RowBox[{
       RowBox[{
        RowBox[{
         RowBox[{
          RowBox[{
          "GEECollection", "[", "\"\<COPERNICUS/S2_SR_HARMONIZED\>\"", "]"}], 
          " ", "//", "\n", "    ", 
          RowBox[{"GEEFilterDate", "[", 
           RowBox[{"\"\<2024-08-01\>\"", ",", " ", "\"\<2024-09-01\>\""}], 
           "]"}]}], " ", "//", "\n", "    ", 
         RowBox[{"GEEFilterBounds", "[", "centralValley", "]"}]}], " ", "//", 
        "\n", "    ", 
        RowBox[{"GEEFilterProperty", "[", 
         RowBox[{"\"\<CLOUDY_PIXEL_PERCENTAGE\>\"", ",", 
          " ", "\"\<LessThan\>\"", ",", " ", "10"}], "]"}]}], " ", "//", "\n",
        "    ", "GEEMedian"}], " ", "//", "\n", "    ", 
      RowBox[{"GEENormalizedDifference", "[", 
       RowBox[{"{", 
        RowBox[{"\"\<B8\>\"", ",", " ", "\"\<B11\>\""}], "}"}], "]"}]}]}], 
    ";"}], "\n", "\n", 
   RowBox[{"(*", " ", 
    RowBox[{
     RowBox[{
     "Positive", " ", "NDWI", " ", "indicates", " ", "high", " ", "water", " ",
       "content"}], ";", " ", 
     RowBox[{"negative", " ", "indicates", " ", "stress"}]}], " ", "*)"}], "\n", 
   RowBox[{"GEEComputePixels", "[", 
    RowBox[{"centralValley", ",", "\n", "  ", 
     RowBox[{"ndwiImage", " ", "//", " ", 
      RowBox[{"GEEVisualize", "[", 
       RowBox[{"<|", "\n", "    ", 
        RowBox[{
         RowBox[{"\"\<min\>\"", " ", "->", " ", 
          RowBox[{"-", "0.4"}]}], ",", " ", 
         RowBox[{"\"\<max\>\"", " ", "->", " ", "0.4"}], ",", "\n", "    ", 
         RowBox[{"\"\<palette\>\"", " ", "->", " ", 
          RowBox[{"{", 
           
           RowBox[{"\"\<brown\>\"", ",", " ", "\"\<lightyellow\>\"", ",", 
            " ", "\"\<cyan\>\"", ",", " ", "\"\<blue\>\""}], "}"}]}]}], "\n", 
        "  ", "|>"}], "]"}]}], ",", "\n", "  ", 
     RowBox[{"\"\<ImageSize\>\"", " ", "->", " ", "800"}]}], 
    "]"}]}]}]], "Input",ExpressionUUID->"4b6284b8-68ad-fa49-ad59-\
d34832cae037"],

Cell["\<\
Water-stressed crops show strongly negative NDWI values. Pairing NDWI with \
NDVI helps distinguish water stress (low NDWI, moderate NDVI) from general \
senescence (both declining).\
\>", "Text",ExpressionUUID->"caf24bc2-5b66-e64e-bae6-2506eb0417f3"]
}, Open  ]],

Cell[CellGroupData[{

Cell["5.1.4 LAI -- Leaf Area Index from MODIS", "Section",ExpressionUUID->"7b5ffa70-5f87-1d46-b113-fe4f665a7e0e"],

Cell[TextData[{
 "LAI quantifies the total one-sided area of leaf tissue per unit ground area \
(m^2/m^2). MODIS provides a global 500 m LAI product every 8 days. This \
example uses ",
 Cell["MOD15A2H", "InlineCode",ExpressionUUID->
  "edbea458-bba3-b244-a155-93482de7e9cc"],
 " (Terra-only, 8-day composite); the combined Terra+Aqua product ",
 Cell["MCD15A3H", "InlineCode",ExpressionUUID->
  "39375e90-3fdf-a748-9170-d7ed4ec0758f"],
 " (4-day composite) is also available and offers higher temporal frequency."
}], "Text",ExpressionUUID->"b7315608-0fe5-4a4e-ad4d-24b833ee267f"],

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"forestRegion", " ", "=", " ", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{"-", "122.5"}], ",", " ", "37.5", ",", " ", 
      RowBox[{"-", "121.5"}], ",", " ", "38.5"}], "}"}]}], ";"}], "\n"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"laiImage", " ", "=", "\n", "  ", 
    RowBox[{
     RowBox[{
      RowBox[{
       RowBox[{
        RowBox[{
         RowBox[{"GEECollection", "[", "\"\<MODIS/061/MOD15A2H\>\"", "]"}], 
         " ", "//", "\n", "    ", 
         RowBox[{"GEEFilterDate", "[", 
          RowBox[{"\"\<2024-07-01\>\"", ",", " ", "\"\<2024-07-31\>\""}], 
          "]"}]}], " ", "//", "\n", "    ", 
        RowBox[{"GEEFilterBounds", "[", "forestRegion", "]"}]}], " ", "//", 
       "\n", "    ", "GEEMean"}], " ", "//", "\n", "    ", 
      RowBox[{"GEESelectBands", "[", 
       RowBox[{"{", "\"\<Lai_500m\>\"", "}"}], "]"}]}], " ", "//", "\n", 
     "    ", 
     RowBox[{"GEEMultiply", "[", "0.1", "]"}]}]}], ";"}], "  ", 
  RowBox[{"(*", " ", 
   RowBox[{
    RowBox[{"Scale", " ", 
     RowBox[{"factor", ":", " ", 
      RowBox[{"raw", " ", "values", " ", "*", " ", "0.1"}]}]}], " ", "=", " ", 
    RowBox[{"true", " ", "LAI"}]}], " ", "*)"}], "\n"}], "\n", 
 RowBox[{"GEEComputePixels", "[", 
  RowBox[{"forestRegion", ",", "\n", "  ", 
   RowBox[{"laiImage", " ", "//", " ", 
    RowBox[{"GEEVisualize", "[", 
     RowBox[{"<|", "\n", "    ", 
      RowBox[{
       RowBox[{"\"\<min\>\"", " ", "->", " ", "0"}], ",", " ", 
       RowBox[{"\"\<max\>\"", " ", "->", " ", "7"}], ",", "\n", "    ", 
       RowBox[{"\"\<palette\>\"", " ", "->", " ", 
        RowBox[{"{", 
         RowBox[{"\"\<#FFFFCC\>\"", ",", " ", "\"\<#41B6C4\>\"", ",", 
          " ", "\"\<#225EA8\>\"", ",", " ", "\"\<#081D58\>\""}], "}"}]}]}], 
      "\n", "  ", "|>"}], "]"}]}], ",", "\n", "  ", 
   RowBox[{"\"\<ImageSize\>\"", " ", "->", " ", "800"}]}], "]"}]}], "Input",Ex\
pressionUUID->"162ea41d-38a2-ba40-9a9a-9a22508e4878"],

Cell["\<\
The scale factor of 0.1 converts the integer-stored values to physical LAI \
units. Dense forests typically show LAI values of 4-7, while grasslands and \
croplands range from 1-4.\
\>", "Text",ExpressionUUID->"03d040b0-7f95-4c46-8bb4-9c3cfbd11e73"],

Cell["", "Text",
 CellFrame->{{0, 0}, {0, 
  1}},ExpressionUUID->"c3da4066-e47c-b743-8691-6cc4d732d7c9"]
}, Open  ]]
}, Open  ]],

Cell[CellGroupData[{

Cell["5.2 Crop Monitoring Workflows", "Chapter",ExpressionUUID->"acd83abb-0b33-ce4e-84ef-e1c2664024f7"],

Cell[CellGroupData[{

Cell["5.2.1 Seasonal Crop Phenology from NDVI", "Section",ExpressionUUID->"44f30803-8f9f-6348-9548-e350d7b94fbe"],

Cell["\<\
A full phenology curve captures the lifecycle of a crop from planting through \
harvest. The key phenological stages are:\
\>", "Text",ExpressionUUID->"632ce806-e771-6142-ab67-78e9041730d9"],

Cell[TextData[{
 StyleBox["Green-up",
  FontWeight->Bold],
 ": NDVI begins rising (planting/emergence)"
}], "Item",ExpressionUUID->"f8bce5df-d669-db4d-bef0-e9b403b64927"],

Cell[TextData[{
 StyleBox["Peak",
  FontWeight->Bold],
 ": Maximum NDVI (full canopy closure)"
}], "Item",ExpressionUUID->"f9d24eff-cf0c-b14b-993a-347915c179ee"],

Cell[TextData[{
 StyleBox["Senescence",
  FontWeight->Bold],
 ": NDVI declining (maturation, drying)"
}], "Item",ExpressionUUID->"62f422af-dcc6-b444-bf45-2e6b9fddea0e"],

Cell[TextData[{
 StyleBox["Harvest",
  FontWeight->Bold],
 ": Abrupt NDVI drop"
}], "Item",ExpressionUUID->"a4b456f1-434f-d244-8fdc-c7654c341bf3"],

Cell[TextData[StyleBox["Full phenology curve -- March through November.",
 FontWeight->Bold]], "Text",ExpressionUUID->"46e642d0-7c99-594a-98a3-\
d2594607cc71"],

Cell[BoxData[{
 RowBox[{
  RowBox[{"fieldBBox", " ", "=", " ", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"-", "120.65"}], ",", " ", "36.85", ",", " ", 
     RowBox[{"-", "120.55"}], ",", " ", "36.95"}], "}"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"fieldGeom", " ", "=", " ", 
    RowBox[{"GEEGeometry", "[", "fieldBBox", "]"}]}], ";"}], "\n"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"phenologyData", " ", "=", " ", 
    RowBox[{"Table", "[", "\n", "  ", 
     RowBox[{
      RowBox[{"Module", "[", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{
         "start", ",", " ", "end", ",", " ", "ndvi", ",", " ", "stats"}], 
         "}"}], ",", "\n", "    ", 
        RowBox[{
         RowBox[{"start", " ", "=", " ", 
          RowBox[{"DateString", "[", 
           RowBox[{
            RowBox[{"DateObject", "[", 
             RowBox[{"{", 
              RowBox[{"2024", ",", " ", "m", ",", " ", "1"}], "}"}], "]"}], ",",
             "\n", "      ", 
            RowBox[{"{", 
             
             RowBox[{"\"\<Year\>\"", ",", " ", "\"\<-\>\"", ",", 
              " ", "\"\<Month\>\"", ",", " ", "\"\<-\>\"", ",", 
              " ", "\"\<Day\>\""}], "}"}]}], "]"}]}], ";", "\n", "    ", 
         RowBox[{"end", " ", "=", " ", 
          RowBox[{"DateString", "[", 
           RowBox[{
            RowBox[{"DatePlus", "[", 
             RowBox[{
              RowBox[{"DateObject", "[", 
               RowBox[{"{", 
                RowBox[{"2024", ",", " ", "m", ",", " ", "1"}], "}"}], "]"}], 
              ",", " ", 
              RowBox[{"{", 
               RowBox[{"1", ",", " ", "\"\<Month\>\""}], "}"}]}], "]"}], ",", 
            "\n", "      ", 
            RowBox[{"{", 
             
             RowBox[{"\"\<Year\>\"", ",", " ", "\"\<-\>\"", ",", 
              " ", "\"\<Month\>\"", ",", " ", "\"\<-\>\"", ",", 
              " ", "\"\<Day\>\""}], "}"}]}], "]"}]}], ";", "\n", "\n", "    ", 
         RowBox[{"ndvi", " ", "=", "\n", "      ", 
          RowBox[{
           RowBox[{
            RowBox[{
             RowBox[{
              RowBox[{
               RowBox[{
               "GEECollection", "[", "\"\<COPERNICUS/S2_SR_HARMONIZED\>\"", 
                "]"}], " ", "//", "\n", "        ", 
               RowBox[{"GEEFilterDate", "[", 
                RowBox[{"start", ",", " ", "end"}], "]"}]}], " ", "//", "\n", 
              "        ", 
              RowBox[{"GEEFilterBounds", "[", "fieldBBox", "]"}]}], " ", "//",
              "\n", "        ", 
             RowBox[{"GEEFilterProperty", "[", 
              
              RowBox[{"\"\<CLOUDY_PIXEL_PERCENTAGE\>\"", ",", 
               " ", "\"\<LessThan\>\"", ",", " ", "25"}], "]"}]}], " ", "//", 
            "\n", "        ", "GEEMedian"}], " ", "//", "\n", "        ", 
           RowBox[{"GEENormalizedDifference", "[", 
            RowBox[{"{", 
             RowBox[{"\"\<B8\>\"", ",", " ", "\"\<B4\>\""}], "}"}], "]"}]}]}],
          ";", "\n", "\n", "    ", 
         RowBox[{"stats", " ", "=", " ", 
          RowBox[{"GEECompute", "[", 
           RowBox[{"ndvi", " ", "//", " ", 
            RowBox[{"GEEReduceRegion", "[", 
             RowBox[{"fieldGeom", ",", " ", "\"\<mean\>\"", ",", " ", "10"}], 
             "]"}]}], "]"}]}], ";", "\n", "    ", 
         RowBox[{"stats", "[", "\"\<nd\>\"", "]"}]}]}], "\n", "  ", "]"}], ",",
       "\n", "  ", 
      RowBox[{"{", 
       RowBox[{"m", ",", " ", "3", ",", " ", "11"}], "}"}]}], "\n", "]"}]}], 
   ";"}], "\n"}], "\n", 
 RowBox[{
  RowBox[{"dates", " ", "=", " ", 
   RowBox[{"Table", "[", 
    RowBox[{
     RowBox[{"DateObject", "[", 
      RowBox[{"{", 
       RowBox[{"2024", ",", " ", "m", ",", " ", "15"}], "}"}], "]"}], ",", 
     " ", 
     RowBox[{"{", 
      RowBox[{"m", ",", " ", "3", ",", " ", "11"}], "}"}]}], "]"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{"phenologyTS", " ", "=", " ", 
   RowBox[{"TimeSeries", "[", 
    RowBox[{"phenologyData", ",", " ", 
     RowBox[{"{", "dates", "}"}]}], "]"}]}], ";"}]}], "Input",ExpressionUUID->\
"3ba4b996-eafc-6040-abcc-8a73158af6e8"],

Cell[TextData[StyleBox["Fourier analysis to identify growing-season \
periodicity.",
 FontWeight->Bold]], "Text",ExpressionUUID->"9a3d5283-5ba7-724e-aea7-\
95e240ba6e39"],

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{
   "Pad", " ", "the", " ", "series", " ", "and", " ", "compute", " ", "the", " ",
     "power", " ", "spectrum"}], " ", "*)"}], "\n", 
  RowBox[{
   RowBox[{
    RowBox[{"paddedValues", " ", "=", " ", 
     RowBox[{"PadRight", "[", 
      RowBox[{"phenologyData", ",", " ", "16", ",", " ", 
       RowBox[{"Mean", "[", "phenologyData", "]"}]}], "]"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"spectrum", " ", "=", " ", 
     RowBox[{
      RowBox[{"Abs", "[", 
       RowBox[{"Fourier", "[", "paddedValues", "]"}], "]"}], "^", "2"}]}], 
    ";"}], "\n", "\n", 
   RowBox[{"ListLinePlot", "[", 
    RowBox[{
     RowBox[{"spectrum", "[", 
      RowBox[{"[", 
       RowBox[{"2", " ", ";;", " ", "8"}], "]"}], "]"}], ",", "\n", "  ", 
     RowBox[{"PlotLabel", " ", "->", " ", "\"\<NDVI Power Spectrum\>\""}], ",",
      "\n", "  ", 
     RowBox[{"FrameLabel", " ", "->", " ", 
      RowBox[{"{", 
       RowBox[{"\"\<Frequency Component\>\"", ",", " ", "\"\<Power\>\""}], 
       "}"}]}], ",", "\n", "  ", 
     RowBox[{"PlotTheme", " ", "->", " ", "\"\<Scientific\>\""}]}], 
    "]"}]}]}]], "Input",ExpressionUUID->"06a8225d-238b-1149-b771-\
c70d5b500534"],

Cell["\<\
A dominant peak at frequency component 2 corresponds to a single growing \
season (one cycle per year). Two peaks would indicate a double-crop system.\
\>", "Text",ExpressionUUID->"e92ba273-acec-ec47-8241-454fc52189d8"],

Cell["", "Text",
 CellFrame->{{0, 0}, {0, 
  1}},ExpressionUUID->"7c3a6aa7-3cfa-064f-baa6-5b338971c456"],

Cell["\<\
With the spectral structure identified, we can now extract specific \
phenological dates from the NDVI curve.\
\>", "Text",ExpressionUUID->"fa4ee667-ae68-1d49-8294-35ba558167b6"],

Cell[TextData[StyleBox["Detecting green-up, peak, and senescence dates.",
 FontWeight->Bold]], "Text",ExpressionUUID->"10e0a160-f2b3-7c47-b3b0-\
8b261f291b9f"],

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{
   "Interpolate", " ", "to", " ", "get", " ", "a", " ", "smooth", " ", 
    "daily", " ", "curve"}], " ", "*)"}], "\n", 
  RowBox[{
   RowBox[{
    RowBox[{"dailyCurve", " ", "=", " ", 
     RowBox[{"Interpolation", "[", "\n", "  ", 
      RowBox[{
       RowBox[{"Transpose", "[", 
        RowBox[{"{", 
         RowBox[{
          RowBox[{"Range", "[", 
           RowBox[{"Length", "[", "phenologyData", "]"}], "]"}], ",", " ", 
          "phenologyData"}], "}"}], "]"}], ",", "\n", "  ", 
       RowBox[{"InterpolationOrder", " ", "->", " ", "3"}]}], "]"}]}], ";"}], 
   "\n", "\n", 
   RowBox[{"(*", " ", 
    RowBox[{"Green", "-", 
     RowBox[{"up", ":", " ", 
      RowBox[{
      "where", " ", "derivative", " ", "first", " ", "exceeds", " ", "a", " ",
        "threshold"}]}]}], " ", "*)"}], "\n", 
   RowBox[{
    RowBox[{"greenUpMonth", " ", "=", " ", 
     RowBox[{"First", " ", "@", " ", 
      RowBox[{"Select", "[", "\n", "  ", 
       RowBox[{
        RowBox[{"Range", "[", 
         RowBox[{"1", ",", " ", 
          RowBox[{
           RowBox[{"Length", "[", "phenologyData", "]"}], " ", "-", " ", 
           "1"}]}], "]"}], ",", "\n", "  ", 
        RowBox[{
         RowBox[{"(", 
          RowBox[{
           RowBox[{
            RowBox[{"dailyCurve", "'"}], "[", "#", "]"}], " ", ">", " ", 
           "0.05"}], ")"}], " ", "&"}]}], "\n", "]"}]}]}], ";"}], "\n", "\n", 
   RowBox[{"(*", " ", 
    RowBox[{"Peak", ":", " ", 
     RowBox[{"maximum", " ", "value"}]}], " ", "*)"}], "\n", 
   RowBox[{
    RowBox[{"peakMonth", " ", "=", " ", 
     RowBox[{"First", " ", "@", " ", 
      RowBox[{"Ordering", "[", 
       RowBox[{"phenologyData", ",", " ", 
        RowBox[{"-", "1"}]}], "]"}]}]}], ";"}], "\n", "\n", 
   RowBox[{"(*", " ", 
    RowBox[{"Senescence", ":", " ", 
     RowBox[{
     "where", " ", "derivative", " ", "becomes", " ", "strongly", " ", 
      "negative", " ", "after", " ", "peak"}]}], " ", "*)"}], "\n", 
   RowBox[{
    RowBox[{"senescenceMonth", " ", "=", " ", 
     RowBox[{"First", " ", "@", " ", 
      RowBox[{"Select", "[", "\n", "  ", 
       RowBox[{
        RowBox[{"Range", "[", 
         RowBox[{
          RowBox[{"peakMonth", " ", "+", " ", "1"}], ",", " ", 
          RowBox[{"Length", "[", "phenologyData", "]"}]}], "]"}], ",", "\n", 
        "  ", 
        RowBox[{
         RowBox[{"(", 
          RowBox[{
           RowBox[{
            RowBox[{"dailyCurve", "'"}], "[", "#", "]"}], " ", "<", " ", 
           RowBox[{"-", "0.05"}]}], ")"}], " ", "&"}]}], "\n", "]"}]}]}], 
    ";"}], "\n", "\n", 
   RowBox[{"(*", " ", 
    RowBox[{"Map", " ", "back", " ", "to", " ", "calendar", " ", "months", " ", 
     RowBox[{"(", 
      RowBox[{
      "offset", " ", "by", " ", "2", " ", "since", " ", "we", " ", "start", " ",
        "at", " ", "March"}], ")"}]}], " ", "*)"}], "\n", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"greenUpMonth", " ", "+", " ", "2"}], ",", " ", 
     RowBox[{"peakMonth", " ", "+", " ", "2"}], ",", " ", 
     RowBox[{"senescenceMonth", " ", "+", " ", "2"}]}], "}"}]}]}]], "Input",Ex\
pressionUUID->"c38bbf1a-2bc0-3d42-98f1-9be0d45b7e60"],

Cell["", "Text",
 CellFrame->{{0, 0}, {0, 
  1}},ExpressionUUID->"dd1e4aae-5792-a840-bffe-d711742477dd"],

Cell[TextData[StyleBox["Compare NDVI profiles for different crop types.",
 FontWeight->Bold]], "Text",ExpressionUUID->"4c361da9-4e74-e846-bced-\
f8b402db34a9"],

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{
   "Define", " ", "fields", " ", "of", " ", "known", " ", "crop", " ", 
    "type"}], " ", "*)"}], "\n", 
  RowBox[{
   RowBox[{
    RowBox[{"cornField", " ", "=", " ", 
     RowBox[{"GEEGeometry", "[", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"-", "120.4"}], ",", " ", "36.9", ",", " ", 
        RowBox[{"-", "120.3"}], ",", " ", "37.0"}], "}"}], "]"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"alfalfaField", " ", "=", " ", 
     RowBox[{"GEEGeometry", "[", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"-", "120.7"}], ",", " ", "36.7", ",", " ", 
        RowBox[{"-", "120.6"}], ",", " ", "36.8"}], "}"}], "]"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"orchardField", " ", "=", " ", 
     RowBox[{"GEEGeometry", "[", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"-", "121.0"}], ",", " ", "37.1", ",", " ", 
        RowBox[{"-", "120.9"}], ",", " ", "37.2"}], "}"}], "]"}]}], ";"}], 
   "\n", "\n", 
   RowBox[{
    RowBox[{
     RowBox[{"extractProfile", "[", 
      RowBox[{"geom_", ",", " ", "bbox_"}], "]"}], " ", ":=", " ", 
     RowBox[{"Table", "[", "\n", "  ", 
      RowBox[{
       RowBox[{"Module", "[", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{
          "start", ",", " ", "end", ",", " ", "ndvi", ",", " ", "stats"}], 
          "}"}], ",", "\n", "    ", 
         RowBox[{
          RowBox[{"start", " ", "=", " ", 
           RowBox[{"DateString", "[", 
            RowBox[{
             RowBox[{"DateObject", "[", 
              RowBox[{"{", 
               RowBox[{"2024", ",", " ", "m", ",", " ", "1"}], "}"}], "]"}], ",",
              "\n", "      ", 
             RowBox[{"{", 
              
              RowBox[{"\"\<Year\>\"", ",", " ", "\"\<-\>\"", ",", 
               " ", "\"\<Month\>\"", ",", " ", "\"\<-\>\"", ",", 
               " ", "\"\<Day\>\""}], "}"}]}], "]"}]}], ";", "\n", "    ", 
          RowBox[{"end", " ", "=", " ", 
           RowBox[{"DateString", "[", 
            RowBox[{
             RowBox[{"DatePlus", "[", 
              RowBox[{
               RowBox[{"DateObject", "[", 
                RowBox[{"{", 
                 RowBox[{"2024", ",", " ", "m", ",", " ", "1"}], "}"}], "]"}],
                ",", " ", 
               RowBox[{"{", 
                RowBox[{"1", ",", " ", "\"\<Month\>\""}], "}"}]}], "]"}], ",",
              "\n", "      ", 
             RowBox[{"{", 
              
              RowBox[{"\"\<Year\>\"", ",", " ", "\"\<-\>\"", ",", 
               " ", "\"\<Month\>\"", ",", " ", "\"\<-\>\"", ",", 
               " ", "\"\<Day\>\""}], "}"}]}], "]"}]}], ";", "\n", "    ", 
          RowBox[{"ndvi", " ", "=", "\n", "      ", 
           RowBox[{
            RowBox[{
             RowBox[{
              RowBox[{
               RowBox[{
                RowBox[{
                "GEECollection", "[", "\"\<COPERNICUS/S2_SR_HARMONIZED\>\"", 
                 "]"}], " ", "//", "\n", "        ", 
                RowBox[{"GEEFilterDate", "[", 
                 RowBox[{"start", ",", " ", "end"}], "]"}]}], " ", "//", "\n",
                "        ", 
               RowBox[{"GEEFilterBounds", "[", "bbox", "]"}]}], " ", "//", 
              "\n", "        ", 
              RowBox[{"GEEFilterProperty", "[", 
               
               RowBox[{"\"\<CLOUDY_PIXEL_PERCENTAGE\>\"", ",", 
                " ", "\"\<LessThan\>\"", ",", " ", "25"}], "]"}]}], " ", "//",
              "\n", "        ", "GEEMedian"}], " ", "//", "\n", "        ", 
            RowBox[{"GEENormalizedDifference", "[", 
             RowBox[{"{", 
              RowBox[{"\"\<B8\>\"", ",", " ", "\"\<B4\>\""}], "}"}], 
             "]"}]}]}], ";", "\n", "    ", 
          RowBox[{"stats", " ", "=", " ", 
           RowBox[{"GEECompute", "[", 
            RowBox[{"ndvi", " ", "//", " ", 
             RowBox[{"GEEReduceRegion", "[", 
              RowBox[{"geom", ",", " ", "\"\<mean\>\"", ",", " ", "10"}], 
              "]"}]}], "]"}]}], ";", "\n", "    ", 
          RowBox[{"stats", "[", "\"\<nd\>\"", "]"}]}]}], "\n", "  ", "]"}], ",",
        "\n", "  ", 
       RowBox[{"{", 
        RowBox[{"m", ",", " ", "3", ",", " ", "11"}], "}"}]}], "\n", "]"}]}], 
    ";"}], "\n", "\n", 
   RowBox[{
    RowBox[{"cornProfile", " ", "=", " ", 
     RowBox[{"extractProfile", "[", 
      RowBox[{"cornField", ",", " ", 
       RowBox[{"{", 
        RowBox[{
         RowBox[{"-", "120.4"}], ",", " ", "36.9", ",", " ", 
         RowBox[{"-", "120.3"}], ",", " ", "37.0"}], "}"}]}], "]"}]}], ";"}], 
   "\n", 
   RowBox[{
    RowBox[{"alfalfaProfile", " ", "=", " ", 
     RowBox[{"extractProfile", "[", 
      RowBox[{"alfalfaField", ",", " ", 
       RowBox[{"{", 
        RowBox[{
         RowBox[{"-", "120.7"}], ",", " ", "36.7", ",", " ", 
         RowBox[{"-", "120.6"}], ",", " ", "36.8"}], "}"}]}], "]"}]}], ";"}], 
   "\n", 
   RowBox[{
    RowBox[{"orchardProfile", " ", "=", " ", 
     RowBox[{"extractProfile", "[", 
      RowBox[{"orchardField", ",", " ", 
       RowBox[{"{", 
        RowBox[{
         RowBox[{"-", "121.0"}], ",", " ", "37.1", ",", " ", 
         RowBox[{"-", "120.9"}], ",", " ", "37.2"}], "}"}]}], "]"}]}], ";"}], 
   "\n", "\n", 
   RowBox[{
    RowBox[{"months", " ", "=", " ", 
     RowBox[{"Table", "[", 
      RowBox[{
       RowBox[{"DateObject", "[", 
        RowBox[{"{", 
         RowBox[{"2024", ",", " ", "m", ",", " ", "15"}], "}"}], "]"}], ",", 
       " ", 
       RowBox[{"{", 
        RowBox[{"m", ",", " ", "3", ",", " ", "11"}], "}"}]}], "]"}]}], ";"}],
    "\n", "\n", 
   RowBox[{"DateListPlot", "[", 
    RowBox[{
     RowBox[{"{", "\n", "    ", 
      RowBox[{
       RowBox[{"TimeSeries", "[", 
        RowBox[{"cornProfile", ",", " ", 
         RowBox[{"{", "months", "}"}]}], "]"}], ",", "\n", "    ", 
       RowBox[{"TimeSeries", "[", 
        RowBox[{"alfalfaProfile", ",", " ", 
         RowBox[{"{", "months", "}"}]}], "]"}], ",", "\n", "    ", 
       RowBox[{"TimeSeries", "[", 
        RowBox[{"orchardProfile", ",", " ", 
         RowBox[{"{", "months", "}"}]}], "]"}]}], "\n", "  ", "}"}], ",", 
     "\n", "  ", 
     RowBox[{"PlotLegends", " ", "->", " ", 
      RowBox[{"{", 
       RowBox[{"\"\<Corn\>\"", ",", " ", "\"\<Alfalfa\>\"", ",", 
        " ", "\"\<Orchard\>\""}], "}"}]}], ",", "\n", "  ", 
     RowBox[{
     "PlotLabel", " ", "->", " ", "\"\<NDVI Profiles by Crop Type\>\""}], ",",
      "\n", "  ", 
     RowBox[{"FrameLabel", " ", "->", " ", 
      RowBox[{"{", 
       RowBox[{"\"\<Date\>\"", ",", " ", "\"\<NDVI\>\""}], "}"}]}], ",", "\n",
      "  ", 
     RowBox[{"PlotRange", " ", "->", " ", 
      RowBox[{"{", 
       RowBox[{"0", ",", " ", "1"}], "}"}]}], ",", "\n", "  ", 
     RowBox[{"PlotTheme", " ", "->", " ", "\"\<Scientific\>\""}]}], 
    "]"}]}]}]], "Input",ExpressionUUID->"971163cb-f4e9-1845-9ac0-\
09a9c032ef63"],

Cell["\<\
Corn shows a single sharp peak in July-August. Alfalfa, cut multiple times \
per season, displays a sawtooth pattern. Orchards maintain relatively stable \
NDVI from spring through fall.\
\>", "Text",ExpressionUUID->"385fffff-f281-e74c-8efa-945f61e25c31"]
}, Open  ]],

Cell[CellGroupData[{

Cell["5.2.2 MODIS 16-Day NDVI", "Section",ExpressionUUID->"2d992d4b-14a6-3f4e-a80a-b9960099e939"],

Cell["\<\
MODIS provides pre-computed NDVI at 16-day intervals with consistent \
atmospheric correction, making it ideal for long time-series analysis.\
\>", "Text",ExpressionUUID->"f1296ae6-bc19-7243-a95e-ee44d8b58022"],

Cell[BoxData[
 RowBox[{
  RowBox[{"modisNDVI", " ", "=", " ", 
   RowBox[{"Table", "[", "\n", "  ", 
    RowBox[{
     RowBox[{"Module", "[", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{"start", ",", " ", "end", ",", " ", "stats"}], "}"}], ",", 
       "\n", "    ", 
       RowBox[{
        RowBox[{"start", " ", "=", " ", 
         RowBox[{"DateString", "[", 
          RowBox[{
           RowBox[{
            RowBox[{"DateObject", "[", 
             RowBox[{"{", 
              RowBox[{"2024", ",", " ", "1", ",", " ", "1"}], "}"}], "]"}], 
            " ", "~", "DatePlus", "~", " ", 
            RowBox[{"{", 
             RowBox[{
              RowBox[{
               RowBox[{"(", 
                RowBox[{"i", " ", "-", " ", "1"}], ")"}], " ", "*", " ", 
               "16"}], ",", " ", "\"\<Day\>\""}], "}"}]}], ",", "\n", 
           "      ", 
           RowBox[{"{", 
            
            RowBox[{"\"\<Year\>\"", ",", " ", "\"\<-\>\"", ",", 
             " ", "\"\<Month\>\"", ",", " ", "\"\<-\>\"", ",", 
             " ", "\"\<Day\>\""}], "}"}]}], "]"}]}], ";", "\n", "    ", 
        RowBox[{"end", " ", "=", " ", 
         RowBox[{"DateString", "[", 
          RowBox[{
           RowBox[{
            RowBox[{"DateObject", "[", 
             RowBox[{"{", 
              RowBox[{"2024", ",", " ", "1", ",", " ", "1"}], "}"}], "]"}], 
            " ", "~", "DatePlus", "~", " ", 
            RowBox[{"{", 
             RowBox[{
              RowBox[{"i", " ", "*", " ", "16"}], ",", " ", "\"\<Day\>\""}], 
             "}"}]}], ",", "\n", "      ", 
           RowBox[{"{", 
            
            RowBox[{"\"\<Year\>\"", ",", " ", "\"\<-\>\"", ",", 
             " ", "\"\<Month\>\"", ",", " ", "\"\<-\>\"", ",", 
             " ", "\"\<Day\>\""}], "}"}]}], "]"}]}], ";", "\n", "\n", "    ", 
        RowBox[{"stats", " ", "=", " ", 
         RowBox[{"GEECompute", "[", "\n", "      ", 
          RowBox[{
           RowBox[{
            RowBox[{
             RowBox[{
              RowBox[{
               RowBox[{
                RowBox[{
                "GEECollection", "[", "\"\<MODIS/061/MOD13A2\>\"", "]"}], " ",
                 "//", "\n", "        ", 
                RowBox[{"GEEFilterDate", "[", 
                 RowBox[{"start", ",", " ", "end"}], "]"}]}], " ", "//", "\n",
                "        ", 
               RowBox[{"GEEFilterBounds", "[", "fieldBBox", "]"}]}], " ", "//",
               "\n", "        ", "GEEMean"}], " ", "//", "\n", "        ", 
             RowBox[{"GEESelectBands", "[", 
              RowBox[{"{", "\"\<NDVI\>\"", "}"}], "]"}]}], " ", "//", "\n", 
            "        ", 
            RowBox[{"GEEMultiply", "[", "0.0001", "]"}]}], " ", "//", "  ", 
           RowBox[{"(*", " ", 
            RowBox[{"MODIS", " ", "scale", " ", "factor"}], " ", "*)"}], "\n",
            "        ", 
           RowBox[{"GEEReduceRegion", "[", 
            RowBox[{"fieldGeom", ",", " ", "\"\<mean\>\"", ",", " ", "1000"}],
             "]"}]}], "\n", "    ", "]"}]}], ";", "\n", "    ", 
        RowBox[{"{", 
         RowBox[{
          RowBox[{
           RowBox[{"DateObject", "[", 
            RowBox[{"{", 
             RowBox[{"2024", ",", " ", "1", ",", " ", "1"}], "}"}], "]"}], 
           " ", "~", "DatePlus", "~", " ", 
           RowBox[{"{", 
            RowBox[{
             RowBox[{
              RowBox[{
               RowBox[{"(", 
                RowBox[{"i", " ", "-", " ", "1"}], ")"}], " ", "*", " ", 
               "16"}], " ", "+", " ", "8"}], ",", " ", "\"\<Day\>\""}], 
            "}"}]}], ",", "\n", "     ", 
          RowBox[{"stats", "[", "\"\<NDVI\>\"", "]"}]}], "}"}]}]}], "\n", 
      "  ", "]"}], ",", "\n", "  ", 
     RowBox[{"{", 
      RowBox[{"i", ",", " ", "1", ",", " ", "23"}], "}"}]}], "\n", "]"}]}], 
  ";"}]], "Input",ExpressionUUID->"816af23e-fe0d-ef42-96d0-24b3767d8e4b"],

Cell[TextData[{
 StyleBox["Smoothing with ",
  FontWeight->Bold],
 Cell["MovingAverage", "InlineCode",ExpressionUUID->
  "76988964-328c-6a44-84fe-71236f41b918"],
 StyleBox[" for cleaner phenology curves.",
  FontWeight->Bold]
}], "Text",ExpressionUUID->"c5e35358-4fb8-564a-80ef-1845aef7bab0"],

Cell[BoxData[{
 RowBox[{
  RowBox[{"rawValues", " ", "=", " ", 
   RowBox[{"modisNDVI", "[", 
    RowBox[{"[", 
     RowBox[{"All", ",", " ", "2"}], "]"}], "]"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{"smoothedValues", " ", "=", " ", 
   RowBox[{"MovingAverage", "[", 
    RowBox[{"rawValues", ",", " ", "3"}], "]"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"smoothedDates", " ", "=", " ", 
    RowBox[{"modisNDVI", "[", 
     RowBox[{"[", 
      RowBox[{
       RowBox[{"2", " ", ";;", " ", 
        RowBox[{"-", "2"}]}], ",", " ", "1"}], "]"}], "]"}]}], ";"}], 
  "\n"}], "\n", 
 RowBox[{"ListLinePlot", "[", 
  RowBox[{
   RowBox[{"{", "\n", "    ", 
    RowBox[{
     RowBox[{"Transpose", "[", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"modisNDVI", "[", 
         RowBox[{"[", 
          RowBox[{"All", ",", " ", "1"}], "]"}], "]"}], ",", " ", 
        "rawValues"}], "}"}], "]"}], ",", "\n", "    ", 
     RowBox[{"Transpose", "[", 
      RowBox[{"{", 
       RowBox[{"smoothedDates", ",", " ", "smoothedValues"}], "}"}], "]"}]}], 
    "\n", "  ", "}"}], ",", "\n", "  ", 
   RowBox[{"PlotLegends", " ", "->", " ", 
    RowBox[{"{", 
     RowBox[{"\"\<Raw MODIS\>\"", ",", 
      " ", "\"\<3-point Moving Average\>\""}], "}"}]}], ",", "\n", "  ", 
   RowBox[{
   "PlotLabel", " ", "->", " ", "\"\<MODIS 16-Day NDVI with Smoothing\>\""}], 
   ",", "\n", "  ", 
   RowBox[{"FrameLabel", " ", "->", " ", 
    RowBox[{"{", 
     RowBox[{"\"\<Date\>\"", ",", " ", "\"\<NDVI\>\""}], "}"}]}], ",", "\n", 
   "  ", 
   RowBox[{"PlotTheme", " ", "->", " ", "\"\<Scientific\>\""}]}], 
  "]"}]}], "Input",ExpressionUUID->"4f220023-26d8-064a-8e3d-9a2d314c7634"],

Cell["\<\
The moving average removes noise from cloud contamination and sensor \
artifacts while preserving the overall phenological shape.\
\>", "Text",ExpressionUUID->"3dd64496-663c-a64e-82a2-3fb40b3b1532"],

Cell["", "Text",
 CellFrame->{{0, 0}, {0, 
  1}},ExpressionUUID->"89850569-5f12-d34f-8769-439e756c2dbc"]
}, Open  ]]
}, Open  ]],

Cell[CellGroupData[{

Cell["5.3 Crop Classification", "Chapter",ExpressionUUID->"52756850-36e9-5843-abdc-108f40baeeff"],

Cell[CellGroupData[{

Cell["5.3.1 USDA Cropland Data Layer (CDL)", "Section",ExpressionUUID->"aecdf8c9-c046-8e44-b3a6-69c2d6f09589"],

Cell["\<\
The Cropland Data Layer is a 30 m annual crop-type map covering the \
contiguous United States, produced by USDA NASS. Each pixel is classified \
into one of over 100 crop categories.\
\>", "Text",ExpressionUUID->"57dd167d-b15b-724e-8168-f6ccd384ab50"],

Cell[TextData[StyleBox["Display the CDL map.",
 FontWeight->Bold]], "Text",ExpressionUUID->"852eb81c-2805-d040-aa5f-59f07d3978c7"],

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"iowaRegion", " ", "=", " ", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{"-", "94.0"}], ",", " ", "41.5", ",", " ", 
      RowBox[{"-", "92.0"}], ",", " ", "42.5"}], "}"}]}], ";"}], "\n"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"cdlImage", " ", "=", "\n", "  ", 
    RowBox[{
     RowBox[{
      RowBox[{
       RowBox[{"GEECollection", "[", "\"\<USDA/NASS/CDL\>\"", "]"}], " ", "//",
        "\n", "    ", 
       RowBox[{"GEEFilterDate", "[", 
        RowBox[{"\"\<2023-01-01\>\"", ",", " ", "\"\<2024-01-01\>\""}], 
        "]"}]}], " ", "//", "\n", "    ", "GEEFirst"}], " ", "//", "\n", 
     "    ", 
     RowBox[{"GEESelectBands", "[", 
      RowBox[{"{", "\"\<cropland\>\"", "}"}], "]"}]}]}], ";"}], "\n"}], "\n", 
 RowBox[{"GEEComputePixels", "[", 
  RowBox[{"iowaRegion", ",", "\n", "  ", 
   RowBox[{"cdlImage", " ", "//", "\n", "    ", 
    RowBox[{"GEEVisualize", "[", 
     RowBox[{"<|", "\n", "      ", 
      RowBox[{
       RowBox[{"\"\<min\>\"", " ", "->", " ", "0"}], ",", " ", 
       RowBox[{"\"\<max\>\"", " ", "->", " ", "255"}], ",", "\n", "      ", 
       RowBox[{"\"\<palette\>\"", " ", "->", " ", 
        RowBox[{"{", 
         RowBox[{"\"\<#FFD700\>\"", ",", " ", "\"\<#00FF00\>\"", ",", 
          " ", "\"\<#FF6347\>\"", ",", " ", "\"\<#8B4513\>\"", ",", "\n", 
          "                    ", "\"\<#1E90FF\>\"", ",", 
          " ", "\"\<#32CD32\>\"", ",", " ", "\"\<#FF69B4\>\"", ",", 
          " ", "\"\<#A0522D\>\""}], "}"}]}]}], "\n", "    ", "|>"}], "]"}]}], 
   ",", "\n", "  ", 
   RowBox[{"\"\<ImageSize\>\"", " ", "->", " ", "1024"}]}], "]"}]}], "Input",E\
xpressionUUID->"9ca53e36-2d61-1f48-90cb-e0cdcf2c6f29"],

Cell[TextData[StyleBox["Compute area by crop type.",
 FontWeight->Bold]], "Text",ExpressionUUID->"71bd89d3-0494-c944-8099-\
0b2eaafbeabe"],

Cell["\<\
CDL class values include 1 = Corn, 5 = Soybeans, 24 = Winter Wheat, among \
others. You can compute the area of each crop type using pixel-level masking \
and area reduction.\
\>", "Text",ExpressionUUID->"f31873fd-9651-334f-9d38-d41cbb4b36b2"],

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"computeCropArea", "[", 
     RowBox[{
     "cdl_", ",", " ", "classValue_", ",", " ", "geom_", ",", " ", "bbox_"}], 
     "]"}], " ", ":=", "\n", "  ", 
    RowBox[{"Module", "[", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{"mask", ",", " ", "area", ",", " ", "stats"}], "}"}], ",", 
      "\n", "    ", 
      RowBox[{
       RowBox[{"mask", " ", "=", " ", 
        RowBox[{"cdl", " ", "//", " ", 
         RowBox[{"GEEEquals", "[", "classValue", "]"}]}]}], ";", "\n", "    ", 
       RowBox[{"area", " ", "=", " ", 
        RowBox[{
         RowBox[{"GEEPixelArea", "[", "]"}], " ", "//", " ", 
         RowBox[{"GEEUpdateMask", "[", "mask", "]"}]}]}], ";", "\n", "    ", 
       RowBox[{"stats", " ", "=", " ", 
        RowBox[{"GEECompute", "[", "\n", "      ", 
         RowBox[{"area", " ", "//", " ", 
          RowBox[{"GEEReduceRegion", "[", 
           RowBox[{"geom", ",", " ", "\"\<sum\>\"", ",", " ", "30"}], "]"}]}],
          "\n", "    ", "]"}]}], ";", "\n", "    ", 
       RowBox[{
        RowBox[{"stats", "[", "\"\<area\>\"", "]"}], " ", "/", " ", 
        "1.0*^6"}]}]}], "  ", 
     RowBox[{"(*", " ", 
      RowBox[{"Convert", " ", 
       RowBox[{"m", "^", "2"}], " ", "to", " ", 
       RowBox[{"km", "^", "2"}]}], " ", "*)"}], "\n", "  ", "]"}]}], ";"}], 
  "\n"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"iowaGeom", " ", "=", " ", 
    RowBox[{"GEEGeometry", "[", "iowaRegion", "]"}]}], ";"}], "\n"}], "\n", 
 RowBox[{
  RowBox[{"cornArea", " ", "=", " ", 
   RowBox[{"computeCropArea", "[", 
    RowBox[{
    "cdlImage", ",", " ", "1", ",", " ", "iowaGeom", ",", " ", "iowaRegion"}],
     "]"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{"soyArea", " ", "=", " ", 
   RowBox[{"computeCropArea", "[", 
    RowBox[{
    "cdlImage", ",", " ", "5", ",", " ", "iowaGeom", ",", " ", "iowaRegion"}],
     "]"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"wheatArea", " ", "=", " ", 
    RowBox[{"computeCropArea", "[", 
     RowBox[{
     "cdlImage", ",", " ", "24", ",", " ", "iowaGeom", ",", " ", 
      "iowaRegion"}], "]"}]}], ";"}], "\n"}], "\n", 
 RowBox[{"BarChart", "[", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{"cornArea", ",", " ", "soyArea", ",", " ", "wheatArea"}], "}"}], ",",
    "\n", "  ", 
   RowBox[{"ChartLabels", " ", "->", " ", 
    RowBox[{"{", 
     RowBox[{"\"\<Corn\>\"", ",", " ", "\"\<Soybeans\>\"", ",", 
      " ", "\"\<Winter Wheat\>\""}], "}"}]}], ",", "\n", "  ", 
   RowBox[{"FrameLabel", " ", "->", " ", 
    RowBox[{"{", 
     RowBox[{"None", ",", " ", "\"\<Area (km\\[Superscript]2)\>\""}], "}"}]}],
    ",", "\n", "  ", 
   RowBox[{
   "PlotLabel", " ", "->", " ", "\"\<Crop Area -- Central Iowa, 2023\>\""}], ",",
    "\n", "  ", 
   RowBox[{"ChartStyle", " ", "->", " ", 
    RowBox[{"{", 
     RowBox[{"Yellow", ",", " ", "Green", ",", " ", 
      RowBox[{"Lighter", "[", "Brown", "]"}]}], "}"}]}], ",", "\n", "  ", 
   RowBox[{"PlotTheme", " ", "->", " ", "\"\<Business\>\""}]}], 
  "]"}]}], "Input",ExpressionUUID->"acfe7ca4-db62-b745-8711-7988a7d341de"]
}, Open  ]],

Cell[CellGroupData[{

Cell["5.3.2 ML-Based Classification from Satellite Imagery", "Section",ExpressionUUID->"5987474c-c7a0-c740-8a40-02f19d81279e"],

Cell["\<\
When CDL is unavailable (outside the US or for custom crop types), you can \
train your own classifier using satellite spectral bands as features.\
\>", "Text",ExpressionUUID->"cec2ff1e-3c5c-744e-9c2f-b20a81e2669b"],

Cell[TextData[StyleBox["Step 1: Extract training data at known locations.",
 FontWeight->Bold]], "Text",ExpressionUUID->"c3077f61-6ffd-c041-b517-\
cd32d2dfe598"],

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{
   "Define", " ", "training", " ", "points", " ", "with", " ", "known", " ", 
    "crop", " ", "labels"}], " ", "*)"}], "\n", 
  RowBox[{
   RowBox[{
    RowBox[{"cornPoints", " ", "=", " ", 
     RowBox[{"{", "\n", "  ", 
      RowBox[{
       RowBox[{"GeoPosition", "[", 
        RowBox[{"{", 
         RowBox[{"41.8", ",", " ", 
          RowBox[{"-", "93.5"}]}], "}"}], "]"}], ",", " ", 
       RowBox[{"GeoPosition", "[", 
        RowBox[{"{", 
         RowBox[{"41.9", ",", " ", 
          RowBox[{"-", "93.4"}]}], "}"}], "]"}], ",", "\n", "  ", 
       RowBox[{"GeoPosition", "[", 
        RowBox[{"{", 
         RowBox[{"42.0", ",", " ", 
          RowBox[{"-", "93.6"}]}], "}"}], "]"}], ",", " ", 
       RowBox[{"GeoPosition", "[", 
        RowBox[{"{", 
         RowBox[{"41.7", ",", " ", 
          RowBox[{"-", "93.3"}]}], "}"}], "]"}], ",", "\n", "  ", 
       RowBox[{"GeoPosition", "[", 
        RowBox[{"{", 
         RowBox[{"42.1", ",", " ", 
          RowBox[{"-", "93.5"}]}], "}"}], "]"}]}], "\n", "}"}]}], ";"}], "\n",
    "\n", 
   RowBox[{
    RowBox[{"soyPoints", " ", "=", " ", 
     RowBox[{"{", "\n", "  ", 
      RowBox[{
       RowBox[{"GeoPosition", "[", 
        RowBox[{"{", 
         RowBox[{"41.6", ",", " ", 
          RowBox[{"-", "93.8"}]}], "}"}], "]"}], ",", " ", 
       RowBox[{"GeoPosition", "[", 
        RowBox[{"{", 
         RowBox[{"41.7", ",", " ", 
          RowBox[{"-", "93.7"}]}], "}"}], "]"}], ",", "\n", "  ", 
       RowBox[{"GeoPosition", "[", 
        RowBox[{"{", 
         RowBox[{"41.8", ",", " ", 
          RowBox[{"-", "93.9"}]}], "}"}], "]"}], ",", " ", 
       RowBox[{"GeoPosition", "[", 
        RowBox[{"{", 
         RowBox[{"41.5", ",", " ", 
          RowBox[{"-", "93.6"}]}], "}"}], "]"}], ",", "\n", "  ", 
       RowBox[{"GeoPosition", "[", 
        RowBox[{"{", 
         RowBox[{"41.9", ",", " ", 
          RowBox[{"-", "93.8"}]}], "}"}], "]"}]}], "\n", "}"}]}], ";"}], "\n",
    "\n", 
   RowBox[{
    RowBox[{"wheatPoints", " ", "=", " ", 
     RowBox[{"{", "\n", "  ", 
      RowBox[{
       RowBox[{"GeoPosition", "[", 
        RowBox[{"{", 
         RowBox[{"42.2", ",", " ", 
          RowBox[{"-", "93.2"}]}], "}"}], "]"}], ",", " ", 
       RowBox[{"GeoPosition", "[", 
        RowBox[{"{", 
         RowBox[{"42.3", ",", " ", 
          RowBox[{"-", "93.1"}]}], "}"}], "]"}], ",", "\n", "  ", 
       RowBox[{"GeoPosition", "[", 
        RowBox[{"{", 
         RowBox[{"42.1", ",", " ", 
          RowBox[{"-", "93.3"}]}], "}"}], "]"}], ",", " ", 
       RowBox[{"GeoPosition", "[", 
        RowBox[{"{", 
         RowBox[{"42.0", ",", " ", 
          RowBox[{"-", "93.2"}]}], "}"}], "]"}], ",", "\n", "  ", 
       RowBox[{"GeoPosition", "[", 
        RowBox[{"{", 
         RowBox[{"42.2", ",", " ", 
          RowBox[{"-", "93.0"}]}], "}"}], "]"}]}], "\n", "}"}]}], ";"}], "\n",
    "\n", 
   RowBox[{"(*", " ", 
    RowBox[{
    "July", " ", "composite", " ", "for", " ", "peak", " ", "growing", " ", 
     "season"}], " ", "*)"}], "\n", 
   RowBox[{
    RowBox[{"julyComposite", " ", "=", "\n", "  ", 
     RowBox[{
      RowBox[{
       RowBox[{
        RowBox[{
         RowBox[{
          RowBox[{
          "GEECollection", "[", "\"\<COPERNICUS/S2_SR_HARMONIZED\>\"", "]"}], 
          " ", "//", "\n", "    ", 
          RowBox[{"GEEFilterDate", "[", 
           RowBox[{"\"\<2024-07-01\>\"", ",", " ", "\"\<2024-08-01\>\""}], 
           "]"}]}], " ", "//", "\n", "    ", 
         RowBox[{"GEEFilterBounds", "[", 
          RowBox[{"{", 
           RowBox[{
            RowBox[{"-", "94.0"}], ",", " ", "41.5", ",", " ", 
            RowBox[{"-", "92.0"}], ",", " ", "42.5"}], "}"}], "]"}]}], " ", "//",
         "\n", "    ", 
        RowBox[{"GEEFilterProperty", "[", 
         RowBox[{"\"\<CLOUDY_PIXEL_PERCENTAGE\>\"", ",", 
          " ", "\"\<LessThan\>\"", ",", " ", "15"}], "]"}]}], " ", "//", "\n",
        "    ", "GEEMedian"}], " ", "//", "\n", "    ", 
      RowBox[{"GEESelectBands", "[", 
       RowBox[{"{", 
        RowBox[{"\"\<B2\>\"", ",", " ", "\"\<B3\>\"", ",", " ", "\"\<B4\>\"", 
         ",", " ", "\"\<B5\>\"", ",", " ", "\"\<B6\>\"", ",", 
         " ", "\"\<B7\>\"", ",", " ", "\"\<B8\>\"", ",", " ", "\"\<B8A\>\"", ",",
          " ", "\"\<B11\>\"", ",", " ", "\"\<B12\>\""}], "}"}], "]"}]}]}], 
    ";"}], "\n", "\n", 
   RowBox[{"(*", " ", 
    RowBox[{"Extract", " ", "spectral", " ", "values"}], " ", "*)"}], "\n", 
   RowBox[{
    RowBox[{"cornSamples", " ", "=", " ", 
     RowBox[{"GEEGetSamples", "[", 
      RowBox[{"cornPoints", ",", " ", "julyComposite"}], "]"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"soySamples", " ", "=", " ", 
     RowBox[{"GEEGetSamples", "[", 
      RowBox[{"soyPoints", ",", " ", "julyComposite"}], "]"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"wheatSamples", " ", "=", " ", 
     RowBox[{"GEEGetSamples", "[", 
      RowBox[{"wheatPoints", ",", " ", "julyComposite"}], "]"}]}], 
    ";"}]}]}]], "Input",ExpressionUUID->"4ff00855-4af2-af48-a2c6-\
235bada1a423"],

Cell[TextData[StyleBox["Step 2: Train a classifier in Wolfram Language.",
 FontWeight->Bold]], "Text",ExpressionUUID->"5cccdbd9-71e5-5142-918f-\
7953eb890627"],

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{"Format", " ", "training", " ", 
    RowBox[{"data", ":", " ", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"feature", " ", "vector"}], " ", "->", " ", "label"}], 
      "}"}]}]}], " ", "*)"}], "\n", 
  RowBox[{
   RowBox[{
    RowBox[{
     RowBox[{"formatSamples", "[", 
      RowBox[{"samples_", ",", " ", "label_"}], "]"}], " ", ":=", "\n", "  ", 
     RowBox[{
      RowBox[{
       RowBox[{"(", 
        RowBox[{
         RowBox[{"#", "[", "\"\<Values\>\"", "]"}], " ", "->", " ", "label"}],
         ")"}], " ", "&"}], " ", "/@", " ", "samples"}]}], ";"}], "\n", "\n", 
   RowBox[{
    RowBox[{"trainingData", " ", "=", " ", 
     RowBox[{"Join", "[", "\n", "  ", 
      RowBox[{
       RowBox[{"formatSamples", "[", 
        RowBox[{"cornSamples", ",", " ", "\"\<Corn\>\""}], "]"}], ",", "\n", 
       "  ", 
       RowBox[{"formatSamples", "[", 
        RowBox[{"soySamples", ",", " ", "\"\<Soybeans\>\""}], "]"}], ",", 
       "\n", "  ", 
       RowBox[{"formatSamples", "[", 
        RowBox[{"wheatSamples", ",", " ", "\"\<Wheat\>\""}], "]"}]}], "\n", 
      "]"}]}], ";"}], "\n", "\n", 
   RowBox[{"(*", " ", 
    RowBox[{
    "Train", " ", "a", " ", "random", " ", "forest", " ", "classifier"}], " ",
     "*)"}], "\n", 
   RowBox[{
    RowBox[{"cropClassifier", " ", "=", " ", 
     RowBox[{"Classify", "[", 
      RowBox[{"trainingData", ",", " ", 
       RowBox[{"Method", " ", "->", " ", "\"\<RandomForest\>\""}]}], "]"}]}], 
    ";"}]}]}]], "Input",ExpressionUUID->"c4392658-94f1-774a-bf79-\
cd43f40f5ee5"],

Cell[TextData[StyleBox["Step 3: Evaluate the classifier.",
 FontWeight->Bold]], "Text",ExpressionUUID->"4dc6e553-eef5-c542-b62f-\
deef760537e3"],

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"measurements", " ", "=", " ", 
    RowBox[{"ClassifierMeasurements", "[", 
     RowBox[{"cropClassifier", ",", " ", "trainingData"}], "]"}]}], ";"}], 
  "\n", "\n", 
  RowBox[{"(*", " ", 
   RowBox[{"Overall", " ", "accuracy"}], " ", "*)"}]}], "\n", 
 RowBox[{
  RowBox[{"measurements", "[", "\"\<Accuracy\>\"", "]"}], "\n", "\n", 
  RowBox[{"(*", " ", 
   RowBox[{"Confusion", " ", "matrix"}], " ", "*)"}]}], "\n", 
 RowBox[{
  RowBox[{"measurements", "[", "\"\<ConfusionMatrixPlot\>\"", "]"}], "\n", 
  "\n", 
  RowBox[{"(*", " ", 
   RowBox[{"Per", "-", 
    RowBox[{"class", " ", "precision", " ", "and", " ", "recall"}]}], " ", 
   "*)"}]}], "\n", 
 RowBox[{"measurements", "[", "\"\<Precision\>\"", "]"}], "\n", 
 RowBox[{"measurements", "[", "\"\<Recall\>\"", "]"}]}], "Input",ExpressionUUI\
D->"7095d466-98cf-8446-8ca4-7b32c8242679"],

Cell[TextData[StyleBox["Step 4: Unsupervised clustering as an alternative.",
 FontWeight->Bold]], "Text",ExpressionUUID->"01d2a958-8559-444c-99fb-\
8d6fe74dc18a"],

Cell[TextData[{
 "When labeled training data is unavailable, ",
 Cell["FindClusters", "InlineCode",ExpressionUUID->
  "576a9b60-8911-064b-b244-3cc8528d388a"],
 " can identify spectrally distinct land cover groups."
}], "Text",ExpressionUUID->"4ee3955f-0232-0743-949b-d51b87735d9d"],

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{"Sample", " ", "a", " ", "grid", " ", "of", " ", "points"}], " ", 
   "*)"}], "\n", 
  RowBox[{
   RowBox[{
    RowBox[{"gridPoints", " ", "=", " ", 
     RowBox[{"Flatten", "[", "\n", "  ", 
      RowBox[{
       RowBox[{"Table", "[", 
        RowBox[{
         RowBox[{"GeoPosition", "[", 
          RowBox[{"{", 
           RowBox[{"lat", ",", " ", "lon"}], "}"}], "]"}], ",", "\n", "    ", 
         RowBox[{"{", 
          RowBox[{
          "lat", ",", " ", "41.5", ",", " ", "42.5", ",", " ", "0.1"}], "}"}],
          ",", " ", 
         RowBox[{"{", 
          RowBox[{"lon", ",", " ", 
           RowBox[{"-", "94.0"}], ",", " ", 
           RowBox[{"-", "92.0"}], ",", " ", "0.1"}], "}"}]}], "]"}], ",", 
       "\n", "  ", "1"}], "]"}]}], ";"}], "\n", "\n", 
   RowBox[{
    RowBox[{"allSamples", " ", "=", " ", 
     RowBox[{"GEEGetSamples", "[", 
      RowBox[{"gridPoints", ",", " ", "julyComposite"}], "]"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"spectralVectors", " ", "=", " ", 
     RowBox[{
      RowBox[{
       RowBox[{"#", "[", "\"\<Values\>\"", "]"}], " ", "&"}], " ", "/@", " ", 
      "allSamples"}]}], ";"}], "\n", "\n", 
   RowBox[{"(*", " ", 
    RowBox[{"Cluster", " ", "into", " ", "5", " ", "groups"}], " ", "*)"}], "\n", 
   RowBox[{
    RowBox[{"clusters", " ", "=", " ", 
     RowBox[{"FindClusters", "[", 
      RowBox[{
       RowBox[{"spectralVectors", " ", "->", " ", 
        RowBox[{"Range", "[", 
         RowBox[{"Length", "[", "spectralVectors", "]"}], "]"}]}], ",", "\n", 
       "  ", "5", ",", " ", 
       RowBox[{"Method", " ", "->", " ", "\"\<KMeans\>\""}]}], "]"}]}], ";"}],
    "\n", "\n", 
   RowBox[{"(*", " ", 
    RowBox[{
    "Assign", " ", "cluster", " ", "labels", " ", "back", " ", "to", " ", 
     "geographic", " ", "positions"}], " ", "*)"}], "\n", 
   RowBox[{
    RowBox[{"clusterLabels", " ", "=", " ", 
     RowBox[{"Table", "[", 
      RowBox[{"0", ",", " ", 
       RowBox[{"Length", "[", "spectralVectors", "]"}]}], "]"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"Do", "[", "\n", "  ", 
     RowBox[{
      RowBox[{
       RowBox[{
        RowBox[{"(", 
         RowBox[{
          RowBox[{"clusterLabels", "[", 
           RowBox[{"[", "#", "]"}], "]"}], " ", "=", " ", "k"}], ")"}], " ", 
        "&"}], " ", "/@", " ", 
       RowBox[{"clusters", "[", 
        RowBox[{"[", "k", "]"}], "]"}]}], ",", "\n", "  ", 
      RowBox[{"{", 
       RowBox[{"k", ",", " ", 
        RowBox[{"Length", "[", "clusters", "]"}]}], "}"}]}], "\n", "]"}], 
    ";"}], "\n", "\n", 
   RowBox[{"(*", " ", 
    RowBox[{"Visualize", " ", "clusters", " ", "on", " ", "a", " ", "map"}], 
    " ", "*)"}], "\n", 
   RowBox[{"GeoListPlot", "[", "\n", "  ", 
    RowBox[{
     RowBox[{"Table", "[", "\n", "    ", 
      RowBox[{
       RowBox[{"Style", "[", 
        RowBox[{
         RowBox[{
          RowBox[{"allSamples", "[", 
           RowBox[{"[", "i", "]"}], "]"}], "[", "\"\<Position\>\"", "]"}], ",",
          " ", 
         RowBox[{
          RowBox[{"ColorData", "[", "97", "]"}], "[", 
          RowBox[{"clusterLabels", "[", 
           RowBox[{"[", "i", "]"}], "]"}], "]"}]}], "]"}], ",", "\n", "    ", 
       RowBox[{"{", 
        RowBox[{"i", ",", " ", 
         RowBox[{"Length", "[", "allSamples", "]"}]}], "}"}]}], "\n", "  ", 
      "]"}], ",", "\n", "  ", 
     RowBox[{
     "PlotLabel", " ", "->", 
      " ", "\"\<Unsupervised Land Cover Clusters\>\""}], ",", "\n", "  ", 
     RowBox[{"GeoRange", " ", "->", " ", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{"41.4", ",", " ", "42.6"}], "}"}], ",", " ", 
        RowBox[{"{", 
         RowBox[{
          RowBox[{"-", "94.1"}], ",", " ", 
          RowBox[{"-", "91.9"}]}], "}"}]}], "}"}]}]}], "]"}]}]}]], "Input",Exp\
ressionUUID->"f5cfc6c8-40ca-484b-9df5-fc6c993a11ee"],

