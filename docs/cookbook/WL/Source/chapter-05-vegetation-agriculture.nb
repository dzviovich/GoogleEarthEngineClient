Cell[TextData[{
 "The common thread is the composable pipeline pattern: build a GEE \
expression with ",
 Cell["//", "InlineCode",ExpressionUUID->
  "c49fc9b2-e489-ce46-8427-a78903d60c3b"],
 " chaining, extract data with ",
 Cell["GEEComputePixels", "InlineCode",ExpressionUUID->
  "7dc31db9-f8a3-e04d-990a-f8e036b08b89"],
 ", ",
 Cell["GEEGetSamples", "InlineCode",ExpressionUUID->
  "9807b750-ca42-6b48-b40f-4340ee71b4ae"],
 ", or ",
 Cell["GEEReduceRegion", "InlineCode",ExpressionUUID->
  "da315379-c2af-564a-a7e8-8b935da23404"],
 ", then analyze with Wolfram Language functions. This pattern scales from \
single-field precision agriculture to regional crop monitoring."
}], "Text",ExpressionUUID->"d237a345-78e0-094d-879b-5d1276ef3d82"],

