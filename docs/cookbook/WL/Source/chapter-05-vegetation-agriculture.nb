Cell[CellGroupData[{

Cell["5.4 Soil Moisture and Water Management", "Chapter",ExpressionUUID->"6127a9d3-702f-2d41-b371-67d03ab8d167"],

Cell[CellGroupData[{

Cell["5.4.1 Sentinel-1 SAR for Soil Moisture", "Section",ExpressionUUID->"196e6552-84a2-dc40-a94d-e8a4a5948be6"],

Cell["\<\
Synthetic Aperture Radar (SAR) operates independently of cloud cover and \
sunlight. The VV-polarized backscatter coefficient from Sentinel-1 correlates \
with surface soil moisture: wetter soils produce stronger backscatter because \
the dielectric constant of water is much higher than that of dry soil.\
\>", "Text",ExpressionUUID->"e7578215-be3c-c149-beb1-768b9386d0c7"],

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"farmRegion", " ", "=", " ", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{"-", "93.5"}], ",", " ", "41.5", ",", " ", 
      RowBox[{"-", "93.0"}], ",", " ", "42.0"}], "}"}]}], ";"}], "\n"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"sarImage", " ", "=", "\n", "  ", 
    RowBox[{
     RowBox[{
      RowBox[{
       RowBox[{
        RowBox[{
         RowBox[{
          RowBox[{"GEECollection", "[", "\"\<COPERNICUS/S1_GRD\>\"", "]"}], 
          " ", "//", "\n", "    ", 
          RowBox[{"GEEFilterDate", "[", 
           RowBox[{"\"\<2024-06-01\>\"", ",", " ", "\"\<2024-06-30\>\""}], 
           "]"}]}], " ", "//", "\n", "    ", 
         RowBox[{"GEEFilterBounds", "[", "farmRegion", "]"}]}], " ", "//", 
        "\n", "    ", 
        RowBox[{"GEEFilterProperty", "[", 
         RowBox[{"\"\<instrumentMode\>\"", ",", " ", "\"\<Equals\>\"", ",", 
          " ", "\"\<IW\>\""}], "]"}]}], " ", "//", "\n", "    ", 
       RowBox[{"GEEFilterProperty", "[", 
        RowBox[{"\"\<orbitProperties_pass\>\"", ",", " ", "\"\<Equals\>\"", ",",
          " ", "\"\<ASCENDING\>\""}], "]"}]}], " ", "//", "\n", "    ", 
      RowBox[{"GEESelectBands", "[", 
       RowBox[{"{", "\"\<VV\>\"", "}"}], "]"}]}], " ", "//", "\n", "    ", 
     "GEEMedian"}]}], ";"}], "\n"}], "\n", 
 RowBox[{"GEEComputePixels", "[", 
  RowBox[{"farmRegion", ",", "\n", "  ", 
   RowBox[{"sarImage", " ", "//", " ", 
    RowBox[{"GEEVisualize", "[", 
     RowBox[{"<|", "\n", "    ", 
      RowBox[{
       RowBox[{"\"\<min\>\"", " ", "->", " ", 
        RowBox[{"-", "25"}]}], ",", " ", 
       RowBox[{"\"\<max\>\"", " ", "->", " ", "0"}], ",", "\n", "    ", 
       RowBox[{"\"\<palette\>\"", " ", "->", " ", 
        RowBox[{"{", 
         RowBox[{"\"\<#000033\>\"", ",", " ", "\"\<#003366\>\"", ",", 
          " ", "\"\<#006699\>\"", ",", " ", "\"\<#3399CC\>\"", ",", "\n", 
          "                  ", "\"\<#66CCFF\>\"", ",", 
          " ", "\"\<#99FFFF\>\""}], "}"}]}]}], "\n", "  ", "|>"}], "]"}]}], ",",
    "\n", "  ", 
   RowBox[{"\"\<ImageSize\>\"", " ", "->", " ", "800"}]}], "]"}]}], "Input",Ex\
pressionUUID->"6ba49dc8-c98c-3c4c-80aa-0eda9b43bf64"],

Cell["\<\
VV backscatter values (in dB) typically range from -25 (very dry) to -5 (very \
wet or standing water). The ascending orbit minimizes wind-induced roughness \
artifacts on vegetation.\
\>", "Text",ExpressionUUID->"5bf27534-784f-934d-b275-e96871bfe8f2"]
}, Open  ]],

Cell[CellGroupData[{

Cell["5.4.2 Temporal SAR for Irrigation Detection", "Section",ExpressionUUID->"58b12fc7-f702-1f41-8c9e-f74faba9bed4"],

Cell["\<\
Irrigated fields show consistently higher SAR backscatter than rainfed fields \
during dry periods. Comparing backscatter statistics between known irrigated \
and rainfed areas confirms this pattern.\
\>", "Text",ExpressionUUID->"4d066c8d-80c6-1342-a8b9-a9a4750aa4be"],

Cell[BoxData[{
 RowBox[{
  RowBox[{"irrigatedField", " ", "=", " ", 
   RowBox[{"GEEGeometry", "[", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{"-", "93.3"}], ",", " ", "41.7", ",", " ", 
      RowBox[{"-", "93.2"}], ",", " ", "41.8"}], "}"}], "]"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"rainfedField", " ", "=", " ", 
    RowBox[{"GEEGeometry", "[", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"-", "93.4"}], ",", " ", "41.6", ",", " ", 
       RowBox[{"-", "93.3"}], ",", " ", "41.7"}], "}"}], "]"}]}], ";"}], 
  "\n"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"sarJune", " ", "=", "\n", "  ", 
    RowBox[{
     RowBox[{
      RowBox[{
       RowBox[{
        RowBox[{
         RowBox[{
          RowBox[{"GEECollection", "[", "\"\<COPERNICUS/S1_GRD\>\"", "]"}], 
          " ", "//", "\n", "    ", 
          RowBox[{"GEEFilterDate", "[", 
           RowBox[{"\"\<2024-06-01\>\"", ",", " ", "\"\<2024-06-30\>\""}], 
           "]"}]}], " ", "//", "\n", "    ", 
         RowBox[{"GEEFilterBounds", "[", "farmRegion", "]"}]}], " ", "//", 
        "\n", "    ", 
        RowBox[{"GEEFilterProperty", "[", 
         RowBox[{"\"\<instrumentMode\>\"", ",", " ", "\"\<Equals\>\"", ",", 
          " ", "\"\<IW\>\""}], "]"}]}], " ", "//", "\n", "    ", 
       RowBox[{"GEEFilterProperty", "[", 
        RowBox[{"\"\<orbitProperties_pass\>\"", ",", " ", "\"\<Equals\>\"", ",",
          " ", "\"\<ASCENDING\>\""}], "]"}]}], " ", "//", "\n", "    ", 
      RowBox[{"GEESelectBands", "[", 
       RowBox[{"{", "\"\<VV\>\"", "}"}], "]"}]}], " ", "//", "\n", "    ", 
     "GEEMedian"}]}], ";"}], "\n"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"irrigatedVV", " ", "=", " ", 
    RowBox[{"GEECompute", "[", "\n", "  ", 
     RowBox[{"sarJune", " ", "//", " ", 
      RowBox[{"GEEReduceRegion", "[", 
       RowBox[{"irrigatedField", ",", " ", "\"\<mean\>\"", ",", " ", "10"}], 
       "]"}]}], "\n", "]"}]}], ";"}], "\n"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"rainfedVV", " ", "=", " ", 
    RowBox[{"GEECompute", "[", "\n", "  ", 
     RowBox[{"sarJune", " ", "//", " ", 
      RowBox[{"GEEReduceRegion", "[", 
       RowBox[{"rainfedField", ",", " ", "\"\<mean\>\"", ",", " ", "10"}], 
       "]"}]}], "\n", "]"}]}], ";"}], "\n", "\n", 
  RowBox[{"(*", " ", 
   RowBox[{"Compare", ":", " ", 
    RowBox[{
     RowBox[{
     "irrigated", " ", "fields", " ", "typically", " ", "show", " ", "2"}], "-", 
     RowBox[{"5", " ", "dB", " ", "higher", " ", "backscatter"}]}]}], " ", 
   "*)"}]}], "\n", 
 RowBox[{"{", 
  RowBox[{
   RowBox[{"irrigatedVV", "[", "\"\<VV\>\"", "]"}], ",", " ", 
   RowBox[{"rainfedVV", "[", "\"\<VV\>\"", "]"}]}], "}"}]}], "Input",Expressio\
nUUID->"c37beb91-dd49-8a43-8cfc-e9ede91a585b"]
}, Open  ]],

Cell[CellGroupData[{

Cell["5.4.3 NDVI-Based Irrigation Detection", "Section",ExpressionUUID->"fad7bf06-3fd2-d641-b7b6-04d7349ca870"],

Cell["\<\
An alternative approach compares NDVI trajectories. Irrigated fields maintain \
high NDVI through dry summer months while rainfed fields decline.\
\>", "Text",ExpressionUUID->"103f3e5c-0b8a-074c-b0d9-b41e42b8da06"],

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"extractNDVIProfile", "[", 
     RowBox[{"geom_", ",", " ", "bbox_"}], "]"}], " ", ":=", " ", 
    RowBox[{"Table", "[", "\n", "  ", 
     RowBox[{
      RowBox[{"Module", "[", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{
         "start", ",", " ", "end", ",", " ", "ndvi", ",", " ", "stats"}], 
         "}"}], ",", "\n", "    ", 
        RowBox[{
         RowBox[{"start", " ", "=", " ", 
          RowBox[{"DateString", "[", 
           RowBox[{
            RowBox[{"DateObject", "[", 
             RowBox[{"{", 
              RowBox[{"2024", ",", " ", "m", ",", " ", "1"}], "}"}], "]"}], ",",
             "\n", "      ", 
            RowBox[{"{", 
             
             RowBox[{"\"\<Year\>\"", ",", " ", "\"\<-\>\"", ",", 
              " ", "\"\<Month\>\"", ",", " ", "\"\<-\>\"", ",", 
              " ", "\"\<Day\>\""}], "}"}]}], "]"}]}], ";", "\n", "    ", 
         RowBox[{"end", " ", "=", " ", 
          RowBox[{"DateString", "[", 
           RowBox[{
            RowBox[{"DatePlus", "[", 
             RowBox[{
              RowBox[{"DateObject", "[", 
               RowBox[{"{", 
                RowBox[{"2024", ",", " ", "m", ",", " ", "1"}], "}"}], "]"}], 
              ",", " ", 
              RowBox[{"{", 
               RowBox[{"1", ",", " ", "\"\<Month\>\""}], "}"}]}], "]"}], ",", 
            "\n", "      ", 
            RowBox[{"{", 
             
             RowBox[{"\"\<Year\>\"", ",", " ", "\"\<-\>\"", ",", 
              " ", "\"\<Month\>\"", ",", " ", "\"\<-\>\"", ",", 
              " ", "\"\<Day\>\""}], "}"}]}], "]"}]}], ";", "\n", "    ", 
         RowBox[{"ndvi", " ", "=", "\n", "      ", 
          RowBox[{
           RowBox[{
            RowBox[{
             RowBox[{
              RowBox[{
               RowBox[{
               "GEECollection", "[", "\"\<COPERNICUS/S2_SR_HARMONIZED\>\"", 
                "]"}], " ", "//", "\n", "        ", 
               RowBox[{"GEEFilterDate", "[", 
                RowBox[{"start", ",", " ", "end"}], "]"}]}], " ", "//", "\n", 
              "        ", 
              RowBox[{"GEEFilterBounds", "[", "bbox", "]"}]}], " ", "//", 
             "\n", "        ", 
             RowBox[{"GEEFilterProperty", "[", 
              
              RowBox[{"\"\<CLOUDY_PIXEL_PERCENTAGE\>\"", ",", 
               " ", "\"\<LessThan\>\"", ",", " ", "25"}], "]"}]}], " ", "//", 
            "\n", "        ", "GEEMedian"}], " ", "//", "\n", "        ", 
           RowBox[{"GEENormalizedDifference", "[", 
            RowBox[{"{", 
             RowBox[{"\"\<B8\>\"", ",", " ", "\"\<B4\>\""}], "}"}], "]"}]}]}],
          ";", "\n", "    ", 
         RowBox[{"stats", " ", "=", " ", 
          RowBox[{"GEECompute", "[", 
           RowBox[{"ndvi", " ", "//", " ", 
            RowBox[{"GEEReduceRegion", "[", 
             RowBox[{"geom", ",", " ", "\"\<mean\>\"", ",", " ", "10"}], 
             "]"}]}], "]"}]}], ";", "\n", "    ", 
         RowBox[{"stats", "[", "\"\<nd\>\"", "]"}]}]}], "\n", "  ", "]"}], ",",
       "\n", "  ", 
      RowBox[{"{", 
       RowBox[{"m", ",", " ", "5", ",", " ", "10"}], "}"}]}], "\n", "]"}]}], 
   ";"}], "\n"}], "\n", 
 RowBox[{
  RowBox[{"irrigatedProfile", " ", "=", " ", 
   RowBox[{"extractNDVIProfile", "[", 
    RowBox[{"irrigatedField", ",", "\n", "  ", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"-", "93.3"}], ",", " ", "41.7", ",", " ", 
       RowBox[{"-", "93.2"}], ",", " ", "41.8"}], "}"}]}], "]"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"rainfedProfile", " ", "=", " ", 
    RowBox[{"extractNDVIProfile", "[", 
     RowBox[{"rainfedField", ",", "\n", "  ", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"-", "93.4"}], ",", " ", "41.6", ",", " ", 
        RowBox[{"-", "93.3"}], ",", " ", "41.7"}], "}"}]}], "]"}]}], ";"}], 
  "\n"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"months", " ", "=", " ", 
    RowBox[{"Table", "[", 
     RowBox[{
      RowBox[{"DateObject", "[", 
       RowBox[{"{", 
        RowBox[{"2024", ",", " ", "m", ",", " ", "15"}], "}"}], "]"}], ",", 
      " ", 
      RowBox[{"{", 
       RowBox[{"m", ",", " ", "5", ",", " ", "10"}], "}"}]}], "]"}]}], ";"}], 
  "\n"}], "\n", 
 RowBox[{"DateListPlot", "[", 
  RowBox[{
   RowBox[{"{", "\n", "    ", 
    RowBox[{
     RowBox[{"TimeSeries", "[", 
      RowBox[{"irrigatedProfile", ",", " ", 
       RowBox[{"{", "months", "}"}]}], "]"}], ",", "\n", "    ", 
     RowBox[{"TimeSeries", "[", 
      RowBox[{"rainfedProfile", ",", " ", 
       RowBox[{"{", "months", "}"}]}], "]"}]}], "\n", "  ", "}"}], ",", "\n", 
   "  ", 
   RowBox[{"PlotLegends", " ", "->", " ", 
    RowBox[{"{", 
     RowBox[{"\"\<Irrigated\>\"", ",", " ", "\"\<Rainfed\>\""}], "}"}]}], ",",
    "\n", "  ", 
   RowBox[{
   "PlotLabel", " ", "->", 
    " ", "\"\<Irrigation Detection via NDVI Divergence\>\""}], ",", "\n", 
   "  ", 
   RowBox[{"FrameLabel", " ", "->", " ", 
    RowBox[{"{", 
     RowBox[{"\"\<Date\>\"", ",", " ", "\"\<NDVI\>\""}], "}"}]}], ",", "\n", 
   "  ", 
   RowBox[{"PlotTheme", " ", "->", " ", "\"\<Scientific\>\""}]}], 
  "]"}]}], "Input",ExpressionUUID->"15fad72d-2686-bb46-953f-19e77fa01d56"],

Cell["\<\
The divergence between the two curves during July-August is the irrigation \
signal. A persistent NDVI difference greater than 0.15 during the dry season \
is a strong indicator of irrigation.\
\>", "Text",ExpressionUUID->"c5dbc4fc-a371-d14a-87cb-831c88cb91ad"],

Cell["", "Text",
 CellFrame->{{0, 0}, {0, 
  1}},ExpressionUUID->"ac45e480-30fb-0440-bdcc-9a4e8a43199a"]
}, Open  ]]
}, Open  ]],

Cell[CellGroupData[{

Cell["5.5 Yield Estimation and Variable Rate Application", "Chapter",ExpressionUUID->"deeec3c6-314e-f649-ad4a-bdf6b0e6f71a"],

Cell[CellGroupData[{

Cell["5.5.1 Correlating NDVI with Yield", "Section",ExpressionUUID->"6731e534-c01d-5445-a090-1f246586568f"],

Cell["\<\
Peak-season NDVI is a well-established proxy for crop yield. The relationship \
is approximately linear for grain crops within a single growing region, \
though it saturates at very high biomass levels. Note that NDVI-yield \
linearity degrades above ~0.8 NDVI due to saturation; EVI may be more \
appropriate for high-biomass scenarios.\
\>", "Text",ExpressionUUID->"f33508c8-994e-ef45-9a58-b7acbb46240b"],

Cell[TextData[StyleBox["Step 1: Extract NDVI at yield sampling points.",
 FontWeight->Bold]], "Text",ExpressionUUID->"8d202f27-9b9b-5042-9a91-\
dec2209b630d"],

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{
   "Field", " ", "sample", " ", "locations", " ", "with", " ", "known", " ", 
    "yield", " ", 
    RowBox[{"(", 
     RowBox[{"bushels", "/", "acre"}], ")"}]}], " ", "*)"}], "\n", 
  RowBox[{
   RowBox[{
    RowBox[{"sampleLocations", " ", "=", " ", 
     RowBox[{"{", "\n", "  ", 
      RowBox[{
       RowBox[{"GeoPosition", "[", 
        RowBox[{"{", 
         RowBox[{"41.80", ",", " ", 
          RowBox[{"-", "93.50"}]}], "}"}], "]"}], ",", " ", 
       RowBox[{"GeoPosition", "[", 
        RowBox[{"{", 
         RowBox[{"41.82", ",", " ", 
          RowBox[{"-", "93.48"}]}], "}"}], "]"}], ",", "\n", "  ", 
       RowBox[{"GeoPosition", "[", 
        RowBox[{"{", 
         RowBox[{"41.84", ",", " ", 
          RowBox[{"-", "93.52"}]}], "}"}], "]"}], ",", " ", 
       RowBox[{"GeoPosition", "[", 
        RowBox[{"{", 
         RowBox[{"41.86", ",", " ", 
          RowBox[{"-", "93.46"}]}], "}"}], "]"}], ",", "\n", "  ", 
       RowBox[{"GeoPosition", "[", 
        RowBox[{"{", 
         RowBox[{"41.88", ",", " ", 
          RowBox[{"-", "93.54"}]}], "}"}], "]"}], ",", " ", 
       RowBox[{"GeoPosition", "[", 
        RowBox[{"{", 
         RowBox[{"41.90", ",", " ", 
          RowBox[{"-", "93.44"}]}], "}"}], "]"}], ",", "\n", "  ", 
       RowBox[{"GeoPosition", "[", 
        RowBox[{"{", 
         RowBox[{"41.78", ",", " ", 
          RowBox[{"-", "93.56"}]}], "}"}], "]"}], ",", " ", 
       RowBox[{"GeoPosition", "[", 
        RowBox[{"{", 
         RowBox[{"41.76", ",", " ", 
          RowBox[{"-", "93.42"}]}], "}"}], "]"}], ",", "\n", "  ", 
       RowBox[{"GeoPosition", "[", 
        RowBox[{"{", 
         RowBox[{"41.92", ",", " ", 
          RowBox[{"-", "93.50"}]}], "}"}], "]"}], ",", " ", 
       RowBox[{"GeoPosition", "[", 
        RowBox[{"{", 
         RowBox[{"41.85", ",", " ", 
          RowBox[{"-", "93.49"}]}], "}"}], "]"}]}], "\n", "}"}]}], ";"}], 
   "\n", "\n", 
   RowBox[{
    RowBox[{"yieldData", " ", "=", " ", 
     RowBox[{"{", 
      RowBox[{
      "182", ",", " ", "175", ",", " ", "190", ",", " ", "168", ",", " ", 
       "195", ",", " ", "172", ",", " ", "160", ",", " ", "188", ",", " ", 
       "178", ",", " ", "185"}], "}"}]}], ";"}], "\n", "\n", 
   RowBox[{"(*", " ", 
    RowBox[{"Peak", "-", 
     RowBox[{
     "season", " ", "NDVI", " ", "at", " ", "those", " ", "points"}]}], " ", 
    "*)"}], "\n", 
   RowBox[{
    RowBox[{"peakComposite", " ", "=", "\n", "  ", 
     RowBox[{
      RowBox[{
       RowBox[{
        RowBox[{
         RowBox[{
          RowBox[{
          "GEECollection", "[", "\"\<COPERNICUS/S2_SR_HARMONIZED\>\"", "]"}], 
          " ", "//", "\n", "    ", 
          RowBox[{"GEEFilterDate", "[", 
           RowBox[{"\"\<2024-07-15\>\"", ",", " ", "\"\<2024-08-15\>\""}], 
           "]"}]}], " ", "//", "\n", "    ", 
         RowBox[{"GEEFilterBounds", "[", 
          RowBox[{"{", 
           RowBox[{
            RowBox[{"-", "93.6"}], ",", " ", "41.7", ",", " ", 
            RowBox[{"-", "93.4"}], ",", " ", "42.0"}], "}"}], "]"}]}], " ", "//",
         "\n", "    ", 
        RowBox[{"GEEFilterProperty", "[", 
         RowBox[{"\"\<CLOUDY_PIXEL_PERCENTAGE\>\"", ",", 
          " ", "\"\<LessThan\>\"", ",", " ", "15"}], "]"}]}], " ", "//", "\n",
        "    ", "GEEMedian"}], " ", "//", "\n", "    ", 
      RowBox[{"GEENormalizedDifference", "[", 
       RowBox[{"{", 
        RowBox[{"\"\<B8\>\"", ",", " ", "\"\<B4\>\""}], "}"}], "]"}]}]}], 
    ";"}], "\n", "\n", 
   RowBox[{
    RowBox[{"ndviSamples", " ", "=", " ", 
     RowBox[{"GEEGetSamples", "[", 
      RowBox[{"sampleLocations", ",", " ", "peakComposite"}], "]"}]}], ";"}], 
   "\n", 
   RowBox[{
    RowBox[{"ndviValues", " ", "=", " ", 
     RowBox[{
      RowBox[{
       RowBox[{"First", "[", 
        RowBox[{"#", "[", "\"\<Values\>\"", "]"}], "]"}], " ", "&"}], " ", "/@",
       " ", "ndviSamples"}]}], ";"}]}]}]], "Input",ExpressionUUID->"7fedec98-f770-d847-b322-ec54f0cdf010"],

Cell[TextData[StyleBox["Step 2: Build a regression model.",
 FontWeight->Bold]], "Text",ExpressionUUID->"577a7a75-2487-4641-b238-\
139a53dfdd15"],

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{
    RowBox[{"Linear", " ", 
     RowBox[{"regression", ":", " ", "yield"}]}], " ", "=", " ", 
    RowBox[{
     RowBox[{"a", " ", "*", " ", "NDVI"}], " ", "+", " ", "b"}]}], " ", 
   "*)"}], "\n", 
  RowBox[{
   RowBox[{
    RowBox[{"yieldModel", " ", "=", " ", 
     RowBox[{"LinearModelFit", "[", "\n", "  ", 
      RowBox[{
       RowBox[{"Transpose", "[", 
        RowBox[{"{", 
         RowBox[{"ndviValues", ",", " ", "yieldData"}], "}"}], "]"}], ",", 
       "\n", "  ", "x", ",", " ", "x"}], "\n", "]"}]}], ";"}], "\n", "\n", 
   RowBox[{"(*", " ", 
    RowBox[{"Model", " ", "summary"}], " ", "*)"}], "\n", 
   RowBox[{"yieldModel", "[", "\"\<ParameterTable\>\"", "]"}], "\n", 
   RowBox[{"yieldModel", "[", "\"\<RSquared\>\"", "]"}], "\n", "\n", 
   RowBox[{"(*", " ", 
    RowBox[{"Visualize", " ", "the", " ", "fit"}], " ", "*)"}], "\n", 
   RowBox[{"Show", "[", "\n", "  ", 
    RowBox[{
     RowBox[{"ListPlot", "[", 
      RowBox[{
       RowBox[{"Transpose", "[", 
        RowBox[{"{", 
         RowBox[{"ndviValues", ",", " ", "yieldData"}], "}"}], "]"}], ",", 
       "\n", "    ", 
       RowBox[{"PlotStyle", " ", "->", " ", 
        RowBox[{"PointSize", "[", "0.02", "]"}]}], ",", "\n", "    ", 
       RowBox[{"FrameLabel", " ", "->", " ", 
        RowBox[{"{", 
         RowBox[{"\"\<Peak NDVI\>\"", ",", " ", "\"\<Yield (bu/acre)\>\""}], 
         "}"}]}], ",", "\n", "    ", 
       RowBox[{
       "PlotLabel", " ", "->", " ", "\"\<NDVI-Yield Regression\>\""}]}], 
      "]"}], ",", "\n", "  ", 
     RowBox[{"Plot", "[", 
      RowBox[{
       RowBox[{"yieldModel", "[", "x", "]"}], ",", " ", 
       RowBox[{"{", 
        RowBox[{"x", ",", " ", "0.4", ",", " ", "0.95"}], "}"}], ",", "\n", 
       "    ", 
       RowBox[{"PlotStyle", " ", "->", " ", "Red"}]}], "]"}]}], "\n", 
    "]"}]}]}]], "Input",ExpressionUUID->"657676c2-4add-454e-a42f-\
5c582a0efb17"],

Cell[TextData[StyleBox["Step 3: Predict yield from new NDVI data.",
 FontWeight->Bold]], "Text",ExpressionUUID->"b8f86e65-6502-ac42-9eb6-\
c8c9f014e514"],

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{
   "Using", " ", "the", " ", "Wolfram", " ", "Predict", " ", "framework", " ",
     "for", " ", "a", " ", "more", " ", "robust", " ", "model"}], " ", "*)"}],
   "\n", 
  RowBox[{
   RowBox[{
    RowBox[{"yieldPredictor", " ", "=", " ", 
     RowBox[{"Predict", "[", "\n", "  ", 
      RowBox[{
       RowBox[{"Thread", "[", 
        RowBox[{"ndviValues", " ", "->", " ", "yieldData"}], "]"}], ",", "\n",
        "  ", 
       RowBox[{"Method", " ", "->", " ", "\"\<GradientBoostedTrees\>\""}]}], 
      "\n", "]"}]}], ";"}], "\n", "\n", 
   RowBox[{"(*", " ", 
    RowBox[{
    "Predict", " ", "yield", " ", "at", " ", "new", " ", "field", " ", 
     "locations"}], " ", "*)"}], "\n", 
   RowBox[{
    RowBox[{"newLocations", " ", "=", " ", 
     RowBox[{"{", "\n", "  ", 
      RowBox[{
       RowBox[{"GeoPosition", "[", 
        RowBox[{"{", 
         RowBox[{"41.83", ",", " ", 
          RowBox[{"-", "93.51"}]}], "}"}], "]"}], ",", "\n", "  ", 
       RowBox[{"GeoPosition", "[", 
        RowBox[{"{", 
         RowBox[{"41.87", ",", " ", 
          RowBox[{"-", "93.47"}]}], "}"}], "]"}]}], "\n", "}"}]}], ";"}], 
   "\n", "\n", 
   RowBox[{
    RowBox[{"newNDVI", " ", "=", " ", 
     RowBox[{"GEEGetSamples", "[", 
      RowBox[{"newLocations", ",", " ", "peakComposite"}], "]"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"newNDVIValues", " ", "=", " ", 
     RowBox[{
      RowBox[{
       RowBox[{"First", "[", 
        RowBox[{"#", "[", "\"\<Values\>\"", "]"}], "]"}], " ", "&"}], " ", "/@",
       " ", "newNDVI"}]}], ";"}], "\n", "\n", 
   RowBox[{"predictedYields", " ", "=", " ", 
    RowBox[{
    "yieldPredictor", " ", "/@", " ", "newNDVIValues"}]}]}]}]], "Input",Expres\
sionUUID->"1d6cde20-3269-0b41-a738-ef0924fc8063"]
}, Open  ]],

Cell[CellGroupData[{

Cell["5.5.2 Variable Rate Application (VRA) Maps", "Section",ExpressionUUID->"8584f76f-f019-7548-8731-8e98584d2536"],

Cell["\<\
Precision agriculture applies inputs (fertilizer, seed, water) at variable \
rates across a field based on spatial productivity patterns. NDVI-derived \
management zones guide these prescriptions.\
\>", "Text",ExpressionUUID->"d5d2edb7-3180-9649-9c5d-e07c3634db83"],

Cell[TextData[StyleBox["Step 1: Sample NDVI across a field grid.",
 FontWeight->Bold]], "Text",ExpressionUUID->"cf171fcf-df48-f949-990c-\
cbd11091081e"],

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{
   "Create", " ", "a", " ", "dense", " ", "sampling", " ", "grid", " ", 
    "within", " ", "a", " ", "field"}], " ", "*)"}], "\n", 
  RowBox[{
   RowBox[{
    RowBox[{"fieldPoints", " ", "=", " ", 
     RowBox[{"Flatten", "[", "\n", "  ", 
      RowBox[{
       RowBox[{"Table", "[", 
        RowBox[{
         RowBox[{"GeoPosition", "[", 
          RowBox[{"{", 
           RowBox[{"lat", ",", " ", "lon"}], "}"}], "]"}], ",", "\n", "    ", 
         RowBox[{"{", 
          RowBox[{
          "lat", ",", " ", "41.80", ",", " ", "41.90", ",", " ", "0.005"}], 
          "}"}], ",", "\n", "    ", 
         RowBox[{"{", 
          RowBox[{"lon", ",", " ", 
           RowBox[{"-", "93.55"}], ",", " ", 
           RowBox[{"-", "93.45"}], ",", " ", "0.005"}], "}"}]}], "]"}], ",", 
       "\n", "  ", "1"}], "]"}]}], ";"}], "\n", "\n", 
   RowBox[{
    RowBox[{"fieldNDVI", " ", "=", " ", 
     RowBox[{"GEEGetSamples", "[", 
      RowBox[{"fieldPoints", ",", " ", "peakComposite"}], "]"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"ndviGrid", " ", "=", " ", 
     RowBox[{
      RowBox[{
       RowBox[{"First", "[", 
        RowBox[{"#", "[", "\"\<Values\>\"", "]"}], "]"}], " ", "&"}], " ", "/@",
       " ", "fieldNDVI"}]}], ";"}]}]}]], "Input",ExpressionUUID->"a189c284-\
75b9-2c41-a4fd-9b5f62f913db"],

Cell[TextData[StyleBox["Step 2: Cluster into management zones.",
 FontWeight->Bold]], "Text",ExpressionUUID->"6ce62634-6ef0-eb49-9a6c-\
1a6c52e73778"],

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{
   "Cluster", " ", "NDVI", " ", "values", " ", "into", " ", "4", " ", 
    "management", " ", "zones"}], " ", "*)"}], "\n", 
  RowBox[{
   RowBox[{
    RowBox[{"zones", " ", "=", " ", 
     RowBox[{"FindClusters", "[", 
      RowBox[{
       RowBox[{"ndviGrid", " ", "->", " ", 
        RowBox[{"Range", "[", 
         RowBox[{"Length", "[", "ndviGrid", "]"}], "]"}]}], ",", " ", "4", ",",
        "\n", "  ", 
       RowBox[{"Method", " ", "->", " ", "\"\<KMeans\>\""}]}], "]"}]}], ";"}],
    "\n", "\n", 
   RowBox[{"(*", " ", 
    RowBox[{
     RowBox[{
      RowBox[{"Sort", " ", "zones", " ", "by", " ", "mean", " ", 
       RowBox[{"NDVI", " ", "--"}], " ", "zone", " ", "1"}], " ", "=", " ", 
      "lowest"}], ",", " ", 
     RowBox[{
      RowBox[{"zone", " ", "4"}], " ", "=", " ", "highest"}]}], " ", "*)"}], "\n", 
   RowBox[{
    RowBox[{"zoneMeans", " ", "=", " ", 
     RowBox[{
      RowBox[{
       RowBox[{"Mean", "[", 
        RowBox[{"ndviGrid", "[", 
         RowBox[{"[", "#", "]"}], "]"}], "]"}], " ", "&"}], " ", "/@", " ", 
      "zones"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"sortOrder", " ", "=", " ", 
     RowBox[{"Ordering", "[", "zoneMeans", "]"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"sortedZones", " ", "=", " ", 
     RowBox[{"zones", "[", 
      RowBox[{"[", "sortOrder", "]"}], "]"}]}], ";"}], "\n", "\n", 
   RowBox[{"(*", " ", 
    RowBox[{"Assign", " ", "zone", " ", "labels"}], " ", "*)"}], "\n", 
   RowBox[{
    RowBox[{"zoneLabels", " ", "=", " ", 
     RowBox[{"Table", "[", 
      RowBox[{"0", ",", " ", 
       RowBox[{"Length", "[", "ndviGrid", "]"}]}], "]"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"Do", "[", "\n", "  ", 
     RowBox[{
      RowBox[{
       RowBox[{
        RowBox[{"(", 
         RowBox[{
          RowBox[{"zoneLabels", "[", 
           RowBox[{"[", "#", "]"}], "]"}], " ", "=", " ", "k"}], ")"}], " ", 
        "&"}], " ", "/@", " ", 
       RowBox[{"sortedZones", "[", 
        RowBox[{"[", "k", "]"}], "]"}]}], ",", "\n", "  ", 
      RowBox[{"{", 
       RowBox[{"k", ",", " ", "4"}], "}"}]}], "\n", "]"}], ";"}]}]}]], "Input",\
ExpressionUUID->"83f318f6-d9e0-b244-81df-98187833334f"],

Cell[TextData[StyleBox["Step 3: Assign fertilizer rates and visualize.",
 FontWeight->Bold]], "Text",ExpressionUUID->"da5d081d-bae1-0248-bf16-\
224a456d4427"],

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{"Prescription", ":", " ", 
    RowBox[{
    "higher", " ", "NDVI", " ", "zones", " ", "need", " ", "less", " ", "N", " ",
      "fertilizer"}]}], " ", "*)"}], "\n", 
  RowBox[{
   RowBox[{
    RowBox[{"fertilizerRates", " ", "=", " ", 
     RowBox[{"<|", 
      RowBox[{
       RowBox[{"1", " ", "->", " ", "200"}], ",", " ", 
       RowBox[{"2", " ", "->", " ", "160"}], ",", " ", 
       RowBox[{"3", " ", "->", " ", "120"}], ",", " ", 
       RowBox[{"4", " ", "->", " ", "80"}]}], "|>"}]}], ";"}], "  ", 
   RowBox[{"(*", " ", 
    RowBox[{"lbs", " ", 
     RowBox[{"N", "/", "acre"}]}], " ", "*)"}], "\n", "\n", 
   RowBox[{
    RowBox[{"prescriptions", " ", "=", " ", 
     RowBox[{"fertilizerRates", " ", "/@", " ", "zoneLabels"}]}], ";"}], "\n",
    "\n", 
   RowBox[{"(*", " ", 
    RowBox[{"Visualize", " ", "the", " ", "prescription", " ", "map"}], " ", 
    "*)"}], "\n", 
   RowBox[{
    RowBox[{"zoneColors", " ", "=", " ", 
     RowBox[{"{", 
      RowBox[{"Red", ",", " ", "Orange", ",", " ", "LightGreen", ",", " ", 
       RowBox[{"Darker", "[", "Green", "]"}]}], "}"}]}], ";"}], "\n", "\n", 
   RowBox[{"GeoListPlot", "[", "\n", "  ", 
    RowBox[{
     RowBox[{"Table", "[", "\n", "    ", 
      RowBox[{
       RowBox[{"Style", "[", 
        RowBox[{
         RowBox[{"fieldPoints", "[", 
          RowBox[{"[", "i", "]"}], "]"}], ",", " ", 
         RowBox[{"zoneColors", "[", 
          RowBox[{"[", 
           RowBox[{"zoneLabels", "[", 
            RowBox[{"[", "i", "]"}], "]"}], "]"}], "]"}]}], "]"}], ",", "\n", 
       "    ", 
       RowBox[{"{", 
        RowBox[{"i", ",", " ", 
         RowBox[{"Length", "[", "fieldPoints", "]"}]}], "}"}]}], "\n", "  ", 
      "]"}], ",", "\n", "  ", 
     RowBox[{
     "PlotLabel", " ", "->", 
      " ", "\"\<VRA Prescription Map (lbs N/acre)\>\""}], ",", "\n", "  ", 
     RowBox[{"PlotLegends", " ", "->", " ", 
      RowBox[{"SwatchLegend", "[", 
       RowBox[{"zoneColors", ",", "\n", "    ", 
        RowBox[{"{", 
         RowBox[{"\"\<200 lbs/ac\>\"", ",", " ", "\"\<160 lbs/ac\>\"", ",", 
          " ", "\"\<120 lbs/ac\>\"", ",", " ", "\"\<80 lbs/ac\>\""}], "}"}]}],
        "]"}]}], ",", "\n", "  ", 
     RowBox[{"GeoRange", " ", "->", " ", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{"41.79", ",", " ", "41.91"}], "}"}], ",", " ", 
        RowBox[{"{", 
         RowBox[{
          RowBox[{"-", "93.56"}], ",", " ", 
          RowBox[{"-", "93.44"}]}], "}"}]}], "}"}]}]}], "]"}]}]}]], "Input",Ex\
pressionUUID->"32039a9e-d0d3-fd4f-9a2f-c36af1f4a017"],

Cell["\<\
The logic is straightforward: zones with low NDVI (low productivity) often \
have depleted soil nitrogen and benefit from higher fertilizer application, \
while high-NDVI zones already have sufficient nutrient availability.\
\>", "Text",ExpressionUUID->"33c63a29-f740-d240-9b08-a2576eb592ee"],

Cell["", "Text",
 CellFrame->{{0, 0}, {0, 
  1}},ExpressionUUID->"cb11a854-a9fc-1b41-9874-0eb4c83c7b92"]
}, Open  ]]
}, Open  ]],

Cell[CellGroupData[{

Cell["5.6 Precision Agriculture Sensor Integration", "Chapter",ExpressionUUID->"c4d8669c-2ccf-a74f-a865-92877d6791cc"],

Cell["\<\
Satellite data provides broad spatial coverage but limited temporal \
resolution (5-16 day revisit) and moderate spatial resolution (10-30 m). \
Ground sensors, weather stations, drones, and GPS instruments fill these gaps.\
\>", "Text",ExpressionUUID->"5b35dc8b-4102-0846-a9a7-748965e4d480"],

Cell[CellGroupData[{

Cell["5.6.1 IoT Soil Sensors", "Section",ExpressionUUID->"e92905f8-e2c6-6a4d-b7d6-538c471306e8"],

Cell["\<\
Modern precision farms deploy networks of in-situ sensors measuring soil \
moisture, temperature, and electrical conductivity (EC) at multiple depths.\
\>", "Text",ExpressionUUID->"cb7817b6-b8fd-8b42-aff7-4c7b22a2167d"],

Cell[TextData[StyleBox["Importing and aligning sensor data.",
 FontWeight->Bold]], "Text",ExpressionUUID->"520e3126-6856-684a-97df-\
89750b202ed5"],

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{
    RowBox[{"Import", " ", "time"}], "-", 
    RowBox[{
    "series", " ", "data", " ", "from", " ", "a", " ", "soil", " ", 
     "moisture", " ", "sensor", " ", "network"}]}], " ", "*)"}], "\n", 
  RowBox[{
   RowBox[{
    RowBox[{"sensorData", " ", "=", " ", 
     RowBox[{"Import", "[", 
      RowBox[{"\"\<soil_sensors.csv\>\"", ",", " ", "\"\<Dataset\>\"", ",", 
       " ", 
       RowBox[{"HeaderLines", " ", "->", " ", "1"}]}], "]"}]}], ";"}], "\n", 
   "\n", 
   RowBox[{"(*", " ", 
    RowBox[{
     RowBox[{"Expected", " ", 
      RowBox[{"columns", ":", " ", "Timestamp"}]}], ",", " ", "SensorID", ",",
      " ", "Depth_cm", ",", " ", "Moisture_pct", ",", " ", "Temp_C", ",", " ",
      "EC"}], " ", "*)"}], "\n", 
   RowBox[{"sensorData", " ", "//", " ", "Dataset"}], "\n", "\n", 
   RowBox[{"(*", " ", 
    RowBox[{
    "Filter", " ", "to", " ", "a", " ", "single", " ", "sensor", " ", "at", " ",
      "30", " ", "cm", " ", "depth"}], " ", "*)"}], "\n", 
   RowBox[{
    RowBox[{"sensor42", " ", "=", " ", 
     RowBox[{"sensorData", "[", "\n", "  ", 
      RowBox[{"Select", "[", 
       RowBox[{
        RowBox[{
         RowBox[{"#SensorID", " ", "==", " ", "42"}], " ", "&&", " ", 
         RowBox[{
          RowBox[{"#Depth", "_cm"}], " ", "==", " ", "30"}]}], " ", "&"}], 
       "]"}], "\n", "]"}]}], ";"}], "\n", "\n", 
   RowBox[{"(*", " ", 
    RowBox[{"Build", " ", "a", " ", "TimeSeries", " ", "object"}], " ", 
    "*)"}], "\n", 
   RowBox[{
    RowBox[{"moistureTS", " ", "=", " ", 
     RowBox[{"TimeSeries", "[", "\n", "  ", 
      RowBox[{
       RowBox[{"Normal", "[", 
        RowBox[{"sensor42", "[", 
         RowBox[{"All", ",", " ", "\"\<Moisture_pct\>\""}], "]"}], "]"}], ",",
        "\n", "  ", 
       RowBox[{"{", 
        RowBox[{"Normal", "[", 
         RowBox[{"sensor42", "[", 
          RowBox[{"All", ",", " ", "\"\<Timestamp\>\""}], "]"}], "]"}], 
        "}"}]}], "\n", "]"}]}], ";"}], "\n", "\n", 
   RowBox[{"DateListPlot", "[", 
    RowBox[{"moistureTS", ",", "\n", "  ", 
     RowBox[{
     "PlotLabel", " ", "->", 
      " ", "\"\<Soil Moisture at 30 cm -- Sensor 42\>\""}], ",", "\n", "  ", 
     RowBox[{"FrameLabel", " ", "->", " ", 
      RowBox[{"{", 
       RowBox[{"\"\<Date\>\"", ",", 
        " ", "\"\<Volumetric Water Content (%)\>\""}], "}"}]}], ",", "\n", 
     "  ", 
     RowBox[{"PlotRange", " ", "->", " ", 
      RowBox[{"{", 
       RowBox[{"0", ",", " ", "50"}], "}"}]}], ",", "\n", "  ", 
     RowBox[{"PlotTheme", " ", "->", " ", "\"\<Scientific\>\""}]}], 
    "]"}]}]}]], "Input",ExpressionUUID->"65f4e313-7de9-df42-b865-\
9c713a57ade1"],

Cell[TextData[StyleBox["Aligning sensor data with satellite overpass dates.",
 FontWeight->Bold]], "Text",ExpressionUUID->"a700ad98-b399-dc4a-88cd-\
137b3fc7de76"],

Cell[TextData[{
 "Satellite-derived soil moisture and in-situ measurements must be compared \
at matching timestamps. ",
 Cell["TimeSeriesResample", "InlineCode",ExpressionUUID->
  "97d72b3e-68a5-7e41-a559-9111a520e155"],
 " handles the temporal alignment."
}], "Text",ExpressionUUID->"9fc45e77-bf33-9b4b-9341-e4e3ab422792"],

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{"Sentinel", "-", 
    RowBox[{
    "1", " ", "overpasses", " ", "occur", " ", "every", " ", "6", " ", "days",
      " ", "for", " ", "our", " ", "region"}]}], " ", "*)"}], "\n", 
  RowBox[{
   RowBox[{
    RowBox[{"sarDates", " ", "=", " ", 
     RowBox[{"DateRange", "[", "\n", "  ", 
      RowBox[{
       RowBox[{"DateObject", "[", 
        RowBox[{"{", 
         RowBox[{"2024", ",", " ", "6", ",", " ", "1"}], "}"}], "]"}], ",", 
       "\n", "  ", 
       RowBox[{"DateObject", "[", 
        RowBox[{"{", 
         RowBox[{"2024", ",", " ", "8", ",", " ", "31"}], "}"}], "]"}], ",", 
       "\n", "  ", 
       RowBox[{"Quantity", "[", 
        RowBox[{"6", ",", " ", "\"\<Days\>\""}], "]"}]}], "\n", "]"}]}], 
    ";"}], "\n", "\n", 
   RowBox[{"(*", " ", 
    RowBox[{
    "Resample", " ", "the", " ", "sensor", " ", "time", " ", "series", " ", 
     "to", " ", "satellite", " ", "overpass", " ", "dates"}], " ", "*)"}], "\n", 
   RowBox[{
    RowBox[{"alignedMoisture", " ", "=", " ", 
     RowBox[{"TimeSeriesResample", "[", 
      RowBox[{"moistureTS", ",", " ", 
       RowBox[{"{", "sarDates", "}"}]}], "]"}]}], ";"}], "\n", "\n", 
   RowBox[{"(*", " ", 
    RowBox[{
    "Now", " ", "extract", " ", "SAR", " ", "backscatter", " ", "at", " ", 
     "the", " ", "sensor", " ", "location", " ", "for", " ", "the", " ", 
     "same", " ", "dates"}], " ", "*)"}], "\n", 
   RowBox[{
    RowBox[{"sensorLocation", " ", "=", " ", 
     RowBox[{"GeoPosition", "[", 
      RowBox[{"{", 
       RowBox[{"41.85", ",", " ", 
        RowBox[{"-", "93.50"}]}], "}"}], "]"}]}], ";"}], "\n", "\n", 
   RowBox[{
    RowBox[{"sarValues", " ", "=", " ", 
     RowBox[{"Table", "[", "\n", "  ", 
      RowBox[{
       RowBox[{"Module", "[", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{
          "start", ",", " ", "end", ",", " ", "sar", ",", " ", "result"}], 
          "}"}], ",", "\n", "    ", 
         RowBox[{
          RowBox[{"start", " ", "=", " ", 
           RowBox[{"DateString", "[", 
            RowBox[{"date", ",", " ", 
             RowBox[{"{", 
              
              RowBox[{"\"\<Year\>\"", ",", " ", "\"\<-\>\"", ",", 
               " ", "\"\<Month\>\"", ",", " ", "\"\<-\>\"", ",", 
               " ", "\"\<Day\>\""}], "}"}]}], "]"}]}], ";", "\n", "    ", 
          RowBox[{"end", " ", "=", " ", 
           RowBox[{"DateString", "[", 
            RowBox[{
             RowBox[{"DatePlus", "[", 
              RowBox[{"date", ",", " ", 
               RowBox[{"{", 
                RowBox[{"2", ",", " ", "\"\<Day\>\""}], "}"}]}], "]"}], ",", 
             "\n", "      ", 
             RowBox[{"{", 
              
              RowBox[{"\"\<Year\>\"", ",", " ", "\"\<-\>\"", ",", 
               " ", "\"\<Month\>\"", ",", " ", "\"\<-\>\"", ",", 
               " ", "\"\<Day\>\""}], "}"}]}], "]"}]}], ";", "\n", "    ", 
          RowBox[{"sar", " ", "=", "\n", "      ", 
           RowBox[{
            RowBox[{
             RowBox[{
              RowBox[{
               RowBox[{
                RowBox[{
                 RowBox[{
                 "GEECollection", "[", "\"\<COPERNICUS/S1_GRD\>\"", "]"}], 
                 " ", "//", "\n", "        ", 
                 RowBox[{"GEEFilterDate", "[", 
                  RowBox[{"start", ",", " ", "end"}], "]"}]}], " ", "//", 
                "\n", "        ", 
                RowBox[{"GEEFilterBounds", "[", 
                 RowBox[{"{", 
                  RowBox[{
                   RowBox[{"-", "93.6"}], ",", " ", "41.7", ",", " ", 
                   RowBox[{"-", "93.4"}], ",", " ", "42.0"}], "}"}], "]"}]}], 
               " ", "//", "\n", "        ", 
               RowBox[{"GEEFilterProperty", "[", 
                
                RowBox[{"\"\<instrumentMode\>\"", ",", " ", "\"\<Equals\>\"", 
                 ",", " ", "\"\<IW\>\""}], "]"}]}], " ", "//", "\n", 
              "        ", 
              RowBox[{"GEEFilterProperty", "[", 
               
               RowBox[{"\"\<orbitProperties_pass\>\"", ",", 
                " ", "\"\<Equals\>\"", ",", " ", "\"\<ASCENDING\>\""}], 
               "]"}]}], " ", "//", "\n", "        ", 
             RowBox[{"GEESelectBands", "[", 
              RowBox[{"{", "\"\<VV\>\"", "}"}], "]"}]}], " ", "//", "\n", 
            "        ", "GEEMedian"}]}], ";", "\n", "    ", 
          RowBox[{"result", " ", "=", " ", 
           RowBox[{"GEEIdentify", "[", 
            RowBox[{"sensorLocation", ",", " ", "sar"}], "]"}]}], ";", "\n", 
          "    ", 
          RowBox[{"First", "[", 
           RowBox[{"result", "[", "\"\<Values\>\"", "]"}], "]"}]}]}], "\n", 
        "  ", "]"}], ",", "\n", "  ", 
       RowBox[{"{", 
        RowBox[{"date", ",", " ", "sarDates"}], "}"}]}], "\n", "]"}]}], ";"}],
    "\n", "\n", 
   RowBox[{"(*", " ", 
    RowBox[{"Validate", ":", " ", 
     RowBox[{
      RowBox[{
      "scatter", " ", "plot", " ", "of", " ", "SAR", " ", "backscatter", " ", 
       "vs", " ", "in"}], "-", 
      RowBox[{"situ", " ", "moisture"}]}]}], " ", "*)"}], "\n", 
   RowBox[{"ListPlot", "[", "\n", "  ", 
    RowBox[{
     RowBox[{"Transpose", "[", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"alignedMoisture", "[", "\"\<Values\>\"", "]"}], ",", " ", 
        "sarValues"}], "}"}], "]"}], ",", "\n", "  ", 
     RowBox[{"FrameLabel", " ", "->", " ", 
      RowBox[{"{", 
       RowBox[{"\"\<In-Situ Moisture (%)\>\"", ",", 
        " ", "\"\<SAR VV Backscatter (dB)\>\""}], "}"}]}], ",", "\n", "  ", 
     RowBox[{
     "PlotLabel", " ", "->", 
      " ", "\"\<Satellite vs Ground Truth Soil Moisture\>\""}], ",", "\n", 
     "  ", 
     RowBox[{"PlotStyle", " ", "->", " ", 
      RowBox[{"PointSize", "[", "0.015", "]"}]}], ",", "\n", "  ", 
     RowBox[{"PlotTheme", " ", "->", " ", "\"\<Scientific\>\""}]}], 
    "]"}]}]}]], "Input",ExpressionUUID->"b6201ac5-fea2-504b-b211-\
4f26023bac51"]
}, Open  ]],

Cell[CellGroupData[{

Cell["5.6.2 Weather Station Data", "Section",ExpressionUUID->"b67e7f4a-0a66-2947-a69c-05f313a1b192"],

Cell[TextData[{
 "Wolfram Language provides built-in access to weather station observations \
via ",
 Cell["WeatherData", "InlineCode",ExpressionUUID->
  "1ae2aaac-e08e-5843-b7a9-b40263a7f0f3"],
 ". Comparing these with GEE gridded climate products (such as ERA5) reveals \
systematic biases that can be corrected."
}], "Text",ExpressionUUID->"62c988b8-a1ab-0444-94f8-3a3a9597067a"],

Cell[TextData[StyleBox["Comparing ground station temperature with ERA5 \
reanalysis.",
 FontWeight->Bold]], "Text",ExpressionUUID->"d09f5910-8b41-be4e-ad57-\
6e827f173f41"],

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{
    RowBox[{"Ground", " ", 
     RowBox[{"station", ":", " ", 
      RowBox[{"Des", " ", "Moines"}]}]}], ",", " ", "IA"}], " ", "*)"}], "\n", 
  RowBox[{
   RowBox[{
    RowBox[{"stationTemp", " ", "=", " ", 
     RowBox[{"WeatherData", "[", "\n", "  ", 
      RowBox[{
       RowBox[{"Entity", "[", 
        RowBox[{"\"\<WeatherStation\>\"", ",", " ", "\"\<KDSM\>\""}], "]"}], ",",
        "\n", "  ", "\"\<MeanTemperature\>\"", ",", "\n", "  ", 
       RowBox[{"{", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{"2024", ",", " ", "6", ",", " ", "1"}], "}"}], ",", " ", 
         RowBox[{"{", 
          RowBox[{"2024", ",", " ", "8", ",", " ", "31"}], "}"}], ",", 
         " ", "\"\<Day\>\""}], "}"}]}], "\n", "]"}]}], ";"}], "\n", "\n", 
   RowBox[{"(*", " ", 
    RowBox[{
    "ERA5", " ", "daily", " ", "mean", " ", "temperature", " ", "at", " ", 
     "the", " ", "same", " ", "location"}], " ", "*)"}], "\n", 
   RowBox[{
    RowBox[{"stationPos", " ", "=", " ", 
     RowBox[{"GeoPosition", "[", 
      RowBox[{"{", 
       RowBox[{"41.534", ",", " ", 
        RowBox[{"-", "93.663"}]}], "}"}], "]"}]}], ";"}], "\n", "\n", 
   RowBox[{
    RowBox[{"era5Temps", " ", "=", " ", 
     RowBox[{"Table", "[", "\n", "  ", 
      RowBox[{
       RowBox[{"Module", "[", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{"start", ",", " ", "end", ",", " ", "result"}], "}"}], ",", 
         "\n", "    ", 
         RowBox[{
          RowBox[{"start", " ", "=", " ", 
           RowBox[{"DateString", "[", 
            RowBox[{"date", ",", " ", 
             RowBox[{"{", 
              
              RowBox[{"\"\<Year\>\"", ",", " ", "\"\<-\>\"", ",", 
               " ", "\"\<Month\>\"", ",", " ", "\"\<-\>\"", ",", 
               " ", "\"\<Day\>\""}], "}"}]}], "]"}]}], ";", "\n", "    ", 
          RowBox[{"end", " ", "=", " ", 
           RowBox[{"DateString", "[", 
            RowBox[{
             RowBox[{"DatePlus", "[", 
              RowBox[{"date", ",", " ", 
               RowBox[{"{", 
                RowBox[{"1", ",", " ", "\"\<Day\>\""}], "}"}]}], "]"}], ",", 
             "\n", "      ", 
             RowBox[{"{", 
              
              RowBox[{"\"\<Year\>\"", ",", " ", "\"\<-\>\"", ",", 
               " ", "\"\<Month\>\"", ",", " ", "\"\<-\>\"", ",", 
               " ", "\"\<Day\>\""}], "}"}]}], "]"}]}], ";", "\n", "    ", 
          RowBox[{"result", " ", "=", " ", 
           RowBox[{"GEEIdentify", "[", 
            RowBox[{"stationPos", ",", "\n", "      ", 
             RowBox[{
              RowBox[{
               RowBox[{
                RowBox[{
                "GEECollection", "[", "\"\<ECMWF/ERA5_LAND/DAILY_AGGR\>\"", 
                 "]"}], " ", "//", "\n", "        ", 
                RowBox[{"GEEFilterDate", "[", 
                 RowBox[{"start", ",", " ", "end"}], "]"}]}], " ", "//", "\n",
                "        ", "GEEFirst"}], " ", "//", "\n", "        ", 
              RowBox[{"GEESelectBands", "[", 
               RowBox[{"{", "\"\<temperature_2m\>\"", "}"}], "]"}]}]}], "\n", 
            "    ", "]"}]}], ";", "\n", "    ", 
          RowBox[{
           RowBox[{"First", "[", 
            RowBox[{"result", "[", "\"\<Values\>\"", "]"}], "]"}], " ", "-", 
           " ", "273.15"}]}]}], "  ", 
        RowBox[{"(*", " ", 
         RowBox[{"Kelvin", " ", "to", " ", "Celsius"}], " ", "*)"}], "\n", 
        "  ", "]"}], ",", "\n", "  ", 
       RowBox[{"{", 
        RowBox[{"date", ",", " ", 
         RowBox[{"DateRange", "[", 
          RowBox[{
           RowBox[{"DateObject", "[", 
            RowBox[{"{", 
             RowBox[{"2024", ",", " ", "6", ",", " ", "1"}], "}"}], "]"}], ",",
            " ", 
           RowBox[{"DateObject", "[", 
            RowBox[{"{", 
             RowBox[{"2024", ",", " ", "8", ",", " ", "31"}], "}"}], "]"}], ",",
            "\n", "    ", 
           RowBox[{"Quantity", "[", 
            RowBox[{"1", ",", " ", "\"\<Day\>\""}], "]"}]}], "]"}]}], "}"}]}],
       "\n", "]"}]}], ";"}], "\n", "\n", 
   RowBox[{"(*", " ", 
    RowBox[{"Bias", " ", "correction", " ", "using", " ", "LinearModelFit"}], 
    " ", "*)"}], "\n", 
   RowBox[{
    RowBox[{"stationValues", " ", "=", " ", 
     RowBox[{"QuantityMagnitude", "[", 
      RowBox[{
       RowBox[{"stationTemp", "[", "\"\<Values\>\"", "]"}], ",", 
       " ", "\"\<DegreesCelsius\>\""}], "]"}]}], ";"}], "\n", "\n", 
   RowBox[{
    RowBox[{"biasModel", " ", "=", " ", 
     RowBox[{"LinearModelFit", "[", "\n", "  ", 
      RowBox[{
       RowBox[{"Transpose", "[", 
        RowBox[{"{", 
         RowBox[{"era5Temps", ",", " ", "stationValues"}], "}"}], "]"}], ",", 
       "\n", "  ", "x", ",", " ", "x"}], "\n", "]"}]}], ";"}], "\n", "\n", 
   RowBox[{"(*", " ", 
    RowBox[{
    "The", " ", "slope", " ", "and", " ", "intercept", " ", "correct", " ", 
     "ERA5", " ", "to", " ", "match", " ", "station", " ", "observations"}], 
    " ", "*)"}], "\n", 
   RowBox[{"biasModel", "[", "\"\<BestFitParameters\>\"", "]"}], "\n", 
   RowBox[{"biasModel", "[", "\"\<RSquared\>\"", "]"}], "\n", "\n", 
   RowBox[{"DateListPlot", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"stationTemp", ",", " ", 
       RowBox[{"TimeSeries", "[", 
        RowBox[{"era5Temps", ",", "\n", "    ", 
         RowBox[{"{", 
          RowBox[{"DateRange", "[", 
           RowBox[{
            RowBox[{"DateObject", "[", 
             RowBox[{"{", 
              RowBox[{"2024", ",", " ", "6", ",", " ", "1"}], "}"}], "]"}], ",",
             " ", 
            RowBox[{"DateObject", "[", 
             RowBox[{"{", 
              RowBox[{"2024", ",", " ", "8", ",", " ", "31"}], "}"}], "]"}], ",",
             "\n", "      ", 
            RowBox[{"Quantity", "[", 
             RowBox[{"1", ",", " ", "\"\<Day\>\""}], "]"}]}], "]"}], "}"}]}], 
        "]"}]}], "}"}], ",", "\n", "  ", 
     RowBox[{"PlotLegends", " ", "->", " ", 
      RowBox[{"{", 
       RowBox[{"\"\<Weather Station\>\"", ",", 
        " ", "\"\<ERA5 Reanalysis\>\""}], "}"}]}], ",", "\n", "  ", 
     RowBox[{
     "PlotLabel", " ", "->", 
      " ", "\"\<Temperature Comparison -- Des Moines, IA\>\""}], ",", "\n", 
     "  ", 
     RowBox[{"FrameLabel", " ", "->", " ", 
      RowBox[{"{", 
       RowBox[{"\"\<Date\>\"", ",", " ", "\"\<Temperature (\[Degree]C)\>\""}],
        "}"}]}], ",", "\n", "  ", 
     RowBox[{"PlotTheme", " ", "->", " ", "\"\<Scientific\>\""}]}], 
    "]"}]}]}]], "Input",ExpressionUUID->"dcf535e7-4147-5343-8968-\
ee0b2d738024"]
}, Open  ]],

Cell[CellGroupData[{

Cell["5.6.3 Drone Multispectral Imagery", "Section",ExpressionUUID->"84e7ec72-a014-5647-b480-e82db0901cd1"],

Cell["\<\
Drones equipped with multispectral cameras (MicaSense RedEdge, DJI P4 \
Multispectral) capture imagery at centimeter resolution. Comparing drone NDVI \
with satellite NDVI validates both data sources and enables temporal fusion.\
\>", "Text",ExpressionUUID->"f2a39d48-5c0a-5249-ae36-766c275269bf"],

Cell[TextData[StyleBox["Import drone GeoTIFF and compute NDVI locally.",
 FontWeight->Bold]], "Text",ExpressionUUID->"ee1d35a8-67c7-4a40-90d3-\
de6e8d4bfc3c"],

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{
    RowBox[{"Import", " ", "a", " ", "5"}], "-", 
    RowBox[{
    "band", " ", "multispectral", " ", "GeoTIFF", " ", "from", " ", "a", " ", 
     "drone", " ", "flight"}]}], " ", "*)"}], "\n", 
  RowBox[{
   RowBox[{
    RowBox[{"droneRaster", " ", "=", " ", 
     RowBox[{"Import", "[", 
      RowBox[{"\"\<drone_multispectral.tif\>\"", ",", 
       " ", "\"\<GeoTIFF\>\""}], "]"}]}], ";"}], "\n", "\n", 
   RowBox[{"(*", " ", 
    RowBox[{
     RowBox[{"MicaSense", " ", "RedEdge", " ", "band", " ", 
      RowBox[{"order", ":", " ", "Blue"}]}], ",", " ", "Green", ",", " ", 
     "Red", ",", " ", "RedEdge", ",", " ", "NIR"}], " ", "*)"}], "\n", 
   RowBox[{
    RowBox[{"droneBands", " ", "=", " ", 
     RowBox[{"ImageData", " ", "/@", " ", 
      RowBox[{"ColorSeparate", "[", 
       RowBox[{"droneRaster", "[", "\"\<Image\>\"", "]"}], "]"}]}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"nirBand", " ", "=", " ", 
     RowBox[{"droneBands", "[", 
      RowBox[{"[", "5", "]"}], "]"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"redBand", " ", "=", " ", 
     RowBox[{"droneBands", "[", 
      RowBox[{"[", "3", "]"}], "]"}]}], ";"}], "\n", "\n", 
   RowBox[{
    RowBox[{"droneNDVI", " ", "=", " ", 
     RowBox[{"Image", "[", 
      RowBox[{
       RowBox[{"(", 
        RowBox[{"nirBand", " ", "-", " ", "redBand"}], ")"}], " ", "/", " ", 
       RowBox[{"(", 
        RowBox[{
        "nirBand", " ", "+", " ", "redBand", " ", "+", " ", "0.0001"}], 
        ")"}]}], "]"}]}], ";"}], "\n", "\n", 
   RowBox[{"(*", " ", 
    RowBox[{
    "Visualize", " ", "with", " ", "a", " ", "green", " ", "palette"}], " ", 
    "*)"}], "\n", 
   RowBox[{"Colorize", "[", 
    RowBox[{"droneNDVI", ",", "\n", "  ", 
     RowBox[{"ColorFunction", " ", "->", " ", 
      RowBox[{"(", 
       RowBox[{
        RowBox[{"Blend", "[", 
         RowBox[{
          RowBox[{"{", 
           RowBox[{"Brown", ",", " ", "Yellow", ",", " ", "Green", ",", " ", 
            RowBox[{"Darker", "[", "Green", "]"}]}], "}"}], ",", " ", "#"}], 
         "]"}], " ", "&"}], ")"}]}], ",", "\n", "  ", 
     RowBox[{
     "PlotLabel", " ", "->", " ", "\"\<Drone NDVI (5 cm resolution)\>\""}]}], 
    "]"}]}]}]], "Input",ExpressionUUID->"e60535f3-6fe7-fe42-bb21-\
28d5902a6784"],

Cell[TextData[StyleBox["Compare drone NDVI with Sentinel-2 NDVI.",
 FontWeight->Bold]], "Text",ExpressionUUID->"d195004e-47ee-cd4e-8eb6-\
46a1f6200242"],

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{"Sentinel", "-", 
    RowBox[{
    "2", " ", "NDVI", " ", "for", " ", "the", " ", "same", " ", "date", " ", 
     "and", " ", "area"}]}], " ", "*)"}], "\n", 
  RowBox[{
   RowBox[{
    RowBox[{"droneFlightDate", " ", "=", " ", "\"\<2024-07-20\>\""}], ";"}], "\n", 
   RowBox[{
    RowBox[{"droneBBox", " ", "=", " ", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"-", "93.52"}], ",", " ", "41.84", ",", " ", 
       RowBox[{"-", "93.48"}], ",", " ", "41.88"}], "}"}]}], ";"}], "\n", "\n", 
   RowBox[{
    RowBox[{"sentinelNDVI", " ", "=", "\n", "  ", 
     RowBox[{
      RowBox[{
       RowBox[{
        RowBox[{
         RowBox[{
          RowBox[{
          "GEECollection", "[", "\"\<COPERNICUS/S2_SR_HARMONIZED\>\"", "]"}], 
          " ", "//", "\n", "    ", 
          RowBox[{"GEEFilterDate", "[", 
           RowBox[{"\"\<2024-07-18\>\"", ",", " ", "\"\<2024-07-22\>\""}], 
           "]"}]}], " ", "//", "\n", "    ", 
         RowBox[{"GEEFilterBounds", "[", "droneBBox", "]"}]}], " ", "//", 
        "\n", "    ", 
        RowBox[{"GEEFilterProperty", "[", 
         RowBox[{"\"\<CLOUDY_PIXEL_PERCENTAGE\>\"", ",", 
          " ", "\"\<LessThan\>\"", ",", " ", "20"}], "]"}]}], " ", "//", "\n",
        "    ", "GEEMedian"}], " ", "//", "\n", "    ", 
      RowBox[{"GEENormalizedDifference", "[", 
       RowBox[{"{", 
        RowBox[{"\"\<B8\>\"", ",", " ", "\"\<B4\>\""}], "}"}], "]"}]}]}], 
    ";"}], "\n", "\n", 
   RowBox[{
    RowBox[{"sentinelImage", " ", "=", " ", 
     RowBox[{"GEEComputePixels", "[", 
      RowBox[{"droneBBox", ",", " ", "sentinelNDVI", ",", " ", 
       RowBox[{"\"\<ImageSize\>\"", " ", "->", " ", "256"}]}], "]"}]}], ";"}],
    "\n", "\n", 
   RowBox[{"(*", " ", 
    RowBox[{
     RowBox[{
     "Downscale", " ", "drone", " ", "NDVI", " ", "to", " ", "match", " ", 
      "Sentinel"}], "-", 
     RowBox[{"2", " ", "resolution", " ", "for", " ", "comparison"}]}], " ", 
    "*)"}], "\n", 
   RowBox[{
    RowBox[{"droneDownscaled", " ", "=", " ", 
     RowBox[{"ImageResize", "[", 
      RowBox[{"droneNDVI", ",", " ", 
       RowBox[{"ImageDimensions", "[", "sentinelImage", "]"}]}], "]"}]}], 
    ";"}], "\n", "\n", 
   RowBox[{"(*", " ", 
    RowBox[{"Pixel", "-", "by", "-", 
     RowBox[{"pixel", " ", "correlation"}]}], " ", "*)"}], "\n", 
   RowBox[{
    RowBox[{"sentinelValues", " ", "=", " ", 
     RowBox[{"Flatten", "[", 
      RowBox[{"ImageData", "[", "sentinelImage", "]"}], "]"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"droneValues", " ", "=", " ", 
     RowBox[{"Flatten", "[", 
      RowBox[{"ImageData", "[", "droneDownscaled", "]"}], "]"}]}], ";"}], 
   "\n", "\n", 
   RowBox[{"ListPlot", "[", 
    RowBox[{
     RowBox[{"Transpose", "[", 
      RowBox[{"{", 
       RowBox[{"droneValues", ",", " ", "sentinelValues"}], "}"}], "]"}], ",",
      "\n", "  ", 
     RowBox[{"FrameLabel", " ", "->", " ", 
      RowBox[{"{", 
       RowBox[{"\"\<Drone NDVI (resampled)\>\"", ",", 
        " ", "\"\<Sentinel-2 NDVI\>\""}], "}"}]}], ",", "\n", "  ", 
     RowBox[{
     "PlotLabel", " ", "->", " ", "\"\<Cross-Platform NDVI Validation\>\""}], 
     ",", "\n", "  ", 
     RowBox[{"PlotStyle", " ", "->", " ", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"PointSize", "[", "0.003", "]"}], ",", " ", 
        RowBox[{"Opacity", "[", "0.3", "]"}]}], "}"}]}], ",", "\n", "  ", 
     RowBox[{"Epilog", " ", "->", " ", 
      RowBox[{"{", 
       RowBox[{"Red", ",", " ", "Dashed", ",", " ", 
        RowBox[{"InfiniteLine", "[", 
         RowBox[{
          RowBox[{"{", 
           RowBox[{"0", ",", " ", "0"}], "}"}], ",", " ", 
          RowBox[{"{", 
           RowBox[{"1", ",", " ", "1"}], "}"}]}], "]"}]}], "}"}]}], ",", "\n",
      "  ", 
     RowBox[{"PlotTheme", " ", "->", " ", "\"\<Scientific\>\""}], ",", "\n", 
     "  ", 
     RowBox[{"AspectRatio", " ", "->", " ", "1"}]}], "]"}]}]}]], "Input",Expre\
ssionUUID->"bc39ef7b-c6db-034f-b76e-961e307103d2"],

Cell["\<\
The 1:1 line (red dashed) shows the ideal agreement. Systematic offsets \
indicate calibration differences between the drone sensor and Sentinel-2.\
\>", "Text",ExpressionUUID->"2c236016-ebf6-9948-be4f-1c92b883edf5"],

Cell[TextData[StyleBox["Temporal fusion: filling gaps between satellite \
passes with drone data.",
 FontWeight->Bold]], "Text",ExpressionUUID->"8e25dca8-2f68-1b49-8413-\
7c37e7fcce09"],

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{
   "Satellite", " ", "NDVI", " ", "available", " ", "roughly", " ", "every", " ",
     "5", " ", "days"}], " ", "*)"}], "\n", 
  RowBox[{
   RowBox[{
    RowBox[{"satelliteDates", " ", "=", " ", 
     RowBox[{"DateRange", "[", "\n", "  ", 
      RowBox[{
       RowBox[{"DateObject", "[", 
        RowBox[{"{", 
         RowBox[{"2024", ",", " ", "7", ",", " ", "1"}], "}"}], "]"}], ",", 
       " ", 
       RowBox[{"DateObject", "[", 
        RowBox[{"{", 
         RowBox[{"2024", ",", " ", "8", ",", " ", "31"}], "}"}], "]"}], ",", 
       "\n", "  ", 
       RowBox[{"Quantity", "[", 
        RowBox[{"5", ",", " ", "\"\<Days\>\""}], "]"}]}], "]"}]}], ";"}], 
   "\n", "\n", 
   RowBox[{
    RowBox[{"satelliteNDVIMeans", " ", "=", " ", 
     RowBox[{"Table", "[", "\n", "  ", 
      RowBox[{
       RowBox[{"Module", "[", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{
          "start", ",", " ", "end", ",", " ", "ndvi", ",", " ", "geom", ",", 
           " ", "stats"}], "}"}], ",", "\n", "    ", 
         RowBox[{
          RowBox[{"start", " ", "=", " ", 
           RowBox[{"DateString", "[", 
            RowBox[{"d", ",", " ", 
             RowBox[{"{", 
              
              RowBox[{"\"\<Year\>\"", ",", " ", "\"\<-\>\"", ",", 
               " ", "\"\<Month\>\"", ",", " ", "\"\<-\>\"", ",", 
               " ", "\"\<Day\>\""}], "}"}]}], "]"}]}], ";", "\n", "    ", 
          RowBox[{"end", " ", "=", " ", 
           RowBox[{"DateString", "[", 
            RowBox[{
             RowBox[{"DatePlus", "[", 
              RowBox[{"d", ",", " ", 
               RowBox[{"{", 
                RowBox[{"3", ",", " ", "\"\<Day\>\""}], "}"}]}], "]"}], ",", 
             "\n", "      ", 
             RowBox[{"{", 
              
              RowBox[{"\"\<Year\>\"", ",", " ", "\"\<-\>\"", ",", 
               " ", "\"\<Month\>\"", ",", " ", "\"\<-\>\"", ",", 
               " ", "\"\<Day\>\""}], "}"}]}], "]"}]}], ";", "\n", "    ", 
          RowBox[{"geom", " ", "=", " ", 
           RowBox[{"GEEGeometry", "[", "droneBBox", "]"}]}], ";", "\n", 
          "    ", 
          RowBox[{"ndvi", " ", "=", "\n", "      ", 
           RowBox[{
            RowBox[{
             RowBox[{
              RowBox[{
               RowBox[{
                RowBox[{
                "GEECollection", "[", "\"\<COPERNICUS/S2_SR_HARMONIZED\>\"", 
                 "]"}], " ", "//", "\n", "        ", 
                RowBox[{"GEEFilterDate", "[", 
                 RowBox[{"start", ",", " ", "end"}], "]"}]}], " ", "//", "\n",
                "        ", 
               RowBox[{"GEEFilterBounds", "[", "droneBBox", "]"}]}], " ", "//",
               "\n", "        ", 
              RowBox[{"GEEFilterProperty", "[", 
               
               RowBox[{"\"\<CLOUDY_PIXEL_PERCENTAGE\>\"", ",", 
                " ", "\"\<LessThan\>\"", ",", " ", "30"}], "]"}]}], " ", "//",
              "\n", "        ", "GEEMedian"}], " ", "//", "\n", "        ", 
            RowBox[{"GEENormalizedDifference", "[", 
             RowBox[{"{", 
              RowBox[{"\"\<B8\>\"", ",", " ", "\"\<B4\>\""}], "}"}], 
             "]"}]}]}], ";", "\n", "    ", 
          RowBox[{"stats", " ", "=", " ", 
           RowBox[{"GEECompute", "[", 
            RowBox[{"ndvi", " ", "//", " ", 
             RowBox[{"GEEReduceRegion", "[", 
              RowBox[{"geom", ",", " ", "\"\<mean\>\"", ",", " ", "10"}], 
              "]"}]}], "]"}]}], ";", "\n", "    ", 
          RowBox[{"stats", "[", "\"\<nd\>\"", "]"}]}]}], "\n", "  ", "]"}], ",",
        "\n", "  ", 
       RowBox[{"{", 
        RowBox[{"d", ",", " ", "satelliteDates"}], "}"}]}], "\n", "]"}]}], 
    ";"}], "\n", "\n", 
   RowBox[{"(*", " ", 
    RowBox[{
    "Drone", " ", "flights", " ", "fill", " ", "specific", " ", "gaps"}], " ",
     "*)"}], "\n", 
   RowBox[{
    RowBox[{"droneFlightDates", " ", "=", " ", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"DateObject", "[", 
        RowBox[{"{", 
         RowBox[{"2024", ",", " ", "7", ",", " ", "12"}], "}"}], "]"}], ",", 
       " ", 
       RowBox[{"DateObject", "[", 
        RowBox[{"{", 
         RowBox[{"2024", ",", " ", "7", ",", " ", "20"}], "}"}], "]"}], ",", 
       "\n", "  ", 
       RowBox[{"DateObject", "[", 
        RowBox[{"{", 
         RowBox[{"2024", ",", " ", "8", ",", " ", "5"}], "}"}], "]"}]}], 
      "}"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"droneMeanNDVI", " ", "=", " ", 
     RowBox[{"{", 
      RowBox[{"0.72", ",", " ", "0.78", ",", " ", "0.81"}], "}"}]}], ";"}], 
   "  ", 
   RowBox[{"(*", " ", 
    RowBox[{"Field", "-", 
     RowBox[{"average", " ", "from", " ", "drone", " ", "imagery"}]}], " ", 
    "*)"}], "\n", "\n", 
   RowBox[{"(*", " ", 
    RowBox[{
    "Merge", " ", "into", " ", "a", " ", "single", " ", "time", " ", 
     "series"}], " ", "*)"}], "\n", 
   RowBox[{
    RowBox[{"allDates", " ", "=", " ", 
     RowBox[{"Sort", " ", "@", " ", 
      RowBox[{"Join", "[", 
       RowBox[{"satelliteDates", ",", " ", "droneFlightDates"}], "]"}]}]}], 
    ";"}], "\n", 
   RowBox[{
    RowBox[{"allValues", " ", "=", " ", 
     RowBox[{
      RowBox[{
       RowBox[{"Join", "[", "\n", "  ", 
        RowBox[{
         RowBox[{"Thread", "[", 
          RowBox[{"satelliteDates", " ", "->", " ", "satelliteNDVIMeans"}], 
          "]"}], ",", "\n", "  ", 
         RowBox[{"Thread", "[", 
          RowBox[{"droneFlightDates", " ", "->", " ", "droneMeanNDVI"}], 
          "]"}]}], "\n", "]"}], " ", "//", " ", 
       RowBox[{"SortBy", "[", "First", "]"}]}], " ", "//", " ", "Values"}]}], 
    ";"}], "\n", "\n", 
   RowBox[{
    RowBox[{"fusedTS", " ", "=", " ", 
     RowBox[{"TimeSeries", "[", 
      RowBox[{"allValues", ",", " ", 
       RowBox[{"{", "allDates", "}"}]}], "]"}]}], ";"}], "\n", "\n", 
   RowBox[{"DateListPlot", "[", 
    RowBox[{"fusedTS", ",", "\n", "  ", 
     RowBox[{
     "PlotLabel", " ", "->", 
      " ", "\"\<Fused Satellite + Drone NDVI Time Series\>\""}], ",", "\n", 
     "  ", 
     RowBox[{"FrameLabel", " ", "->", " ", 
      RowBox[{"{", 
       RowBox[{"\"\<Date\>\"", ",", " ", "\"\<Field Mean NDVI\>\""}], "}"}]}],
      ",", "\n", "  ", 
     RowBox[{"PlotMarkers", " ", "->", " ", "Automatic"}], ",", "\n", "  ", 
     RowBox[{"PlotTheme", " ", "->", " ", "\"\<Scientific\>\""}]}], 
    "]"}]}]}]], "Input",ExpressionUUID->"2b57c42c-2200-5d40-ae42-\
4daf0d6dcf00"]
}, Open  ]],

Cell[CellGroupData[{

Cell["5.6.4 GNSS/RTK Positioning for Field Sampling", "Section",ExpressionUUID->"8d1561c9-3818-054d-b4f6-5af0298e5e41"],

Cell[TextData[{
 "High-precision GPS coordinates from RTK-enabled receivers georeferenced \
field samples (soil cores, yield monitor points) to within centimeters. These \
coordinates feed directly into ",
 Cell["GEEGetSamples", "InlineCode",ExpressionUUID->
  "2cfa5d49-efc3-3740-add6-aff24d8fa498"],
 " for multi-point extraction."
}], "Text",ExpressionUUID->"5fc5cb33-b1b7-7941-937e-ccb34e0ac1cc"],

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{
   "Import", " ", "RTK", " ", "GPS", " ", "coordinates", " ", "from", " ", 
    "a", " ", "field", " ", "sampling", " ", "campaign"}], " ", "*)"}], "\n", 
  RowBox[{
   RowBox[{
    RowBox[{"gpsData", " ", "=", " ", 
     RowBox[{"Import", "[", 
      RowBox[{"\"\<field_samples_rtk.csv\>\"", ",", " ", "\"\<Dataset\>\"", ",",
        " ", 
       RowBox[{"HeaderLines", " ", "->", " ", "1"}]}], "]"}]}], ";"}], "\n", 
   "\n", 
   RowBox[{"(*", " ", 
    RowBox[{
     RowBox[{"Expected", " ", 
      RowBox[{"columns", ":", " ", "SampleID"}]}], ",", " ", "Latitude", ",", 
     " ", "Longitude", ",", " ", 
     RowBox[{"Yield_bu", "_acre"}]}], " ", "*)"}], "\n", 
   RowBox[{
    RowBox[{"samplePositions", " ", "=", " ", 
     RowBox[{
      RowBox[{
       RowBox[{"GeoPosition", "[", 
        RowBox[{"{", 
         RowBox[{"#Latitude", ",", " ", "#Longitude"}], "}"}], "]"}], " ", 
       "&"}], " ", "/@", "\n", "  ", 
      RowBox[{"Normal", "[", "gpsData", "]"}]}]}], ";"}], "\n", "\n", 
   RowBox[{"(*", " ", 
    RowBox[{
     RowBox[{"Extract", " ", "multi"}], "-", 
     RowBox[{
     "band", " ", "satellite", " ", "data", " ", "at", " ", "each", " ", 
      "GPS", " ", "point"}]}], " ", "*)"}], "\n", 
   RowBox[{
    RowBox[{"multiBandComposite", " ", "=", "\n", "  ", 
     RowBox[{
      RowBox[{
       RowBox[{
        RowBox[{
         RowBox[{
          RowBox[{
          "GEECollection", "[", "\"\<COPERNICUS/S2_SR_HARMONIZED\>\"", "]"}], 
          " ", "//", "\n", "    ", 
          RowBox[{"GEEFilterDate", "[", 
           RowBox[{"\"\<2024-07-15\>\"", ",", " ", "\"\<2024-08-15\>\""}], 
           "]"}]}], " ", "//", "\n", "    ", 
         RowBox[{"GEEFilterBounds", "[", 
          RowBox[{"{", 
           RowBox[{
            RowBox[{"-", "93.6"}], ",", " ", "41.7", ",", " ", 
            RowBox[{"-", "93.4"}], ",", " ", "42.0"}], "}"}], "]"}]}], " ", "//",
         "\n", "    ", 
        RowBox[{"GEEFilterProperty", "[", 
         RowBox[{"\"\<CLOUDY_PIXEL_PERCENTAGE\>\"", ",", 
          " ", "\"\<LessThan\>\"", ",", " ", "15"}], "]"}]}], " ", "//", "\n",
        "    ", "GEEMedian"}], " ", "//", "\n", "    ", 
      RowBox[{"GEESelectBands", "[", 
       RowBox[{"{", 
        RowBox[{"\"\<B2\>\"", ",", " ", "\"\<B3\>\"", ",", " ", "\"\<B4\>\"", 
         ",", " ", "\"\<B8\>\"", ",", " ", "\"\<B11\>\"", ",", 
         " ", "\"\<B12\>\""}], "}"}], "]"}]}]}], ";"}], "\n", "\n", 
   RowBox[{
    RowBox[{"spectralData", " ", "=", " ", 
     RowBox[{"GEEGetSamples", "[", 
      RowBox[{"samplePositions", ",", " ", "multiBandComposite"}], "]"}]}], 
    ";"}], "\n", "\n", 
   RowBox[{"(*", " ", 
    RowBox[{
    "Combine", " ", "with", " ", "yield", " ", "data", " ", "for", " ", 
     "regression", " ", "modeling"}], " ", "*)"}], "\n", 
   RowBox[{
    RowBox[{"yieldValues", " ", "=", " ", 
     RowBox[{"Normal", "[", 
      RowBox[{"gpsData", "[", 
       RowBox[{"All", ",", " ", "\"\<Yield_bu_acre\>\""}], "]"}], "]"}]}], 
    ";"}], "\n", 
   RowBox[{
    RowBox[{"featureVectors", " ", "=", " ", 
     RowBox[{
      RowBox[{
       RowBox[{"#", "[", "\"\<Values\>\"", "]"}], " ", "&"}], " ", "/@", " ", 
      "spectralData"}]}], ";"}], "\n", "\n", 
   RowBox[{
    RowBox[{"multiVariateModel", " ", "=", " ", 
     RowBox[{"LinearModelFit", "[", "\n", "  ", 
      RowBox[{
       RowBox[{"Join", "[", 
        RowBox[{"featureVectors", ",", " ", 
         RowBox[{"List", " ", "/@", " ", "yieldValues"}], ",", " ", "2"}], 
        "]"}], ",", "\n", "  ", 
       RowBox[{"{", 
        RowBox[{
        "b2", ",", " ", "b3", ",", " ", "b4", ",", " ", "b8", ",", " ", "b11",
          ",", " ", "b12"}], "}"}], ",", "\n", "  ", 
       RowBox[{"{", 
        RowBox[{
        "b2", ",", " ", "b3", ",", " ", "b4", ",", " ", "b8", ",", " ", "b11",
          ",", " ", "b12"}], "}"}]}], "\n", "]"}]}], ";"}], "\n", "\n", 
   RowBox[{"multiVariateModel", "[", "\"\<RSquared\>\"", "]"}], "\n", 
   RowBox[{
   "multiVariateModel", "[", "\"\<ParameterTable\>\"", "]"}]}]}]], "Input",Exp\
ressionUUID->"a39da020-63d3-0846-816d-d9134b062b8b"],

Cell["\<\
Using the full spectral signature (not just NDVI) typically improves yield \
prediction because shortwave infrared bands capture moisture stress and soil \
background effects that NDVI alone misses.\
\>", "Text",ExpressionUUID->"e73e552d-f87a-9f4f-b5da-228f25deb4fe"],

Cell["", "Text",
 CellFrame->{{0, 0}, {0, 
  1}},ExpressionUUID->"f419b29f-5ae6-b848-80c0-178d35be1d57"]
}, Open  ]]
}, Open  ]],

Cell[CellGroupData[{

Cell["5.7 Field Boundary Detection", "Chapter",ExpressionUUID->"8c757fa6-8763-7a4f-b8de-ce03c7def796"],

Cell["\<\
Detecting field boundaries from satellite imagery is useful for delineating \
management units without manual digitization. NDVI gradients mark the edges \
between fields with different crop types or management practices.\
\>", "Text",ExpressionUUID->"6ced16de-e2ed-1b42-afd3-deab4e493765"],

Cell[TextData[StyleBox["Step 1: Compute NDVI gradient magnitude.",
 FontWeight->Bold]], "Text",ExpressionUUID->"9e32d284-244b-7c4f-90ee-\
196b1da6d1a6"],

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"fieldBoundaryRegion", " ", "=", " ", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{"-", "93.5"}], ",", " ", "41.8", ",", " ", 
      RowBox[{"-", "93.3"}], ",", " ", "42.0"}], "}"}]}], ";"}], "\n"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"ndviForEdges", " ", "=", "\n", "  ", 
    RowBox[{
     RowBox[{
      RowBox[{
       RowBox[{
        RowBox[{
         RowBox[{
         "GEECollection", "[", "\"\<COPERNICUS/S2_SR_HARMONIZED\>\"", "]"}], 
         " ", "//", "\n", "    ", 
         RowBox[{"GEEFilterDate", "[", 
          RowBox[{"\"\<2024-07-01\>\"", ",", " ", "\"\<2024-08-01\>\""}], 
          "]"}]}], " ", "//", "\n", "    ", 
        RowBox[{"GEEFilterBounds", "[", "fieldBoundaryRegion", "]"}]}], " ", "//",
        "\n", "    ", 
       RowBox[{"GEEFilterProperty", "[", 
        RowBox[{"\"\<CLOUDY_PIXEL_PERCENTAGE\>\"", ",", 
         " ", "\"\<LessThan\>\"", ",", " ", "10"}], "]"}]}], " ", "//", "\n", 
      "    ", "GEEMedian"}], " ", "//", "\n", "    ", 
     RowBox[{"GEENormalizedDifference", "[", 
      RowBox[{"{", 
       RowBox[{"\"\<B8\>\"", ",", " ", "\"\<B4\>\""}], "}"}], "]"}]}]}], 
   ";"}], "\n", "\n", 
  RowBox[{"(*", " ", 
   RowBox[{
   "GEEGradient", " ", "computes", " ", "x", " ", "and", " ", "y", " ", 
    "partial", " ", "derivatives"}], " ", "*)"}]}], "\n", 
 RowBox[{
  RowBox[{"gradientImage", " ", "=", " ", 
   RowBox[{"ndviForEdges", " ", "//", " ", "GEEGradient"}]}], ";"}]}], "Input",\
ExpressionUUID->"b48f1ce9-d869-5347-929e-1cda2eda8980"],

Cell[TextData[StyleBox["Step 2: Retrieve and process with Wolfram image \
functions.",
 FontWeight->Bold]], "Text",ExpressionUUID->"0628ab1b-aaeb-5041-bd20-\
406957e4d39c"],

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{
   "Fetch", " ", "the", " ", "gradient", " ", "as", " ", "a", " ", "raster"}],
    " ", "*)"}], "\n", 
  RowBox[{
   RowBox[{
    RowBox[{"gradImg", " ", "=", " ", 
     RowBox[{"GEEComputePixels", "[", 
      RowBox[{
      "fieldBoundaryRegion", ",", " ", "gradientImage", ",", "\n", "  ", 
       RowBox[{"\"\<ImageSize\>\"", " ", "->", " ", "1024"}]}], "]"}]}], 
    ";"}], "\n", "\n", 
   RowBox[{"(*", " ", 
    RowBox[{
    "Compute", " ", "gradient", " ", "magnitude", " ", "from", " ", "x", " ", 
     "and", " ", "y", " ", "components"}], " ", "*)"}], "\n", 
   RowBox[{
    RowBox[{"gradBands", " ", "=", " ", 
     RowBox[{"ColorSeparate", "[", "gradImg", "]"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"gradX", " ", "=", " ", 
     RowBox[{"ImageData", "[", 
      RowBox[{"gradBands", "[", 
       RowBox[{"[", "1", "]"}], "]"}], "]"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"gradY", " ", "=", " ", 
     RowBox[{"ImageData", "[", 
      RowBox[{"gradBands", "[", 
       RowBox[{"[", "2", "]"}], "]"}], "]"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"gradMagnitude", " ", "=", " ", 
     RowBox[{"Image", "[", 
      RowBox[{"Sqrt", "[", 
       RowBox[{
        RowBox[{"gradX", "^", "2"}], " ", "+", " ", 
        RowBox[{"gradY", "^", "2"}]}], "]"}], "]"}]}], ";"}], "\n", "\n", 
   RowBox[{"(*", " ", 
    RowBox[{
    "Threshold", " ", "to", " ", "find", " ", "strong", " ", "edges"}], " ", 
    "*)"}], "\n", 
   RowBox[{
    RowBox[{"binaryEdges", " ", "=", " ", 
     RowBox[{"Binarize", "[", 
      RowBox[{"gradMagnitude", ",", " ", "0.05"}], "]"}]}], ";"}], "\n", "\n", 
   RowBox[{"(*", " ", 
    RowBox[{
    "Clean", " ", "up", " ", "with", " ", "morphological", " ", 
     "operations"}], " ", "*)"}], "\n", 
   RowBox[{
    RowBox[{"cleanEdges", " ", "=", " ", 
     RowBox[{"Closing", "[", 
      RowBox[{
       RowBox[{"Thinning", "[", "binaryEdges", "]"}], ",", " ", "1"}], 
      "]"}]}], ";"}], "\n", "\n", 
   RowBox[{"(*", " ", 
    RowBox[{"Overlay", " ", "on", " ", "the", " ", "NDVI", " ", "image"}], 
    " ", "*)"}], "\n", 
   RowBox[{
    RowBox[{"ndviRaster", " ", "=", " ", 
     RowBox[{"GEEComputePixels", "[", 
      RowBox[{"fieldBoundaryRegion", ",", "\n", "  ", 
       RowBox[{"ndviForEdges", " ", "//", " ", 
        RowBox[{"GEEVisualize", "[", 
         RowBox[{"<|", "\n", "    ", 
          RowBox[{
           RowBox[{"\"\<min\>\"", " ", "->", " ", "0"}], ",", " ", 
           RowBox[{"\"\<max\>\"", " ", "->", " ", "0.9"}], ",", "\n", "    ", 
           RowBox[{"\"\<palette\>\"", " ", "->", " ", 
            RowBox[{"{", 
             
             RowBox[{"\"\<#8B4513\>\"", ",", " ", "\"\<#ADFF2F\>\"", ",", 
              " ", "\"\<#006400\>\""}], "}"}]}]}], "\n", "  ", "|>"}], 
         "]"}]}], ",", "\n", "  ", 
       RowBox[{"\"\<ImageSize\>\"", " ", "->", " ", "1024"}]}], "]"}]}], 
    ";"}], "\n", "\n", 
   RowBox[{"HighlightImage", "[", 
    RowBox[{"ndviRaster", ",", " ", "cleanEdges", ",", "\n", "  ", 
     RowBox[{"Method", " ", "->", " ", 
      RowBox[{"{", 
       RowBox[{"\"\<DiskMarker\>\"", ",", " ", "1"}], "}"}]}], ",", "\n", 
     "  ", 
     RowBox[{"\"\<HighlightColor\>\"", " ", "->", " ", "Red"}]}], 
    "]"}]}]}]], "Input",ExpressionUUID->"9d6a0fb5-509e-544c-8189-\
f6a1a7a1c714"],

Cell[TextData[{
 StyleBox["Alternative: Using Wolfram's ",
  FontWeight->Bold],
 Cell["EdgeDetect", "InlineCode",ExpressionUUID->
  "842898cc-c422-3d44-85fd-d94e16e79b64"],
 StyleBox[".",
  FontWeight->Bold]
}], "Text",ExpressionUUID->"a171d70e-caf2-8049-9ea7-13fa20638e5a"],

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{
    RowBox[{"Fetch", " ", "NDVI", " ", "as", " ", "a", " ", "single"}], "-", 
    RowBox[{"channel", " ", "image"}]}], " ", "*)"}], "\n", 
  RowBox[{
   RowBox[{
    RowBox[{"ndviGray", " ", "=", " ", 
     RowBox[{"GEEComputePixels", "[", 
      RowBox[{
      "fieldBoundaryRegion", ",", " ", "ndviForEdges", ",", "\n", "  ", 
       RowBox[{"\"\<ImageSize\>\"", " ", "->", " ", "1024"}]}], "]"}]}], 
    ";"}], "\n", "\n", 
   RowBox[{"(*", " ", 
    RowBox[{"Apply", " ", "Canny", " ", "edge", " ", "detection"}], " ", 
    "*)"}], "\n", 
   RowBox[{
    RowBox[{"edges", " ", "=", " ", 
     RowBox[{"EdgeDetect", "[", 
      RowBox[{"ndviGray", ",", " ", "2", ",", " ", 
       RowBox[{"{", 
        RowBox[{"0.05", ",", " ", "0.15"}], "}"}]}], "]"}]}], ";"}], "\n", 
   "\n", 
   RowBox[{"(*", " ", 
    RowBox[{
    "Identify", " ", "connected", " ", "components", " ", "as", " ", 
     "potential", " ", "field", " ", "polygons"}], " ", "*)"}], "\n", 
   RowBox[{
    RowBox[{"components", " ", "=", " ", 
     RowBox[{"MorphologicalComponents", "[", 
      RowBox[{"ColorNegate", "[", "edges", "]"}], "]"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"numFields", " ", "=", " ", 
     RowBox[{"Max", "[", "components", "]"}]}], ";"}], "\n", "\n", 
   RowBox[{"Colorize", "[", 
    RowBox[{"components", ",", "\n", "  ", 
     RowBox[{"PlotLabel", " ", "->", " ", 
      RowBox[{
       RowBox[{
       "StringTemplate", "[", "\"\<Detected `` potential fields\>\"", "]"}], "[",
        "numFields", "]"}]}]}], "]"}]}]}]], "Input",ExpressionUUID->"1bda3a46-\
d358-7e4a-953a-e1a232ac8a70"],

Cell["\<\
This approach works best during peak growing season when adjacent fields with \
different crops show maximum NDVI contrast.\
\>", "Text",ExpressionUUID->"7aab796f-f8ea-0b44-8027-fe7681e90d5c"],

