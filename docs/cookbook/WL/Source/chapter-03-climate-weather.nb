Cell[CellGroupData[{

Cell["3.2.2 GPM IMERG Precipitation", "Section",ExpressionUUID->"f33932af-dc68-154a-a584-dbfc61ace1bd"],

Cell[TextData[{
 "The Global Precipitation Measurement (GPM) IMERG product at ",
 Cell["NASA/GPM_L3/IMERG_V07", "InlineCode",ExpressionUUID->
  "02935534-c94f-a143-8547-ebab80a0b883"],
 " provides higher temporal resolution precipitation data (half-hourly to \
monthly aggregates) at 0.1 degree (~10 km) resolution."
}], "Text",ExpressionUUID->"de3d9f14-f467-3344-b1cb-f5b352df894c"],

Cell[TextData[{
 StyleBox["Note:",
  FontWeight->Bold],
 " GPM IMERG half-hourly records contain precipitation ",
 StyleBox["rates",
  FontSlant->Italic],
 " (mm/hr), not accumulations. Using ",
 Cell["GEECollectionSum", "InlineCode",ExpressionUUID->
  "f3675408-4a67-6f49-9a79-231fe8d1ba75"],
 " directly on the raw values does not yield total precipitation -- you must \
multiply by 0.5 (the time step in hours) to convert rates to per-interval \
totals. For monthly totals, consider using the monthly product ",
 Cell["NASA/GPM_L3/IMERG_MONTHLY_V07", "InlineCode",ExpressionUUID->
  "52afaa7b-e5f9-2a4a-b0a3-8c68d78210fc"],
 " instead."
}], "Text",
 CellFrame->{{True, False}, {
   False, False}},ExpressionUUID->"75621344-f7a4-9a49-a0dd-2288523cae2a"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{
   "GPM", " ", "monthly", " ", "precipitation", " ", "map", " ", "for", " ", 
    "Southeast", " ", "Asia"}], " ", "*)"}], "\n", 
  RowBox[{
   RowBox[{
    RowBox[{"gpmRain", " ", "=", " ", 
     RowBox[{
      RowBox[{
       RowBox[{
        RowBox[{
         RowBox[{"GEECollection", "[", "\"\<NASA/GPM_L3/IMERG_V07\>\"", "]"}],
          " ", "//", "\n", "  ", 
         RowBox[{"GEEFilterDate", "[", 
          RowBox[{"\"\<2024-07-01\>\"", ",", " ", "\"\<2024-08-01\>\""}], 
          "]"}]}], " ", "//", "\n", "  ", 
        RowBox[{"GEEFilterBounds", "[", 
         RowBox[{"{", 
          RowBox[{"95.0", ",", " ", 
           RowBox[{"-", "10.0"}], ",", " ", "140.0", ",", " ", "20.0"}], 
          "}"}], "]"}]}], " ", "//", "\n", "  ", 
       RowBox[{"GEESelectBands", "[", 
        RowBox[{"{", "\"\<precipitation\>\"", "}"}], "]"}]}], " ", "//", "\n",
       "  ", "GEECollectionSum"}]}], ";"}], "\n", "\n", 
   RowBox[{"GEEComputePixels", "[", 
    RowBox[{
