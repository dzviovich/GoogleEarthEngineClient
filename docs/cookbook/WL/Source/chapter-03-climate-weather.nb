Cell[CellGroupData[{

Cell["3.1.3 Satellite vs. Ground Station Validation", "Section",ExpressionUUID->"79ab5e82-563e-5c48-b117-635633435ccf"],

Cell["\<\
Comparing satellite-derived LST with ground-based air temperature helps \
establish confidence in the remote sensing product. Note that LST (skin \
temperature) and air temperature (measured at ~2 m height) differ physically, \
so systematic offsets are expected.\
\>", "Text",ExpressionUUID->"ee288a91-8374-644e-97ea-e236e3546f4f"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{
    RowBox[{
    "Wolfram", " ", "Language", " ", "ground", " ", "station", " ", "data", " ",
      "for", " ", "Austin"}], ",", " ", 
    RowBox[{"July", " ", "2024"}]}], " ", "*)"}], "\n", 
  RowBox[{
   RowBox[{
    RowBox[{"groundTemp", " ", "=", " ", 
     RowBox[{"WeatherData", "[", 
      RowBox[{"\"\<Austin\>\"", ",", " ", "\"\<Temperature\>\"", ",", "\n", 
       "  ", 
       RowBox[{"{", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{"2024", ",", " ", "7", ",", " ", "1"}], "}"}], ",", " ", 
         RowBox[{"{", 
          RowBox[{"2024", ",", " ", "7", ",", " ", "31"}], "}"}], ",", 
         " ", "\"\<Day\>\""}], "}"}]}], "]"}]}], ";"}], "\n", "\n", 
   RowBox[{"(*", " ", 
    RowBox[{
    "GEE", " ", "satellite", " ", "LST", " ", "at", " ", "the", " ", "Austin",
      " ", "weather", " ", "station", " ", "location"}], " ", "*)"}], "\n", 
   RowBox[{
    RowBox[{"stationPos", " ", "=", " ", 
     RowBox[{"GeoPosition", "[", 
      RowBox[{"{", 
       RowBox[{"30.30", ",", " ", 
        RowBox[{"-", "97.70"}]}], "}"}], "]"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"satelliteLST", " ", "=", " ", 
     RowBox[{"Table", "[", "\n", "  ", 
      RowBox[{
       RowBox[{"Module", "[", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{
          "dateStr", ",", " ", "endStr", ",", " ", "expr", ",", " ", 
           "result"}], "}"}], ",", "\n", "    ", 
         RowBox[{"(*", " ", 
          RowBox[{
           RowBox[{
            RowBox[{"MOD11A2", " ", "is", " ", "an", " ", "8"}], "-", 
            RowBox[{"day", " ", "composite"}]}], ";", " ", 
           RowBox[{
            RowBox[{"use", " ", "an", " ", "8"}], "-", 
            RowBox[{
            "day", " ", "filter", " ", "window", "\n", "       ", "aligned", " ",
              "to", " ", "composite", " ", "start", " ", "dates"}]}]}], " ", 
          "*)"}], "\n", "    ", 
         RowBox[{
          RowBox[{"dateStr", " ", "=", " ", 
           RowBox[{"DateString", "[", 
            RowBox[{
             RowBox[{"{", 
              RowBox[{"2024", ",", " ", "7", ",", " ", "d"}], "}"}], ",", " ", 
             RowBox[{"{", 
              
              RowBox[{"\"\<Year\>\"", ",", " ", "\"\<-\>\"", ",", 
               " ", "\"\<Month\>\"", ",", " ", "\"\<-\>\"", ",", 
               " ", "\"\<Day\>\""}], "}"}]}], "]"}]}], ";", "\n", "    ", 
          RowBox[{"endStr", " ", "=", " ", 
           RowBox[{"DateString", "[", 
            RowBox[{
             RowBox[{"{", 
              RowBox[{"2024", ",", " ", "7", ",", " ", 
               RowBox[{"d", " ", "+", " ", "8"}]}], "}"}], ",", " ", 
             RowBox[{"{", 
              
              RowBox[{"\"\<Year\>\"", ",", " ", "\"\<-\>\"", ",", 
               " ", "\"\<Month\>\"", ",", " ", "\"\<-\>\"", ",", 
               " ", "\"\<Day\>\""}], "}"}]}], "]"}]}], ";", "\n", "    ", 
          RowBox[{"expr", " ", "=", " ", 
           RowBox[{
            RowBox[{
             RowBox[{
              RowBox[{
               RowBox[{
                RowBox[{
                "GEECollection", "[", "\"\<MODIS/061/MOD11A2\>\"", "]"}], " ",
                 "//", "\n", "      ", 
                RowBox[{"GEEFilterDate", "[", 
                 RowBox[{"dateStr", ",", " ", "endStr"}], "]"}]}], " ", "//", 
               "\n", "      ", 
               RowBox[{"GEESelectBands", "[", 
                RowBox[{"{", "\"\<LST_Day_1km\>\"", "}"}], "]"}]}], " ", "//",
               "\n", "      ", "GEEMosaic"}], " ", "//", "\n", "      ", 
             RowBox[{"GEEMultiply", "[", "0.02", "]"}]}], " ", "//", "\n", 
            "      ", 
            RowBox[{"GEEAdd", "[", 
             RowBox[{"-", "273.15"}], "]"}]}]}], ";", "\n", "    ", 
          RowBox[{"result", " ", "=", " ", 
           RowBox[{"GEEIdentify", "[", 
            RowBox[{"stationPos", ",", " ", "expr"}], "]"}]}], ";", "\n", 
          "    ", 
          RowBox[{"If", "[", 
           RowBox[{
            RowBox[{
             RowBox[{
              RowBox[{"result", "[", "\"\<Values\>\"", "]"}], "[", 
              RowBox[{"[", "1", "]"}], "]"}], " ", "===", " ", "Null"}], ",", 
            "\n", "      ", 
            RowBox[{"Missing", "[", "\"\<NoData\>\"", "]"}], ",", "\n", 
            "      ", 
            RowBox[{
             RowBox[{"result", "[", "\"\<Values\>\"", "]"}], "[", 
             RowBox[{"[", "1", "]"}], "]"}]}], "\n", "    ", "]"}]}]}], "\n", 
        "  ", "]"}], ",", "\n", "  ", 
       RowBox[{"{", 
        RowBox[{"d", ",", " ", "1", ",", " ", "28", ",", " ", "8"}], "}"}]}], 
      "  ", 
      RowBox[{"(*", " ", 
       RowBox[{"8", "-", 
        RowBox[{
        "day", " ", "intervals", " ", "matching", " ", "MODIS", " ", 
         "compositing"}]}], " ", "*)"}], "\n", "]"}]}], ";"}], "\n", "\n", 
   RowBox[{"(*", " ", 
    RowBox[{
    "Build", " ", "time", " ", "series", " ", "for", " ", "both", " ", 
     "sources"}], " ", "*)"}], "\n", 
   RowBox[{
    RowBox[{"modDates", " ", "=", " ", 
     RowBox[{"Table", "[", 
      RowBox[{
       RowBox[{"DateObject", "[", 
        RowBox[{"{", 
         RowBox[{"2024", ",", " ", "7", ",", " ", "d"}], "}"}], "]"}], ",", 
       " ", 
       RowBox[{"{", 
        RowBox[{"d", ",", " ", "1", ",", " ", "28", ",", " ", "8"}], "}"}]}], 
      "]"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"satelliteTS", " ", "=", " ", 
     RowBox[{"TimeSeries", "[", "\n", "  ", 
      RowBox[{"DeleteCases", "[", "\n", "    ", 
       RowBox[{
        RowBox[{"Transpose", "[", 
         RowBox[{"{", 
          RowBox[{"modDates", ",", " ", "satelliteLST"}], "}"}], "]"}], ",", 
        "\n", "    ", 
        RowBox[{"{", 
         RowBox[{"_", ",", " ", "_Missing"}], "}"}]}], "\n", "  ", "]"}], 
      "\n", "]"}]}], ";"}], "\n", "\n", 
   RowBox[{"(*", " ", 
    RowBox[{
    "Plot", " ", "both", " ", "on", " ", "the", " ", "same", " ", "axis"}], 
    " ", "*)"}], "\n", 
   RowBox[{"DateListPlot", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"groundTemp", ",", " ", "satelliteTS"}], "}"}], ",", "\n", "  ", 
     RowBox[{"PlotLegends", " ", "->", " ", 
      RowBox[{"{", 
       RowBox[{"\"\<Ground Station (Air Temp)\>\"", ",", 
        " ", "\"\<MODIS LST (Skin Temp)\>\""}], "}"}]}], ",", "\n", "  ", 
     RowBox[{
     "PlotLabel", " ", "->", 
      " ", "\"\<Austin, TX - July 2024: Ground vs. Satellite \
Temperature\>\""}], ",", "\n", "  ", 
     RowBox[{"AxesLabel", " ", "->", " ", 
      RowBox[{"{", 
       RowBox[{"None", ",", " ", "\"\<Temperature (\[Degree]C)\>\""}], 
       "}"}]}], ",", "\n", "  ", 
     RowBox[{"PlotStyle", " ", "->", " ", 
      RowBox[{"{", 
       RowBox[{"Blue", ",", " ", "Red"}], "}"}]}], ",", "\n", "  ", 
     RowBox[{"Joined", " ", "->", " ", 
      RowBox[{"{", 
       RowBox[{"True", ",", " ", "False"}], "}"}]}], ",", "\n", "  ", 
     RowBox[{"PlotMarkers", " ", "->", " ", 
      RowBox[{"{", 
       RowBox[{"None", ",", " ", "Automatic"}], "}"}]}]}], "]"}], "\n", 
   RowBox[{"(*", " ", 
    RowBox[{
     RowBox[{
     "LST", " ", "is", " ", "typically", " ", "warmer", " ", "than", " ", 
      "air", " ", "temperature"}], ",", " ", 
     RowBox[{"especially", " ", "on", " ", "sunny", " ", "days"}]}], " ", 
    "*)"}]}]}]], "Input",
 CellLabel->
  "In[155]:=",ExpressionUUID->"8f15aa23-1347-134f-be56-387a560b9c02"],

