Cell[CellGroupData[{

Cell["3.4 Evapotranspiration", "Chapter",ExpressionUUID->"9c17bdf9-20cf-6c40-ad24-a8715796a9c4"],

Cell["\<\
Evapotranspiration (ET) quantifies water loss from the land surface through \
soil evaporation and plant transpiration. It is a critical variable for \
agricultural water management, drought assessment, and hydrological modeling. \
For a complete watershed-scale water budget combining precipitation and ET, \
see Section 6.8.\
\>", "Text",ExpressionUUID->"1e33c9db-ea51-9f40-8afc-813a82226d7f"],

Cell[CellGroupData[{

Cell["3.4.1 MODIS Evapotranspiration", "Section",ExpressionUUID->"60e75d00-3a31-924e-b93b-ac01f8221e7c"],

Cell[TextData[{
 Cell["MODIS/061/MOD16A2", "InlineCode",ExpressionUUID->
  "665abe29-2904-354b-8c55-2c2c3b39b7ed"],
 " provides 8-day ET composites at 500 m resolution. The ",
 Cell["ET", "InlineCode",ExpressionUUID->
  "8f315f6d-24ff-d349-b536-f6cf225cd936"],
 " band stores values in units of kg/m^2/8-day (equivalent to mm/8-day); the \
scale factor is 0.1."
}], "Text",ExpressionUUID->"e7bbde7c-e0d8-4347-83c1-481efee89418"],

Cell[TextData[StyleBox["Map seasonal ET over an agricultural region:",
 FontWeight->Bold]], "Text",ExpressionUUID->"0ab5c6d9-0c58-314c-9c13-\
a9639ce9bc86"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{
   "Growing", " ", "season", " ", "ET", " ", "for", " ", "the", " ", 
    "California", " ", "Central", " ", "Valley"}], " ", "*)"}], "\n", 
  RowBox[{
   RowBox[{
    RowBox[{
     RowBox[{"etExpr", " ", "=", " ", 
      RowBox[{
       RowBox[{
        RowBox[{
         RowBox[{
          RowBox[{
           RowBox[{"GEECollection", "[", "\"\<MODIS/061/MOD16A2\>\"", "]"}], 
           " ", "//", "\n", "  ", 
           RowBox[{"GEEFilterDate", "[", 
            RowBox[{"\"\<2024-04-01\>\"", ",", " ", "\"\<2024-10-01\>\""}], 
            "]"}]}], " ", "//", "\n", "  ", 
          RowBox[{"GEEFilterBounds", "[", 
           RowBox[{"{", 
            RowBox[{
             RowBox[{"-", "122.0"}], ",", " ", "35.0", ",", " ", 
             RowBox[{"-", "119.0"}], ",", " ", "38.5"}], "}"}], "]"}]}], " ", 
         "//", "\n", "  ", 
         RowBox[{"GEESelectBands", "[", 
          RowBox[{"{", "\"\<ET\>\"", "}"}], "]"}]}], " ", "//", "\n", "  ", 
        "GEECollectionSum"}], "  ", "//", "\[IndentingNewLine]", 
       RowBox[{"GEEMultiply", "[", "0.1", "]"}]}]}], ";"}], "  ", 
    RowBox[{"(*", 
     RowBox[{"Scale", " ", "to", " ", "mm"}], "*)"}], ";"}], "  ", 
   RowBox[{"(*", " ", 
    RowBox[{"Scale", " ", "to", " ", "mm"}], " ", "*)"}], "\n", "\n", 
   RowBox[{"GEEComputePixels", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
       RowBox[{"-", "122.0"}], ",", " ", "35.0", ",", " ", 
       RowBox[{"-", "119.0"}], ",", " ", "38.5"}], "}"}], ",", " ", "etExpr", 
     ",", "\n", "  ", 
     RowBox[{"\"\<VisParams\>\"", " ", "->", " ", 
      RowBox[{"<|", 
       RowBox[{
        RowBox[{"\"\<min\>\"", " ", "->", " ", "0"}], ",", " ", 
        RowBox[{"\"\<max\>\"", " ", "->", " ", "800"}], ",", "\n", "    ", 
        RowBox[{"\"\<palette\>\"", " ", "->", " ", 
         RowBox[{"{", 
          
          RowBox[{"\"\<#ffffff\>\"", ",", "\"\<#fcd163\>\"", 
           ",", "\"\<#99b718\>\"", ",", "\"\<#66a000\>\"", 
           ",", "\"\<#3e8601\>\"", ",", "\"\<#207401\>\"", 
           ",", "\"\<#056201\>\"", ",", "\"\<#004c00\>\"", 
           ",", "\"\<#011301\>\""}], "}"}]}]}], "|>"}]}], ",", "\n", "  ", 
     RowBox[{"\"\<ImageSize\>\"", " ", "->", " ", 
      RowBox[{"{", 
       RowBox[{"500", ",", " ", "600"}], "}"}]}]}], "]"}], "\n", 
   RowBox[{"(*", " ", 
    RowBox[{
     RowBox[{
     "High", " ", "ET", " ", "over", " ", "irrigated", " ", "farmland"}], ",",
      " ", 
     RowBox[{
     "low", " ", "ET", " ", "over", " ", "the", " ", "Coast", " ", 
      "Ranges"}]}], " ", "*)"}]}]}]], "Input",
 CellChangeTimes->{{3.984497519887148*^9, 3.9844975841544056`*^9}, {
  3.984497725202759*^9, 3.9844978036855774`*^9}, {3.984498230274763*^9, 
  3.9844982608833256`*^9}, {3.984498292610752*^9, 3.9844982929458904`*^9}},
 CellLabel->
