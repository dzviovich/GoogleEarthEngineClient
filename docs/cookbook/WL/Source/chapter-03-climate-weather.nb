              RowBox[{"If", "[", 
               RowBox[{
                RowBox[{"y", " ", ">", " ", "0"}], ",", " ", "Blue", ",", " ",
                 "Red"}], "]"}]}], "]"}]}], ",", "\n", "      ", 
           RowBox[{"ColorFunctionScaling", " ", "->", " ", "False"}], ",", 
           "\n", "      ", 
           RowBox[{"ImageSize", " ", "->", " ", "350"}]}], "]"}]}], "\n", 
        "  ", "}"}]}], "\n", "}"}], ",", " ", 
     RowBox[{"Spacings", " ", "->", " ", 
      RowBox[{"{", 
       RowBox[{"1", ",", " ", "1"}], "}"}]}], ",", "\n", "  ", 
     RowBox[{"Frame", " ", "->", " ", "All"}], ",", "\n", "  ", 
     RowBox[{"Background", " ", "->", " ", "White"}]}], "]"}]}]}]], "Input",Ex\
pressionUUID->"b0c0f2e3-bdf9-3841-8cac-451ed4bfdccf"],

Cell[TextData[StyleBox["Compute annual summary statistics:",
 FontWeight->Bold]], "Text",ExpressionUUID->"09e64055-acdc-3c45-b254-\
2e7ff1ce813c"],

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"annualSummary", " ", "=", " ", 
    RowBox[{"<|", "\n", "  ", 
     RowBox[{
      RowBox[{"\"\<Mean Temperature\>\"", " ", "->", "\n", "    ", 
       RowBox[{"Row", "[", 
        RowBox[{"{", 
         RowBox[{
          RowBox[{"Round", "[", 
           RowBox[{
            RowBox[{"Mean", "[", "tempData", "]"}], ",", " ", "0.1"}], "]"}], 
          ",", " ", "\"\< \[Degree]C\>\""}], "}"}], "]"}]}], ",", "\n", "  ", 
      RowBox[{"\"\<Total Precipitation\>\"", " ", "->", "\n", "    ", 
       RowBox[{"Row", "[", 
        RowBox[{"{", 
         RowBox[{
          RowBox[{"Round", "[", 
           RowBox[{
            RowBox[{"Total", "[", "precipData", "]"}], ",", " ", "1"}], "]"}],
           ",", " ", "\"\< mm\>\""}], "}"}], "]"}]}], ",", "\n", "  ", 
      RowBox[{"\"\<Total ET\>\"", " ", "->", "\n", "    ", 
       RowBox[{"Row", "[", 
        RowBox[{"{", 
         RowBox[{
          RowBox[{"Round", "[", 
           RowBox[{
            RowBox[{"Total", "[", "etData", "]"}], ",", " ", "1"}], "]"}], ",",
           " ", "\"\< mm\>\""}], "}"}], "]"}]}], ",", "\n", "  ", 
      RowBox[{"\"\<Annual Water Balance\>\"", " ", "->", "\n", "    ", 
       RowBox[{"Row", "[", 
        RowBox[{"{", 
         RowBox[{
          RowBox[{"Round", "[", 
           RowBox[{
            RowBox[{
             RowBox[{"Total", "[", "precipData", "]"}], " ", "-", " ", 
             RowBox[{"Total", "[", "etData", "]"}]}], ",", " ", "1"}], "]"}], 
          ",", " ", "\"\< mm\>\""}], "}"}], "]"}]}], ",", "\n", "  ", 
      RowBox[{"\"\<Wettest Month\>\"", " ", "->", "\n", "    ", 
       RowBox[{"DateString", "[", 
        RowBox[{
         RowBox[{"months", "[", 
          RowBox[{"[", 
           RowBox[{
            RowBox[{"Ordering", "[", 
             RowBox[{"precipData", ",", " ", 
              RowBox[{"-", "1"}]}], "]"}], "[", 
            RowBox[{"[", "1", "]"}], "]"}], "]"}], "]"}], ",", "\n", "      ", 
         RowBox[{"{", "\"\<MonthName\>\"", "}"}]}], "]"}]}], ",", "\n", "  ", 
      RowBox[{"\"\<Driest Month\>\"", " ", "->", "\n", "    ", 
       RowBox[{"DateString", "[", 
        RowBox[{
         RowBox[{"months", "[", 
          RowBox[{"[", 
           RowBox[{
            RowBox[{"Ordering", "[", 
             RowBox[{"precipData", ",", " ", "1"}], "]"}], "[", 
            RowBox[{"[", "1", "]"}], "]"}], "]"}], "]"}], ",", "\n", "      ", 
         RowBox[{"{", "\"\<MonthName\>\"", "}"}]}], "]"}]}], ",", "\n", "  ", 
      RowBox[{"\"\<Hottest Month\>\"", " ", "->", "\n", "    ", 
       RowBox[{"DateString", "[", 
        RowBox[{
         RowBox[{"months", "[", 
          RowBox[{"[", 
           RowBox[{
            RowBox[{"Ordering", "[", 
             RowBox[{"tempData", ",", " ", 
              RowBox[{"-", "1"}]}], "]"}], "[", 
            RowBox[{"[", "1", "]"}], "]"}], "]"}], "]"}], ",", "\n", "      ", 
         RowBox[{"{", "\"\<MonthName\>\"", "}"}]}], "]"}]}]}], "\n", "|>"}]}],
    ";"}], "\n"}], "\n", 
 RowBox[{"Dataset", "[", "annualSummary", "]"}]}], "Input",ExpressionUUID->\
"e4f33637-df54-9241-ac4e-aa5ca46cb74a"],

