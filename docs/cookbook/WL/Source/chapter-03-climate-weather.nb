Cell[TextData[{
 "The scale factor pipeline (",
 Cell["GEEMultiply[0.02] // GEEAdd[-273.15]", "InlineCode",ExpressionUUID->
  "20deb3a0-ec97-1a4e-972f-9515b868d71c"],
 ") runs entirely server-side, so you receive physically meaningful Celsius \
values without downloading raw integers."
}], "Text",ExpressionUUID->"de9aa345-320c-ca4c-aa8e-6ccc41d9d31a"],

Cell[TextData[StyleBox["Query LST at specific points across the urban-rural \
gradient:",
 FontWeight->Bold]], "Text",ExpressionUUID->"cfaded66-1237-3b4e-a718-\
8422f74214ef"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{
    RowBox[{"Define", " ", 
     RowBox[{"points", ":", " ", "downtown"}]}], ",", " ", "suburb", ",", " ", 
    RowBox[{"agricultural", " ", "fringe"}]}], " ", "*)"}], "\n", 
  RowBox[{
   RowBox[{
    RowBox[{"points", " ", "=", " ", 
     RowBox[{"<|", "\n", "  ", 
      RowBox[{
       RowBox[{"\"\<Downtown Phoenix\>\"", " ", "->", " ", 
        RowBox[{"GeoPosition", "[", 
         RowBox[{"{", 
          RowBox[{"33.45", ",", " ", 
           RowBox[{"-", "112.07"}]}], "}"}], "]"}]}], ",", "\n", "  ", 
       RowBox[{"\"\<Scottsdale Suburb\>\"", " ", "->", " ", 
        RowBox[{"GeoPosition", "[", 
         RowBox[{"{", 
          RowBox[{"33.50", ",", " ", 
           RowBox[{"-", "111.93"}]}], "}"}], "]"}]}], ",", "\n", "  ", 
       RowBox[{"\"\<Rural Farmland\>\"", " ", "->", " ", 
        RowBox[{"GeoPosition", "[", 
         RowBox[{"{", 
          RowBox[{"33.38", ",", " ", 
           RowBox[{"-", "112.25"}]}], "}"}], "]"}]}]}], "\n", "|>"}]}], ";"}],
    "\n", "\n", 
   RowBox[{
    RowBox[{"lstResults", " ", "=", " ", 
     RowBox[{"Association", " ", "@", " ", 
      RowBox[{"KeyValueMap", "[", "\n", "  ", 
       RowBox[{
        RowBox[{"Function", "[", 
         RowBox[{
          RowBox[{"{", 
           RowBox[{"name", ",", " ", "pos"}], "}"}], ",", "\n", "    ", 
          RowBox[{"name", " ", "->", " ", 
           RowBox[{
            RowBox[{
             RowBox[{"GEEIdentify", "[", 
              RowBox[{"pos", ",", " ", "lstExpr"}], "]"}], 
             "[", "\"\<Values\>\"", "]"}], "[", 
            RowBox[{"[", "1", "]"}], "]"}]}]}], "\n", "  ", "]"}], ",", "\n", 
        "  ", "points"}], "\n", "]"}]}]}], ";"}], "\n", "\n", 
   RowBox[{"BarChart", "[", 
    RowBox[{"lstResults", ",", "\n", "  ", 
     RowBox[{"ChartLabels", " ", "->", " ", 
      RowBox[{"Keys", "[", "lstResults", "]"}]}], ",", "\n", "  ", 
     RowBox[{"AxesLabel", " ", "->", " ", 
      RowBox[{"{", 
       RowBox[{"None", ",", " ", "\"\<LST (\[Degree]C)\>\""}], "}"}]}], ",", 
     "\n", "  ", 
     RowBox[{
     "PlotLabel", " ", "->", 
      " ", "\"\<Phoenix Urban Heat Island - Summer 2024\>\""}], ",", "\n", 
     "  ", 
     RowBox[{"ChartStyle", " ", "->", " ", "\"\<TemperatureMap\>\""}], ",", 
     "\[IndentingNewLine]", 
     RowBox[{"ImageSize", "->", "Large"}], ",", "\[IndentingNewLine]", 
     RowBox[{"PlotTheme", "->", "\"\<Detailed\>\""}]}], "]"}], "\n", 
   RowBox[{"(*", " ", 
    RowBox[{
     RowBox[{"Downtown", " ", "typically", " ", "5"}], "-", 
     RowBox[{
     "10", "\[Degree]C", " ", "warmer", " ", "than", " ", "surrounding", " ", 
      "farmland"}]}], " ", "*)"}]}]}]], "Input",
 CellChangeTimes->{{3.984492521383463*^9, 3.9844925949470177`*^9}},
 CellLabel->
  "In[146]:=",ExpressionUUID->"579f82c5-d651-fc47-a84c-02de07a135f9"],

