Cell[TextData[{
 "Note the ",
 Cell["_mean", "InlineCode",ExpressionUUID->
  "aa3669d5-f0a6-3a4e-a02a-b8fc1352320a"],
 " suffix on band names: ",
 Cell["GEEMean", "InlineCode",ExpressionUUID->
  "7412b344-a8de-884b-ba76-d76a488436a9"],
 " appends this suffix during collection reduction (see Section 3.3.1 note on \
band naming)."
}], "Text",ExpressionUUID->"d92e582e-0873-6b48-bbc8-44f29e376370"]
}, Open  ]],

Cell[CellGroupData[{

Cell["3.3.3 MODIS Aerosol Optical Depth", "Section",ExpressionUUID->"c7612141-91ed-1e4f-954d-dbc98cc03ca0"],

Cell[TextData[{
 "Aerosol optical depth (AOD) measures the amount of particulate matter in \
the atmosphere. High AOD values indicate pollution, dust storms, or wildfire \
smoke. ",
 Cell["MODIS/061/MCD19A2_GRANULES", "InlineCode",ExpressionUUID->
  "0d97a783-baf8-f343-9c99-90efaa2768bd"],
 " provides AOD at 1 km resolution."
}], "Text",
 CellChangeTimes->{
  3.984495057031622*^9, {3.984495100961916*^9, 
   3.984495109695467*^9}},ExpressionUUID->"1f68eb42-1240-fa48-ad28-\
884220a36c06"],

Cell[BoxData[
 RowBox[{
  RowBox[{"aColors", "=", 
   RowBox[{"<|", 
    RowBox[{
     RowBox[{
      TemplateBox[<|"color" -> GrayLevel[0]|>,
       "GrayLevelColorSwatchTemplate"], "\[Rule]", "\"\<#000000\>\""}], ",", 
     RowBox[{
      TemplateBox[<|"color" -> RGBColor[0, 0, 1]|>,
       "RGBColorSwatchTemplate"], "\[Rule]", "\"\<#0000ff\>\""}], ",", 
     RowBox[{
      TemplateBox[<|"color" -> RGBColor[0.5, 0, 0.5]|>,
       "RGBColorSwatchTemplate"], "\[Rule]", "\"\<#800080\>\""}], ",", 
     RowBox[{
      TemplateBox[<|"color" -> RGBColor[0, 1, 1]|>,
       "RGBColorSwatchTemplate"], "\[Rule]", "\"\<#00ffff\>\""}], ",", 
     RowBox[{
      TemplateBox[<|"color" -> RGBColor[0, 1, 0]|>,
       "RGBColorSwatchTemplate"], "\[Rule]", "\"\<#00ff00\>\""}], ",", 
