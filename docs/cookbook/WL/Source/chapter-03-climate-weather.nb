Cell[CellGroupData[{

Cell["3.2 Precipitation and Rainfall", "Chapter",ExpressionUUID->"0858468b-448c-ef46-a632-1a7b2b45561c"],

Cell["\<\
Precipitation is the primary driver of hydrology, agriculture, and flood \
risk. Two complementary products provide global coverage at different \
resolutions.\
\>", "Text",ExpressionUUID->"5b5d0467-24f7-7c44-8f04-5c1c166f1a30"],

Cell[CellGroupData[{

Cell["3.2.1 CHIRPS Daily Rainfall", "Section",ExpressionUUID->"89c99fa8-4f3e-c040-8d58-bb16fe740b72"],

Cell[TextData[{
 "The Climate Hazards Group InfraRed Precipitation with Station data (CHIRPS) \
at ",
 Cell["UCSB-CHG/CHIRPS/DAILY", "InlineCode",ExpressionUUID->
  "31af9036-2c22-1c48-b312-d2c6d9f6da28"],
 " provides daily rainfall at approximately 5 km resolution with records \
extending back to 1981. This long record makes it ideal for climatological \
analysis."
}], "Text",ExpressionUUID->"48f37353-b1c4-a945-a5ef-d85a51f7a5c3"],

Cell[TextData[StyleBox["Monthly rainfall accumulation:",
 FontWeight->Bold]], "Text",ExpressionUUID->"f5834d36-ee25-a540-b28e-\
9e07a9bab564"],

Cell[TextData[{
 "Summing daily images over one month gives total precipitation in \
millimeters. ",
 Cell["GEECollectionSum", "InlineCode",ExpressionUUID->
  "c2948836-d794-534e-b60b-a8c54af69e72"],
 " performs a pixel-wise sum across the entire filtered collection."
}], "Text",ExpressionUUID->"372d53f5-2391-a04d-90bd-e78a2b6f3ebc"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{
   "Total", " ", "rainfall", " ", "for", " ", "July", " ", "2024", " ", 
    "over", " ", "the", " ", "Indian", " ", "monsoon", " ", "region"}], " ", 
   "*)"}], "\n", 
  RowBox[{
   RowBox[{
    RowBox[{"julyRain", " ", "=", " ", 
     RowBox[{
      RowBox[{
       RowBox[{
        RowBox[{
         RowBox[{"GEECollection", "[", "\"\<UCSB-CHG/CHIRPS/DAILY\>\"", "]"}],
          " ", "//", "\n", "  ", 
         RowBox[{"GEEFilterDate", "[", 
          RowBox[{"\"\<2024-07-01\>\"", ",", " ", "\"\<2024-08-01\>\""}], 
          "]"}]}], " ", "//", "\n", "  ", 
        RowBox[{"GEEFilterBounds", "[", 
         RowBox[{"{", 
          RowBox[{
          "68.0", ",", " ", "8.0", ",", " ", "90.0", ",", " ", "28.0"}], 
          "}"}], "]"}]}], " ", "//", "\n", "  ", 
       RowBox[{"GEESelectBands", "[", 
        RowBox[{"{", "\"\<precipitation\>\"", "}"}], "]"}]}], " ", "//", "\n",
       "  ", "GEECollectionSum"}]}], ";"}], "\n", "\n", 
   RowBox[{"(*", " ", 
    RowBox[{
    "Render", " ", "the", " ", "monthly", " ", "accumulation", " ", "map"}], 
    " ", "*)"}], "\n", 
   RowBox[{"GEEComputePixels", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"68.0", ",", " ", "8.0", ",", " ", "90.0", ",", " ", "28.0"}], 
      "}"}], ",", " ", "julyRain", ",", "\n", "  ", 
     RowBox[{"\"\<VisParams\>\"", " ", "->", " ", 
      RowBox[{"<|", 
       RowBox[{
        RowBox[{"\"\<min\>\"", " ", "->", " ", "0"}], ",", " ", 
        RowBox[{"\"\<max\>\"", " ", "->", " ", "800"}], ",", "\n", "    ", 
        RowBox[{"\"\<palette\>\"", " ", "->", " ", 
         RowBox[{"{", 
          
          RowBox[{"\"\<#ffffcc\>\"", ",", " ", "\"\<#a1dab4\>\"", ",", 
           " ", "\"\<#41b6c4\>\"", ",", "\n", "      ", "\"\<#2c7fb8\>\"", ",",
            " ", "\"\<#253494\>\""}], "}"}]}]}], "|>"}]}], ",", "\n", "  ", 
     RowBox[{"\"\<ImageSize\>\"", " ", "->", " ", 
      RowBox[{"{", 
       RowBox[{"600", ",", " ", "500"}], "}"}]}]}], "]"}], "\n", 
   RowBox[{"(*", " ", 
    RowBox[{
    "Western", " ", "Ghats", " ", "and", " ", "northeast", " ", "India", " ", 
     "show", " ", "peak", " ", "monsoon", " ", "rainfall"}], " ", 
    "*)"}]}]}]], "Input",
 CellLabel->
  "In[161]:=",ExpressionUUID->"0ccceee5-7a63-8c4b-9753-529813e1ff14"],

