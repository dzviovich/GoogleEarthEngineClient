Cell[CellGroupData[{

Cell["3.3 Atmospheric Data", "Chapter",ExpressionUUID->"f47c2e84-ab99-c14a-af5b-8fff1deb2728"],

Cell["\<\
Atmospheric reanalysis products combine satellite observations with numerical \
weather models to produce spatially complete, temporally consistent records \
of key atmospheric variables.\
\>", "Text",ExpressionUUID->"9175f864-92c7-5e4a-892a-45f2fa869303"],

Cell[CellGroupData[{

Cell["3.3.1 ERA5-Land Reanalysis", "Section",ExpressionUUID->"575c24cb-909b-2043-be9b-eb5a95a24e3f"],

Cell[TextData[{
 Cell["ECMWF/ERA5_LAND/DAILY_AGGR", "InlineCode",ExpressionUUID->
  "221dc362-fe70-4f4f-b487-956d5bf5a977"],
 " provides daily aggregates of temperature, precipitation, wind, humidity, \
and pressure at approximately 11 km resolution. Its consistent methodology \
makes it well suited for climate trend studies."
}], "Text",ExpressionUUID->"673cf963-e080-0648-9f88-bd5ba813dc7f"],

Cell[TextData[StyleBox["Extract a temperature time series for a single point \
over one year:",
 FontWeight->Bold]], "Text",ExpressionUUID->"36f9e7c5-354f-2445-9dcc-\
cedbe08e6bf7"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{
    RowBox[{
    "Monthly", " ", "mean", " ", "temperature", " ", "for", " ", "Berlin"}], ",",
     " ", "2024"}], " ", "*)"}], "\n", 
  RowBox[{
   RowBox[{
    RowBox[{"berlinPos", " ", "=", " ", 
     RowBox[{"GeoPosition", "[", 
      RowBox[{"{", 
       RowBox[{"52.52", ",", " ", "13.40"}], "}"}], "]"}]}], ";"}], "\n", "\n", 
   RowBox[{
    RowBox[{"monthlyTemp", " ", "=", " ", 
     RowBox[{"Table", "[", "\n", "  ", 
      RowBox[{
       RowBox[{"Module", "[", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{
          "startDate", ",", " ", "endDate", ",", " ", "expr", ",", " ", 
           "result"}], "}"}], ",", "\n", "    ", 
         RowBox[{
          RowBox[{"startDate", " ", "=", " ", 
           RowBox[{"DateString", "[", 
            RowBox[{
             RowBox[{"DateObject", "[", 
              RowBox[{"{", 
               RowBox[{"2024", ",", " ", "mo", ",", " ", "1"}], "}"}], "]"}], 
             ",", "\n", "      ", 
             RowBox[{"{", 
              
              RowBox[{"\"\<Year\>\"", ",", " ", "\"\<-\>\"", ",", 
               " ", "\"\<Month\>\"", ",", " ", "\"\<-\>\"", ",", 
               " ", "\"\<Day\>\""}], "}"}]}], "]"}]}], ";", "\n", "    ", 
          RowBox[{"endDate", " ", "=", " ", 
           RowBox[{"DateString", "[", 
            RowBox[{
             RowBox[{"DateObject", "[", 
              RowBox[{"{", 
               RowBox[{"2024", ",", " ", 
                RowBox[{"mo", " ", "+", " ", "1"}], ",", " ", "1"}], "}"}], 
              "]"}], ",", "\n", "      ", 
             RowBox[{"{", 
              
              RowBox[{"\"\<Year\>\"", ",", " ", "\"\<-\>\"", ",", 
               " ", "\"\<Month\>\"", ",", " ", "\"\<-\>\"", ",", 
               " ", "\"\<Day\>\""}], "}"}]}], "]"}]}], ";", "\n", "    ", 
          RowBox[{"expr", " ", "=", " ", 
           RowBox[{
            RowBox[{
             RowBox[{
              RowBox[{
               RowBox[{
               "GEECollection", "[", "\"\<ECMWF/ERA5_LAND/DAILY_AGGR\>\"", 
                "]"}], " ", "//", "\n", "      ", 
               RowBox[{"GEEFilterDate", "[", 
                RowBox[{"startDate", ",", " ", "endDate"}], "]"}]}], " ", "//",
               "\n", "      ", 
              RowBox[{"GEESelectBands", "[", 
               RowBox[{"{", "\"\<temperature_2m\>\"", "}"}], "]"}]}], " ", "//",
              "\n", "      ", "GEEMean"}], " ", "//", "\n", "      ", 
            RowBox[{"GEEAdd", "[", 
             RowBox[{"-", "273.15"}], "]"}]}]}], ";", "  ", 
          RowBox[{"(*", " ", 
           RowBox[{"Kelvin", " ", "to", " ", "Celsius"}], " ", "*)"}], "\n", 
          "    ", 
          RowBox[{"result", " ", "=", " ", 
           RowBox[{"GEEIdentify", "[", 
            RowBox[{"berlinPos", ",", " ", "expr"}], "]"}]}], ";", "\n", 
          "    ", 
          RowBox[{
           RowBox[{"result", "[", "\"\<Values\>\"", "]"}], "[", 
           RowBox[{"[", "1", "]"}], "]"}]}]}], "\n", "  ", "]"}], ",", "\n", 
       "  ", 
       RowBox[{"{", 
        RowBox[{"mo", ",", " ", "1", ",", " ", "12"}], "}"}]}], "\n", "]"}]}],
     ";"}], "\n", "\n", 
   RowBox[{
    RowBox[{"dates", " ", "=", " ", 
     RowBox[{"Table", "[", 
      RowBox[{
       RowBox[{"DateObject", "[", 
        RowBox[{"{", 
         RowBox[{"2024", ",", " ", "mo", ",", " ", "15"}], "}"}], "]"}], ",", 
       " ", 
       RowBox[{"{", 
        RowBox[{"mo", ",", " ", "1", ",", " ", "12"}], "}"}]}], "]"}]}], 
    ";"}], "\n", 
   RowBox[{
    RowBox[{"tempTS", " ", "=", " ", 
     RowBox[{"TimeSeries", "[", 
      RowBox[{"monthlyTemp", ",", " ", 
       RowBox[{"{", "dates", "}"}]}], "]"}]}], ";"}], "\n", "\n", 
   RowBox[{"DateListPlot", "[", 
    RowBox[{"tempTS", ",", "\n", "  ", 
     RowBox[{
     "PlotLabel", " ", "->", 
      " ", "\"\<Berlin Monthly Mean Temperature - ERA5-Land 2024\>\""}], ",", 
     "\n", "  ", 
     RowBox[{"AxesLabel", " ", "->", " ", 
      RowBox[{"{", 
       RowBox[{"None", ",", " ", "\"\<Temperature (\[Degree]C)\>\""}], 
       "}"}]}], ",", "\n", "  ", 
     RowBox[{"Joined", " ", "->", " ", "True"}], ",", "\n", "  ", 
     RowBox[{"PlotMarkers", " ", "->", " ", "Automatic"}], ",", "\n", "  ", 
     RowBox[{"Filling", " ", "->", " ", "0"}], ",", "\n", "  ", 
     RowBox[{"FillingStyle", " ", "->", " ", 
      RowBox[{"Directive", "[", 
       RowBox[{
        RowBox[{"Opacity", "[", "0.2", "]"}], ",", " ", "Red"}], "]"}]}], ",",
      "\n", "  ", 
     RowBox[{"GridLines", " ", "->", " ", "Automatic"}]}], "]"}]}]}]], "Input",
 CellLabel->
  "In[262]:=",ExpressionUUID->"b67b20c3-e895-db41-9824-a9d1269027f4"],

