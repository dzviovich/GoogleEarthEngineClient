Cell[TextData[StyleBox["Apply smoothing and trend detection:",
 FontWeight->Bold]], "Text",ExpressionUUID->"a12b9524-a80a-3a4d-a290-\
1dd084c19f68"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{"3", "-", 
    RowBox[{
    "month", " ", "moving", " ", "average", " ", "to", " ", "highlight", " ", 
     "seasonal", " ", "cycles"}]}], " ", "*)"}], "\n", "\n", 
  RowBox[{
   RowBox[{
    RowBox[{"smoothTS", " ", "=", " ", 
     RowBox[{"MovingAverage", "[", 
      RowBox[{"rainTS", ",", 
       RowBox[{"Quantity", "[", 
        RowBox[{"3", ",", "\"\<Months\>\""}], "]"}]}], "]"}]}], ";"}], "\n", "\n", 
   RowBox[{
    RowBox[{"annualTS", "=", 
     RowBox[{"MovingAverage", "[", 
      RowBox[{"rainTS", ",", 
       RowBox[{"Quantity", "[", 
        RowBox[{"3", ",", "\"\<Year\>\""}], "]"}]}], "]"}]}], ";"}], "\n", 
   "\n", 
   RowBox[{"(*", " ", 
    RowBox[{"Combined", " ", "visualization"}], " ", "*)"}], "\n", 
   RowBox[{"Show", "[", "\n", "  ", 
    RowBox[{
     RowBox[{"DateListPlot", "[", 
      RowBox[{"rainTS", ",", "\n", "    ", 
       RowBox[{"PlotStyle", " ", "->", " ", 
        RowBox[{"Directive", "[", 
         RowBox[{
          RowBox[{"Opacity", "[", "0.5", "]"}], ",", " ", "Blue"}], "]"}]}], ",",
        "\n", "    ", 
       RowBox[{
       "PlotLabel", " ", "->", 
        " ", "\"\<Tucuman Rainfall: Trend Analysis\>\""}]}], "]"}], ",", "\n",
      "  ", 
     RowBox[{"DateListPlot", "[", 
      RowBox[{"smoothTS", ",", "\n", "    ", 
       RowBox[{"PlotStyle", " ", "->", " ", 
        RowBox[{"Directive", "[", 
         RowBox[{"Thick", ",", " ", "Orange"}], "]"}]}], ",", "\n", "    ", 
       RowBox[{"Joined", " ", "->", " ", "True"}]}], "]"}], ",", "\n", "   ", 
     RowBox[{"DateListPlot", "[", 
      RowBox[{"annualTS", ",", "\n", "    ", 
       RowBox[{"PlotStyle", " ", "->", " ", 
        RowBox[{"Directive", "[", 
         RowBox[{"Thick", ",", " ", "Green"}], "]"}]}], ",", "\n", "    ", 
       RowBox[{"Joined", " ", "->", " ", "True"}]}], "]"}], ",", "\n", "  ", 
     RowBox[{"PlotLegends", " ", "->", " ", 
      RowBox[{"{", 
       RowBox[{"\"\<Monthly\>\"", ",", " ", "\"\<3-Month Moving Avg\>\"", ",",
         " ", "\"\<3-yr Moving Avg\>\""}], "}"}]}], ",", "\n", "  ", 
     RowBox[{"AxesLabel", " ", "->", " ", 
      RowBox[{"{", 
       RowBox[{"None", ",", " ", "\"\<Rainfall (mm)\>\""}], "}"}]}], ",", 
     RowBox[{"PlotTheme", "->", "\"\<Detailed\>\""}], ",", 
     RowBox[{"ImageSize", "->", "Large"}]}], "\n", "]"}], "\n"}]}]], "Input",
 CellChangeTimes->{{3.9844938403162575`*^9, 3.984493841375738*^9}, {
