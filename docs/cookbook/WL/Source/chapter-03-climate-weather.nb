Cell[TextData[StyleBox["Rainfall anomaly -- compare to the long-term mean:",
 FontWeight->Bold]], "Text",ExpressionUUID->"c9e5a9c5-fd80-9446-b553-\
f3343085f447"],

Cell["\<\
A rainfall anomaly highlights whether a given month was wetter or drier than \
normal. Compute the long-term July mean (e.g., 2010-2023), then subtract from \
the current year.\
\>", "Text",ExpressionUUID->"db10ab45-3ded-5f43-a799-ef4b9b5809c4"],

Cell[TextData[{
 StyleBox["Note:",
  FontWeight->Bold],
 " This simplified approach averages all daily values in the date range, not \
just July values. For a precise July climatology, compute each year's July \
total separately and average them (see Section 3.2.3 for the per-month loop \
pattern)."
}], "Text",
 CellFrame->{{True, False}, {
   False, False}},ExpressionUUID->"424f93e7-6362-3346-accc-a4ed5032d74d"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{"Long", "-", 
    RowBox[{"term", " ", "July", " ", 
     RowBox[{"mean", ":", " ", 
      RowBox[{"14", " ", "years", " ", "of", " ", "July", " ", "data"}]}]}]}],
    " ", "*)"}], "\n", 
  RowBox[{
   RowBox[{
    RowBox[{"longTermJuly", " ", "=", " ", 
     RowBox[{
      RowBox[{
       RowBox[{
        RowBox[{
         RowBox[{
          RowBox[{
           RowBox[{
           "GEECollection", "[", "\"\<UCSB-CHG/CHIRPS/DAILY\>\"", "]"}], " ", 
           "//", "\n", "  ", 
           RowBox[{"GEEFilterDate", "[", 
            RowBox[{"\"\<2010-07-01\>\"", ",", " ", "\"\<2023-08-01\>\""}], 
            "]"}]}], " ", "//", "\n", "  ", 
          RowBox[{"GEEFilterBounds", "[", 
           RowBox[{"{", 
            RowBox[{
            "68.0", ",", " ", "8.0", ",", " ", "90.0", ",", " ", "28.0"}], 
            "}"}], "]"}]}], " ", "//", "\n", "  ", 
         RowBox[{"GEEFilterProperty", "[", 
          
          RowBox[{"\"\<system:time_start\>\"", ",", 
           " ", "\"\<GreaterThanOrEquals\>\"", ",", "\n", "    ", 
           RowBox[{
            RowBox[{"UnixTime", "[", 
             RowBox[{"DateObject", "[", 
              RowBox[{"{", 
               RowBox[{"2010", ",", " ", "7", ",", " ", "1"}], "}"}], "]"}], 
             "]"}], " ", "*", " ", "1000"}]}], "]"}]}], " ", "//", "\n", "  ", 
        RowBox[{"GEESelectBands", "[", 
         RowBox[{"{", "\"\<precipitation\>\"", "}"}], "]"}]}], " ", "//", 
       "\n", "  ", "GEEMean"}], " ", "//", "\n", "  ", 
      RowBox[{"GEEMultiply", "[", "31", "]"}]}]}], ";"}], "  ", 
   RowBox[{"(*", " ", 
    RowBox[{
    "Scale", " ", "daily", " ", "mean", " ", "to", " ", "monthly", " ", 
     "total"}], " ", "*)"}], "\n", "\n", 
   RowBox[{"(*", " ", 
    RowBox[{
     RowBox[{"Current", " ", "year", " ", "July", " ", 
      RowBox[{"total", " ", "--"}], " ", "use", " ", "GEEMean", " ", "*", " ",
       "31", " ", "so", " ", "the", " ", "output", " ", "band", " ", "name", "\n",
       "   ", 
      RowBox[{"(", "precipitation_mean", ")"}], " ", "matches", " ", "the", " ",
       "long"}], "-", 
     RowBox[{"term", " ", "mean", " ", "for", " ", "subtraction"}]}], " ", 
    "*)"}], "\n", 
   RowBox[{
    RowBox[{"currentJuly", " ", "=", " ", 
     RowBox[{
      RowBox[{
       RowBox[{
        RowBox[{
         RowBox[{
          RowBox[{
          "GEECollection", "[", "\"\<UCSB-CHG/CHIRPS/DAILY\>\"", "]"}], " ", "//",
           "\n", "  ", 
          RowBox[{"GEEFilterDate", "[", 
           RowBox[{"\"\<2024-07-01\>\"", ",", " ", "\"\<2024-08-01\>\""}], 
           "]"}]}], " ", "//", "\n", "  ", 
         RowBox[{"GEEFilterBounds", "[", 
          RowBox[{"{", 
           RowBox[{
           "68.0", ",", " ", "8.0", ",", " ", "90.0", ",", " ", "28.0"}], 
           "}"}], "]"}]}], " ", "//", "\n", "  ", 
        RowBox[{"GEESelectBands", "[", 
         RowBox[{"{", "\"\<precipitation\>\"", "}"}], "]"}]}], " ", "//", 
       "\n", "  ", "GEEMean"}], " ", "//", "\n", "  ", 
      RowBox[{"GEEMultiply", "[", "31", "]"}]}]}], ";"}], "\n", "\n", 
   RowBox[{"(*", " ", 
    RowBox[{"Anomaly", " ", "=", " ", 
     RowBox[{"current", " ", "-", " ", "long", "-", 
      RowBox[{"term", " ", "mean"}]}]}], " ", "*)"}], "\n", 
   RowBox[{
    RowBox[{"anomaly", " ", "=", " ", 
     RowBox[{"GEESubtract", "[", 
      RowBox[{"currentJuly", ",", " ", "longTermJuly"}], "]"}]}], ";"}], "\n",
    "\n", 
   RowBox[{"GEEComputePixels", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"68.0", ",", " ", "8.0", ",", " ", "90.0", ",", " ", "28.0"}], 
      "}"}], ",", " ", "anomaly", ",", "\n", "  ", 
     RowBox[{"\"\<VisParams\>\"", " ", "->", " ", 
      RowBox[{"<|", 
       RowBox[{
        RowBox[{"\"\<min\>\"", " ", "->", " ", 
         RowBox[{"-", "200"}]}], ",", " ", 
        RowBox[{"\"\<max\>\"", " ", "->", " ", "200"}], ",", "\n", "    ", 
        RowBox[{"\"\<palette\>\"", " ", "->", " ", 
         RowBox[{"{", 
          RowBox[{"\"\<#8c510a\>\"", ",", " ", "\"\<#d8b365\>\"", ",", 
           " ", "\"\<#f6e8c3\>\"", ",", "\n", "      ", "\"\<#f5f5f5\>\"", ",",
            " ", "\"\<#c7eae5\>\"", ",", " ", "\"\<#5ab4ac\>\"", ",", 
           " ", "\"\<#01665e\>\""}], "}"}]}]}], "|>"}]}], ",", "\n", "  ", 
     RowBox[{"\"\<ImageSize\>\"", " ", "->", " ", 
      RowBox[{"{", 
       RowBox[{"600", ",", " ", "500"}], "}"}]}]}], "]"}], "\n", 
   RowBox[{"(*", " ", 
    RowBox[{
     RowBox[{"Brown", " ", "=", " ", 
      RowBox[{"drier", " ", "than", " ", "normal"}]}], ",", " ", 
     RowBox[{"teal", " ", "=", " ", 
      RowBox[{"wetter", " ", "than", " ", "normal"}]}]}], " ", 
    "*)"}]}]}]], "Input",
 CellLabel->
  "In[163]:=",ExpressionUUID->"09a137a4-9edc-984b-a103-86b00600ec3b"],

