Cell[CellGroupData[{

Cell["3.5.4 Detecting Seasonal Cycles with Fourier Analysis", "Section",ExpressionUUID->"e7a62c05-7caf-9141-adb5-aae1bfc24c67"],

Cell[TextData[{
 "Wolfram Language's ",
 Cell["Fourier", "InlineCode",ExpressionUUID->
  "bbb00b7d-367e-364f-9076-515b9f4c1b9b"],
 " and ",
 Cell["Periodogram", "InlineCode",ExpressionUUID->
  "72935bfa-16ea-4c42-aff7-7c5e75885bb4"],
 " functions reveal dominant periodicities in climate time series. A monthly \
temperature series should show a strong 12-month cycle."
}], "Text",ExpressionUUID->"9b2187c4-195e-9a41-8bcf-81372b1bfac1"],

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{
   "Use", " ", "the", " ", "monthly", " ", "LST", " ", "time", " ", "series", 
    " ", "from", " ", "Section", " ", "3.5", ".2"}], " ", "*)"}], "\n", 
  RowBox[{"(*", " ", 
   RowBox[{"Compute", " ", "the", " ", "power", " ", "spectrum"}], " ", 
   "*)"}], "\n", 
  RowBox[{
   RowBox[{"Periodogram", "[", 
    RowBox[{
     RowBox[{"lstMonthlyTS", "[", "\"\<Values\>\"", "]"}], ",", "\n", "  ", 
     RowBox[{
     "PlotLabel", " ", "->", " ", "\"\<LST Power Spectrum - Madrid\>\""}], ",",
      "\n", "  ", 
     RowBox[{"PlotRange", " ", "->", " ", "All"}], ",", "\n", "  ", 
     RowBox[{"ScalingFunctions", " ", "->", " ", "\"\<Log\>\""}]}], "]"}], 
   "\n", "\n", 
   RowBox[{"(*", " ", 
    RowBox[{
    "The", " ", "dominant", " ", "peak", " ", "near", " ", "frequency", " ", 
     RowBox[{"1", "/", "12"}], " ", "confirms", " ", "the", " ", "annual", " ",
      "cycle"}], " ", "*)"}], "\n", 
   RowBox[{"(*", " ", 
    RowBox[{"A", " ", "secondary", " ", "peak", " ", "at", " ", 
     RowBox[{"1", "/", "6"}], " ", 
     RowBox[{"(", "semiannual", ")"}], " ", "may", " ", "also", " ", "appear",
      " ", "due", " ", "to", " ", "the", "\n", "   ", "bimodal", " ", 
     "temperature", " ", "distribution", " ", "in", " ", "continental", " ", 
     "climates"}], " ", "*)"}], "\n", "\n", 
   RowBox[{"(*", " ", 
    RowBox[{"Extract", " ", "the", " ", "dominant", " ", "period"}], " ", 
    "*)"}], "\n", 
   RowBox[{
    RowBox[{"ft", " ", "=", " ", 
     RowBox[{
      RowBox[{"Abs", "[", 
       RowBox[{"Fourier", "[", 
        RowBox[{"lstMonthlyTS", "[", "\"\<Values\>\"", "]"}], "]"}], "]"}], "^",
       "2"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"freqs", " ", "=", " ", 
     RowBox[{
      RowBox[{"Range", "[", 
       RowBox[{"0", ",", " ", 
        RowBox[{
         RowBox[{"Length", "[", "ft", "]"}], " ", "-", " ", "1"}]}], "]"}], 
      " ", "/", " ", 
      RowBox[{"Length", "[", "ft", "]"}]}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"peakIdx", " ", "=", " ", 
     RowBox[{
      RowBox[{
       RowBox[{"Ordering", "[", 
        RowBox[{
         RowBox[{"ft", "[", 
          RowBox[{"[", 
           RowBox[{"2", " ", ";;", " ", 
            RowBox[{"Floor", "[", 
             RowBox[{
              RowBox[{"Length", "[", "ft", "]"}], "/", "2"}], "]"}]}], "]"}], 
          "]"}], ",", " ", 
         RowBox[{"-", "1"}]}], "]"}], "[", 
       RowBox[{"[", "1", "]"}], "]"}], " ", "+", " ", "1"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"dominantPeriod", " ", "=", " ", 
     RowBox[{
      RowBox[{"Length", "[", "ft", "]"}], " ", "/", " ", 
      RowBox[{"(", 
       RowBox[{"peakIdx", " ", "-", " ", "1"}], ")"}]}]}], ";"}], "\n", 
   RowBox[{"Print", "[", 
    RowBox[{"\"\<Dominant period: \>\"", ",", " ", 
     RowBox[{"Round", "[", 
      RowBox[{"dominantPeriod", ",", " ", "0.1"}], "]"}], ",", 
     " ", "\"\< months\>\""}], "]"}], "\n", 
   RowBox[{"(*", " ", 
    RowBox[{"Expected", ":", " ", 
     RowBox[{
      RowBox[{"~", "12"}], " ", "months"}]}], " ", "*)"}]}]}]], "Input",Expres\
sionUUID->"4bcec780-109f-af49-9d60-f19c2e3ea16e"],

Cell["", "Text",
 CellFrame->{{0, 0}, {0, 
  1}},ExpressionUUID->"09d05a75-c9f5-a64d-aa64-df8e1de272d1"]
}, Open  ]]
}, Open  ]],

Cell[CellGroupData[{

Cell["3.6 Solar Radiation", "Chapter",ExpressionUUID->"9633e202-6e2d-a947-b015-bd8a07bab2dd"],

Cell["\<\
Solar radiation drives the surface energy budget and is critical for solar \
energy site assessment. Combining Wolfram Language's astronomical functions \
with GEE terrain data enables physically based irradiance estimation.\
\>", "Text",ExpressionUUID->"541075ce-ab4d-6641-aefd-18c5cda3c95f"],

Cell[CellGroupData[{

Cell["3.6.1 Solar Geometry with Wolfram Language", "Section",ExpressionUUID->"cdfecdcf-ee8b-f040-94ab-177ff3749afb"],

Cell[TextData[{
 "The built-in ",
 Cell["SunPosition", "InlineCode",ExpressionUUID->
  "3cb5b30d-570a-da4d-9e85-db1dc20cdd42"],
 " function computes solar altitude and azimuth for any location and time, \
which determines how much direct sunlight reaches a tilted surface."
}], "Text",ExpressionUUID->"56c004d1-33d3-d64e-a5cf-f9f454ee9fe9"],

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{
    RowBox[{
    "Solar", " ", "position", " ", "at", " ", "noon", " ", "on", " ", "the", " ",
      "summer", " ", "solstice", " ", "in", " ", "Austin"}], ",", " ", "TX"}],
    " ", "*)"}], "\n", 
  RowBox[{
   RowBox[{
    RowBox[{"pos", " ", "=", " ", 
     RowBox[{"GeoPosition", "[", 
      RowBox[{"{", 
       RowBox[{"30.27", ",", " ", 
        RowBox[{"-", "97.74"}]}], "}"}], "]"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"date", " ", "=", " ", 
     RowBox[{"DateObject", "[", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{
        "2024", ",", " ", "6", ",", " ", "21", ",", " ", "12", ",", " ", "0", 
         ",", " ", "0"}], "}"}], ",", " ", 
       RowBox[{"TimeZone", " ", "->", " ", 
        RowBox[{"-", "5"}]}]}], "]"}]}], ";"}], "\n", "\n", 
   RowBox[{
    RowBox[{"sunPos", " ", "=", " ", 
     RowBox[{"SunPosition", "[", 
      RowBox[{"pos", ",", " ", "date"}], "]"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"altitude", " ", "=", " ", 
     RowBox[{"QuantityMagnitude", "[", 
      RowBox[{
       RowBox[{"sunPos", "[", 
        RowBox[{"[", "1", "]"}], "]"}], ",", " ", "\"\<AngularDegrees\>\""}], 
      "]"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"azimuth", " ", "=", " ", 
     RowBox[{"QuantityMagnitude", "[", 
      RowBox[{
       RowBox[{"sunPos", "[", 
        RowBox[{"[", "2", "]"}], "]"}], ",", " ", "\"\<AngularDegrees\>\""}], 
      "]"}]}], ";"}], "\n", "\n", 
   RowBox[{"Print", "[", 
    RowBox[{"\"\<Solar altitude: \>\"", ",", " ", 
     RowBox[{"Round", "[", 
      RowBox[{"altitude", ",", " ", "0.1"}], "]"}], ",", 
     " ", "\"\<\[Degree]\>\""}], "]"}], "\n", 
   RowBox[{"Print", "[", 
    RowBox[{"\"\<Solar azimuth: \>\"", ",", " ", 
     RowBox[{"Round", "[", 
      RowBox[{"azimuth", ",", " ", "0.1"}], "]"}], ",", 
     " ", "\"\<\[Degree]\>\""}], "]"}], "\n", "\n", 
   RowBox[{"(*", " ", 
    RowBox[{"Daily", " ", "solar", " ", "trajectory"}], " ", "*)"}], "\n", 
   RowBox[{
    RowBox[{"times", " ", "=", " ", 
     RowBox[{"Table", "[", "\n", "  ", 
      RowBox[{
       RowBox[{"DateObject", "[", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{
          "2024", ",", " ", "6", ",", " ", "21", ",", " ", "h", ",", " ", "0",
            ",", " ", "0"}], "}"}], ",", " ", 
         RowBox[{"TimeZone", " ", "->", " ", 
          RowBox[{"-", "5"}]}]}], "]"}], ",", "\n", "  ", 
       RowBox[{"{", 
        RowBox[{"h", ",", " ", "6", ",", " ", "20", ",", " ", "0.5"}], 
        "}"}]}], "\n", "]"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"trajectory", " ", "=", " ", 
     RowBox[{"Table", "[", "\n", "  ", 
      RowBox[{
       RowBox[{"Module", "[", 
        RowBox[{
         RowBox[{"{", "sp", "}"}], ",", "\n", "    ", 
         RowBox[{
          RowBox[{"sp", " ", "=", " ", 
           RowBox[{"SunPosition", "[", 
            RowBox[{"pos", ",", " ", "t"}], "]"}]}], ";", "\n", "    ", 
          RowBox[{"{", 
           RowBox[{
            RowBox[{"QuantityMagnitude", "[", 
             RowBox[{
              RowBox[{"sp", "[", 
               RowBox[{"[", "2", "]"}], "]"}], ",", 
              " ", "\"\<AngularDegrees\>\""}], "]"}], ",", "\n", "     ", 
            RowBox[{"QuantityMagnitude", "[", 
             RowBox[{
              RowBox[{"sp", "[", 
               RowBox[{"[", "1", "]"}], "]"}], ",", 
              " ", "\"\<AngularDegrees\>\""}], "]"}]}], "}"}]}]}], "\n", "  ",
         "]"}], ",", "\n", "  ", 
       RowBox[{"{", 
        RowBox[{"t", ",", " ", "times"}], "}"}]}], "\n", "]"}]}], ";"}], "\n",
    "\n", 
   RowBox[{"ListLinePlot", "[", 
    RowBox[{"trajectory", ",", "\n", "  ", 
     RowBox[{
     "PlotLabel", " ", "->", 
      " ", "\"\<Solar Trajectory - Austin, TX (Summer Solstice)\>\""}], ",", 
     "\n", "  ", 
     RowBox[{"AxesLabel", " ", "->", " ", 
      RowBox[{"{", 
       RowBox[{"\"\<Azimuth (\[Degree])\>\"", ",", 
        " ", "\"\<Altitude (\[Degree])\>\""}], "}"}]}], ",", "\n", "  ", 
     RowBox[{"PlotRange", " ", "->", " ", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{"0", ",", " ", "360"}], "}"}], ",", " ", 
        RowBox[{"{", 
         RowBox[{"0", ",", " ", "90"}], "}"}]}], "}"}]}], ",", "\n", "  ", 
     RowBox[{"AspectRatio", " ", "->", " ", 
      RowBox[{"1", "/", "3"}]}], ",", "\n", "  ", 
     RowBox[{"PlotMarkers", " ", "->", " ", "Automatic"}]}], 
    "]"}]}]}]], "Input",ExpressionUUID->"826cbd34-76ec-874e-b853-\
76dacc4c1a97"]
}, Open  ]],

Cell[CellGroupData[{

Cell["3.6.2 Terrain-Adjusted Solar Irradiance", "Section",ExpressionUUID->"b205d978-7a56-f343-961e-0f258ce11118"],

Cell["\<\
Slope and aspect from GEE terrain data determine how a surface is oriented \
relative to incoming sunlight. South-facing slopes in the Northern Hemisphere \
receive more direct radiation than north-facing slopes.\
\>", "Text",ExpressionUUID->"7a906f48-9726-0f42-b956-288e185ac776"],

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{"Compute", " ", "terrain", " ", "from", " ", "SRTM", " ", "DEM"}], 
   " ", "*)"}], "\n", 
  RowBox[{
   RowBox[{
    RowBox[{"dem", " ", "=", " ", 
     RowBox[{"GEELoadImage", "[", "\"\<USGS/SRTMGL1_003\>\"", "]"}]}], ";"}], 
   "\n", 
   RowBox[{
    RowBox[{"terrain", " ", "=", " ", 
     RowBox[{"GEETerrain", "[", "dem", "]"}]}], ";"}], "\n", "\n", 
   RowBox[{"(*", " ", 
    RowBox[{
    "Sample", " ", "slope", " ", "and", " ", "aspect", " ", "at", " ", "a", " ",
      "mountain", " ", "location"}], " ", "*)"}], "\n", 
   RowBox[{
    RowBox[{"mountainPos", " ", "=", " ", 
     RowBox[{"GeoPosition", "[", 
      RowBox[{"{", 
       RowBox[{"39.75", ",", " ", 
        RowBox[{"-", "105.25"}]}], "}"}], "]"}]}], ";"}], "  ", 
   RowBox[{"(*", " ", 
    RowBox[{"Rocky", " ", "Mountain", " ", "foothills"}], " ", "*)"}], "\n", 
   RowBox[{
    RowBox[{"terrainVals", " ", "=", " ", 
     RowBox[{"GEEIdentify", "[", 
      RowBox[{"mountainPos", ",", " ", "terrain"}], "]"}]}], ";"}], "\n", 
   "\n", 
   RowBox[{"(*", " ", 
    RowBox[{
     RowBox[{"GEETerrain", " ", "produces", " ", 
      RowBox[{"bands", ":", " ", "elevation"}]}], ",", " ", "slope", ",", " ",
      "aspect", ",", " ", "hillshade"}], " ", "*)"}], "\n", 
   RowBox[{"Print", "[", "\"\<Terrain at sample point:\>\"", "]"}], "\n", 
   RowBox[{"MapThread", "[", "\n", "  ", 
    RowBox[{
     RowBox[{
      RowBox[{"Print", "[", 
       RowBox[{"\"\<  \>\"", ",", " ", "#1", ",", " ", "\"\<: \>\"", ",", " ",
         "#2"}], "]"}], " ", "&"}], ",", "\n", "  ", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"terrainVals", "[", "\"\<Bands\>\"", "]"}], ",", " ", 
       RowBox[{"terrainVals", "[", "\"\<Values\>\"", "]"}]}], "}"}]}], "\n", 
    "]"}]}]}]], "Input",ExpressionUUID->"ae430ca6-4188-174e-9c28-\
003a7f33c1c4"],

Cell[TextData[StyleBox["Estimate clear-sky solar irradiance on a tilted \
surface:",
 FontWeight->Bold]], "Text",ExpressionUUID->"df44d7aa-ba7b-4b4d-b555-\
df3c16c18b42"],

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{"Solar", " ", "constant", " ", 
    RowBox[{"(", 
     RowBox[{"W", "/", 
      RowBox[{"m", "^", "2"}]}], ")"}]}], " ", "*)"}], "\n", 
  RowBox[{
   RowBox[{
    RowBox[{"solarConstant", " ", "=", " ", "1361"}], ";"}], "\n", "\n", 
   RowBox[{"(*", " ", 
    RowBox[{
    "Sample", " ", "terrain", " ", "across", " ", "a", " ", "mountain", " ", 
     "transect"}], " ", "*)"}], "\n", 
   RowBox[{
    RowBox[{"transectPoints", " ", "=", " ", 
     RowBox[{"Table", "[", "\n", "  ", 
      RowBox[{
       RowBox[{"GeoPosition", "[", 
        RowBox[{"{", 
         RowBox[{"39.75", ",", " ", "lon"}], "}"}], "]"}], ",", "\n", "  ", 
       RowBox[{"{", 
        RowBox[{"lon", ",", " ", 
         RowBox[{"-", "105.40"}], ",", " ", 
         RowBox[{"-", "105.10"}], ",", " ", "0.03"}], "}"}]}], "\n", "]"}]}], 
    ";"}], "\n", 
   RowBox[{
    RowBox[{"terrainSamples", " ", "=", " ", 
     RowBox[{"GEEGetSamples", "[", 
      RowBox[{"transectPoints", ",", " ", "terrain"}], "]"}]}], ";"}], "\n", 
   "\n", 
   RowBox[{"(*", " ", 
    RowBox[{
     RowBox[{"Compute", " ", "solar", " ", "angle", " ", "at", " ", "noon"}], 
     ",", " ", 
     RowBox[{"summer", " ", "solstice"}]}], " ", "*)"}], "\n", 
   RowBox[{
    RowBox[{"solarAlt", " ", "=", " ", 
     RowBox[{"QuantityMagnitude", "[", "\n", "  ", 
      RowBox[{
       RowBox[{
        RowBox[{"SunPosition", "[", 
         RowBox[{
          RowBox[{"GeoPosition", "[", 
           RowBox[{"{", 
            RowBox[{"39.75", ",", " ", 
             RowBox[{"-", "105.25"}]}], "}"}], "]"}], ",", "\n", "    ", 
          RowBox[{"DateObject", "[", 
           RowBox[{
            RowBox[{"{", 
             RowBox[{
             "2024", ",", " ", "6", ",", " ", "21", ",", " ", "12", ",", " ", 
              "0", ",", " ", "0"}], "}"}], ",", " ", 
            RowBox[{"TimeZone", " ", "->", " ", 
             RowBox[{"-", "6"}]}]}], "]"}]}], "]"}], "[", 
        RowBox[{"[", "1", "]"}], "]"}], ",", "\n", 
       "  ", "\"\<AngularDegrees\>\""}], "]"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"solarAz", " ", "=", " ", 
     RowBox[{"QuantityMagnitude", "[", "\n", "  ", 
      RowBox[{
       RowBox[{
        RowBox[{"SunPosition", "[", 
         RowBox[{
          RowBox[{"GeoPosition", "[", 
           RowBox[{"{", 
            RowBox[{"39.75", ",", " ", 
             RowBox[{"-", "105.25"}]}], "}"}], "]"}], ",", "\n", "    ", 
          RowBox[{"DateObject", "[", 
           RowBox[{
            RowBox[{"{", 
             RowBox[{
             "2024", ",", " ", "6", ",", " ", "21", ",", " ", "12", ",", " ", 
              "0", ",", " ", "0"}], "}"}], ",", " ", 
            RowBox[{"TimeZone", " ", "->", " ", 
             RowBox[{"-", "6"}]}]}], "]"}]}], "]"}], "[", 
        RowBox[{"[", "2", "]"}], "]"}], ",", "\n", 
       "  ", "\"\<AngularDegrees\>\""}], "]"}]}], ";"}], "\n", "\n", 
   RowBox[{"(*", " ", 
    RowBox[{
    "Compute", " ", "irradiance", " ", "on", " ", "tilted", " ", "surfaces"}],
     " ", "*)"}], "\n", 
   RowBox[{"(*", " ", 
    RowBox[{
     RowBox[{"Bands", " ", "are", " ", 
      RowBox[{"alphabetical", ":", " ", "aspect"}]}], ",", " ", "elevation", ",",
      " ", "hillshade", ",", " ", "slope"}], " ", "*)"}], "\n", 
   RowBox[{
    RowBox[{"irradiance", " ", "=", " ", 
     RowBox[{"Table", "[", "\n", "  ", 
      RowBox[{
       RowBox[{"Module", "[", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{
          "vals", ",", " ", "aspect", ",", " ", "slope", ",", " ", 
           "cosIncidence", ",", " ", "irr"}], "}"}], ",", "\n", "    ", 
         RowBox[{
          RowBox[{"vals", " ", "=", " ", 
           RowBox[{
            RowBox[{"terrainSamples", "[", 
             RowBox[{"[", "i", "]"}], "]"}], "[", "\"\<Values\>\"", "]"}]}], ";",
           "\n", "    ", 
          RowBox[{"(*", " ", 
           RowBox[{
            RowBox[{"Band", " ", "order", " ", "from", " ", 
             RowBox[{"GEETerrain", ":", " ", "aspect"}]}], ",", " ", 
            "elevation", ",", " ", "hillshade", ",", " ", "slope"}], " ", 
           "*)"}], "\n", "    ", 
          RowBox[{"aspect", " ", "=", " ", 
           RowBox[{
            RowBox[{"vals", "[", 
             RowBox[{"[", "1", "]"}], "]"}], " ", "*", " ", 
            RowBox[{"Pi", " ", "/", " ", "180"}]}]}], ";", "   ", 
          RowBox[{"(*", " ", 
           RowBox[{"Convert", " ", "to", " ", "radians"}], " ", "*)"}], "\n", 
          "    ", 
          RowBox[{"slope", " ", "=", " ", 
           RowBox[{
            RowBox[{"vals", "[", 
             RowBox[{"[", "4", "]"}], "]"}], " ", "*", " ", 
            RowBox[{"Pi", " ", "/", " ", "180"}]}]}], ";", "\n", "    ", 
          RowBox[{"(*", " ", 
           RowBox[{
           "Cosine", " ", "of", " ", "incidence", " ", "angle", " ", 
            "between", " ", "sun", " ", "vector", " ", "and", " ", "surface", 
            " ", "normal"}], " ", "*)"}], "\n", "    ", 
          RowBox[{"cosIncidence", " ", "=", " ", 
           RowBox[{
            RowBox[{
             RowBox[{"Sin", "[", 
              RowBox[{"solarAlt", " ", "*", " ", 
               RowBox[{"Pi", " ", "/", " ", "180"}]}], "]"}], " ", "*", " ", 
             RowBox[{"Cos", "[", "slope", "]"}]}], " ", "+", "\n", "      ", 
            RowBox[{
             RowBox[{"Cos", "[", 
              RowBox[{"solarAlt", " ", "*", " ", 
               RowBox[{"Pi", " ", "/", " ", "180"}]}], "]"}], " ", "*", " ", 
             RowBox[{"Sin", "[", "slope", "]"}], " ", "*", "\n", "      ", 
             RowBox[{"Cos", "[", 
              RowBox[{
               RowBox[{"(", 
                RowBox[{"solarAz", " ", "-", " ", 
                 RowBox[{"vals", "[", 
                  RowBox[{"[", "1", "]"}], "]"}]}], ")"}], " ", "*", " ", 
               RowBox[{"Pi", " ", "/", " ", "180"}]}], "]"}]}]}]}], ";", "\n",
           "    ", 
          RowBox[{"irr", " ", "=", " ", 
           RowBox[{"solarConstant", " ", "*", " ", 
            RowBox[{"Max", "[", 
             RowBox[{"0", ",", " ", "cosIncidence"}], "]"}], " ", "*", " ", 
            "0.75"}]}], ";", "  ", 
          RowBox[{"(*", " ", 
           RowBox[{"0.75", " ", "atmospheric", " ", "transmittance"}], " ", 
           "*)"}], "\n", "    ", "irr"}]}], "\n", "  ", "]"}], ",", "\n", 
       "  ", 
       RowBox[{"{", 
        RowBox[{"i", ",", " ", 
         RowBox[{"Length", "[", "terrainSamples", "]"}]}], "}"}]}], "\n", 
      "]"}]}], ";"}], "\n", "\n", 
   RowBox[{"ListLinePlot", "[", "\n", "  ", 
    RowBox[{
     RowBox[{"Transpose", "[", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"Range", "[", 
         RowBox[{"Length", "[", "irradiance", "]"}], "]"}], ",", " ", 
        "irradiance"}], "}"}], "]"}], ",", "\n", "  ", 
     RowBox[{
     "PlotLabel", " ", "->", 
      " ", "\"\<Estimated Solar Irradiance Along Mountain Transect\>\""}], ",",
      "\n", "  ", 
     RowBox[{"AxesLabel", " ", "->", " ", 
      RowBox[{"{", 
       RowBox[{"\"\<Transect Point\>\"", ",", 
        " ", "\"\<Irradiance (W/m\\[TwoSuperior])\>\""}], "}"}]}], ",", "\n", 
     "  ", 
     RowBox[{"Filling", " ", "->", " ", "Bottom"}], ",", "\n", "  ", 
     RowBox[{"FillingStyle", " ", "->", " ", 
      RowBox[{"Directive", "[", 
       RowBox[{
        RowBox[{"Opacity", "[", "0.3", "]"}], ",", " ", "Yellow"}], "]"}]}], ",",
      "\n", "  ", 
     RowBox[{"PlotRange", " ", "->", " ", 
      RowBox[{"{", 
       RowBox[{"0", ",", " ", "All"}], "}"}]}]}], "]"}]}]}]], "Input",Expressi\
onUUID->"b27f7201-be01-3941-ae49-e4b75f4f5516"]
