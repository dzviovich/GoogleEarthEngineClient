Cell[CellGroupData[{

Cell["3.2.3 Monthly Rainfall Time Series with Trend Analysis", "Section",ExpressionUUID->"a6589741-1531-c245-b6a9-d26e4f44f819"],

Cell["\<\
Building a multi-month rainfall time series from GEE point queries and \
analyzing it with Wolfram Language statistical tools is a powerful workflow \
for detecting climate trends.\
\>", "Text",ExpressionUUID->"9f70c733-1650-004e-9045-0272aeb896d8"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{
   "Extract", " ", "monthly", " ", "rainfall", " ", "for", " ", "Tucuman", " ",
     "Province", " ", "over", " ", "3", " ", "years"}], " ", "*)"}], "\n", 
  RowBox[{
   RowBox[{
    RowBox[{"months", " ", "=", " ", 
     RowBox[{"Flatten", " ", "[", " ", 
      RowBox[{
       RowBox[{"Table", "[", "\n", "  ", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{"year", ",", " ", "month"}], "}"}], ",", "\n", "  ", 
         RowBox[{"{", 
          RowBox[{"year", ",", " ", "2012", ",", " ", "2024"}], "}"}], ",", 
         " ", 
         RowBox[{"{", 
          RowBox[{"month", ",", " ", "1", ",", " ", "12"}], "}"}]}], "\n", 
        "]"}], ",", "1"}], "]"}]}], ";"}], "\n", "\n", 
   RowBox[{
    RowBox[{"tucuGeom", " ", "=", " ", 
     RowBox[{"GEEGeometry", "[", 
      RowBox[{"bbox", "=", 
       RowBox[{"{", 
        RowBox[{
         RowBox[{"-", "66.18"}], ",", " ", 
         RowBox[{"-", "28.02"}], " ", ",", 
         RowBox[{"-", "64.48"}], ",", " ", 
         RowBox[{"-", "26.13"}]}], "}"}]}], "]"}]}], ";"}], "\n", "\n", 
   RowBox[{
    RowBox[{"monthlyRain", " ", "=", " ", 
     RowBox[{"Table", "[", "\n", "  ", 
      RowBox[{
       RowBox[{"Module", "[", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{
          "startDate", ",", " ", "endDate", ",", " ", "expr", ",", " ", 
           "result"}], "}"}], ",", "\n", "    ", 
         RowBox[{
          RowBox[{"startDate", " ", "=", " ", 
           RowBox[{"DateString", "[", 
            RowBox[{
             RowBox[{"DateObject", "[", 
              RowBox[{"{", 
               RowBox[{
                RowBox[{"period", "[", 
                 RowBox[{"[", "1", "]"}], "]"}], ",", " ", 
                RowBox[{"period", "[", 
                 RowBox[{"[", "2", "]"}], "]"}], ",", " ", "1"}], "}"}], 
              "]"}], ",", "\n", "      ", 
             RowBox[{"{", 
              
              RowBox[{"\"\<Year\>\"", ",", " ", "\"\<-\>\"", ",", 
               " ", "\"\<Month\>\"", ",", " ", "\"\<-\>\"", ",", 
               " ", "\"\<Day\>\""}], "}"}]}], "]"}]}], ";", "\n", "    ", 
          RowBox[{"endDate", " ", "=", " ", 
           RowBox[{"DateString", "[", 
            RowBox[{
             RowBox[{"DateObject", "[", 
              RowBox[{"{", 
               RowBox[{
                RowBox[{"period", "[", 
                 RowBox[{"[", "1", "]"}], "]"}], ",", " ", 
                RowBox[{
                 RowBox[{"period", "[", 
                  RowBox[{"[", "2", "]"}], "]"}], " ", "+", " ", "1"}], ",", 
                " ", "1"}], "}"}], "]"}], ",", "\n", "      ", 
             RowBox[{"{", 
              
              RowBox[{"\"\<Year\>\"", ",", " ", "\"\<-\>\"", ",", 
               " ", "\"\<Month\>\"", ",", " ", "\"\<-\>\"", ",", 
               " ", "\"\<Day\>\""}], "}"}]}], "]"}]}], ";", "\n", "    ", 
          RowBox[{"expr", " ", "=", " ", 
           RowBox[{
            RowBox[{
             RowBox[{
              RowBox[{
               RowBox[{
                RowBox[{
                "GEECollection", "[", "\"\<UCSB-CHG/CHIRPS/DAILY\>\"", "]"}], 
                " ", "//", "\n", "      ", 
                RowBox[{"GEEFilterDate", "[", 
                 RowBox[{"startDate", ",", " ", "endDate"}], "]"}]}], " ", "//",
                "\n", "      ", 
               RowBox[{"GEEFilterBounds", "[", "bbox", "]"}]}], " ", "//", 
              "\n", "      ", 
              RowBox[{"GEESelectBands", "[", 
               RowBox[{"{", "\"\<precipitation\>\"", "}"}], "]"}]}], " ", "//",
              "\n", "      ", "GEECollectionSum"}], " ", "//", "\n", "      ", 
            RowBox[{"GEEReduceRegion", "[", 
             RowBox[{"tucuGeom", ",", " ", "\"\<mean\>\"", ",", " ", "5000"}],
              "]"}]}]}], ";", "\n", "    ", 
          RowBox[{"result", " ", "=", " ", 
           RowBox[{"GEECompute", "[", "expr", "]"}]}], ";", "\n", "    ", 
          RowBox[{"First", "[", 
           RowBox[{"Values", "[", "result", "]"}], "]"}]}]}], "\n", "  ", 
        "]"}], ",", "\n", "  ", 
       RowBox[{"{", 
        RowBox[{"period", ",", " ", "months"}], "}"}]}], " ", "\n", "]"}]}], 
    ";"}], "\n", "\n", 
   RowBox[{"(*", " ", 
