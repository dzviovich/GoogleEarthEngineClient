Cell[TextData[{
 StyleBox["Client-side approach using ",
  FontWeight->Bold],
 Cell["GEECompute", "InlineCode",ExpressionUUID->
  "2bfe9949-4fa3-a247-83b3-81009a77d526"],
 StyleBox[" results:",
  FontWeight->Bold]
}], "Text",ExpressionUUID->"7ec18d6d-21fe-834d-8bd6-4d87d5d5e9b5"],

Cell[TextData[{
 "When you need the numeric values for further analysis in Wolfram Language, \
use ",
 Cell["GEEReduceRegion", "InlineCode",ExpressionUUID->
  "eb81191c-349b-fc46-94e7-a43d10de4bcd"],
 " to extract regional means, then compute the balance client-side."
}], "Text",ExpressionUUID->"69d89553-56bb-cc4d-8687-68b8cd258d58"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"regionGeom", " ", "=", " ", 
    RowBox[{"GEEGeometry", "[", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"-", "121.0"}], ",", " ", "36.0", ",", " ", 
       RowBox[{"-", "120.0"}], ",", " ", "37.0"}], "}"}], "]"}]}], ";"}], 
  "\n"}], "\n", 
 RowBox[{
  RowBox[{"precipMean", " ", "=", " ", 
   RowBox[{"GEECompute", "[", "\n", "  ", 
    RowBox[{"annualPrecip", " ", "//", " ", 
     RowBox[{"GEEReduceRegion", "[", 
      RowBox[{"regionGeom", ",", " ", "\"\<mean\>\"", ",", " ", "5000"}], 
      "]"}]}], "\n", "]"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"etMean", " ", "=", " ", 
    RowBox[{"GEECompute", "[", "\n", "  ", 
     RowBox[{"annualET", " ", "//", " ", 
      RowBox[{"GEEReduceRegion", "[", 
       RowBox[{"regionGeom", ",", " ", "\"\<mean\>\"", ",", " ", "500"}], 
       "]"}]}], "\n", "]"}]}], ";"}], "\n"}], "\n", 
 RowBox[{
  RowBox[{"pVal", " ", "=", " ", 
   RowBox[{"First", "[", 
    RowBox[{"Values", "[", "precipMean", "]"}], "]"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{"etVal", " ", "=", " ", 
   RowBox[{"First", "[", 
    RowBox[{"Values", "[", "etMean", "]"}], "]"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"balance", " ", "=", " ", 
    RowBox[{"pVal", " ", "-", " ", "etVal"}]}], ";"}], "\n"}], "\n", 
 RowBox[{"Print", "[", 
  RowBox[{"\"\<Precipitation: \>\"", ",", " ", 
   RowBox[{"Round", "[", 
    RowBox[{"pVal", ",", " ", "1"}], "]"}], ",", " ", "\"\< mm/year\>\""}], 
  "]"}], "\n", 
 RowBox[{"Print", "[", 
  RowBox[{"\"\<Evapotranspiration: \>\"", ",", " ", 
   RowBox[{"Round", "[", 
    RowBox[{"etVal", ",", " ", "1"}], "]"}], ",", " ", "\"\< mm/year\>\""}], 
  "]"}], "\n", 
 RowBox[{"Print", "[", 
  RowBox[{"\"\<Water Balance: \>\"", ",", " ", 
   RowBox[{"Round", "[", 
    RowBox[{"balance", ",", " ", "1"}], "]"}], ",", " ", "\"\< mm/year\>\""}],
   "]"}], "\n", 
 RowBox[{"Print", "[", 
  RowBox[{"\"\<Status: \>\"", ",", " ", 
   RowBox[{"If", "[", 
    RowBox[{
     RowBox[{"balance", " ", ">", " ", "0"}], ",", " ", "\"\<Surplus\>\"", ",",
      " ", "\"\<Deficit\>\""}], "]"}]}], "]"}]}], "Input",
 CellLabel->
  "In[347]:=",ExpressionUUID->"77369b30-1a5d-8b4b-ad74-e9f66e3e5321"],

