Cell[CellGroupData[{

Cell["Summary", "Chapter",ExpressionUUID->"92bde301-b61f-f046-ba1f-f51ccb4affe8"],

Cell[TextData[{
 StyleBox["Scale factors matter.",
  FontWeight->Bold],
 " Most climate products store values as scaled integers for compression. \
Always check the dataset documentation and apply the correct scale factor (",
 Cell["GEEMultiply", "InlineCode",ExpressionUUID->
  "b23bb90f-e849-0a43-9f2a-0e9b61e55438"],
 ") and offset (",
 Cell["GEEAdd", "InlineCode",ExpressionUUID->
  "1e017485-9e7f-5c43-884c-0c86542d853e"],
 ") before interpreting values."
}], "ItemNumbered",ExpressionUUID->"ef537b22-879b-cf44-9b36-0934c6bff233"],

Cell[TextData[{
 StyleBox["Server-side vs. client-side processing.",
  FontWeight->Bold],
 " Use server-side arithmetic (",
 Cell["GEEMultiply", "InlineCode",ExpressionUUID->
  "866b85a7-579d-a648-a300-40537d810b1b"],
 ", ",
 Cell["GEEAdd", "InlineCode",ExpressionUUID->
  "9a29b7a4-8e13-0442-b4f0-41ab151533ed"],
 ", ",
 Cell["GEESubtract", "InlineCode",ExpressionUUID->
  "a7482a6f-f15d-174c-b28f-ff589086f903"],
 ", ",
 Cell["GEEExpression", "InlineCode",ExpressionUUID->
  "bdad10d3-e57d-c144-b4d1-1042734d3b79"],
 ") when you need to produce maps or process large regions. Use client-side \
computation when you need fine-grained statistical analysis with Wolfram \
Language tools (",
 Cell["LinearModelFit", "InlineCode",ExpressionUUID->
  "77d922b6-cdf8-0443-bab9-c82554f7ae9d"],
 ", ",
 Cell["TimeSeries", "InlineCode",ExpressionUUID->
  "aacf4960-6a0c-4e4c-bd84-47c39beba7bc"],
 ", ",
 Cell["Fourier", "InlineCode",ExpressionUUID->
  "24b25da3-3b50-fb4d-b31c-997c839181e3"],
 ")."
}], "ItemNumbered",ExpressionUUID->"d6f7516f-9811-6141-b378-022224f4410a"],

Cell[CellGroupData[{

Cell[TextData[{
 StyleBox["The ",
  FontWeight->Bold],
 Cell["//", "InlineCode",ExpressionUUID->
  "0a0c431f-d701-9941-a078-575f1601b86e"],
 StyleBox[" pipeline is composable.",
  FontWeight->Bold],
 " Each expression builder returns an expression tree that can be passed to \
any consumer function. Build reusable pipeline fragments and combine them:"
}], "ItemNumbered",ExpressionUUID->"35dfb127-a207-1148-9722-6aae2eaafc7d"],

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{
   "Reusable", " ", "CHIRPS", " ", "monthly", " ", "sum", " ", "builder"}], 
   " ", "*)"}], "\n", 
  RowBox[{
   RowBox[{
    RowBox[{"chirpsMonthlySum", "[", 
     RowBox[{"startDate_", ",", " ", "endDate_", ",", " ", "bbox_"}], "]"}], 
    " ", ":=", "\n", "  ", 
    RowBox[{
     RowBox[{
      RowBox[{
       RowBox[{
        RowBox[{"GEECollection", "[", "\"\<UCSB-CHG/CHIRPS/DAILY\>\"", "]"}], 
        " ", "//", "\n", "    ", 
        RowBox[{"GEEFilterDate", "[", 
         RowBox[{"startDate", ",", " ", "endDate"}], "]"}]}], " ", "//", "\n",
        "    ", 
       RowBox[{"GEEFilterBounds", "[", "bbox", "]"}]}], " ", "//", "\n", 
      "    ", 
      RowBox[{"GEESelectBands", "[", 
       RowBox[{"{", "\"\<precipitation\>\"", "}"}], "]"}]}], " ", "//", "\n", 
     "    ", "GEECollectionSum"}]}], ";"}]}]], "Input",ExpressionUUID->\
"4a1e8d7f-9797-bb4d-a740-cf9804a28b3e"]
}, Open  ]],

Cell[TextData[{
 Cell["GEEReduceRegion", "InlineCode",ExpressionUUID->
  "8619fe64-9be0-b144-a249-c5c95a763a4b"],
 StyleBox[" bridges server and client.",
  FontWeight->Bold],
 " It computes a spatial statistic on the server and returns a single number, \
which is the natural interface point for Wolfram Language time series \
analysis."
}], "ItemNumbered",ExpressionUUID->"b84c5a31-1f6f-d443-9137-1d636662dd41"],

Cell[TextData[{
 StyleBox["Band name suffixes.",
  FontWeight->Bold],
 " ",
 Cell["GEEMean", "InlineCode",ExpressionUUID->
  "eeec9a80-51ee-f541-b3d7-6aa2cb65ecc3"],
 " appends ",
 Cell["_mean", "InlineCode",ExpressionUUID->
  "f3899587-609c-394b-ab29-0e53b9368f09"],
 " and ",
 Cell["GEEMedian", "InlineCode",ExpressionUUID->
  "447d737b-8fc8-2c4c-a18a-8e333b676325"],
 " appends ",
 Cell["_median", "InlineCode",ExpressionUUID->
  "9e40a833-7b85-3147-8e20-c2d059adb07f"],
 " to band names. When using ",
 Cell["GEEExpression", "InlineCode",ExpressionUUID->
  "2065740b-5080-934e-93b4-962f0551e434"],
 " after an aggregation step, reference the suffixed names (e.g., ",
 Cell["\"temperature_2m_mean\"", "InlineCode",ExpressionUUID->
  "ea0004dd-05d2-7b46-909f-a0db3acc7dc3"],
 ")."
}], "ItemNumbered",ExpressionUUID->"49f9c45e-47b6-2044-8584-aaa945972ae6"],

Cell[TextData[{
 StyleBox["Wolfram Language statistical tools complement GEE.",
  FontWeight->Bold],
 " Functions like ",
 Cell["TimeSeries", "InlineCode",ExpressionUUID->
  "66e52784-d947-264b-99f3-9470d134054a"],
 ", ",
 Cell["MovingAverage", "InlineCode",ExpressionUUID->
  "f5399739-c6d7-8d40-a7b6-008ab1855111"],
 ", ",
 Cell["LinearModelFit", "InlineCode",ExpressionUUID->
  "334f542d-2b70-f945-aa8e-bf478b617121"],
 ", ",
 Cell["TimeSeriesForecast", "InlineCode",ExpressionUUID->
  "37225bd8-e7eb-504c-9121-6a5823857c68"],
 ", ",
 Cell["Periodogram", "InlineCode",ExpressionUUID->
  "20968ddf-7cf6-324c-878c-0c55648c10da"],
 ", and ",
 Cell["Fourier", "InlineCode",ExpressionUUID->
  "d39c26db-4cf3-724a-91c6-b16cebd1c6fb"],
 " add analytical depth that the GEE API alone cannot provide."
}], "ItemNumbered",ExpressionUUID->"120e60eb-58d7-3742-8490-03d91a522611"],

