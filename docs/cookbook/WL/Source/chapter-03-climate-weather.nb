       "  ", 
       RowBox[{"{", 
        RowBox[{"\"\<Difference\>\"", ",", " ", 
         RowBox[{"Round", "[", 
          RowBox[{
           RowBox[{"urbanTemps", " ", "-", " ", "parkTemps"}], ",", " ", 
           "0.1"}], "]"}]}], "}"}]}], "\n", "}"}], ",", " ", 
