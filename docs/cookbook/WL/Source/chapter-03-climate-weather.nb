Cell[CellGroupData[{

Cell["3.5 Multi-Year Climate Analysis", "Chapter",ExpressionUUID->"474b3740-cb4c-5b49-86e3-70188b650db6"],

Cell["\<\
Longer time horizons reveal trends, periodicities, and climate shifts that \
single-year snapshots cannot capture. This section demonstrates decadal \
analysis workflows that combine GEE data extraction with Wolfram Language \
statistical and time series functions.\
\>", "Text",ExpressionUUID->"e671f647-8be8-dd49-bd10-e1cc4940afb0"],

Cell[CellGroupData[{

Cell["3.5.1 Decadal Temperature Trend", "Section",ExpressionUUID->"99c278e8-03b8-2f4c-b938-5787789f0a0e"],

Cell["\<\
Extract annual mean land surface temperature for 10 years, fit a linear \
trend, and forecast future values.\
\>", "Text",ExpressionUUID->"32b7e276-bdc0-5341-8e32-43daf6725b5f"],

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{
    RowBox[{
    "Annual", " ", "mean", " ", "LST", " ", "for", " ", "a", " ", "region", " ",
      "near", " ", "Madrid"}], ",", " ", 
    RowBox[{"2014", "-", "2024"}]}], " ", "*)"}], "\n", 
  RowBox[{
   RowBox[{
    RowBox[{"madridGeom", " ", "=", " ", 
     RowBox[{"GEEGeometry", "[", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"-", "3.8"}], ",", " ", "40.3", ",", " ", 
        RowBox[{"-", "3.5"}], ",", " ", "40.5"}], "}"}], "]"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"years", " ", "=", " ", 
     RowBox[{"Range", "[", 
      RowBox[{"2014", ",", " ", "2024"}], "]"}]}], ";"}], "\n", "\n", 
   RowBox[{
    RowBox[{"annualLST", " ", "=", " ", 
     RowBox[{"Table", "[", "\n", "  ", 
      RowBox[{
       RowBox[{"Module", "[", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{
          "startDate", ",", " ", "endDate", ",", " ", "expr", ",", " ", 
           "result"}], "}"}], ",", "\n", "    ", 
         RowBox[{
          RowBox[{"startDate", " ", "=", " ", 
           RowBox[{
            RowBox[{"ToString", "[", "yr", "]"}], " ", "<>", 
            " ", "\"\<-01-01\>\""}]}], ";", "\n", "    ", 
          RowBox[{"endDate", " ", "=", " ", 
           RowBox[{
            RowBox[{"ToString", "[", 
             RowBox[{"yr", " ", "+", " ", "1"}], "]"}], " ", "<>", 
            " ", "\"\<-01-01\>\""}]}], ";", "\n", "    ", 
          RowBox[{"expr", " ", "=", " ", 
           RowBox[{
            RowBox[{
             RowBox[{
              RowBox[{
               RowBox[{
                RowBox[{
                 RowBox[{
                  RowBox[{
                  "GEECollection", "[", "\"\<MODIS/061/MOD11A2\>\"", "]"}], 
                  " ", "//", "\n", "      ", 
                  RowBox[{"GEEFilterDate", "[", 
                   RowBox[{"startDate", ",", " ", "endDate"}], "]"}]}], " ", "//",
                  "\n", "      ", 
                 RowBox[{"GEEFilterBounds", "[", 
                  RowBox[{"{", 
                   RowBox[{
                    RowBox[{"-", "3.8"}], ",", " ", "40.3", ",", " ", 
                    RowBox[{"-", "3.5"}], ",", " ", "40.5"}], "}"}], "]"}]}], 
                " ", "//", "\n", "      ", 
                RowBox[{"GEESelectBands", "[", 
                 RowBox[{"{", "\"\<LST_Day_1km\>\"", "}"}], "]"}]}], " ", "//",
                "\n", "      ", "GEEMean"}], " ", "//", "\n", "      ", 
              RowBox[{"GEEMultiply", "[", "0.02", "]"}]}], " ", "//", "\n", 
             "      ", 
             RowBox[{"GEEAdd", "[", 
              RowBox[{"-", "273.15"}], "]"}]}], " ", "//", "\n", "      ", 
            RowBox[{"GEEReduceRegion", "[", 
             RowBox[{
             "madridGeom", ",", " ", "\"\<mean\>\"", ",", " ", "1000"}], 
             "]"}]}]}], ";", "\n", "    ", 
          RowBox[{"result", " ", "=", " ", 
           RowBox[{"GEECompute", "[", "expr", "]"}]}], ";", "\n", "    ", 
          RowBox[{"First", "[", 
           RowBox[{"Values", "[", "result", "]"}], "]"}]}]}], "\n", "  ", 
        "]"}], ",", "\n", "  ", 
       RowBox[{"{", 
        RowBox[{"yr", ",", " ", "years"}], "}"}]}], "\n", "]"}]}], ";"}], 
   "\n", "\n", 
   RowBox[{"(*", " ", 
    RowBox[{"Build", " ", "TimeSeries"}], " ", "*)"}], "\n", 
   RowBox[{
    RowBox[{"dates", " ", "=", " ", 
     RowBox[{
      RowBox[{
       RowBox[{"DateObject", "[", 
        RowBox[{"{", 
         RowBox[{"#", ",", " ", "7", ",", " ", "1"}], "}"}], "]"}], " ", 
       "&"}], " ", "/@", " ", "years"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"lstTS", " ", "=", " ", 
     RowBox[{"TimeSeries", "[", 
      RowBox[{"annualLST", ",", " ", 
       RowBox[{"{", "dates", "}"}]}], "]"}]}], ";"}], "\n", "\n", 
   RowBox[{"(*", " ", 
    RowBox[{"Linear", " ", "trend", " ", "fit"}], " ", "*)"}], "\n", 
   RowBox[{
    RowBox[{"lm", " ", "=", " ", 
     RowBox[{"LinearModelFit", "[", "\n", "  ", 
      RowBox[{
       RowBox[{"Transpose", "[", 
        RowBox[{"{", 
         RowBox[{"years", ",", " ", "annualLST"}], "}"}], "]"}], ",", "\n", 
       "  ", "x", ",", " ", "x"}], "]"}]}], ";"}], "\n", "\n", 
   RowBox[{"(*", " ", 
    RowBox[{"Forecast", " ", "5", " ", "years", " ", "ahead"}], " ", "*)"}], "\n", 
   RowBox[{
    RowBox[{"futureYears", " ", "=", " ", 
     RowBox[{"Range", "[", 
      RowBox[{"2025", ",", " ", "2029"}], "]"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"forecast", " ", "=", " ", 
     RowBox[{"lm", " ", "/@", " ", "futureYears"}]}], ";"}], "\n", "\n", 
   RowBox[{"(*", " ", 
    RowBox[{"Visualization", " ", "with", " ", "confidence", " ", "bands"}], 
    " ", "*)"}], "\n", 
   RowBox[{"Show", "[", "\n", "  ", 
    RowBox[{
     RowBox[{"ListPlot", "[", 
      RowBox[{
       RowBox[{"Transpose", "[", 
        RowBox[{"{", 
         RowBox[{"years", ",", " ", "annualLST"}], "}"}], "]"}], ",", "\n", 
       "    ", 
       RowBox[{"PlotStyle", " ", "->", " ", 
        RowBox[{"{", 
         RowBox[{
          RowBox[{"PointSize", "[", "0.015", "]"}], ",", " ", "Blue"}], 
         "}"}]}], ",", "\n", "    ", 
       RowBox[{
       "PlotLabel", " ", "->", 
        " ", "\"\<Madrid Decadal LST Trend (2014-2024)\>\""}]}], "]"}], ",", 
     "\n", "  ", 
     RowBox[{"Plot", "[", 
      RowBox[{
       RowBox[{"{", "\n", "      ", 
        RowBox[{
         RowBox[{"lm", "[", "x", "]"}], ",", "\n", "      ", 
         RowBox[{
          RowBox[{"lm", "[", "x", "]"}], " ", "+", " ", 
          RowBox[{"2", " ", "*", " ", 
           RowBox[{
            RowBox[{"lm", "[", "\"\<EstimatedVariance\>\"", "]"}], "^", 
            "0.5"}]}]}], ",", "\n", "      ", 
         RowBox[{
          RowBox[{"lm", "[", "x", "]"}], " ", "-", " ", 
          RowBox[{"2", " ", "*", " ", 
           RowBox[{
            RowBox[{"lm", "[", "\"\<EstimatedVariance\>\"", "]"}], "^", 
            "0.5"}]}]}]}], "\n", "    ", "}"}], ",", " ", 
       RowBox[{"{", 
        RowBox[{"x", ",", " ", "2014", ",", " ", "2029"}], "}"}], ",", "\n", 
       "    ", 
       RowBox[{"PlotStyle", " ", "->", " ", 
        RowBox[{"{", "\n", "      ", 
         RowBox[{
          RowBox[{"Directive", "[", 
           RowBox[{"Thick", ",", " ", "Red"}], "]"}], ",", "\n", "      ", 
          RowBox[{"Directive", "[", 
           RowBox[{"Thin", ",", " ", "Dashed", ",", " ", "Red"}], "]"}], ",", 
          "\n", "      ", 
          RowBox[{"Directive", "[", 
           RowBox[{"Thin", ",", " ", "Dashed", ",", " ", "Red"}], "]"}]}], 
         "}"}]}], ",", "\n", "    ", 
       RowBox[{"Filling", " ", "->", " ", 
        RowBox[{"{", 
         RowBox[{"2", " ", "->", " ", 
          RowBox[{"{", "3", "}"}]}], "}"}]}]}], "]"}], ",", "\n", "  ", 
     RowBox[{"ListPlot", "[", 
      RowBox[{
       RowBox[{"Transpose", "[", 
        RowBox[{"{", 
         RowBox[{"futureYears", ",", " ", "forecast"}], "}"}], "]"}], ",", 
       "\n", "    ", 
       RowBox[{"PlotStyle", " ", "->", " ", 
        RowBox[{"{", 
         RowBox[{
          RowBox[{"PointSize", "[", "0.012", "]"}], ",", " ", "Red", ",", " ", 
          RowBox[{"Opacity", "[", "0.5", "]"}]}], "}"}]}]}], "]"}], ",", "\n",
      "  ", 
     RowBox[{"AxesLabel", " ", "->", " ", 
      RowBox[{"{", 
       RowBox[{"\"\<Year\>\"", ",", " ", "\"\<Mean LST (\[Degree]C)\>\""}], 
       "}"}]}], ",", "\n", "  ", 
     RowBox[{"PlotRange", " ", "->", " ", "All"}], ",", "\n", "  ", 
     RowBox[{"GridLines", " ", "->", " ", "Automatic"}]}], "\n", "]"}], "\n", 
   "\n", 
   RowBox[{"(*", " ", 
    RowBox[{"Report", " ", "the", " ", "trend"}], " ", "*)"}], "\n", 
   RowBox[{
    RowBox[{"slope", " ", "=", " ", 
     RowBox[{
      RowBox[{"lm", "[", "\"\<BestFitParameters\>\"", "]"}], "[", 
      RowBox[{"[", "2", "]"}], "]"}]}], ";"}], "\n", 
   RowBox[{"Print", "[", 
    RowBox[{"\"\<Warming rate: \>\"", ",", " ", 
     RowBox[{"Round", "[", 
      RowBox[{"slope", ",", " ", "0.01"}], "]"}], ",", 
     " ", "\"\< \[Degree]C/year\>\""}], "]"}], "\n", 
   RowBox[{"Print", "[", 
    RowBox[{"\"\<R-squared: \>\"", ",", " ", 
     RowBox[{"Round", "[", 
      RowBox[{
       RowBox[{"lm", "[", "\"\<RSquared\>\"", "]"}], ",", " ", "0.001"}], 
      "]"}]}], "]"}]}]}]], "Input",ExpressionUUID->"f305c628-77a5-8149-9318-\
a42c2b68c819"]
}, Open  ]],

Cell[CellGroupData[{

Cell["3.5.2 Time Series Forecasting", "Section",ExpressionUUID->"7976334b-80b1-b241-8f2f-dc68538404c7"],

Cell[TextData[{
 "Use Wolfram Language's ",
 Cell["TimeSeriesForecast", "InlineCode",ExpressionUUID->
  "9f02d13c-285b-384f-acca-51a045b64796"],
 " for a model-based projection that accounts for seasonality."
}], "Text",ExpressionUUID->"5ec5c551-c029-784f-8582-b8b30abd1338"],

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{
   "Monthly", " ", "LST", " ", "time", " ", "series", " ", "for", " ", "5", " ",
     "years"}], " ", "*)"}], "\n", 
  RowBox[{
   RowBox[{
    RowBox[{"monthlyLST", " ", "=", " ", 
     RowBox[{"Flatten", " ", "@", " ", 
      RowBox[{"Table", "[", "\n", "  ", 
       RowBox[{
        RowBox[{"Module", "[", 
         RowBox[{
          RowBox[{"{", 
           RowBox[{
           "startDate", ",", " ", "endDate", ",", " ", "expr", ",", " ", 
            "result"}], "}"}], ",", "\n", "    ", 
          RowBox[{
           RowBox[{"startDate", " ", "=", " ", 
            RowBox[{"DateString", "[", 
             RowBox[{
              RowBox[{"DateObject", "[", 
               RowBox[{"{", 
                RowBox[{"yr", ",", " ", "mo", ",", " ", "1"}], "}"}], "]"}], ",",
               "\n", "      ", 
              RowBox[{"{", 
               
               RowBox[{"\"\<Year\>\"", ",", " ", "\"\<-\>\"", ",", 
                " ", "\"\<Month\>\"", ",", " ", "\"\<-\>\"", ",", 
                " ", "\"\<Day\>\""}], "}"}]}], "]"}]}], ";", "\n", "    ", 
           RowBox[{"endDate", " ", "=", " ", 
            RowBox[{"DateString", "[", 
             RowBox[{
              RowBox[{"DateObject", "[", 
               RowBox[{"{", 
                RowBox[{"yr", ",", " ", 
                 RowBox[{"mo", " ", "+", " ", "1"}], ",", " ", "1"}], "}"}], 
               "]"}], ",", "\n", "      ", 
              RowBox[{"{", 
               
               RowBox[{"\"\<Year\>\"", ",", " ", "\"\<-\>\"", ",", 
                " ", "\"\<Month\>\"", ",", " ", "\"\<-\>\"", ",", 
                " ", "\"\<Day\>\""}], "}"}]}], "]"}]}], ";", "\n", "    ", 
           RowBox[{"expr", " ", "=", " ", 
            RowBox[{
             RowBox[{
              RowBox[{
               RowBox[{
                RowBox[{
                 RowBox[{
                  RowBox[{
                   RowBox[{
                   "GEECollection", "[", "\"\<MODIS/061/MOD11A2\>\"", "]"}], 
                   " ", "//", "\n", "      ", 
                   RowBox[{"GEEFilterDate", "[", 
                    RowBox[{"startDate", ",", " ", "endDate"}], "]"}]}], " ", 
                  "//", "\n", "      ", 
                  RowBox[{"GEEFilterBounds", "[", 
                   RowBox[{"{", 
                    RowBox[{
                    RowBox[{"-", "3.8"}], ",", " ", "40.3", ",", " ", 
                    RowBox[{"-", "3.5"}], ",", " ", "40.5"}], "}"}], "]"}]}], 
                 " ", "//", "\n", "      ", 
                 RowBox[{"GEESelectBands", "[", 
                  RowBox[{"{", "\"\<LST_Day_1km\>\"", "}"}], "]"}]}], " ", "//",
                 "\n", "      ", "GEEMean"}], " ", "//", "\n", "      ", 
               RowBox[{"GEEMultiply", "[", "0.02", "]"}]}], " ", "//", "\n", 
              "      ", 
              RowBox[{"GEEAdd", "[", 
               RowBox[{"-", "273.15"}], "]"}]}], " ", "//", "\n", "      ", 
             RowBox[{"GEEReduceRegion", "[", 
              RowBox[{
              "madridGeom", ",", " ", "\"\<mean\>\"", ",", " ", "1000"}], 
              "]"}]}]}], ";", "\n", "    ", 
           RowBox[{"result", " ", "=", " ", 
            RowBox[{"GEECompute", "[", "expr", "]"}]}], ";", "\n", "    ", 
           RowBox[{"First", "[", 
            RowBox[{"Values", "[", "result", "]"}], "]"}]}]}], "\n", "  ", 
         "]"}], ",", "\n", "  ", 
        RowBox[{"{", 
         RowBox[{"yr", ",", " ", "2020", ",", " ", "2024"}], "}"}], ",", " ", 
        RowBox[{"{", 
         RowBox[{"mo", ",", " ", "1", ",", " ", "12"}], "}"}]}], "\n", 
       "]"}]}]}], ";"}], "\n", "\n", 
   RowBox[{
    RowBox[{"monthDates", " ", "=", " ", 
     RowBox[{"Flatten", " ", "@", " ", 
      RowBox[{"Table", "[", "\n", "  ", 
       RowBox[{
        RowBox[{"DateObject", "[", 
         RowBox[{"{", 
          RowBox[{"yr", ",", " ", "mo", ",", " ", "15"}], "}"}], "]"}], ",", 
        "\n", "  ", 
        RowBox[{"{", 
         RowBox[{"yr", ",", " ", "2020", ",", " ", "2024"}], "}"}], ",", " ", 
        RowBox[{"{", 
         RowBox[{"mo", ",", " ", "1", ",", " ", "12"}], "}"}]}], "\n", 
       "]"}]}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"lstMonthlyTS", " ", "=", " ", 
     RowBox[{"TimeSeries", "[", 
      RowBox[{"monthlyLST", ",", " ", 
       RowBox[{"{", "monthDates", "}"}]}], "]"}]}], ";"}], "\n", "\n", 
   RowBox[{"(*", " ", 
    RowBox[{"Forecast", " ", "12", " ", "months", " ", "ahead"}], " ", "*)"}],
    "\n", 
   RowBox[{
    RowBox[{"forecastTS", " ", "=", " ", 
     RowBox[{"TimeSeriesForecast", "[", 
      RowBox[{"lstMonthlyTS", ",", " ", "12"}], "]"}]}], ";"}], "\n", "\n", 
   RowBox[{"DateListPlot", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"lstMonthlyTS", ",", " ", "forecastTS"}], "}"}], ",", "\n", 
     "  ", 
     RowBox[{"PlotLegends", " ", "->", " ", 
      RowBox[{"{", 
       RowBox[{"\"\<Observed\>\"", ",", " ", "\"\<Forecast\>\""}], "}"}]}], ",",
      "\n", "  ", 
     RowBox[{
     "PlotLabel", " ", "->", 
      " ", "\"\<Madrid Monthly LST with 12-Month Forecast\>\""}], ",", "\n", 
     "  ", 
     RowBox[{"AxesLabel", " ", "->", " ", 
      RowBox[{"{", 
       RowBox[{"None", ",", " ", "\"\<LST (\[Degree]C)\>\""}], "}"}]}], ",", 
     "\n", "  ", 
     RowBox[{"PlotStyle", " ", "->", " ", 
      RowBox[{"{", 
       RowBox[{"Blue", ",", " ", 
        RowBox[{"Directive", "[", 
         RowBox[{"Dashed", ",", " ", "Red"}], "]"}]}], "}"}]}]}], 
    "]"}]}]}]], "Input",ExpressionUUID->"09be0c5e-3f0b-f942-97ff-\
8ed7b246209b"]
}, Open  ]],

Cell[CellGroupData[{

Cell["\<\
3.5.3 Drought Monitoring with Standardized Precipitation Index\
\>", "Section",ExpressionUUID->"341e0e92-916e-b842-8a93-c84ca696e731"],

Cell["\<\
The Standardized Precipitation Index (SPI) transforms precipitation data into \
a standardized metric where negative values indicate drought. This simplified \
implementation computes monthly precipitation z-scores using the long-term \
mean and standard deviation.\
\>", "Text",ExpressionUUID->"5009b5ee-2789-7545-87f5-41f02ce95b02"],

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{
    RowBox[{
    "Monthly", " ", "precipitation", " ", "for", " ", "a", " ", "drought"}], "-", 
    RowBox[{"prone", " ", "region", " ", "over", " ", "10", " ", "years"}]}], 
   " ", "*)"}], "\n", 
  RowBox[{
   RowBox[{
    RowBox[{"regionGeom", " ", "=", " ", 
     RowBox[{"GEEGeometry", "[", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"-", "5.5"}], ",", " ", "36.5", ",", " ", 
        RowBox[{"-", "4.5"}], ",", " ", "37.5"}], "}"}], "]"}]}], ";"}], "  ", 
   RowBox[{"(*", " ", 
    RowBox[{"Southern", " ", "Spain"}], " ", "*)"}], "\n", "\n", 
   RowBox[{
    RowBox[{"monthlyPrecip", " ", "=", " ", 
     RowBox[{"Flatten", " ", "@", " ", 
      RowBox[{"Table", "[", "\n", "  ", 
       RowBox[{
        RowBox[{"Module", "[", 
         RowBox[{
          RowBox[{"{", 
           RowBox[{
           "startDate", ",", " ", "endDate", ",", " ", "expr", ",", " ", 
            "result"}], "}"}], ",", "\n", "    ", 
          RowBox[{
           RowBox[{"startDate", " ", "=", " ", 
            RowBox[{"DateString", "[", 
             RowBox[{
              RowBox[{"DateObject", "[", 
               RowBox[{"{", 
                RowBox[{"yr", ",", " ", "mo", ",", " ", "1"}], "}"}], "]"}], ",",
               "\n", "      ", 
              RowBox[{"{", 
               
               RowBox[{"\"\<Year\>\"", ",", " ", "\"\<-\>\"", ",", 
                " ", "\"\<Month\>\"", ",", " ", "\"\<-\>\"", ",", 
                " ", "\"\<Day\>\""}], "}"}]}], "]"}]}], ";", "\n", "    ", 
           RowBox[{"endDate", " ", "=", " ", 
            RowBox[{"DateString", "[", 
             RowBox[{
              RowBox[{"DateObject", "[", 
               RowBox[{"{", 
                RowBox[{"yr", ",", " ", 
                 RowBox[{"mo", " ", "+", " ", "1"}], ",", " ", "1"}], "}"}], 
               "]"}], ",", "\n", "      ", 
              RowBox[{"{", 
               
               RowBox[{"\"\<Year\>\"", ",", " ", "\"\<-\>\"", ",", 
                " ", "\"\<Month\>\"", ",", " ", "\"\<-\>\"", ",", 
                " ", "\"\<Day\>\""}], "}"}]}], "]"}]}], ";", "\n", "    ", 
           RowBox[{"expr", " ", "=", " ", 
            RowBox[{
             RowBox[{
              RowBox[{
               RowBox[{
                RowBox[{
                 RowBox[{
                 "GEECollection", "[", "\"\<UCSB-CHG/CHIRPS/DAILY\>\"", "]"}],
                  " ", "//", "\n", "      ", 
                 RowBox[{"GEEFilterDate", "[", 
                  RowBox[{"startDate", ",", " ", "endDate"}], "]"}]}], " ", "//",
                 "\n", "      ", 
                RowBox[{"GEEFilterBounds", "[", 
                 RowBox[{"{", 
                  RowBox[{
                   RowBox[{"-", "5.5"}], ",", " ", "36.5", ",", " ", 
                   RowBox[{"-", "4.5"}], ",", " ", "37.5"}], "}"}], "]"}]}], 
               " ", "//", "\n", "      ", 
               RowBox[{"GEESelectBands", "[", 
                RowBox[{"{", "\"\<precipitation\>\"", "}"}], "]"}]}], " ", "//",
               "\n", "      ", "GEECollectionSum"}], " ", "//", "\n", 
             "      ", 
             RowBox[{"GEEReduceRegion", "[", 
              RowBox[{
              "regionGeom", ",", " ", "\"\<mean\>\"", ",", " ", "5000"}], 
              "]"}]}]}], ";", "\n", "    ", 
           RowBox[{"result", " ", "=", " ", 
            RowBox[{"GEECompute", "[", "expr", "]"}]}], ";", "\n", "    ", 
           RowBox[{"First", "[", 
            RowBox[{"Values", "[", "result", "]"}], "]"}]}]}], "\n", "  ", 
         "]"}], ",", "\n", "  ", 
        RowBox[{"{", 
         RowBox[{"yr", ",", " ", "2015", ",", " ", "2024"}], "}"}], ",", " ", 
        RowBox[{"{", 
         RowBox[{"mo", ",", " ", "1", ",", " ", "12"}], "}"}]}], "\n", 
       "]"}]}]}], ";"}], "\n", "\n", 
   RowBox[{"(*", " ", 
    RowBox[{
     RowBox[{"Compute", " ", "SPI"}], "-", 
     RowBox[{"like", " ", "z"}], "-", 
     RowBox[{"scores", " ", "by", " ", "month"}]}], " ", "*)"}], "\n", 
   RowBox[{"(*", " ", 
    RowBox[{
    "Group", " ", "values", " ", "by", " ", "calendar", " ", "month", " ", 
     "to", " ", "compute", " ", "monthly", " ", "climatology"}], " ", "*)"}], 
   "\n", 
   RowBox[{
    RowBox[{"byMonth", " ", "=", " ", 
     RowBox[{"Table", "[", "\n", "  ", 
      RowBox[{
       RowBox[{"monthlyPrecip", "[", 
        RowBox[{"[", 
         RowBox[{"mo", " ", ";;", " ", ";;", " ", "12"}], "]"}], "]"}], ",", 
       "  ", 
       RowBox[{"(*", " ", 
        RowBox[{
        "Every", " ", "value", " ", "for", " ", "this", " ", "calendar", " ", 
         "month"}], " ", "*)"}], "\n", "  ", 
       RowBox[{"{", 
        RowBox[{"mo", ",", " ", "1", ",", " ", "12"}], "}"}]}], "\n", "]"}]}],
     ";"}], "\n", 
   RowBox[{
    RowBox[{"monthMeans", " ", "=", " ", 
     RowBox[{"Mean", " ", "/@", " ", "byMonth"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"monthStdDevs", " ", "=", " ", 
     RowBox[{"StandardDeviation", " ", "/@", " ", "byMonth"}]}], ";"}], "\n", 
   "\n", 
   RowBox[{
    RowBox[{"spi", " ", "=", " ", 
     RowBox[{"Table", "[", "\n", "  ", 
      RowBox[{
       RowBox[{"Module", "[", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{"mo", ",", " ", "idx"}], "}"}], ",", "\n", "    ", 
         RowBox[{
          RowBox[{"idx", " ", "=", " ", 
           RowBox[{
            RowBox[{"Mod", "[", 
             RowBox[{
              RowBox[{"i", " ", "-", " ", "1"}], ",", " ", "12"}], "]"}], " ",
             "+", " ", "1"}]}], ";", "\n", "    ", 
          RowBox[{"If", "[", 
           RowBox[{
            RowBox[{
             RowBox[{"monthStdDevs", "[", 
              RowBox[{"[", "idx", "]"}], "]"}], " ", "==", " ", "0"}], ",", 
            " ", "0", ",", "\n", "      ", 
            RowBox[{
             RowBox[{"(", 
              RowBox[{
               RowBox[{"monthlyPrecip", "[", 
                RowBox[{"[", "i", "]"}], "]"}], " ", "-", " ", 
               RowBox[{"monthMeans", "[", 
                RowBox[{"[", "idx", "]"}], "]"}]}], ")"}], " ", "/", " ", 
             RowBox[{"monthStdDevs", "[", 
              RowBox[{"[", "idx", "]"}], "]"}]}]}], "\n", "    ", "]"}]}]}], 
        "\n", "  ", "]"}], ",", "\n", "  ", 
       RowBox[{"{", 
        RowBox[{"i", ",", " ", 
         RowBox[{"Length", "[", "monthlyPrecip", "]"}]}], "}"}]}], "\n", 
      "]"}]}], ";"}], "\n", "\n", 
   RowBox[{"(*", " ", 
    RowBox[{"Classify", " ", "drought", " ", "severity"}], " ", "*)"}], "\n", 
   RowBox[{"(*", " ", 
    RowBox[{
     RowBox[{"SPI", " ", 
      RowBox[{"categories", ":", " ", 
       RowBox[{">=", " ", 
        RowBox[{"2.0", " ", "extremely", " ", "wet"}]}]}]}], ",", " ", 
     RowBox[{"1.5", "-", 
      RowBox[{"2.0", " ", "very", " ", "wet"}]}], ",", " ", 
     RowBox[{"1.0", "-", 
      RowBox[{"1.5", " ", "moderately", " ", "wet"}]}], ",", "\n", "   ", 
     RowBox[{
      RowBox[{"-", "1.0"}], " ", "to", " ", "1.0", " ", "near", " ", 
      "normal"}], ",", " ", 
     RowBox[{
      RowBox[{
       RowBox[{"-", "1.0"}], " ", "to"}], " ", "-", 
      RowBox[{"1.5", " ", "moderately", " ", "dry"}]}], ",", "\n", "   ", 
     RowBox[{
      RowBox[{
       RowBox[{"-", "1.5"}], " ", "to"}], " ", "-", 
      RowBox[{"2.0", " ", "severely", " ", "dry"}]}], ",", " ", 
     RowBox[{"<=", " ", 
      RowBox[{
       RowBox[{"-", "2.0"}], " ", "extremely", " ", "dry"}]}]}], " ", "*)"}], 
   "\n", "\n", 
   RowBox[{
    RowBox[{"spiDates", " ", "=", " ", 
     RowBox[{"Flatten", " ", "@", " ", 
      RowBox[{"Table", "[", "\n", "  ", 
       RowBox[{
        RowBox[{"DateObject", "[", 
         RowBox[{"{", 
          RowBox[{"yr", ",", " ", "mo", ",", " ", "15"}], "}"}], "]"}], ",", 
        "\n", "  ", 
        RowBox[{"{", 
         RowBox[{"yr", ",", " ", "2015", ",", " ", "2024"}], "}"}], ",", " ", 
        RowBox[{"{", 
         RowBox[{"mo", ",", " ", "1", ",", " ", "12"}], "}"}]}], "\n", 
       "]"}]}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"spiTS", " ", "=", " ", 
     RowBox[{"TimeSeries", "[", 
      RowBox[{"spi", ",", " ", 
       RowBox[{"{", "spiDates", "}"}]}], "]"}]}], ";"}], "\n", "\n", 
   RowBox[{"(*", " ", 
    RowBox[{"Color", "-", 
     RowBox[{"coded", " ", "drought", " ", "plot"}]}], " ", "*)"}], "\n", 
   RowBox[{"DateListPlot", "[", 
    RowBox[{"spiTS", ",", "\n", "  ", 
     RowBox[{
     "PlotLabel", " ", "->", 
      " ", "\"\<Standardized Precipitation Index - Southern Spain (2015-2024)\
\>\""}], ",", "\n", "  ", 
     RowBox[{"AxesLabel", " ", "->", " ", 
      RowBox[{"{", 
       RowBox[{"None", ",", " ", "\"\<SPI\>\""}], "}"}]}], ",", "\n", "  ", 
     RowBox[{"Filling", " ", "->", " ", "0"}], ",", "\n", "  ", 
     RowBox[{"ColorFunction", " ", "->", " ", 
      RowBox[{"Function", "[", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{"x", ",", " ", "y"}], "}"}], ",", "\n", "    ", 
        RowBox[{"Which", "[", "\n", "      ", 
         RowBox[{
          RowBox[{"y", " ", "<", " ", 
           RowBox[{"-", "2"}]}], ",", " ", 
          RowBox[{"Darker", "[", "Red", "]"}], ",", "\n", "      ", 
          RowBox[{"y", " ", "<", " ", 
           RowBox[{"-", "1.5"}]}], ",", " ", "Red", ",", "\n", "      ", 
          RowBox[{"y", " ", "<", " ", 
           RowBox[{"-", "1"}]}], ",", " ", "Orange", ",", "\n", "      ", 
          RowBox[{"y", " ", ">", " ", "1.5"}], ",", " ", 
          RowBox[{"Darker", "[", "Blue", "]"}], ",", "\n", "      ", 
          RowBox[{"y", " ", ">", " ", "1"}], ",", " ", "Blue", ",", "\n", 
          "      ", "True", ",", " ", "Gray"}], "\n", "    ", "]"}]}], 
       "]"}]}], ",", "\n", "  ", 
     RowBox[{"ColorFunctionScaling", " ", "->", " ", "False"}], ",", "\n", 
     "  ", 
     RowBox[{"PlotRange", " ", "->", " ", 
      RowBox[{"{", 
       RowBox[{"All", ",", " ", 
        RowBox[{"{", 
         RowBox[{
          RowBox[{"-", "3"}], ",", " ", "3"}], "}"}]}], "}"}]}], ",", "\n", 
     "  ", 
     RowBox[{"GridLines", " ", "->", " ", 
      RowBox[{"{", 
       RowBox[{"None", ",", " ", 
        RowBox[{"{", 
         RowBox[{
          RowBox[{"-", "2"}], ",", " ", 
          RowBox[{"-", "1.5"}], ",", " ", 
          RowBox[{"-", "1"}], ",", " ", "1", ",", " ", "1.5", ",", " ", "2"}],
          "}"}]}], "}"}]}], ",", "\n", "  ", 
     RowBox[{"GridLinesStyle", " ", "->", " ", 
      RowBox[{"Directive", "[", 
       RowBox[{"Dashed", ",", " ", 
        RowBox[{"GrayLevel", "[", "0.7", "]"}]}], "]"}]}], ",", "\n", "  ", 
     RowBox[{"Epilog", " ", "->", " ", 
      RowBox[{"{", "\n", "    ", 
       RowBox[{
        RowBox[{"Text", "[", 
         RowBox[{
          RowBox[{"Style", "[", 
           RowBox[{"\"\<Extremely Dry\>\"", ",", " ", "8", ",", " ", "Red"}], 
           "]"}], ",", " ", 
          RowBox[{"Scaled", "[", 
           RowBox[{"{", 
            RowBox[{"0.95", ",", " ", "0.05"}], "}"}], "]"}], ",", " ", 
          RowBox[{"{", 
           RowBox[{"1", ",", " ", "0"}], "}"}]}], "]"}], ",", "\n", "    ", 
        RowBox[{"Text", "[", 
         RowBox[{
          RowBox[{"Style", "[", 
           RowBox[{"\"\<Extremely Wet\>\"", ",", " ", "8", ",", " ", "Blue"}],
            "]"}], ",", " ", 
          RowBox[{"Scaled", "[", 
           RowBox[{"{", 
            RowBox[{"0.95", ",", " ", "0.95"}], "}"}], "]"}], ",", " ", 
          RowBox[{"{", 
           RowBox[{"1", ",", " ", "0"}], "}"}]}], "]"}]}], "\n", "  ", 
       "}"}]}]}], "]"}]}]}]], "Input",ExpressionUUID->"dfde4524-db0b-6f47-\
9e3d-0ff27c9ea4ef"]
