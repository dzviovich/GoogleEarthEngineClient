Cell[CellGroupData[{

Cell["3.4.2 Irrigated vs. Rainfed Cropland ET Comparison", "Section",ExpressionUUID->"7f08b7d1-c0b6-2045-aa37-50e03c2f9933"],

Cell[TextData[{
 "Use ",
 Cell["GEEReduceRegion", "InlineCode",ExpressionUUID->
  "c3c45fab-1ed2-d245-9c34-e6fe17b44f2d"],
 " on two different geometries to compare mean ET between irrigated and \
rainfed areas. This reveals the water demand differential driven by \
irrigation practices."
}], "Text",ExpressionUUID->"b2342582-38b9-314b-8205-6cf595691855"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{"Define", " ", "two", " ", 
    RowBox[{"geometries", ":", " ", 
     RowBox[{
     "irrigated", " ", "and", " ", "rainfed", " ", "zones", " ", "in", " ", 
      "the", " ", "Central", " ", "Valley"}]}]}], " ", "*)"}], "\n", 
  RowBox[{
   RowBox[{
    RowBox[{"irrigatedGeom", " ", "=", " ", 
     RowBox[{"GEEGeometry", "[", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"-", "120.8"}], ",", " ", "36.5", ",", " ", 
        RowBox[{"-", "120.4"}], ",", " ", "36.9"}], "}"}], "]"}]}], ";"}], 
   "  ", 
   RowBox[{"(*", " ", 
    RowBox[{"West", " ", "side"}], " ", "*)"}], "\n", 
   RowBox[{
    RowBox[{"rainfedGeom", " ", "=", " ", 
     RowBox[{"GEEGeometry", "[", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"-", "119.8"}], ",", " ", "36.0", ",", " ", 
        RowBox[{"-", "119.4"}], ",", " ", "36.4"}], "}"}], "]"}]}], ";"}], 
   "    ", 
   RowBox[{"(*", " ", 
    RowBox[{"East", " ", "foothills"}], " ", "*)"}], "\n", "\n", 
   RowBox[{"(*", " ", 
    RowBox[{"Mean", " ", "ET", " ", "for", " ", "each", " ", "zone"}], " ", 
    "*)"}], "\n", 
   RowBox[{
    RowBox[{"irrigatedET", " ", "=", " ", 
     RowBox[{"GEECompute", "[", "\n", "  ", 
      RowBox[{"etExpr", " ", "//", " ", 
       RowBox[{"GEEReduceRegion", "[", 
        RowBox[{"irrigatedGeom", ",", " ", "\"\<mean\>\"", ",", " ", "500"}], 
        "]"}]}], "\n", "]"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"rainfedET", " ", "=", " ", 
     RowBox[{"GEECompute", "[", "\n", "  ", 
      RowBox[{"etExpr", " ", "//", " ", 
       RowBox[{"GEEReduceRegion", "[", 
        RowBox[{"rainfedGeom", ",", " ", "\"\<mean\>\"", ",", " ", "500"}], 
        "]"}]}], "\n", "]"}]}], ";"}], "\n", "\n", 
   RowBox[{"Grid", "[", 
    RowBox[{
     RowBox[{"{", "\n", "  ", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{"\"\<Zone\>\"", ",", " ", "\"\<Mean ET (mm/season)\>\""}], 
        "}"}], ",", "\n", "  ", 
       RowBox[{"{", 
        RowBox[{"\"\<Irrigated\>\"", ",", " ", 
         RowBox[{"Round", "[", 
          RowBox[{
           RowBox[{"First", "[", 
            RowBox[{"Values", "[", "irrigatedET", "]"}], "]"}], ",", " ", 
           "1"}], "]"}]}], "}"}], ",", "\n", "  ", 
       RowBox[{"{", 
        RowBox[{"\"\<Rainfed\>\"", ",", " ", 
         RowBox[{"Round", "[", 
          RowBox[{
           RowBox[{"First", "[", 
            RowBox[{"Values", "[", "rainfedET", "]"}], "]"}], ",", " ", "1"}],
           "]"}]}], "}"}], ",", "\n", "  ", 
       RowBox[{"{", 
        RowBox[{"\"\<Ratio\>\"", ",", " ", 
         RowBox[{"Round", "[", "\n", "    ", 
          RowBox[{
           RowBox[{
            RowBox[{"First", "[", 
             RowBox[{"Values", "[", "irrigatedET", "]"}], "]"}], " ", "/", 
            " ", 
            RowBox[{"First", "[", 
             RowBox[{"Values", "[", "rainfedET", "]"}], "]"}]}], ",", " ", 
           "0.1"}], "]"}]}], "}"}]}], "\n", "}"}], ",", " ", 
     RowBox[{"Frame", " ", "->", " ", "All"}], ",", "\n", "  ", 
     RowBox[{"Background", " ", "->", " ", 
      RowBox[{"{", 
       RowBox[{"None", ",", " ", 
        RowBox[{"{", 
         RowBox[{
         "LightBlue", ",", " ", "None", ",", " ", "None", ",", " ", "None"}], 
         "}"}]}], "}"}]}]}], "]"}], "\n", 
   RowBox[{"(*", " ", 
    RowBox[{
     RowBox[{
     "Irrigated", " ", "areas", " ", "typically", " ", "show", " ", "2"}], "-", 
     RowBox[{
     "3", "x", " ", "higher", " ", "ET", " ", "than", " ", "rainfed"}]}], " ",
     "*)"}]}]}]], "Input",
 CellLabel->
  "In[338]:=",ExpressionUUID->"fecd5160-6030-3245-bd65-3c9522890fd5"],

Cell[BoxData[
 TagBox[GridBox[{
    {"\<\"Zone\"\>", "\<\"Mean ET (mm/season)\"\>"},
    {"\<\"Irrigated\"\>", "114"},
    {"\<\"Rainfed\"\>", "147"},
    {"\<\"Ratio\"\>", "0.8`"}
   },
   AutoDelete->False,
   GridBoxBackground->{"Columns" -> {{None}}, "Rows" -> {
       RGBColor[0.87, 0.94, 1], None, None, None}},
   GridBoxFrame->{"Columns" -> {{True}}, "Rows" -> {{True}}},
   GridBoxItemSize->{"Columns" -> {{Automatic}}, "Rows" -> {{Automatic}}}],
  "Grid"]], "Output",
 CellChangeTimes->{3.984498317625471*^9},
 CellLabel->
  "Out[342]=",ExpressionUUID->"89360a31-3e55-c64b-98cc-814473a87c32"]
}, Open  ]]
}, Open  ]],

Cell[CellGroupData[{

Cell["3.4.3 Water Balance: Precipitation Minus Evapotranspiration", "Section",ExpressionUUID->"9c15f677-f070-2c49-ae1a-ea5f647d1347"],

Cell["\<\
A simplified water balance model uses precipitation minus ET to estimate net \
water availability. Positive values indicate surplus (potential runoff or \
groundwater recharge); negative values indicate deficit (requiring irrigation \
or drawing from storage).\
\>", "Text",ExpressionUUID->"7fd566bd-6894-dd4d-9fc6-bbd89c73bef5"],

Cell[TextData[{
 StyleBox["Server-side approach using ",
  FontWeight->Bold],
 Cell["GEESubtract", "InlineCode",ExpressionUUID->
  "cbd90c3b-c203-4c4d-a7d4-e3cdf8f38794"],
 StyleBox[":",
  FontWeight->Bold]
}], "Text",ExpressionUUID->"0b280c22-c9fa-a44f-9ce0-0cd1f6d31492"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{"Annual", " ", "precipitation", " ", "from", " ", "CHIRPS", " ", 
    RowBox[{"(", 
     RowBox[{"sum", " ", "of", " ", "daily", " ", "values"}], ")"}]}], " ", 
   "*)"}], "\n", 
  RowBox[{"(*", " ", 
   RowBox[{
    RowBox[{
    "GEECollectionSum", " ", "appends", " ", "_sum", " ", "to", " ", "band", " ",
      "names"}], ";", " ", 
    RowBox[{
    "rename", " ", "to", " ", "a", " ", "common", "\n", "   ", "band", " ", 
     "name", " ", "so", " ", "GEESubtract", " ", "can", " ", "match", " ", 
     "bands", " ", "between", " ", "the", " ", "two", " ", "images"}]}], " ", 
   "*)"}], "\n", 
  RowBox[{
   RowBox[{
    RowBox[{"annualPrecip", " ", "=", " ", 
     RowBox[{
      RowBox[{
       RowBox[{
        RowBox[{
         RowBox[{
          RowBox[{
          "GEECollection", "[", "\"\<UCSB-CHG/CHIRPS/DAILY\>\"", "]"}], " ", "//",
           "\n", "  ", 
          RowBox[{"GEEFilterDate", "[", 
           RowBox[{"\"\<2024-01-01\>\"", ",", " ", "\"\<2025-01-01\>\""}], 
           "]"}]}], " ", "//", "\n", "  ", 
         RowBox[{"GEEFilterBounds", "[", 
          RowBox[{"{", 
           RowBox[{
            RowBox[{"-", "122.0"}], ",", " ", "35.0", ",", " ", 
            RowBox[{"-", "119.0"}], ",", " ", "38.5"}], "}"}], "]"}]}], " ", "//",
         "\n", "  ", 
        RowBox[{"GEESelectBands", "[", 
         RowBox[{"{", "\"\<precipitation\>\"", "}"}], "]"}]}], " ", "//", 
       "\n", "  ", "GEECollectionSum"}], " ", "//", "\n", "  ", 
      RowBox[{"GEERename", "[", 
       RowBox[{"{", "\"\<annual_mm\>\"", "}"}], "]"}]}]}], ";"}], "\n", "\n", 
