Notebook[{

Cell[CellGroupData[{
Cell["Chapter 3: Climate and Weather Analysis", "Title",ExpressionUUID->"6f464113-b532-594d-a8bf-f886b4890c27"],

Cell["\<\
Climate and weather datasets form the backbone of Earth observation science. \
Google Earth Engine hosts decades of satellite-derived temperature, \
precipitation, atmospheric, and radiation products at global scales. This \
chapter demonstrates how to extract, process, and analyze these datasets \
using the GoogleEarthEngineClient paclet alongside Wolfram Language's \
built-in statistical and time series tools.\
\>", "Text",ExpressionUUID->"d87e3a0d-8c63-3c4e-82ad-d6402d71517d"],

Cell[TextData[{
 "Every example follows a consistent pattern: build a server-side processing \
pipeline with the ",
 Cell["//", "InlineCode",ExpressionUUID->
  "6e1fa4e2-e0a4-654f-98c3-420777445c9f"],
 " operator, retrieve the result with ",
 Cell["GEECompute", "InlineCode",ExpressionUUID->
  "5e0545af-278d-d54f-98a0-95a985c04b41"],
 ", ",
 Cell["GEEIdentify", "InlineCode",ExpressionUUID->
  "daebfe5e-d75a-c742-ab92-ec0b77ae3add"],
 ", or ",
 Cell["GEEComputePixels", "InlineCode",ExpressionUUID->
  "29154606-8b0d-9f42-ab2b-0306f86b1774"],
 ", then analyze client-side with Wolfram Language functions such as ",
 Cell["TimeSeries", "InlineCode",ExpressionUUID->
  "54361374-1a06-414b-92c7-c7b40a5115b2"],
 ", ",
 Cell["LinearModelFit", "InlineCode",ExpressionUUID->
  "6738fb28-231b-0e43-957f-cb8775f4d226"],
 ", ",
 Cell["MovingAverage", "InlineCode",ExpressionUUID->
  "4cb268b2-1b2c-9b4d-a38a-faf348d20494"],
 ", and ",
 Cell["DateListPlot", "InlineCode",ExpressionUUID->
  "2d790468-5d3d-c744-b82e-879474a413dc"],
 "."
}], "Text",ExpressionUUID->"9d010ec0-d3a4-9e49-a6e3-eac6e3a90dbc"],

Cell[TextData[{
 StyleBox["Prerequisite:",
  FontWeight->Bold],
 " Authenticate per Section 1.3 and load the paclet with ",
 Cell["Needs[\"GoogleEarthEngineClient`\"]", "InlineCode",ExpressionUUID->
  "41c286a6-d639-dd46-950a-2a8a6f002f07"],
 "."
}], "Text",ExpressionUUID->"d751558a-7fcd-7746-a43b-c2616bd0698c"],

Cell["", "Text",
 CellFrame->{{0, 0}, {0, 
  1}},ExpressionUUID->"e32dcfa5-7ec3-6b4b-9bba-a82501c19d86"],

Cell[CellGroupData[{

Cell["3.1 Surface Temperature", "Chapter",ExpressionUUID->"22b265c0-fda6-ee43-a4f3-4794f83c778a"],

Cell["\<\
Land surface temperature (LST) is a fundamental climate variable that governs \
surface energy balance, evapotranspiration, and urban comfort. Two \
complementary satellite products provide LST at different spatial and \
temporal resolutions.\
\>", "Text",ExpressionUUID->"39d5f83f-f2d0-8742-bae7-a2b5ab4c5a02"],

Cell[CellGroupData[{

Cell["3.1.1 MODIS Land Surface Temperature", "Section",ExpressionUUID->"cba2ed53-c454-4b41-934c-fd0c4a1e13cd"],

Cell[TextData[{
 "The ",
 Cell["MODIS/061/MOD11A2", "InlineCode",ExpressionUUID->
  "7568b358-6f0a-3f46-91c1-fb6cc9ab17bf"],
 " product delivers 8-day composite LST at 1 km resolution. Raw pixel values \
are stored as scaled integers; multiply by 0.02 to convert to Kelvin, then \
subtract 273.15 to obtain degrees Celsius."
}], "Text",ExpressionUUID->"8db034eb-4aa0-3143-b559-7c7a3c478e0e"],

Cell[TextData[StyleBox["Map daytime LST over a city to reveal the urban heat \
island effect:",
 FontWeight->Bold]], "Text",ExpressionUUID->"be8c3cb2-75be-2548-9623-\
da9b570f2a30"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{
    RowBox[{
    "Build", " ", "a", " ", "summer", " ", "LST", " ", "composite", " ", 
     "for", " ", "Phoenix"}], ",", " ", "Arizona"}], " ", "*)"}], "\n", 
  RowBox[{
   RowBox[{
    RowBox[{"loc", "=", 
     RowBox[{"GeoCircle", "[", 
      RowBox[{
       TemplateBox[<|
        "query" -> "Phoenix, Arizona", "boxes" -> TemplateBox[{"\"Phoenix\"", 
            RowBox[{"Entity", "[", 
              RowBox[{"\"City\"", ",", 
                RowBox[{"{", 
                  
                  RowBox[{
                   "\"Phoenix\"", ",", "\"Arizona\"", ",", 
                    "\"UnitedStates\""}], "}"}]}], "]"}], 
            "\"Entity[\\\"City\\\", {\\\"Phoenix\\\", \\\"Arizona\\\", \
\\\"UnitedStates\\\"}]\"", "\"city\""}, "Entity"], 
         "allassumptions" -> {{
           "word" -> "", "template" -> 
            "Assuming the input is a city${separator}Use \"Phoenix\" as \
${desc} or ${desc} or ${desc} instead", "count" -> "4", "pulldown" -> "false",
             "type" -> "MultiClash", "default" -> 
            "{\"MC\", \"\"} -> {\"City\", \"dflt\"}", 
            "Values" -> {{
              "name" -> "City", "desc" -> "a city", "input" -> 
               "{\"MC\", \"\"} -> {\"City\"}", "word" -> "the input"}, {
              "name" -> "DeepSpaceProbe", "desc" -> "a deep space probe", 
               "input" -> "{\"MC\", \"\"} -> {\"DeepSpaceProbe\"}", "word" -> 
               "Phoenix"}, {
              "name" -> "Satellite", "desc" -> "a spacecraft", "input" -> 
               "{\"MC\", \"\"} -> {\"Satellite\"}", "word" -> "Phoenix"}, {
              "name" -> "Constellation", "desc" -> "a constellation", "input" -> 
               "{\"MC\", \"\"} -> {\"Constellation\"}", "word" -> 
               "Phoenix"}}}}, "assumptions" -> {}, "open" -> {1, 2}, 
         "querystate" -> {
          "Online" -> True, "Allowed" -> True, "mparse.jsp" -> 
           1.2424696`7.545830764974767, "Messages" -> {}}, "contextinfo" -> 
         Automatic, "version" -> 5|>,
        "LinguisticAssistantTemplate"], ",", 
       RowBox[{"Quantity", "[", 
        RowBox[{"50", ",", "\"\<Kilometers\>\""}], "]"}]}], "]"}]}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"lstExpr", " ", "=", " ", 
     RowBox[{
      RowBox[{
       RowBox[{
        RowBox[{
         RowBox[{
          RowBox[{
           RowBox[{"GEECollection", "[", "\"\<MODIS/061/MOD11A2\>\"", "]"}], 
           " ", "//", "\n", "  ", 
           RowBox[{"GEEFilterDate", "[", 
            RowBox[{"\"\<2024-06-01\>\"", ",", " ", "\"\<2024-09-01\>\""}], 
            "]"}]}], " ", "//", "\n", "  ", 
          RowBox[{"GEEFilterBounds", "[", "loc", "]"}]}], " ", "//", "\n", 
         "  ", 
         RowBox[{"GEESelectBands", "[", 
          RowBox[{"{", "\"\<LST_Day_1km\>\"", "}"}], "]"}]}], " ", "//", "\n",
         "  ", "GEEMean"}], " ", "//", "\n", "  ", 
       RowBox[{"GEEMultiply", "[", "0.02", "]"}]}], " ", "//", "\n", "  ", 
      RowBox[{"GEEAdd", "[", 
       RowBox[{"-", "273.15"}], "]"}]}]}], ";"}], "\n", "\n", 
   RowBox[{"(*", " ", 
    RowBox[{
     RowBox[{"Render", " ", "as", " ", "a", " ", "color"}], "-", 
     RowBox[{"mapped", " ", "temperature", " ", "image"}]}], " ", "*)"}], "\n", 
   RowBox[{"lstImage", " ", "=", " ", 
    RowBox[{"GEEComputePixels", "[", 
     RowBox[{"loc", ",", " ", "lstExpr", ",", "\n", "  ", 
      RowBox[{"\"\<VisParams\>\"", " ", "->", " ", 
       RowBox[{"<|", 
        RowBox[{
         RowBox[{"\"\<min\>\"", " ", "->", " ", "35"}], ",", " ", 
         RowBox[{"\"\<max\>\"", " ", "->", " ", "55"}], ",", "\n", "    ", 
         RowBox[{"\"\<palette\>\"", " ", "->", " ", 
          RowBox[{"{", 
           
           RowBox[{"\"\<#2166ac\>\"", ",", " ", "\"\<#67a9cf\>\"", ",", 
            " ", "\"\<#d1e5f0\>\"", ",", "\n", "      ", "\"\<#fddbc7\>\"", ",",
             " ", "\"\<#ef8a62\>\"", ",", " ", "\"\<#b2182b\>\""}], "}"}]}]}],
         "|>"}]}], ",", "\n", "  ", 
      RowBox[{"\"\<ImageSize\>\"", " ", "->", " ", 
       RowBox[{"{", 
        RowBox[{"512", ",", " ", "512"}], "}"}]}]}], "]"}]}], "\n", 
   RowBox[{"(*", " ", 
    RowBox[{
     RowBox[{"Blue", " ", "=", " ", 
      RowBox[{
      "cooler", " ", "parks", " ", "and", " ", "irrigated", " ", "areas"}]}], 
     ",", " ", 
     RowBox[{"red", " ", "=", " ", 
      RowBox[{"hot", " ", "impervious", " ", "surfaces"}]}]}], " ", 
    "*)"}]}]}]], "Input",
 CellChangeTimes->{{3.98449107531534*^9, 3.9844911123393497`*^9}},
 CellLabel->
  "In[129]:=",ExpressionUUID->"e18bbfe7-a51a-d344-9f25-f759bd58235e"],

