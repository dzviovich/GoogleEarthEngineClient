Cell[CellGroupData[{

Cell["3.3.2 An Alternative Approach: GEEExpression for Wind Speed", "Section",ExpressionUUID->"c6d266e7-b42b-4a47-94c0-cfd5b0659007"],

Cell[TextData[{
 "When the arithmetic involves multiple bands from the same image, ",
 Cell["GEEExpression", "InlineCode",ExpressionUUID->
  "58a5288d-ad10-9a45-af61-9e8c0d63560b"],
 " can be more concise than chaining individual math operators. This approach \
requires all bands in a single image, so the pipeline selects both components \
and uses the text expression syntax."
}], "Text",ExpressionUUID->"2a50120b-f208-424d-8ab3-9f7034604062"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"windExpr", " ", "=", " ", 
    RowBox[{
     RowBox[{
      RowBox[{
       RowBox[{
        RowBox[{
         RowBox[{
         "GEECollection", "[", "\"\<ECMWF/ERA5_LAND/DAILY_AGGR\>\"", "]"}], 
         " ", "//", "\n", "  ", 
         RowBox[{"GEEFilterDate", "[", 
          RowBox[{"\"\<2024-01-01\>\"", ",", " ", "\"\<2024-02-01\>\""}], 
          "]"}]}], " ", "//", "\n", "  ", 
        RowBox[{"GEEFilterBounds", "[", 
         RowBox[{"{", 
          RowBox[{
           RowBox[{"-", "10.0"}], ",", " ", "35.0", ",", " ", "15.0", ",", 
           " ", "60.0"}], "}"}], "]"}]}], " ", "//", "\n", "  ", 
       RowBox[{"GEESelectBands", "[", 
        RowBox[{"{", 
         RowBox[{"\"\<u_component_of_wind_10m\>\"", ",", 
          " ", "\"\<v_component_of_wind_10m\>\""}], "}"}], "]"}]}], " ", "//",
       "\n", "  ", "GEEMean"}], " ", "//", "\n", "  ", 
     RowBox[{"GEEExpression", "[", 
      RowBox[{"\"\<(u * u + v * v)**(0.5)\>\"", ",", " ", 
       RowBox[{"<|", "\n", "    ", 
        RowBox[{
         RowBox[{"\"\<u\>\"", " ", "->", 
          " ", "\"\<u_component_of_wind_10m_mean\>\""}], ",", "\n", "    ", 
         RowBox[{"\"\<v\>\"", " ", "->", 
          " ", "\"\<v_component_of_wind_10m_mean\>\""}]}], "|>"}]}], 
      "]"}]}]}], ";"}], "\n"}], "\n", 
 RowBox[{"GEEComputePixels", "[", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{
     RowBox[{"-", "10.0"}], ",", " ", "35.0", ",", " ", "15.0", ",", " ", 
     "60.0"}], "}"}], ",", " ", "windExpr", ",", "\n", "  ", 
   RowBox[{"\"\<VisParams\>\"", " ", "->", " ", 
    RowBox[{"<|", 
     RowBox[{
      RowBox[{"\"\<min\>\"", " ", "->", " ", "0"}], ",", " ", 
      RowBox[{"\"\<max\>\"", " ", "->", " ", "8"}], ",", "\n", "    ", 
      RowBox[{"\"\<palette\>\"", " ", "->", " ", 
       RowBox[{"{", 
        RowBox[{"\"\<#ffffcc\>\"", ",", " ", "\"\<#c7e9b4\>\"", ",", 
         " ", "\"\<#7fcdbb\>\"", ",", "\n", "      ", "\"\<#41b6c4\>\"", ",", 
         " ", "\"\<#1d91c0\>\"", ",", " ", "\"\<#225ea8\>\"", ",", 
         " ", "\"\<#0c2c84\>\""}], "}"}]}]}], "|>"}]}], ",", "\n", "  ", 
   RowBox[{"\"\<ImageSize\>\"", " ", "->", " ", 
    RowBox[{"{", 
     RowBox[{"500", ",", " ", "500"}], "}"}]}]}], "]"}]}], "Input",
 CellChangeTimes->{{3.984494665798544*^9, 3.9844946726940193`*^9}},
 CellLabel->
  "In[275]:=",ExpressionUUID->"a0cf35f7-3648-6c47-8ef8-e354f03acd73"],

