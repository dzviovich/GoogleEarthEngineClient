Cell[CellGroupData[{

Cell["3.1.2 Landsat Thermal Band", "Section",ExpressionUUID->"6adbf672-e1ab-df41-b012-f0415e500649"],

Cell[TextData[{
 "Landsat 8 Collection 2 Level 2 provides surface temperature via the ",
 Cell["ST_B10", "InlineCode",ExpressionUUID->
  "ce4c073f-030f-f04f-8908-7b6271396a1d"],
 " band at 30 m resolution -- much finer than MODIS. This enables intra-urban \
thermal comparisons between parks and built-up areas. For the Landsat thermal \
scale factors and band conventions, see Section 2.2. For urban heat island \
analysis using these thermal products, see Section 7.2."
}], "Text",ExpressionUUID->"94e63b9a-9866-f642-86fc-09fb3bc06ff5"],

Cell[TextData[StyleBox["Compare LST between an urban park and its \
surroundings:",
 FontWeight->Bold]], "Text",ExpressionUUID->"6534bde9-d4df-9e4a-86ec-\
bc0b4f9f9506"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{
    RowBox[{"Cloud", "-", 
     RowBox[{
     "filtered", " ", "Landsat", " ", "8", " ", "surface", " ", "temperature",
       " ", "for", " ", "Austin"}]}], ",", " ", "TX"}], " ", "*)"}], "\n", 
  RowBox[{
   RowBox[{
    RowBox[{"landsatLST", " ", "=", " ", 
     RowBox[{
      RowBox[{
       RowBox[{
        RowBox[{
         RowBox[{
          RowBox[{
           RowBox[{
            RowBox[{
            "GEECollection", "[", "\"\<LANDSAT/LC08/C02/T1_L2\>\"", "]"}], 
            " ", "//", "\n", "  ", 
            RowBox[{"GEEFilterDate", "[", 
             RowBox[{"\"\<2024-06-01\>\"", ",", " ", "\"\<2024-09-01\>\""}], 
             "]"}]}], " ", "//", "\n", "  ", 
           RowBox[{"GEEFilterBounds", "[", 
            RowBox[{"{", 
             RowBox[{
              RowBox[{"-", "97.8"}], ",", " ", "30.2", ",", " ", 
              RowBox[{"-", "97.7"}], ",", " ", "30.35"}], "}"}], "]"}]}], " ",
           "//", "\n", "  ", 
          RowBox[{"GEEFilterProperty", "[", 
           
           RowBox[{"\"\<CLOUD_COVER\>\"", ",", " ", "\"\<LessThan\>\"", ",", 
            " ", "20"}], "]"}]}], " ", "//", "\n", "  ", 
         RowBox[{"GEESelectBands", "[", 
          RowBox[{"{", "\"\<ST_B10\>\"", "}"}], "]"}]}], " ", "//", "\n", 
        "  ", "GEEMedian"}], " ", "//", "\n", "  ", 
       RowBox[{"GEEMultiply", "[", "0.00341802", "]"}]}], " ", "//", "\n", 
      "  ", 
      RowBox[{"GEEAdd", "[", 
       RowBox[{"149.0", " ", "-", " ", "273.15"}], "]"}]}]}], ";"}], "\n", 
   "\n", 
   RowBox[{"(*", " ", 
    RowBox[{"Sample", " ", "at", " ", "multiple", " ", 
     RowBox[{"points", ":", " ", 
      RowBox[{"Zilker", " ", "Park", " ", 
       RowBox[{"vs", ".", " ", "downtown"}]}]}]}], " ", "*)"}], "\n", 
   RowBox[{
    RowBox[{"parkPoints", " ", "=", " ", 
     RowBox[{"{", "\n", "  ", 
      RowBox[{
       RowBox[{"GeoPosition", "[", 
        RowBox[{"{", 
         RowBox[{"30.267", ",", " ", 
          RowBox[{"-", "97.773"}]}], "}"}], "]"}], ",", "  ", 
       RowBox[{"(*", " ", 
        RowBox[{"Zilker", " ", "Park", " ", "center"}], " ", "*)"}], "\n", 
       "  ", 
       RowBox[{"GeoPosition", "[", 
        RowBox[{"{", 
         RowBox[{"30.271", ",", " ", 
          RowBox[{"-", "97.770"}]}], "}"}], "]"}], ",", "  ", 
       RowBox[{"(*", " ", 
        RowBox[{"Zilker", " ", "Park", " ", "edge"}], " ", "*)"}], "\n", "  ", 
       RowBox[{"GeoPosition", "[", 
        RowBox[{"{", 
         RowBox[{"30.264", ",", " ", 
          RowBox[{"-", "97.776"}]}], "}"}], "]"}]}], "   ", 
      RowBox[{"(*", " ", 
       RowBox[{"Barton", " ", "Springs"}], " ", "*)"}], "\n", "}"}]}], ";"}], 
   "\n", 
   RowBox[{
    RowBox[{"urbanPoints", " ", "=", " ", 
     RowBox[{"{", "\n", "  ", 
      RowBox[{
       RowBox[{"GeoPosition", "[", 
        RowBox[{"{", 
         RowBox[{"30.267", ",", " ", 
          RowBox[{"-", "97.743"}]}], "}"}], "]"}], ",", "  ", 
       RowBox[{"(*", " ", 
        RowBox[{"Congress", " ", "Avenue"}], " ", "*)"}], "\n", "  ", 
       RowBox[{"GeoPosition", "[", 
        RowBox[{"{", 
         RowBox[{"30.270", ",", " ", 
          RowBox[{"-", "97.740"}]}], "}"}], "]"}], ",", "  ", 
       RowBox[{"(*", " ", 
        RowBox[{"East", " ", "6", "th", " ", "Street"}], " ", "*)"}], "\n", 
       "  ", 
       RowBox[{"GeoPosition", "[", 
        RowBox[{"{", 
         RowBox[{"30.265", ",", " ", 
          RowBox[{"-", "97.747"}]}], "}"}], "]"}]}], "   ", 
      RowBox[{"(*", " ", 
       RowBox[{"Rainey", " ", "Street"}], " ", "*)"}], "\n", "}"}]}], ";"}], 
   "\n", "\n", 
   RowBox[{
    RowBox[{"parkTemps", " ", "=", " ", 
     RowBox[{"Mean", "[", "\n", "  ", 
      RowBox[{"First", " ", "/@", " ", 
       RowBox[{"(", 
        RowBox[{
         RowBox[{
          RowBox[{"#", "[", "\"\<Values\>\"", "]"}], " ", "&"}], " ", "/@", 
         " ", 
         RowBox[{"GEEGetSamples", "[", 
          RowBox[{"parkPoints", ",", " ", "landsatLST"}], "]"}]}], ")"}]}], 
      "]"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"urbanTemps", " ", "=", " ", 
     RowBox[{"Mean", "[", "\n", "  ", 
      RowBox[{"First", " ", "/@", " ", 
       RowBox[{"(", 
        RowBox[{
         RowBox[{
          RowBox[{"#", "[", "\"\<Values\>\"", "]"}], " ", "&"}], " ", "/@", 
         " ", 
         RowBox[{"GEEGetSamples", "[", 
          RowBox[{"urbanPoints", ",", " ", "landsatLST"}], "]"}]}], ")"}]}], 
      "]"}]}], ";"}], "\n", "\n", 
   RowBox[{"Grid", "[", 
    RowBox[{
     RowBox[{"{", "\n", "  ", 
