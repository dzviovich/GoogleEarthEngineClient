Cell[CellGroupData[{

Cell["3.6.3 Hillshade Visualization", "Section",ExpressionUUID->"5954411e-8f29-ca44-acbf-78ce92d16188"],

Cell[TextData[{
 "GEE's ",
 Cell["GEETerrain", "InlineCode",ExpressionUUID->
  "9a9a308c-c127-ab46-83ca-95f5a12e5f40"],
 " also computes hillshade (simulated shadow pattern) which provides an \
intuitive view of terrain relief. Combining hillshade with elevation creates \
publication-quality terrain maps."
}], "Text",ExpressionUUID->"d71b32ab-f147-5244-9ad6-dbaf40885a80"],

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{
   "Hillshade", " ", "map", " ", "of", " ", "the", " ", "Colorado", " ", 
    "Rockies"}], " ", "*)"}], "\n", 
  RowBox[{
   RowBox[{
    RowBox[{"terrainImg", " ", "=", " ", 
     RowBox[{"GEETerrain", "[", 
      RowBox[{"GEELoadImage", "[", "\"\<USGS/SRTMGL1_003\>\"", "]"}], "]"}]}],
     ";"}], "\n", "\n", 
   RowBox[{"(*", " ", 
    RowBox[{
    "Select", " ", "just", " ", "the", " ", "hillshade", " ", "band"}], " ", 
    "*)"}], "\n", 
   RowBox[{
    RowBox[{"hillshade", " ", "=", " ", 
     RowBox[{"terrainImg", " ", "//", " ", 
      RowBox[{"GEESelectBands", "[", 
       RowBox[{"{", "\"\<hillshade\>\"", "}"}], "]"}]}]}], ";"}], "\n", "\n", 
   RowBox[{"GEEComputePixels", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
       RowBox[{"-", "106.0"}], ",", " ", "39.0", ",", " ", 
       RowBox[{"-", "105.0"}], ",", " ", "40.0"}], "}"}], ",", " ", 
     "hillshade", ",", "\n", "  ", 
     RowBox[{"\"\<VisParams\>\"", " ", "->", " ", 
      RowBox[{"<|", 
       RowBox[{
        RowBox[{"\"\<min\>\"", " ", "->", " ", "0"}], ",", " ", 
        RowBox[{"\"\<max\>\"", " ", "->", " ", "255"}]}], "|>"}]}], ",", "\n",
      "  ", 
     RowBox[{"\"\<ImageSize\>\"", " ", "->", " ", 
      RowBox[{"{", 
       RowBox[{"512", ",", " ", "512"}], "}"}]}]}], "]"}]}]}]], "Input",Expres\
sionUUID->"46cdcc15-5cc7-6144-887f-f01bd984dc4b"],

