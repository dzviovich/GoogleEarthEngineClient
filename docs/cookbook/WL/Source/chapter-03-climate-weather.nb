Cell[TextData[StyleBox["Query AOD at specific cities for comparison:",
 FontWeight->Bold]], "Text",ExpressionUUID->"fd4aea06-3788-4942-b269-\
2021e7cd84cc"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"cities", " ", "=", " ", 
    RowBox[{"<|", "\n", "  ", 
     RowBox[{
      RowBox[{"\"\<Delhi\>\"", " ", "->", " ", 
       RowBox[{"GeoPosition", "[", 
        RowBox[{"{", 
         RowBox[{"28.61", ",", " ", "77.21"}], "}"}], "]"}]}], ",", "\n", 
      "  ", 
      RowBox[{"\"\<Kolkata\>\"", " ", "->", " ", 
       RowBox[{"GeoPosition", "[", 
        RowBox[{"{", 
         RowBox[{"22.57", ",", " ", "88.36"}], "}"}], "]"}]}], ",", "\n", 
      "  ", 
      RowBox[{"\"\<Mumbai\>\"", " ", "->", " ", 
       RowBox[{"GeoPosition", "[", 
        RowBox[{"{", 
         RowBox[{"19.08", ",", " ", "72.88"}], "}"}], "]"}]}], ",", "\n", 
      "  ", 
      RowBox[{"\"\<Bangalore\>\"", " ", "->", " ", 
       RowBox[{"GeoPosition", "[", 
        RowBox[{"{", 
         RowBox[{"12.97", ",", " ", "77.59"}], "}"}], "]"}]}]}], "\n", 
     "|>"}]}], ";"}], "\n"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"aodValues", " ", "=", " ", 
    RowBox[{"Association", " ", "@", " ", 
     RowBox[{"KeyValueMap", "[", "\n", "  ", 
      RowBox[{
       RowBox[{"Function", "[", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{"name", ",", " ", "pos"}], "}"}], ",", "\n", "    ", 
         RowBox[{"name", " ", "->", " ", 
          RowBox[{
           RowBox[{
            RowBox[{"GEEIdentify", "[", 
             RowBox[{"pos", ",", " ", "aodExpr"}], "]"}], 
            "[", "\"\<Values\>\"", "]"}], "[", 
           RowBox[{"[", "1", "]"}], "]"}]}]}], "\n", "  ", "]"}], ",", "\n", 
       "  ", "cities"}], "\n", "]"}]}]}], ";"}], "\n"}], "\n", 
 RowBox[{"BarChart", "[", 
  RowBox[{"aodValues", ",", "\n", "  ", 
   RowBox[{"ChartLabels", " ", "->", " ", 
    RowBox[{"Keys", "[", "aodValues", "]"}]}], ",", "\n", "  ", 
   RowBox[{"AxesLabel", " ", "->", " ", 
    RowBox[{"{", 
     RowBox[{"None", ",", " ", "\"\<AOD (unitless)\>\""}], "}"}]}], ",", "\n",
    "  ", 
   RowBox[{
   "PlotLabel", " ", "->", 
    " ", "\"\<Winter Aerosol Optical Depth - Nov 2024 to Jan 2025\>\""}], ",",
    "\n", "  ", 
   RowBox[{"ChartStyle", " ", "->", " ", "\"\<SunsetColors\>\""}]}], 
  "]"}]}], "Input",
 CellLabel->
  "In[315]:=",ExpressionUUID->"1ef78593-4ef8-944e-a1cb-33bbc009a350"],

Cell[BoxData[
 GraphicsBox[{
   {Opacity[0], 
