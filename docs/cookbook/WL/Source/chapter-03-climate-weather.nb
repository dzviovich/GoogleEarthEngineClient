Cell[CellGroupData[{

Cell["\<\
3.7 Putting It All Together: Multi-Variable Climate Dashboard\
\>", "Chapter",ExpressionUUID->"fbab4913-9c7d-b848-a77c-94ab57e2ddc7"],

Cell["\<\
This final section demonstrates how to combine multiple climate variables \
into a unified analysis. The workflow extracts temperature, precipitation, \
ET, and wind data for a single region and present them as an integrated \
dashboard.\
\>", "Text",ExpressionUUID->"65945e21-3999-bc42-a2d1-995291f7e7eb"],

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{"Define", " ", "the", " ", "study", " ", 
    RowBox[{"region", ":", " ", 
     RowBox[{"Central", " ", "Spain"}]}]}], " ", "*)"}], "\n", 
  RowBox[{
   RowBox[{
    RowBox[{"region", " ", "=", " ", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"-", "4.0"}], ",", " ", "39.5", ",", " ", 
       RowBox[{"-", "3.0"}], ",", " ", "40.5"}], "}"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"regionGeom", " ", "=", " ", 
     RowBox[{"GEEGeometry", "[", "region", "]"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"studyPoint", " ", "=", " ", 
     RowBox[{"GeoPosition", "[", 
      RowBox[{"{", 
       RowBox[{"40.0", ",", " ", 
        RowBox[{"-", "3.5"}]}], "}"}], "]"}]}], ";"}], "\n", "\n", 
   RowBox[{"(*", " ", 
    RowBox[{
     RowBox[{
      RowBox[{"--", 
       RowBox[{"-", " ", "Temperature"}]}], " ", "from", " ", 
      RowBox[{"ERA5", " ", "--"}]}], "-"}], " ", "*)"}], "\n", 
   RowBox[{
    RowBox[{"tempData", " ", "=", " ", 
     RowBox[{"Table", "[", "\n", "  ", 
      RowBox[{
       RowBox[{"Module", "[", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{"s", ",", " ", "e", ",", " ", "expr", ",", " ", "result"}], 
          "}"}], ",", "\n", "    ", 
         RowBox[{
          RowBox[{"s", " ", "=", " ", 
           RowBox[{"DateString", "[", 
            RowBox[{
             RowBox[{"DateObject", "[", 
              RowBox[{"{", 
               RowBox[{"2024", ",", " ", "mo", ",", " ", "1"}], "}"}], "]"}], 
             ",", " ", 
             RowBox[{"{", 
              
              RowBox[{"\"\<Year\>\"", ",", " ", "\"\<-\>\"", ",", 
               " ", "\"\<Month\>\"", ",", " ", "\"\<-\>\"", ",", 
               " ", "\"\<Day\>\""}], "}"}]}], "]"}]}], ";", "\n", "    ", 
          RowBox[{"e", " ", "=", " ", 
           RowBox[{"DateString", "[", 
            RowBox[{
             RowBox[{"DateObject", "[", 
              RowBox[{"{", 
               RowBox[{"2024", ",", " ", 
                RowBox[{"mo", " ", "+", " ", "1"}], ",", " ", "1"}], "}"}], 
              "]"}], ",", " ", 
             RowBox[{"{", 
              
              RowBox[{"\"\<Year\>\"", ",", " ", "\"\<-\>\"", ",", 
               " ", "\"\<Month\>\"", ",", " ", "\"\<-\>\"", ",", 
               " ", "\"\<Day\>\""}], "}"}]}], "]"}]}], ";", "\n", "    ", 
          RowBox[{"expr", " ", "=", " ", 
           RowBox[{
            RowBox[{
             RowBox[{
              RowBox[{
               RowBox[{
               "GEECollection", "[", "\"\<ECMWF/ERA5_LAND/DAILY_AGGR\>\"", 
                "]"}], " ", "//", "\n", "      ", 
               RowBox[{"GEEFilterDate", "[", 
                RowBox[{"s", ",", " ", "e"}], "]"}]}], " ", "//", "\n", 
              "      ", 
              RowBox[{"GEESelectBands", "[", 
               RowBox[{"{", "\"\<temperature_2m\>\"", "}"}], "]"}]}], " ", "//",
              "\n", "      ", "GEEMean"}], " ", "//", "\n", "      ", 
            RowBox[{"GEEAdd", "[", 
             RowBox[{"-", "273.15"}], "]"}]}]}], ";", "\n", "    ", 
          RowBox[{"result", " ", "=", " ", 
           RowBox[{"GEEIdentify", "[", 
            RowBox[{"studyPoint", ",", " ", "expr"}], "]"}]}], ";", "\n", 
          "    ", 
          RowBox[{
           RowBox[{"result", "[", "\"\<Values\>\"", "]"}], "[", 
           RowBox[{"[", "1", "]"}], "]"}]}]}], "\n", "  ", "]"}], ",", "\n", 
       "  ", 
       RowBox[{"{", 
        RowBox[{"mo", ",", " ", "1", ",", " ", "12"}], "}"}]}], "\n", "]"}]}],
     ";"}], "\n", "\n", 
   RowBox[{"(*", " ", 
    RowBox[{
     RowBox[{
      RowBox[{"--", 
       RowBox[{"-", " ", "Precipitation"}]}], " ", "from", " ", 
      RowBox[{"CHIRPS", " ", "--"}]}], "-"}], " ", "*)"}], "\n", 
   RowBox[{
    RowBox[{"precipData", " ", "=", " ", 
     RowBox[{"Table", "[", "\n", "  ", 
      RowBox[{
       RowBox[{"Module", "[", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{"s", ",", " ", "e", ",", " ", "expr", ",", " ", "result"}], 
          "}"}], ",", "\n", "    ", 
         RowBox[{
          RowBox[{"s", " ", "=", " ", 
           RowBox[{"DateString", "[", 
            RowBox[{
             RowBox[{"DateObject", "[", 
              RowBox[{"{", 
               RowBox[{"2024", ",", " ", "mo", ",", " ", "1"}], "}"}], "]"}], 
             ",", " ", 
             RowBox[{"{", 
              
              RowBox[{"\"\<Year\>\"", ",", " ", "\"\<-\>\"", ",", 
               " ", "\"\<Month\>\"", ",", " ", "\"\<-\>\"", ",", 
               " ", "\"\<Day\>\""}], "}"}]}], "]"}]}], ";", "\n", "    ", 
          RowBox[{"e", " ", "=", " ", 
           RowBox[{"DateString", "[", 
            RowBox[{
             RowBox[{"DateObject", "[", 
              RowBox[{"{", 
               RowBox[{"2024", ",", " ", 
                RowBox[{"mo", " ", "+", " ", "1"}], ",", " ", "1"}], "}"}], 
              "]"}], ",", " ", 
             RowBox[{"{", 
              
              RowBox[{"\"\<Year\>\"", ",", " ", "\"\<-\>\"", ",", 
               " ", "\"\<Month\>\"", ",", " ", "\"\<-\>\"", ",", 
               " ", "\"\<Day\>\""}], "}"}]}], "]"}]}], ";", "\n", "    ", 
          RowBox[{"expr", " ", "=", " ", 
           RowBox[{
            RowBox[{
             RowBox[{
              RowBox[{
               RowBox[{
                RowBox[{
                "GEECollection", "[", "\"\<UCSB-CHG/CHIRPS/DAILY\>\"", "]"}], 
                " ", "//", "\n", "      ", 
                RowBox[{"GEEFilterDate", "[", 
                 RowBox[{"s", ",", " ", "e"}], "]"}]}], " ", "//", "\n", 
               "      ", 
               RowBox[{"GEEFilterBounds", "[", "region", "]"}]}], " ", "//", 
              "\n", "      ", 
              RowBox[{"GEESelectBands", "[", 
               RowBox[{"{", "\"\<precipitation\>\"", "}"}], "]"}]}], " ", "//",
              "\n", "      ", "GEECollectionSum"}], " ", "//", "\n", "      ", 
            RowBox[{"GEEReduceRegion", "[", 
             RowBox[{
             "regionGeom", ",", " ", "\"\<mean\>\"", ",", " ", "5000"}], 
             "]"}]}]}], ";", "\n", "    ", 
          RowBox[{"result", " ", "=", " ", 
           RowBox[{"GEECompute", "[", "expr", "]"}]}], ";", "\n", "    ", 
          RowBox[{"First", "[", 
           RowBox[{"Values", "[", "result", "]"}], "]"}]}]}], "\n", "  ", 
        "]"}], ",", "\n", "  ", 
       RowBox[{"{", 
        RowBox[{"mo", ",", " ", "1", ",", " ", "12"}], "}"}]}], "\n", "]"}]}],
     ";"}], "\n", "\n", 
   RowBox[{"(*", " ", 
    RowBox[{
     RowBox[{
      RowBox[{"--", 
       RowBox[{"-", " ", "Evapotranspiration"}]}], " ", "from", " ", 
      RowBox[{"MODIS", " ", "--"}]}], "-"}], " ", "*)"}], "\n", 
   RowBox[{
    RowBox[{"etData", " ", "=", " ", 
     RowBox[{"Table", "[", "\n", "  ", 
      RowBox[{
       RowBox[{"Module", "[", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{"s", ",", " ", "e", ",", " ", "expr", ",", " ", "result"}], 
          "}"}], ",", "\n", "    ", 
         RowBox[{
          RowBox[{"s", " ", "=", " ", 
           RowBox[{"DateString", "[", 
            RowBox[{
             RowBox[{"DateObject", "[", 
              RowBox[{"{", 
               RowBox[{"2024", ",", " ", "mo", ",", " ", "1"}], "}"}], "]"}], 
             ",", " ", 
             RowBox[{"{", 
              
              RowBox[{"\"\<Year\>\"", ",", " ", "\"\<-\>\"", ",", 
               " ", "\"\<Month\>\"", ",", " ", "\"\<-\>\"", ",", 
               " ", "\"\<Day\>\""}], "}"}]}], "]"}]}], ";", "\n", "    ", 
          RowBox[{"e", " ", "=", " ", 
           RowBox[{"DateString", "[", 
            RowBox[{
             RowBox[{"DateObject", "[", 
              RowBox[{"{", 
               RowBox[{"2024", ",", " ", 
                RowBox[{"mo", " ", "+", " ", "1"}], ",", " ", "1"}], "}"}], 
              "]"}], ",", " ", 
             RowBox[{"{", 
              
              RowBox[{"\"\<Year\>\"", ",", " ", "\"\<-\>\"", ",", 
               " ", "\"\<Month\>\"", ",", " ", "\"\<-\>\"", ",", 
               " ", "\"\<Day\>\""}], "}"}]}], "]"}]}], ";", "\n", "    ", 
          RowBox[{"expr", " ", "=", " ", 
           RowBox[{
            RowBox[{
             RowBox[{
              RowBox[{
               RowBox[{
                RowBox[{
                 RowBox[{
                 "GEECollection", "[", "\"\<MODIS/061/MOD16A2\>\"", "]"}], 
                 " ", "//", "\n", "      ", 
                 RowBox[{"GEEFilterDate", "[", 
                  RowBox[{"s", ",", " ", "e"}], "]"}]}], " ", "//", "\n", 
                "      ", 
                RowBox[{"GEEFilterBounds", "[", "region", "]"}]}], " ", "//", 
               "\n", "      ", 
               RowBox[{"GEESelectBands", "[", 
                RowBox[{"{", "\"\<ET\>\"", "}"}], "]"}]}], " ", "//", "\n", 
              "      ", "GEECollectionSum"}], " ", "//", "\n", "      ", 
             RowBox[{"GEEMultiply", "[", "0.1", "]"}]}], " ", "//", "\n", 
            "      ", 
            RowBox[{"GEEReduceRegion", "[", 
             RowBox[{
             "regionGeom", ",", " ", "\"\<mean\>\"", ",", " ", "500"}], 
             "]"}]}]}], ";", "\n", "    ", 
          RowBox[{"result", " ", "=", " ", 
           RowBox[{"GEECompute", "[", "expr", "]"}]}], ";", "\n", "    ", 
          RowBox[{"First", "[", 
           RowBox[{"Values", "[", "result", "]"}], "]"}]}]}], "\n", "  ", 
        "]"}], ",", "\n", "  ", 
       RowBox[{"{", 
        RowBox[{"mo", ",", " ", "1", ",", " ", "12"}], "}"}]}], "\n", "]"}]}],
     ";"}], "\n", "\n", 
   RowBox[{"(*", " ", 
    RowBox[{
     RowBox[{
      RowBox[{"--", 
       RowBox[{"-", " ", "Build"}]}], " ", 
      RowBox[{"dashboard", " ", "--"}]}], "-"}], " ", "*)"}], "\n", 
   RowBox[{
    RowBox[{"months", " ", "=", " ", 
     RowBox[{"Table", "[", 
      RowBox[{
       RowBox[{"DateObject", "[", 
        RowBox[{"{", 
         RowBox[{"2024", ",", " ", "mo", ",", " ", "15"}], "}"}], "]"}], ",", 
       " ", 
       RowBox[{"{", 
        RowBox[{"mo", ",", " ", "1", ",", " ", "12"}], "}"}]}], "]"}]}], 
    ";"}], "\n", "\n", 
   RowBox[{
    RowBox[{"tempTS", " ", "=", " ", 
     RowBox[{"TimeSeries", "[", 
      RowBox[{"tempData", ",", " ", 
       RowBox[{"{", "months", "}"}]}], "]"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"precipTS", " ", "=", " ", 
     RowBox[{"TimeSeries", "[", 
      RowBox[{"precipData", ",", " ", 
       RowBox[{"{", "months", "}"}]}], "]"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"etTS", " ", "=", " ", 
     RowBox[{"TimeSeries", "[", 
      RowBox[{"etData", ",", " ", 
       RowBox[{"{", "months", "}"}]}], "]"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"waterBalanceTS", " ", "=", " ", 
     RowBox[{"TimeSeries", "[", 
      RowBox[{
       RowBox[{"precipData", " ", "-", " ", "etData"}], ",", " ", 
       RowBox[{"{", "months", "}"}]}], "]"}]}], ";"}], "\n", "\n", 
   RowBox[{"Grid", "[", 
    RowBox[{
     RowBox[{"{", "\n", "  ", 
      RowBox[{
       RowBox[{"{", "\n", "    ", 
        RowBox[{
         RowBox[{"DateListPlot", "[", 
          RowBox[{"tempTS", ",", "\n", "      ", 
           RowBox[{
           "PlotLabel", " ", "->", " ", "\"\<Temperature (\[Degree]C)\>\""}], 
           ",", "\n", "      ", 
           RowBox[{"PlotStyle", " ", "->", " ", "Red"}], ",", " ", 
           RowBox[{"Joined", " ", "->", " ", "True"}], ",", " ", 
           RowBox[{"PlotMarkers", " ", "->", " ", "Automatic"}], ",", "\n", 
           "      ", 
           RowBox[{"ImageSize", " ", "->", " ", "350"}]}], "]"}], ",", "\n", 
         "    ", 
         RowBox[{"DateListPlot", "[", 
          RowBox[{"precipTS", ",", "\n", "      ", 
           RowBox[{
           "PlotLabel", " ", "->", " ", "\"\<Precipitation (mm)\>\""}], ",", 
           "\n", "      ", 
           RowBox[{"Filling", " ", "->", " ", "Axis"}], ",", " ", 
           RowBox[{"FillingStyle", " ", "->", " ", 
            RowBox[{"Directive", "[", 
             RowBox[{
              RowBox[{"Opacity", "[", "0.3", "]"}], ",", " ", "Blue"}], 
             "]"}]}], ",", "\n", "      ", 
           RowBox[{"ImageSize", " ", "->", " ", "350"}]}], "]"}]}], "\n", 
        "  ", "}"}], ",", "\n", "  ", 
       RowBox[{"{", "\n", "    ", 
        RowBox[{
         RowBox[{"DateListPlot", "[", 
          RowBox[{"etTS", ",", "\n", "      ", 
           RowBox[{
           "PlotLabel", " ", "->", " ", "\"\<Evapotranspiration (mm)\>\""}], ",",
            "\n", "      ", 
           RowBox[{"PlotStyle", " ", "->", " ", 
            RowBox[{"Darker", "[", "Green", "]"}]}], ",", " ", 
           RowBox[{"Joined", " ", "->", " ", "True"}], ",", " ", 
           RowBox[{"PlotMarkers", " ", "->", " ", "Automatic"}], ",", "\n", 
           "      ", 
           RowBox[{"ImageSize", " ", "->", " ", "350"}]}], "]"}], ",", "\n", 
         "    ", 
         RowBox[{"DateListPlot", "[", 
          RowBox[{"waterBalanceTS", ",", "\n", "      ", 
           RowBox[{
           "PlotLabel", " ", "->", 
            " ", "\"\<Water Balance: P - ET (mm)\>\""}], ",", "\n", "      ", 
           RowBox[{"Filling", " ", "->", " ", "0"}], ",", "\n", "      ", 
           RowBox[{"ColorFunction", " ", "->", " ", 
            RowBox[{"Function", "[", 
             RowBox[{
              RowBox[{"{", 
