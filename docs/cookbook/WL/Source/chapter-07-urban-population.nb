Cell[CellGroupData[{

Cell["7.8 Multi-City Comparative Analysis", "Chapter",ExpressionUUID->"4d3341e7-7d1a-c147-851c-bb67bc7a7e0f"],

Cell["\<\
The workflows introduced in this chapter converge in a multi-city comparative \
analysis. By extracting several urban indicators for a consistent set of \
cities, you can build a dashboard-style summary that reveals how cities \
differ in their nightlight intensity, thermal signatures, built-up extent, \
and vegetation cover.\
\>", "Text",ExpressionUUID->"3daf57f2-ceeb-3c4b-8d1a-e0abbe63a1f0"],

Cell[CellGroupData[{

Cell["Define the Study Cities", "Section",ExpressionUUID->"a352f9c9-bd36-1d4c-b462-021e250e761a"],

Cell[BoxData[
 RowBox[{
  RowBox[{"studyCities", " ", "=", " ", 
   RowBox[{"<|", "\n", "  ", 
    RowBox[{
     RowBox[{"\"\<Tokyo\>\"", "     ", "->", " ", 
      RowBox[{"<|", 
       RowBox[{
        RowBox[{"\"\<bbox\>\"", " ", "->", " ", 
         RowBox[{"{", 
          RowBox[{
          "139.55", ",", " ", "35.55", ",", " ", "139.95", ",", " ", 
           "35.80"}], "}"}]}], ",", "\n", "                   ", 
        RowBox[{"\"\<center\>\"", " ", "->", " ", 
         RowBox[{"GeoPosition", "[", 
          RowBox[{"{", 
           RowBox[{"35.68", ",", " ", "139.75"}], "}"}], "]"}]}]}], "|>"}]}], 
     ",", "\n", "  ", 
     RowBox[{"\"\<New York\>\"", "  ", "->", " ", 
      RowBox[{"<|", 
       RowBox[{
        RowBox[{"\"\<bbox\>\"", " ", "->", " ", 
         RowBox[{"{", 
          RowBox[{
           RowBox[{"-", "74.05"}], ",", " ", "40.65", ",", " ", 
           RowBox[{"-", "73.75"}], ",", " ", "40.85"}], "}"}]}], ",", "\n", 
        "                   ", 
        RowBox[{"\"\<center\>\"", " ", "->", " ", 
         RowBox[{"GeoPosition", "[", 
          RowBox[{"{", 
           RowBox[{"40.75", ",", " ", 
            RowBox[{"-", "73.90"}]}], "}"}], "]"}]}]}], "|>"}]}], ",", "\n", 
     "  ", 
     RowBox[{"\"\<Sao Paulo\>\"", " ", "->", " ", 
      RowBox[{"<|", 
       RowBox[{
        RowBox[{"\"\<bbox\>\"", " ", "->", " ", 
         RowBox[{"{", 
          RowBox[{
           RowBox[{"-", "46.75"}], ",", " ", 
           RowBox[{"-", "23.65"}], ",", " ", 
           RowBox[{"-", "46.45"}], ",", " ", 
           RowBox[{"-", "23.45"}]}], "}"}]}], ",", "\n", 
        "                   ", 
        RowBox[{"\"\<center\>\"", " ", "->", " ", 
         RowBox[{"GeoPosition", "[", 
          RowBox[{"{", 
           RowBox[{
            RowBox[{"-", "23.55"}], ",", " ", 
            RowBox[{"-", "46.60"}]}], "}"}], "]"}]}]}], "|>"}]}], ",", "\n", 
     "  ", 
     RowBox[{"\"\<Cairo\>\"", "     ", "->", " ", 
      RowBox[{"<|", 
       RowBox[{
        RowBox[{"\"\<bbox\>\"", " ", "->", " ", 
         RowBox[{"{", 
          RowBox[{
          "31.15", ",", " ", "29.95", ",", " ", "31.45", ",", " ", "30.15"}], 
          "}"}]}], ",", "\n", "                   ", 
        RowBox[{"\"\<center\>\"", " ", "->", " ", 
         RowBox[{"GeoPosition", "[", 
          RowBox[{"{", 
           RowBox[{"30.05", ",", " ", "31.30"}], "}"}], "]"}]}]}], "|>"}]}], ",",
      "\n", "  ", 
     RowBox[{"\"\<Mumbai\>\"", "    ", "->", " ", 
      RowBox[{"<|", 
       RowBox[{
        RowBox[{"\"\<bbox\>\"", " ", "->", " ", 
         RowBox[{"{", 
          RowBox[{
          "72.80", ",", " ", "18.90", ",", " ", "73.05", ",", " ", "19.15"}], 
          "}"}]}], ",", "\n", "                   ", 
        RowBox[{"\"\<center\>\"", " ", "->", " ", 
         RowBox[{"GeoPosition", "[", 
          RowBox[{"{", 
           RowBox[{"19.05", ",", " ", "72.90"}], "}"}], "]"}]}]}], "|>"}]}]}],
     "\n", "|>"}]}], ";"}]], "Input",ExpressionUUID->"3dca3e42-39e0-e140-ad6b-\
01317dae3928"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Extract Indicators", "Section",ExpressionUUID->"29eaa048-3869-f743-a379-f6ac6dac348e"],

Cell["Build a reusable extraction function for each indicator.", "Text",ExpressionUUID->"66254ad1-6561-ab43-acfd-fa95a72de147"],

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{"1.", " ", "Mean", " ", "nightlight", " ", "radiance"}], " ", 
   "*)"}], "\n", 
  RowBox[{
   RowBox[{
    RowBox[{"extractRadiance", "[", "bbox_", "]"}], " ", ":=", " ", 
    RowBox[{"Module", "[", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{"img", ",", " ", "geom"}], "}"}], ",", "\n", "  ", 
      RowBox[{
       RowBox[{"img", " ", "=", " ", 
        RowBox[{
         RowBox[{
          RowBox[{
           RowBox[{
            RowBox[{
            "GEECollection", "[", "\"\<NOAA/VIIRS/DNB/MONTHLY_V1/VCMSLCFG\>\"",
              "]"}], " ", "//", "\n", "    ", 
            RowBox[{"GEEFilterDate", "[", 
             RowBox[{"\"\<2024-01-01\>\"", ",", " ", "\"\<2024-07-01\>\""}], 
             "]"}]}], " ", "//", "\n", "    ", 
           RowBox[{"GEEFilterBounds", "[", "bbox", "]"}]}], " ", "//", "\n", 
          "    ", 
          RowBox[{"GEESelectBands", "[", 
           RowBox[{"{", "\"\<avg_rad\>\"", "}"}], "]"}]}], " ", "//", "\n", 
         "    ", "GEEMedian"}]}], ";", "\n", "  ", 
       RowBox[{"geom", " ", "=", " ", 
        RowBox[{"GEEGeometry", "[", "bbox", "]"}]}], ";", "\n", "  ", 
       RowBox[{"First", " ", "@", " ", 
        RowBox[{"Values", " ", "@", " ", 
         RowBox[{"GEECompute", "[", 
          RowBox[{"img", " ", "//", " ", 
           RowBox[{"GEEReduceRegion", "[", 
            RowBox[{"geom", ",", " ", "\"\<mean\>\"", ",", " ", "500"}], 
            "]"}]}], "]"}]}]}]}]}], "\n", "]"}]}], "\n", "\n", 
   RowBox[{"(*", " ", 
    RowBox[{
    "2.", " ", "Mean", " ", "land", " ", "surface", " ", "temperature", " ", 
     RowBox[{"(", "Celsius", ")"}]}], " ", "*)"}], "\n", 
   RowBox[{
    RowBox[{"extractLST", "[", "bbox_", "]"}], " ", ":=", " ", 
    RowBox[{"Module", "[", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{"img", ",", " ", "geom"}], "}"}], ",", "\n", "  ", 
      RowBox[{
       RowBox[{"img", " ", "=", " ", 
        RowBox[{
         RowBox[{
          RowBox[{
           RowBox[{
            RowBox[{
             RowBox[{
              RowBox[{
              "GEECollection", "[", "\"\<MODIS/061/MOD11A2\>\"", "]"}], " ", "//",
               "\n", "    ", 
              RowBox[{"GEEFilterDate", "[", 
               RowBox[{"\"\<2024-06-01\>\"", ",", " ", "\"\<2024-09-01\>\""}],
                "]"}]}], " ", "//", "\n", "    ", 
             RowBox[{"GEEFilterBounds", "[", "bbox", "]"}]}], " ", "//", "\n",
             "    ", 
            RowBox[{"GEESelectBands", "[", 
             RowBox[{"{", "\"\<LST_Day_1km\>\"", "}"}], "]"}]}], " ", "//", 
           "\n", "    ", "GEEMedian"}], " ", "//", "\n", "    ", 
          RowBox[{"GEEMultiply", "[", "0.02", "]"}]}], " ", "//", "\n", 
         "    ", 
         RowBox[{"GEEAdd", "[", 
          RowBox[{"-", "273.15"}], "]"}]}]}], ";", "\n", "  ", 
       RowBox[{"geom", " ", "=", " ", 
        RowBox[{"GEEGeometry", "[", "bbox", "]"}]}], ";", "\n", "  ", 
       RowBox[{"First", " ", "@", " ", 
        RowBox[{"Values", " ", "@", " ", 
         RowBox[{"GEECompute", "[", 
          RowBox[{"img", " ", "//", " ", 
           RowBox[{"GEEReduceRegion", "[", 
            RowBox[{"geom", ",", " ", "\"\<mean\>\"", ",", " ", "1000"}], 
            "]"}]}], "]"}]}]}]}]}], "\n", "]"}]}], "\n", "\n", 
   RowBox[{"(*", " ", 
    RowBox[{"3.", " ", "Mean", " ", "NDBI"}], " ", "*)"}], "\n", 
   RowBox[{
    RowBox[{"extractNDBI", "[", "bbox_", "]"}], " ", ":=", " ", 
    RowBox[{"Module", "[", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{"img", ",", " ", "geom"}], "}"}], ",", "\n", "  ", 
      RowBox[{
       RowBox[{"img", " ", "=", " ", 
        RowBox[{
         RowBox[{
          RowBox[{
           RowBox[{
            RowBox[{
             RowBox[{
             "GEECollection", "[", "\"\<COPERNICUS/S2_SR_HARMONIZED\>\"", 
              "]"}], " ", "//", "\n", "    ", 
             RowBox[{"GEEFilterDate", "[", 
              RowBox[{"\"\<2024-03-01\>\"", ",", " ", "\"\<2024-06-01\>\""}], 
              "]"}]}], " ", "//", "\n", "    ", 
            RowBox[{"GEEFilterBounds", "[", "bbox", "]"}]}], " ", "//", "\n", 
           "    ", 
           RowBox[{"GEEFilterProperty", "[", 
            
            RowBox[{"\"\<CLOUDY_PIXEL_PERCENTAGE\>\"", ",", 
             " ", "\"\<LessThan\>\"", ",", " ", "15"}], "]"}]}], " ", "//", 
          "\n", "    ", "GEEMedian"}], " ", "//", "\n", "    ", 
         RowBox[{"GEENormalizedDifference", "[", 
          RowBox[{"{", 
           RowBox[{"\"\<B11\>\"", ",", " ", "\"\<B8\>\""}], "}"}], "]"}]}]}], 
       ";", "\n", "  ", 
       RowBox[{"geom", " ", "=", " ", 
        RowBox[{"GEEGeometry", "[", "bbox", "]"}]}], ";", "\n", "  ", 
       RowBox[{"First", " ", "@", " ", 
        RowBox[{"Values", " ", "@", " ", 
         RowBox[{"GEECompute", "[", 
          RowBox[{"img", " ", "//", " ", 
           RowBox[{"GEEReduceRegion", "[", 
            RowBox[{"geom", ",", " ", "\"\<mean\>\"", ",", " ", "20"}], 
            "]"}]}], "]"}]}]}]}]}], "\n", "]"}]}], "\n", "\n", 
   RowBox[{"(*", " ", 
    RowBox[{
     RowBox[{"4.", " ", "Built"}], "-", 
     RowBox[{
     "up", " ", "area", " ", "percentage", " ", "from", " ", "ESA", " ", 
      "WorldCover"}]}], " ", "*)"}], "\n", 
   RowBox[{
    RowBox[{"extractBuiltUpPct", "[", "bbox_", "]"}], " ", ":=", " ", 
    RowBox[{"Module", "[", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{
       "builtUp", ",", " ", "geom", ",", " ", "builtArea", ",", " ", 
        "totalArea"}], "}"}], ",", "\n", "  ", 
      RowBox[{
       RowBox[{"builtUp", " ", "=", " ", 
        RowBox[{
         RowBox[{
          RowBox[{
           RowBox[{
            RowBox[{
            "GEECollection", "[", "\"\<ESA/WorldCover/v200\>\"", "]"}], " ", "//",
             "\n", "    ", 
            RowBox[{"GEEFilterDate", "[", 
             RowBox[{"\"\<2021-01-01\>\"", ",", " ", "\"\<2022-01-01\>\""}], 
             "]"}]}], " ", "//", "\n", "    ", "GEEMosaic"}], " ", "//", "\n",
           "    ", 
          RowBox[{"GEESelectBands", "[", 
           RowBox[{"{", "\"\<Map\>\"", "}"}], "]"}]}], " ", "//", "\n", 
         "    ", 
         RowBox[{"GEEEquals", "[", "50", "]"}]}]}], ";", "\n", "  ", 
       RowBox[{"geom", " ", "=", " ", 
        RowBox[{"GEEGeometry", "[", "bbox", "]"}]}], ";", "\n", "  ", 
       RowBox[{"builtArea", " ", "=", " ", 
        RowBox[{"First", " ", "@", " ", 
         RowBox[{"Values", " ", "@", " ", 
          RowBox[{"GEECompute", "[", "\n", "    ", 
           RowBox[{
            RowBox[{"builtUp", " ", "//", " ", 
             RowBox[{"GEEMultiply", "[", 
              RowBox[{"GEEPixelArea", "[", "]"}], "]"}]}], " ", "//", "\n", 
            "      ", 
            RowBox[{"GEEReduceRegion", "[", 
             RowBox[{"geom", ",", " ", "\"\<sum\>\"", ",", " ", "10"}], 
             "]"}]}], "\n", "  ", "]"}]}]}]}], ";", "\n", "  ", 
       RowBox[{"totalArea", " ", "=", " ", 
        RowBox[{"First", " ", "@", " ", 
         RowBox[{"Values", " ", "@", " ", 
          RowBox[{"GEECompute", "[", "\n", "    ", 
           RowBox[{
            RowBox[{
             RowBox[{"GEEPixelArea", "[", "]"}], " ", "//", " ", 
             RowBox[{"GEEClip", "[", "geom", "]"}]}], " ", "//", "\n", 
            "      ", 
            RowBox[{"GEEReduceRegion", "[", 
             RowBox[{"geom", ",", " ", "\"\<sum\>\"", ",", " ", "10"}], 
             "]"}]}], "\n", "  ", "]"}]}]}]}], ";", "\n", "  ", 
       RowBox[{"100.0", " ", "*", " ", 
        RowBox[{"builtArea", " ", "/", " ", "totalArea"}]}]}]}], "\n", 
     "]"}]}]}]}]], "Input",ExpressionUUID->"73372971-e9f8-8947-98f0-\
1795387eb637"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Build the Comparative Dataset", "Section",ExpressionUUID->"325b072b-cc52-dd49-bed8-8124a30a7d77"],

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"dashboard", " ", "=", " ", 
    RowBox[{"Association", " ", "@", " ", 
     RowBox[{"KeyValueMap", "[", "\n", "  ", 
      RowBox[{
       RowBox[{"Function", "[", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{"city", ",", " ", "info"}], "}"}], ",", "\n", "    ", 
         RowBox[{"city", " ", "->", " ", 
          RowBox[{"<|", "\n", "      ", 
           RowBox[{
            RowBox[{"\"\<Nightlight (nW/cm2/sr)\>\"", " ", "->", " ", 
             RowBox[{"Round", "[", 
              RowBox[{
               RowBox[{"extractRadiance", "[", 
                RowBox[{"info", "[", "\"\<bbox\>\"", "]"}], "]"}], ",", " ", 
               "0.1"}], "]"}]}], ",", "\n", "      ", 
            RowBox[{"\"\<LST (C)\>\"", "                ", "->", " ", 
             RowBox[{"Round", "[", 
              RowBox[{
               RowBox[{"extractLST", "[", 
                RowBox[{"info", "[", "\"\<bbox\>\"", "]"}], "]"}], ",", " ", 
               "0.1"}], "]"}]}], ",", "\n", "      ", 
            RowBox[{"\"\<Mean NDBI\>\"", "              ", "->", " ", 
             RowBox[{"Round", "[", 
              RowBox[{
               RowBox[{"extractNDBI", "[", 
                RowBox[{"info", "[", "\"\<bbox\>\"", "]"}], "]"}], ",", " ", 
               "0.01"}], "]"}]}], ",", "\n", "      ", 
            RowBox[{"\"\<Built-Up %\>\"", "             ", "->", " ", 
             RowBox[{"Round", "[", 
              RowBox[{
               RowBox[{"extractBuiltUpPct", "[", 
                RowBox[{"info", "[", "\"\<bbox\>\"", "]"}], "]"}], ",", " ", 
               "0.1"}], "]"}]}]}], "\n", "    ", "|>"}]}]}], "\n", "  ", 
        "]"}], ",", "\n", "  ", "studyCities"}], "\n", "]"}]}]}], ";"}], 
  "\n"}], "\n", 
 RowBox[{"Dataset", "[", "dashboard", "]"}]}], "Input",ExpressionUUID->\
"bdff427c-5a8d-6b40-93e8-fa2df601c722"],

Cell["\<\
This produces a five-row table with four columns, providing an at-a-glance \
comparison of urban intensity across continents.\
\>", "Text",ExpressionUUID->"fe42b657-00f0-3545-ba81-ea558380fcda"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Comparative Bar Charts", "Section",ExpressionUUID->"75d4c5bf-161f-404b-b542-441dbead6206"],

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"indicators", " ", "=", " ", 
    RowBox[{"{", 
     RowBox[{"\"\<Nightlight (nW/cm2/sr)\>\"", ",", " ", "\"\<LST (C)\>\"", ",",
       "\n", "  ", "\"\<Mean NDBI\>\"", ",", " ", "\"\<Built-Up %\>\""}], 
     "}"}]}], ";"}], "\n"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"charts", " ", "=", " ", 
    RowBox[{"Map", "[", "\n", "  ", 
     RowBox[{
      RowBox[{"Function", "[", 
       RowBox[{"ind", ",", "\n", "    ", 
        RowBox[{"BarChart", "[", "\n", "      ", 
         RowBox[{
          RowBox[{"Map", "[", 
           RowBox[{
            RowBox[{
             RowBox[{
              RowBox[{"dashboard", "[", "#", "]"}], "[", "ind", "]"}], " ", 
             "&"}], ",", " ", 
            RowBox[{"Keys", "[", "studyCities", "]"}]}], "]"}], ",", "\n", 
          "      ", 
          RowBox[{"ChartLabels", " ", "->", " ", 
           RowBox[{"Keys", "[", "studyCities", "]"}]}], ",", "\n", "      ", 
          RowBox[{"PlotLabel", " ", "->", " ", "ind"}], ",", "\n", "      ", 
          RowBox[{"ChartStyle", " ", "->", " ", "\"\<Pastel\>\""}]}], "\n", 
         "    ", "]"}]}], "\n", "  ", "]"}], ",", "\n", "  ", "indicators"}], 
     "\n", "]"}]}], ";"}], "\n"}], "\n", 
 RowBox[{"GraphicsGrid", "[", 
  RowBox[{
   RowBox[{"Partition", "[", 
    RowBox[{"charts", ",", " ", "2"}], "]"}], ",", " ", 
   RowBox[{"ImageSize", " ", "->", " ", "800"}]}], "]"}]}], "Input",Expression\
UUID->"c2ac8813-dfcb-a343-a950-59d1970b3b9c"]
}, Open  ]],

Cell[CellGroupData[{

Cell["City Location Map", "Section",ExpressionUUID->"4d18b4bb-ed19-684a-93fd-cac56551e49d"],

Cell[TextData[{
 "Add geographic context with a ",
 Cell["GeoGraphics", "InlineCode",ExpressionUUID->
  "5d5d3cb1-2f1d-914f-9f3e-ac69bc0b6491"],
 " display showing all five study cities."
}], "Text",ExpressionUUID->"a6f6bfd5-4b26-a347-b2ea-ad08b39c60cc"],

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"markers", " ", "=", " ", 
    RowBox[{"KeyValueMap", "[", "\n", "  ", 
     RowBox[{
      RowBox[{"Function", "[", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{"city", ",", " ", "info"}], "}"}], ",", "\n", "    ", 
        RowBox[{"{", 
         RowBox[{
          RowBox[{"PointSize", "[", "0.02", "]"}], ",", " ", "Red", ",", "\n",
           "     ", 
          RowBox[{"GeoMarker", "[", 
           RowBox[{
            RowBox[{"info", "[", "\"\<center\>\"", "]"}], ",", " ", 
            RowBox[{"\"\<Label\>\"", " ", "->", " ", "city"}]}], "]"}]}], 
         "}"}]}], "\n", "  ", "]"}], ",", "\n", "  ", "studyCities"}], "\n", 
     "]"}]}], ";"}], "\n"}], "\n", 
 RowBox[{"GeoGraphics", "[", 
  RowBox[{"markers", ",", "\n", "  ", 
   RowBox[{"GeoRange", " ", "->", " ", "\"\<World\>\""}], ",", "\n", "  ", 
   RowBox[{"GeoProjection", " ", "->", " ", "\"\<Robinson\>\""}], ",", "\n", 
   "  ", 
   RowBox[{"ImageSize", " ", "->", " ", "700"}]}], "\n", "]"}]}], "Input",Expr\
essionUUID->"13117fe3-6627-1749-8e7c-3c5dd045c668"],

Cell["", "Text",
 CellFrame->{{0, 0}, {0, 
  1}},ExpressionUUID->"a2c5f89e-c882-8e40-bbec-843e91ff9516"]
}, Open  ]]
}, Open  ]],

Cell[CellGroupData[{

Cell["Summary", "Chapter",ExpressionUUID->"182767ce-bc1c-ea48-a3cc-5eb63f8729b8"],

Cell["\<\
This chapter demonstrated how to combine Google Earth Engine's global \
satellite archive with Wolfram Language's analytical and visualization \
capabilities to study urban environments. The key techniques covered were:\
\>", "Text",ExpressionUUID->"a37ef8e2-a9d7-b646-a5de-c6b67e32db2e"],

Cell[TextData[{
 StyleBox["Nighttime lights",
  FontWeight->Bold],
 " (VIIRS, DMSP-OLS) as proxies for economic activity, with ",
 Cell["GEELog10", "InlineCode",ExpressionUUID->
  "e0536f16-86bd-c948-b0f6-3f8487eaee9b"],
 " for dynamic range compression and ",
 Cell["GeoRegionValuePlot", "InlineCode",ExpressionUUID->
  "c0807f66-d363-8549-8e73-66ae31c1ca44"],
 " for choropleth mapping."
}], "Item",ExpressionUUID->"49f30279-3987-7c45-a0ca-dbefbe5b2a57"],

Cell[TextData[{
 StyleBox["Urban heat islands",
  FontWeight->Bold],
 " measured via Landsat and MODIS thermal bands, quantified as the \
temperature differential between urban and rural reference areas using ",
 Cell["GEEReduceRegion", "InlineCode",ExpressionUUID->
  "e3fad0a3-e802-1249-8d29-e6db9a5999a3"],
 "."
}], "Item",ExpressionUUID->"068db5ab-862a-3240-b265-f8ebbe708d67"],

Cell[TextData[{
 StyleBox["Built-up area mapping",
  FontWeight->Bold],
 " through NDBI, ESA WorldCover classification, and the GHSL time series, \
with ",
 Cell["GEEEquals", "InlineCode",ExpressionUUID->
  "80107305-13ca-924e-ada3-83ddab31c42c"],
 ", ",
 Cell["GEEPixelArea", "InlineCode",ExpressionUUID->
  "ecb11d92-14a8-fb4a-a2b0-dc84742fd890"],
 ", and ",
 Cell["GEEReduceRegion", "InlineCode",ExpressionUUID->
  "bd1e7cdd-de7e-3046-9e66-e9ef15afecd9"],
 " for area computation."
}], "Item",ExpressionUUID->"eb93c613-f88b-af4f-9fe3-8def60277649"],

Cell[TextData[{
 StyleBox["Change detection",
  FontWeight->Bold],
 " using multi-temporal land cover comparison and NDVI differencing to \
identify urbanization fronts."
}], "Item",ExpressionUUID->"2574cea5-d918-7f44-b74e-e50a3ebfa54e"],

Cell[TextData[{
 StyleBox["Population estimation",
  FontWeight->Bold],
 " with WorldPop gridded data, validated against Wolfram's ",
 Cell["Entity", "InlineCode",ExpressionUUID->
  "cb209d44-d587-564c-9811-9eb6ce75d45e"],
 " framework and visualized with ",
 Cell["GeoBubbleChart", "InlineCode",ExpressionUUID->
  "7329796c-cb87-7848-9ae5-f89a9f9fb42c"],
 "."
}], "Item",ExpressionUUID->"a3f7e1ef-3b31-1540-ac10-38f12604e5a2"],

Cell[TextData[{
 StyleBox["Air quality monitoring",
  FontWeight->Bold],
 " via Sentinel-5P NO2 and MODIS AOD, including correlation analysis with \
nightlight intensity using ",
 Cell["GEEGetSamples", "InlineCode",ExpressionUUID->
  "bb2dc264-65f0-f341-8a96-ca33bc3d8173"],
 " and ",
 Cell["LinearModelFit", "InlineCode",ExpressionUUID->
  "dc54d541-9491-3747-8df8-bba1731845cf"],
 "."
}], "Item",ExpressionUUID->"cb88e8ad-69ad-5f46-8325-5fc53a7c85aa"],

Cell[TextData[{
 StyleBox["Infrastructure analysis",
  FontWeight->Bold],
 " through texture-based feature extraction with ",
 Cell["GEEEntropy", "InlineCode",ExpressionUUID->
  "a99d479e-9918-9f4c-96ba-db77fad57bfc"],
 " and vector queries via ",
 Cell["GEEComputeFeatures", "InlineCode",ExpressionUUID->
  "ef84f176-5b17-3647-814c-0260ad1e9ec9"],
 "."
}], "Item",ExpressionUUID->"e0c29971-4ca3-0d4f-b5d8-8d971eee5d5b"],

Cell[TextData[{
 StyleBox["Multi-city dashboards",
  FontWeight->Bold],
 " that synthesize multiple indicators into a single comparative ",
 Cell["Dataset", "InlineCode",ExpressionUUID->
  "4717ca18-5201-1c49-8a77-f3a871c6172c"],
 " with ",
 Cell["BarChart", "InlineCode",ExpressionUUID->
  "da44d51a-cd9b-f94a-9e89-7fc6df361a0f"],
 " visualizations."
}], "Item",ExpressionUUID->"8dd3fd96-9079-114c-a39e-1f1a5e5f3a52"],

Cell["\<\
These workflows are building blocks. A natural next step is to add temporal \
depth -- repeating the extraction for multiple years to construct time series \
of urban indicators -- or to scale the analysis to dozens or hundreds of \
cities for global comparative studies.\
\>", "Text",ExpressionUUID->"9d87e346-ee7e-0b41-a946-e0bcec5d0b29"],

Cell["", "Text",
 CellFrame->{{0, 0}, {0, 
  1}},ExpressionUUID->"088fed85-c7ad-9d4f-8458-e977205a4a07"],

Cell[TextData[{
 StyleBox["Next: ",
  FontSlant->Italic],
 StyleBox[ButtonBox["Chapter 8: Advanced Techniques and Wolfram Language \
Integration",
  BaseStyle->"Hyperlink",
  ButtonData->{
    URL["chapter-08-advanced-techniques.md"], None},
  ButtonNote->"chapter-08-advanced-techniques.md"],
  FontSlant->Italic]
}], "Text",ExpressionUUID->"2d9e39c5-bf43-264a-8fdf-0d3512881567"]
}, Open  ]]
}, Open  ]]
},
