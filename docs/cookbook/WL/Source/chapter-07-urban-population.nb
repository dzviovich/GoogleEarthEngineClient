}, Open  ]],

Cell[CellGroupData[{

Cell["7.5 Population and Demographics", "Chapter",ExpressionUUID->"858dd6db-66e6-7c49-8262-cea85ac46fb2"],

Cell["\<\
Gridded population datasets disaggregate census counts into continuous raster \
surfaces, enabling population estimates for arbitrary regions without relying \
on administrative boundary alignment.\
\>", "Text",ExpressionUUID->"5dcda558-b9e1-694a-a55f-7ed0789b5d73"],

Cell[CellGroupData[{

Cell["WorldPop Population Density", "Section",ExpressionUUID->"533f89d3-eb13-f84d-aff4-f2b3ab8d472e"],

Cell["\<\
WorldPop provides 100 m resolution population count grids. Because population \
density varies by orders of magnitude, logarithmic scaling is essential for \
meaningful visualization.\
\>", "Text",ExpressionUUID->"7470bc9f-6163-6b4b-a47c-bf595e015559"],

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"pop", " ", "=", " ", 
    RowBox[{
     RowBox[{
      RowBox[{
       RowBox[{
        RowBox[{"GEECollection", "[", "\"\<WorldPop/GP/100m/pop\>\"", "]"}], 
        " ", "//", "\n", "  ", 
        RowBox[{"GEEFilterDate", "[", 
         RowBox[{"\"\<2020-01-01\>\"", ",", " ", "\"\<2021-01-01\>\""}], 
         "]"}]}], " ", "//", "\n", "  ", 
       RowBox[{"GEEFilterBounds", "[", 
        RowBox[{"{", 
         RowBox[{"28.8", ",", " ", 
          RowBox[{"-", "2.0"}], ",", " ", "30.2", ",", " ", 
          RowBox[{"-", "1.0"}]}], "}"}], "]"}]}], " ", "//", "\n", "  ", 
      RowBox[{"GEESelectBands", "[", 
       RowBox[{"{", "\"\<population\>\"", "}"}], "]"}]}], " ", "//", "\n", 
     "  ", "GEEMosaic"}]}], ";"}], "\n"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"popLog", " ", "=", " ", 
    RowBox[{
     RowBox[{"pop", " ", "//", "\n", "  ", 
      RowBox[{"GEEAdd", "[", "1", "]"}]}], " ", "//", "     ", 
     RowBox[{"(*", " ", 
      RowBox[{"avoid", " ", "log", 
       RowBox[{"(", "0", ")"}]}], " ", "*)"}], "\n", "  ", "GEELog10"}]}], 
   ";"}], "\n"}], "\n", 
 RowBox[{"GEEImage", "[", "\n", "  ", 
  RowBox[{
   RowBox[{"GeoPosition", "[", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{"-", "1.95"}], ",", " ", "29.87"}], "}"}], "]"}], ",", "   ", 
   RowBox[{"(*", " ", 
    RowBox[{"Kigali", ",", " ", "Rwanda"}], " ", "*)"}], "\n", "  ", "popLog",
    ",", "\n", "  ", 
   RowBox[{"GeoRange", " ", "->", " ", 
    RowBox[{"Quantity", "[", 
     RowBox[{"30", ",", " ", "\"\<Kilometers\>\""}], "]"}]}], ",", "\n", "  ", 
   RowBox[{"RasterSize", " ", "->", " ", 
    RowBox[{"{", 
     RowBox[{"1024", ",", " ", "1024"}], "}"}]}], ",", "\n", "  ", 
   RowBox[{"\"\<VisParams\>\"", " ", "->", " ", 
    RowBox[{"<|", 
     RowBox[{
      RowBox[{"\"\<min\>\"", " ", "->", " ", "0"}], ",", " ", 
      RowBox[{"\"\<max\>\"", " ", "->", " ", "3"}], ",", "\n", "    ", 
      RowBox[{"\"\<palette\>\"", " ", "->", " ", 
       RowBox[{"{", 
        RowBox[{"\"\<#ffffcc\>\"", ",", " ", "\"\<#c2e699\>\"", ",", 
         " ", "\"\<#78c679\>\"", ",", "\n", "      ", "\"\<#238443\>\"", ",", 
         " ", "\"\<#004529\>\""}], "}"}]}]}], "|>"}]}]}], "\n", 
  "]"}]}], "Input",ExpressionUUID->"90efe6b4-93bd-af4e-a7ac-321bfa75fcb3"],

Cell["\<\
On this log10 scale, a value of 1 corresponds to 10 people per pixel, 2 to \
100, and 3 to 1000. The concentric density gradient from Kigali's center to \
its rural outskirts is immediately apparent.\
\>", "Text",ExpressionUUID->"42bc3f2b-8597-c54d-b402-b7624e0b10e4"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Estimate Population Within a Custom Polygon", "Section",ExpressionUUID->"b3d42f88-886f-5e44-854c-cf385460ebcb"],

Cell["\<\
Define an arbitrary region of interest and compute the total population by \
summing all pixels within it.\
\>", "Text",ExpressionUUID->"5bc75933-7da9-104f-a389-c8011fc99cfe"],

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{
   "Define", " ", "a", " ", "polygon", " ", "around", " ", "central", " ", 
    "Nairobi"}], " ", "*)"}], "\n", 
  RowBox[{
   RowBox[{
    RowBox[{"nairobiPoly", " ", "=", " ", 
     RowBox[{"GEEPolygon", "[", 
      RowBox[{"{", "\n", "  ", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{"36.75", ",", " ", 
          RowBox[{"-", "1.35"}]}], "}"}], ",", " ", 
        RowBox[{"{", 
         RowBox[{"36.90", ",", " ", 
          RowBox[{"-", "1.35"}]}], "}"}], ",", " ", 
        RowBox[{"{", 
         RowBox[{"36.90", ",", " ", 
          RowBox[{"-", "1.22"}]}], "}"}], ",", "\n", "  ", 
        RowBox[{"{", 
         RowBox[{"36.75", ",", " ", 
          RowBox[{"-", "1.22"}]}], "}"}], ",", " ", 
        RowBox[{"{", 
         RowBox[{"36.75", ",", " ", 
          RowBox[{"-", "1.35"}]}], "}"}]}], "\n", "}"}], "]"}]}], ";"}], "\n",
    "\n", 
   RowBox[{
    RowBox[{"pop", " ", "=", " ", 
     RowBox[{
      RowBox[{
       RowBox[{
        RowBox[{
         RowBox[{"GEECollection", "[", "\"\<WorldPop/GP/100m/pop\>\"", "]"}], 
         " ", "//", "\n", "  ", 
         RowBox[{"GEEFilterDate", "[", 
          RowBox[{"\"\<2020-01-01\>\"", ",", " ", "\"\<2021-01-01\>\""}], 
          "]"}]}], " ", "//", "\n", "  ", 
        RowBox[{"GEESelectBands", "[", 
         RowBox[{"{", "\"\<population\>\"", "}"}], "]"}]}], " ", "//", "\n", 
       "  ", "GEEMosaic"}], " ", "//", "\n", "  ", 
      RowBox[{"GEEClip", "[", "nairobiPoly", "]"}]}]}], ";"}], "\n", "\n", 
   RowBox[{
    RowBox[{"totalPop", " ", "=", " ", 
     RowBox[{"First", " ", "@", " ", 
      RowBox[{"Values", " ", "@", " ", 
       RowBox[{"GEECompute", "[", "\n", "  ", 
        RowBox[{"pop", " ", "//", " ", 
         RowBox[{"GEEReduceRegion", "[", 
          RowBox[{"nairobiPoly", ",", " ", "\"\<sum\>\"", ",", " ", "100"}], 
          "]"}]}], "\n", "]"}]}]}]}], ";"}], "\n", "\n", 
   RowBox[{"StringForm", "[", 
    RowBox[{"\"\<Estimated population within polygon: `` people\>\"", ",", 
     "\n", "  ", 
     RowBox[{"Round", "[", "totalPop", "]"}]}], "\n", "]"}]}]}]], "Input",Expr\
essionUUID->"0477234b-b277-cf44-a177-49a34ce192ad"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Wolfram Integration: Cross-Referencing with Entity Data", "Section",ExpressionUUID->"212f82ce-a78f-ef4c-a9d1-17dd67a9d1a2"],

Cell[TextData[{
 "Wolfram Language's built-in ",
 Cell["Entity", "InlineCode",ExpressionUUID->
  "f00d6544-541b-934c-a526-ae6dc4d58ec8"],
 " framework provides census-derived population figures. Comparing these with \
satellite-derived estimates helps validate gridded products and identify \
discrepancies."
}], "Text",ExpressionUUID->"17f931b9-0022-014c-b01e-50c687cb8715"],

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"citiesWL", " ", "=", " ", 
    RowBox[{"{", "\n", "  ", 
     RowBox[{
      RowBox[{"Entity", "[", 
       RowBox[{"\"\<City\>\"", ",", " ", 
        RowBox[{"{", 
         RowBox[{"\"\<Nairobi\>\"", ",", " ", "\"\<Nairobi\>\"", ",", 
          " ", "\"\<Kenya\>\""}], "}"}]}], "]"}], ",", "\n", "  ", 
      RowBox[{"Entity", "[", 
       RowBox[{"\"\<City\>\"", ",", " ", 
        RowBox[{"{", 
         RowBox[{"\"\<Lagos\>\"", ",", " ", "\"\<Lagos\>\"", ",", 
          " ", "\"\<Nigeria\>\""}], "}"}]}], "]"}], ",", "\n", "  ", 
      RowBox[{"Entity", "[", 
       RowBox[{"\"\<City\>\"", ",", " ", 
        RowBox[{"{", 
         RowBox[{"\"\<Kinshasa\>\"", ",", " ", "\"\<Kinshasa\>\"", ",", 
          " ", "\"\<DemocraticRepublicOfTheCongo\>\""}], "}"}]}], "]"}], ",", 
      "\n", "  ", 
      RowBox[{"Entity", "[", 
       RowBox[{"\"\<City\>\"", ",", " ", 
        RowBox[{"{", 
         RowBox[{"\"\<AddisAbaba\>\"", ",", " ", "\"\<AddisAbaba\>\"", ",", 
          " ", "\"\<Ethiopia\>\""}], "}"}]}], "]"}], ",", "\n", "  ", 
      RowBox[{"Entity", "[", 
       RowBox[{"\"\<City\>\"", ",", " ", 
        RowBox[{"{", 
         RowBox[{"\"\<Dar Es Salaam\>\"", ",", " ", "\"\<DarEsSalaam\>\"", ",",
           " ", "\"\<Tanzania\>\""}], "}"}]}], "]"}]}], "\n", "}"}]}], ";"}], 
  "\n"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"censusPop", " ", "=", " ", 
    RowBox[{"Map", "[", "\n", "  ", 
     RowBox[{
      RowBox[{
       RowBox[{"#", " ", "->", " ", 
        RowBox[{"#", "[", "\"\<Population\>\"", "]"}]}], " ", "&"}], ",", 
      "\n", "  ", "citiesWL"}], "\n", "]"}]}], ";"}], "\n"}], "\n", 
 RowBox[{"Dataset", "[", "censusPop", "]"}]}], "Input",ExpressionUUID->\
"6890fe83-d3f3-bd47-85a7-1438230b2bad"]
}, Open  ]],

Cell[CellGroupData[{

Cell["GeoBubbleChart for Multi-City Visualization", "Section",ExpressionUUID->"fb26624b-9bc1-e04e-aede-df3b06b1ddf9"],

Cell[TextData[{
 Cell["GeoBubbleChart", "InlineCode",ExpressionUUID->
  "d1111ec7-c12c-bf46-9949-b9656d9388a9"],
 " provides an intuitive way to display population or any scalar quantity at \
geographic locations, with bubble size proportional to the value."
}], "Text",ExpressionUUID->"3685a0a7-8e80-5a4b-b900-ce2850683d94"],

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"cityData", " ", "=", " ", 
    RowBox[{"{", "\n", "  ", 
     RowBox[{
      RowBox[{
       RowBox[{"GeoPosition", "[", 
        RowBox[{"{", 
         RowBox[{
          RowBox[{"-", "1.29"}], ",", " ", "36.82"}], "}"}], "]"}], "  ", "->",
        " ", 
       RowBox[{"4.4", " ", "*", " ", 
        RowBox[{"10", "^", "6"}]}]}], ",", "   ", 
      RowBox[{"(*", " ", "Nairobi", " ", "*)"}], "\n", "  ", 
      RowBox[{
       RowBox[{"GeoPosition", "[", 
        RowBox[{"{", 
         RowBox[{"6.52", ",", " ", "3.38"}], "}"}], "]"}], "    ", "->", " ", 
       RowBox[{"15.4", " ", "*", " ", 
        RowBox[{"10", "^", "6"}]}]}], ",", "   ", 
      RowBox[{"(*", " ", "Lagos", " ", "*)"}], "\n", "  ", 
      RowBox[{
       RowBox[{"GeoPosition", "[", 
        RowBox[{"{", 
         RowBox[{
          RowBox[{"-", "4.32"}], ",", " ", "15.31"}], "}"}], "]"}], "  ", "->",
        " ", 
       RowBox[{"17.1", " ", "*", " ", 
        RowBox[{"10", "^", "6"}]}]}], ",", "   ", 
      RowBox[{"(*", " ", "Kinshasa", " ", "*)"}], "\n", "  ", 
      RowBox[{
       RowBox[{"GeoPosition", "[", 
        RowBox[{"{", 
         RowBox[{"9.02", ",", " ", "38.75"}], "}"}], "]"}], "   ", "->", " ", 
       RowBox[{"5.4", " ", "*", " ", 
        RowBox[{"10", "^", "6"}]}]}], ",", "    ", 
      RowBox[{"(*", " ", 
       RowBox[{"Addis", " ", "Ababa"}], " ", "*)"}], "\n", "  ", 
      RowBox[{
       RowBox[{"GeoPosition", "[", 
        RowBox[{"{", 
         RowBox[{
          RowBox[{"-", "6.79"}], ",", " ", "39.28"}], "}"}], "]"}], "  ", "->",
        " ", 
       RowBox[{"7.4", " ", "*", " ", 
        RowBox[{"10", "^", "6"}]}]}]}], "     ", 
     RowBox[{"(*", " ", 
      RowBox[{"Dar", " ", "es", " ", "Salaam"}], " ", "*)"}], "\n", "}"}]}], 
   ";"}], "\n"}], "\n", 
 RowBox[{"GeoBubbleChart", "[", 
  RowBox[{"cityData", ",", "\n", "  ", 
   RowBox[{
   "PlotLabel", " ", "->", 
    " ", "\"\<Major African Cities by Population\>\""}], ",", "\n", "  ", 
   RowBox[{"GeoRange", " ", "->", " ", "\"\<Africa\>\""}], ",", "\n", "  ", 
   RowBox[{"BubbleSizes", " ", "->", " ", 
    RowBox[{"{", 
     RowBox[{"0.02", ",", " ", "0.08"}], "}"}]}], ",", "\n", "  ", 
   RowBox[{"ChartStyle", " ", "->", " ", "\"\<DarkRainbow\>\""}]}], "\n", 
  "]"}]}], "Input",ExpressionUUID->"947c8956-1ade-2f43-91b9-f5e7ffde9943"],

Cell["", "Text",
 CellFrame->{{0, 0}, {0, 
  1}},ExpressionUUID->"734b625d-1485-7045-9efd-3abd0c3098c7"]
}, Open  ]]
}, Open  ]],

Cell[CellGroupData[{

Cell["7.6 Air Quality and Pollution", "Chapter",ExpressionUUID->"d16745e2-3a18-d94c-af51-7b78f729966e"],

Cell["\<\
Urban pollution is both a consequence of dense economic activity and a major \
public health concern. Satellite instruments now provide daily global maps of \
key pollutants, enabling analysis that was impossible with ground station \
networks alone.\
\>", "Text",ExpressionUUID->"55d00f82-e426-7546-9c2b-2e62d8a3f929"],

Cell[CellGroupData[{

Cell["Sentinel-5P TROPOMI: Nitrogen Dioxide", "Section",ExpressionUUID->"d09cb707-78a9-c849-a83f-111d51f3d3c4"],

Cell["\<\
The TROPOspheric Monitoring Instrument (TROPOMI) on Sentinel-5P measures \
tropospheric NO2 column density, a primary indicator of combustion-related \
air pollution from vehicles, power plants, and industry.\
\>", "Text",ExpressionUUID->"e97a2138-ad97-474f-82bc-26326fec3eef"],

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"no2", " ", "=", " ", 
    RowBox[{
     RowBox[{
      RowBox[{
       RowBox[{
        RowBox[{
        "GEECollection", "[", "\"\<COPERNICUS/S5P/OFFL/L3_NO2\>\"", "]"}], 
        " ", "//", "\n", "  ", 
        RowBox[{"GEEFilterDate", "[", 
         RowBox[{"\"\<2024-01-01\>\"", ",", " ", "\"\<2024-04-01\>\""}], 
         "]"}]}], " ", "//", "\n", "  ", 
       RowBox[{"GEEFilterBounds", "[", 
        RowBox[{"{", 
         RowBox[{
         "112.5", ",", " ", "22.0", ",", " ", "114.5", ",", " ", "23.5"}], 
         "}"}], "]"}]}], " ", "//", "\n", "  ", 
      RowBox[{"GEESelectBands", "[", 
       RowBox[{"{", "\"\<tropospheric_NO2_column_number_density\>\"", "}"}], 
       "]"}]}], " ", "//", "\n", "  ", "GEEMean"}]}], ";"}], "\n"}], "\n", 
 RowBox[{"GEEImage", "[", "\n", "  ", 
  RowBox[{
   RowBox[{"GeoPosition", "[", 
    RowBox[{"{", 
     RowBox[{"23.0", ",", " ", "113.3"}], "}"}], "]"}], ",", "   ", 
   RowBox[{"(*", " ", 
    RowBox[{"Pearl", " ", "River", " ", "Delta"}], " ", "*)"}], "\n", "  ", 
   "no2", ",", "\n", "  ", 
   RowBox[{"GeoRange", " ", "->", " ", 
    RowBox[{"Quantity", "[", 
     RowBox[{"100", ",", " ", "\"\<Kilometers\>\""}], "]"}]}], ",", "\n", 
   "  ", 
   RowBox[{"RasterSize", " ", "->", " ", 
    RowBox[{"{", 
     RowBox[{"1024", ",", " ", "1024"}], "}"}]}], ",", "\n", "  ", 
   RowBox[{"\"\<VisParams\>\"", " ", "->", " ", 
    RowBox[{"<|", "\n", "    ", 
     RowBox[{
      RowBox[{"\"\<min\>\"", " ", "->", " ", "0"}], ",", " ", 
      RowBox[{"\"\<max\>\"", " ", "->", " ", "0.0002"}], ",", "\n", "    ", 
      RowBox[{"\"\<palette\>\"", " ", "->", " ", 
       RowBox[{"{", 
        RowBox[{"\"\<#ffffb2\>\"", ",", " ", "\"\<#fecc5c\>\"", ",", 
         " ", "\"\<#fd8d3c\>\"", ",", "\n", "      ", "\"\<#f03b20\>\"", ",", 
         " ", "\"\<#bd0026\>\""}], "}"}]}]}], "|>"}]}]}], "\n", 
  "]"}]}], "Input",ExpressionUUID->"a3ab7e23-ab46-654c-97c5-9fa34c2ed838"],

Cell["\<\
The Pearl River Delta -- encompassing Guangzhou, Shenzhen, Dongguan, and Hong \
Kong -- is one of the world's most industrialized regions. The NO2 map \
reveals pollution hotspots centered on industrial zones and major highway \
corridors.\
\>", "Text",ExpressionUUID->"0d47a45d-493e-5547-8c83-4c16b2a97c06"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Aerosol Optical Depth from MODIS", "Section",ExpressionUUID->"2af1a46a-f7ce-324d-9dfc-50f1a87cc569"],

Cell[TextData[{
 "Aerosol Optical Depth (AOD) measures the extinction of sunlight by \
atmospheric particulates. MODIS provides daily AOD at 1 km resolution through \
the ",
 Cell["MODIS/061/MCD19A2_GRANULES", "InlineCode",ExpressionUUID->
  "6c9ba904-bb0b-0345-8382-2924da83f7f9"],
 " product."
}], "Text",ExpressionUUID->"e95f64fe-d6f0-404d-bc9e-dbf30911d4c7"],

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"aod", " ", "=", " ", 
    RowBox[{
     RowBox[{
      RowBox[{
       RowBox[{
        RowBox[{
         RowBox[{
         "GEECollection", "[", "\"\<MODIS/061/MCD19A2_GRANULES\>\"", "]"}], 
         " ", "//", "\n", "  ", 
         RowBox[{"GEEFilterDate", "[", 
          RowBox[{"\"\<2024-01-01\>\"", ",", " ", "\"\<2024-04-01\>\""}], 
          "]"}]}], " ", "//", "\n", "  ", 
        RowBox[{"GEEFilterBounds", "[", 
         RowBox[{"{", 
          RowBox[{
          "76.8", ",", " ", "28.3", ",", " ", "77.5", ",", " ", "28.9"}], 
          "}"}], "]"}]}], " ", "//", "\n", "  ", 
       RowBox[{"GEESelectBands", "[", 
        RowBox[{"{", "\"\<Optical_Depth_047\>\"", "}"}], "]"}]}], " ", "//", 
      "\n", "  ", "GEEMean"}], " ", "//", "\n", "  ", 
     RowBox[{"GEEMultiply", "[", "0.001", "]"}]}]}], ";"}], "   ", 
  RowBox[{"(*", " ", 
   RowBox[{"scale", " ", "factor"}], " ", "*)"}], "\n"}], "\n", 
 RowBox[{"GEEImage", "[", "\n", "  ", 
  RowBox[{
   RowBox[{"Entity", "[", 
    RowBox[{"\"\<City\>\"", ",", " ", 
     RowBox[{"{", 
      RowBox[{"\"\<NewDelhi\>\"", ",", " ", "\"\<Delhi\>\"", ",", 
       " ", "\"\<India\>\""}], "}"}]}], "]"}], ",", "\n", "  ", "aod", ",", 
   "\n", "  ", 
   RowBox[{"GeoRange", " ", "->", " ", 
    RowBox[{"Quantity", "[", 
     RowBox[{"40", ",", " ", "\"\<Kilometers\>\""}], "]"}]}], ",", "\n", "  ", 
   RowBox[{"RasterSize", " ", "->", " ", 
    RowBox[{"{", 
     RowBox[{"512", ",", " ", "512"}], "}"}]}], ",", "\n", "  ", 
   RowBox[{"\"\<VisParams\>\"", " ", "->", " ", 
    RowBox[{"<|", 
     RowBox[{
      RowBox[{"\"\<min\>\"", " ", "->", " ", "0"}], ",", " ", 
      RowBox[{"\"\<max\>\"", " ", "->", " ", "1.5"}], ",", "\n", "    ", 
      RowBox[{"\"\<palette\>\"", " ", "->", " ", 
       RowBox[{"{", 
        RowBox[{"\"\<#00ff00\>\"", ",", " ", "\"\<#ffff00\>\"", ",", 
         " ", "\"\<#ff0000\>\"", ",", " ", "\"\<#800000\>\""}], "}"}]}]}], 
     "|>"}]}]}], "\n", "]"}]}], "Input",ExpressionUUID->"dc517cee-f0ef-6445-\
acd6-dcde454428b4"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Correlating Nightlights with NO2 Pollution", "Section",ExpressionUUID->"dfefc96b-f55c-074a-a065-6669ba71ee87"],

Cell["\<\
A scientifically interesting question: does nighttime light intensity predict \
NO2 pollution? Extracting both quantities at the same set of locations \
enables a scatter plot and regression analysis.\
\>", "Text",ExpressionUUID->"94574f3e-834e-5144-9fbc-98272ee59698"],

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{
   "Define", " ", "sample", " ", "points", " ", "across", " ", "a", " ", 
    "metropolitan", " ", "region"}], " ", "*)"}], "\n", 
  RowBox[{
   RowBox[{
    RowBox[{"samplePoints", " ", "=", " ", 
     RowBox[{
      RowBox[{"Table", "[", "\n", "  ", 
       RowBox[{
        RowBox[{"GeoPosition", "[", 
         RowBox[{"{", 
          RowBox[{"lat", ",", " ", "lon"}], "}"}], "]"}], ",", "\n", "  ", 
        RowBox[{"{", 
         RowBox[{
         "lat", ",", " ", "40.5", ",", " ", "41.0", ",", " ", "0.05"}], "}"}],
         ",", "\n", "  ", 
        RowBox[{"{", 
         RowBox[{"lon", ",", " ", 
          RowBox[{"-", "74.2"}], ",", " ", 
          RowBox[{"-", "73.7"}], ",", " ", "0.05"}], "}"}]}], "\n", "]"}], 
      " ", "//", " ", "Flatten"}]}], ";"}], "\n", "\n", 
   RowBox[{"(*", " ", 
    RowBox[{"Build", " ", "VIIRS", " ", "composite"}], " ", "*)"}], "\n", 
   RowBox[{
    RowBox[{"viirs", " ", "=", " ", 
     RowBox[{
      RowBox[{
       RowBox[{
        RowBox[{
         RowBox[{
         "GEECollection", "[", "\"\<NOAA/VIIRS/DNB/MONTHLY_V1/VCMSLCFG\>\"", 
          "]"}], " ", "//", "\n", "  ", 
         RowBox[{"GEEFilterDate", "[", 
          RowBox[{"\"\<2024-01-01\>\"", ",", " ", "\"\<2024-07-01\>\""}], 
          "]"}]}], " ", "//", "\n", "  ", 
        RowBox[{"GEEFilterBounds", "[", 
         RowBox[{"{", 
          RowBox[{
           RowBox[{"-", "74.3"}], ",", " ", "40.4", ",", " ", 
           RowBox[{"-", "73.6"}], ",", " ", "41.1"}], "}"}], "]"}]}], " ", "//",
        "\n", "  ", 
       RowBox[{"GEESelectBands", "[", 
        RowBox[{"{", "\"\<avg_rad\>\"", "}"}], "]"}]}], " ", "//", "\n", "  ",
       "GEEMedian"}]}], ";"}], "\n", "\n", 
   RowBox[{"(*", " ", 
    RowBox[{"Build", " ", "NO2", " ", "composite"}], " ", "*)"}], "\n", 
   RowBox[{
    RowBox[{"no2", " ", "=", " ", 
     RowBox[{
      RowBox[{
       RowBox[{
        RowBox[{
         RowBox[{
         "GEECollection", "[", "\"\<COPERNICUS/S5P/OFFL/L3_NO2\>\"", "]"}], 
         " ", "//", "\n", "  ", 
         RowBox[{"GEEFilterDate", "[", 
          RowBox[{"\"\<2024-01-01\>\"", ",", " ", "\"\<2024-07-01\>\""}], 
          "]"}]}], " ", "//", "\n", "  ", 
        RowBox[{"GEEFilterBounds", "[", 
         RowBox[{"{", 
          RowBox[{
           RowBox[{"-", "74.3"}], ",", " ", "40.4", ",", " ", 
           RowBox[{"-", "73.6"}], ",", " ", "41.1"}], "}"}], "]"}]}], " ", "//",
        "\n", "  ", 
       RowBox[{"GEESelectBands", "[", 
        RowBox[{"{", "\"\<tropospheric_NO2_column_number_density\>\"", "}"}], 
        "]"}]}], " ", "//", "\n", "  ", "GEEMean"}]}], ";"}], "\n", "\n", 
   RowBox[{"(*", " ", 
    RowBox[{
    "Sample", " ", "both", " ", "datasets", " ", "at", " ", "the", " ", 
     "same", " ", "points"}], " ", "*)"}], "\n", 
   RowBox[{
    RowBox[{"lightSamples", " ", "=", " ", 
     RowBox[{"GEEGetSamples", "[", 
      RowBox[{"samplePoints", ",", " ", "viirs"}], "]"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"no2Samples", " ", "=", " ", 
     RowBox[{"GEEGetSamples", "[", 
      RowBox[{"samplePoints", ",", " ", "no2"}], "]"}]}], ";"}], "\n", "\n", 
   RowBox[{"(*", " ", 
    RowBox[{"Extract", " ", "numeric", " ", "values"}], " ", "*)"}], "\n", 
   RowBox[{
    RowBox[{"lightVals", " ", "=", " ", 
     RowBox[{"Map", "[", 
      RowBox[{
       RowBox[{
        RowBox[{"First", " ", "@", " ", 
         RowBox[{"Values", " ", "@", " ", 
          RowBox[{"#", "[", "\"\<Values\>\"", "]"}]}]}], " ", "&"}], ",", " ",
        "lightSamples"}], "]"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"no2Vals", " ", "=", " ", 
     RowBox[{"Map", "[", 
      RowBox[{
       RowBox[{
        RowBox[{"First", " ", "@", " ", 
         RowBox[{"Values", " ", "@", " ", 
          RowBox[{"#", "[", "\"\<Values\>\"", "]"}]}]}], " ", "&"}], ",", " ",
        "no2Samples"}], "]"}]}], ";"}], "\n", "\n", 
   RowBox[{
    RowBox[{"pairs", " ", "=", " ", 
     RowBox[{"Select", "[", "\n", "  ", 
      RowBox[{
       RowBox[{"Transpose", "[", 
        RowBox[{"{", 
         RowBox[{"lightVals", ",", " ", "no2Vals"}], "}"}], "]"}], ",", "\n", 
       "  ", 
       RowBox[{"AllTrue", "[", "NumericQ", "]"}]}], "   ", 
      RowBox[{"(*", " ", 
       RowBox[{
        RowBox[{"remove", " ", "any", " ", "missing"}], "-", 
        RowBox[{"data", " ", "points"}]}], " ", "*)"}], "\n", "]"}]}], ";"}], 
   "\n", "\n", 
   RowBox[{"(*", " ", 
    RowBox[{"Scatter", " ", "plot", " ", "with", " ", "linear", " ", "fit"}], 
    " ", "*)"}], "\n", 
   RowBox[{
    RowBox[{"fit", " ", "=", " ", 
     RowBox[{"LinearModelFit", "[", 
      RowBox[{"pairs", ",", " ", "x", ",", " ", "x"}], "]"}]}], ";"}], "\n", "\n", 
   RowBox[{"Show", "[", "\n", "  ", 
    RowBox[{
     RowBox[{"ListPlot", "[", 
      RowBox[{"pairs", ",", "\n", "    ", 
       RowBox[{"AxesLabel", " ", "->", " ", 
        RowBox[{"{", 
         RowBox[{"\"\<Nightlight Radiance (nW/cm2/sr)\>\"", ",", "\n", 
          "      ", "\"\<NO2 Column Density (mol/m2)\>\""}], "}"}]}], ",", 
       "\n", "    ", 
       RowBox[{
       "PlotLabel", " ", "->", 
        " ", "\"\<Nightlight vs NO2: New York Metro\>\""}], ",", "\n", "    ", 
       RowBox[{"PlotStyle", " ", "->", " ", 
        RowBox[{"PointSize", "[", "0.015", "]"}]}]}], "]"}], ",", "\n", "  ", 
     RowBox[{"Plot", "[", 
      RowBox[{
       RowBox[{"fit", "[", "x", "]"}], ",", " ", 
       RowBox[{"{", 
        RowBox[{"x", ",", " ", 
         RowBox[{"Min", "[", 
          RowBox[{"pairs", "[", 
           RowBox[{"[", 
            RowBox[{"All", ",", " ", "1"}], "]"}], "]"}], "]"}], ",", " ", 
         RowBox[{"Max", "[", 
          RowBox[{"pairs", "[", 
           RowBox[{"[", 
            RowBox[{"All", ",", " ", "1"}], "]"}], "]"}], "]"}]}], "}"}], ",",
        "\n", "    ", 
       RowBox[{"PlotStyle", " ", "->", " ", 
        RowBox[{"{", 
         RowBox[{"Red", ",", " ", "Thick"}], "}"}]}]}], "]"}]}], "\n", "]"}], 
   "\n", "\n", 
   RowBox[{"(*", " ", 
    RowBox[{
     RowBox[{"Report", " ", "R"}], "-", "squared"}], " ", "*)"}], "\n", 
   RowBox[{"fit", "[", "\"\<RSquared\>\"", "]"}]}]}]], "Input",ExpressionUUID->\
"f502abb8-e5c4-9d4b-8007-979c8c76c2f0"],

Cell["\<\
A positive correlation is generally expected, though the strength depends on \
the mix of residential versus industrial lighting in the study area.\
\>", "Text",ExpressionUUID->"97bbaeb5-4676-9646-8a06-5c5bc55aa5f1"],

