Cell[CellGroupData[{
Cell["Chapter 7: Urban and Population Analysis", "Title",ExpressionUUID->"5c8e95fa-67ef-e94f-9145-a2af8eb44863"],

Cell["\<\
Cities occupy less than 3% of the Earth's land surface yet account for over \
70% of global energy consumption and CO2 emissions. Understanding where and \
how cities grow is therefore central to climate adaptation, infrastructure \
planning, and public health. Satellite remote sensing provides a unique \
vantage point for studying urbanization: nighttime lights reveal economic \
activity, thermal sensors expose heat islands, and multispectral imagery \
tracks the physical expansion of impervious surfaces. This chapter \
demonstrates how to combine Google Earth Engine datasets with Wolfram \
Language analysis tools to quantify and visualize urban phenomena at scales \
ranging from a single neighborhood to a multi-city global comparison.\
\>", "Text",ExpressionUUID->"b9043b68-17e9-f14e-befb-8ea1905d5c27"],

Cell[TextData[{
 StyleBox["Prerequisite:",
  FontWeight->Bold],
 " Authenticate per Section 1.3 and load the paclet with ",
 Cell["Needs[\"GoogleEarthEngineClient`\"]", "InlineCode",ExpressionUUID->
  "437a67da-08c4-4e42-b8bd-a1946fa54988"],
 "."
}], "Text",ExpressionUUID->"fd609d81-1643-ea40-947b-d34a2dac74b4"],

Cell["", "Text",
 CellFrame->{{0, 0}, {0, 
  1}},ExpressionUUID->"25650ee8-ded9-3948-a7de-2f5261731a34"],

Cell[CellGroupData[{

Cell["7.1 Nighttime Lights", "Chapter",ExpressionUUID->"cff4917e-5cc3-0f4b-a5b5-4730a92abf4d"],

Cell["\<\
Nighttime light emissions are among the most direct satellite-observable \
proxies for human economic activity. Brighter lights generally correlate with \
higher population density, greater GDP, and more developed infrastructure. \
Two complementary datasets provide coverage from 1992 to the present.\
\>", "Text",ExpressionUUID->"f745e8e7-afd9-f042-add9-8125b214e35c"],

Cell[CellGroupData[{

Cell["VIIRS Monthly Nighttime Lights", "Section",ExpressionUUID->"906c0056-1b5e-e146-a302-acc77d3be43d"],

Cell[TextData[{
 "The Visible Infrared Imaging Radiometer Suite (VIIRS) Day/Night Band \
produces monthly composites of nighttime radiance. The native sensor \
resolution is approximately 750 m, but the GEE product is gridded at \
approximately 500 m. The ",
 Cell["avg_rad", "InlineCode",ExpressionUUID->
  "01c438fb-3356-004d-b7b2-75324b539900"],
 " band reports average radiance in nanowatts per square centimeter per \
steradian (nW/cm2/sr)."
}], "Text",ExpressionUUID->"0db81222-1e31-1d47-849c-0371131886e6"],

Cell[TextData[StyleBox["Nightlight map of the Tokyo metropolitan area:",
 FontWeight->Bold]], "Text",ExpressionUUID->"785301cf-259f-344f-aadd-\
6c8999567e46"],

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"tokyoLights", " ", "=", " ", 
    RowBox[{
     RowBox[{
      RowBox[{
       RowBox[{
        RowBox[{
        "GEECollection", "[", "\"\<NOAA/VIIRS/DNB/MONTHLY_V1/VCMSLCFG\>\"", 
         "]"}], " ", "//", "\n", "  ", 
        RowBox[{"GEEFilterDate", "[", 
         RowBox[{"\"\<2024-01-01\>\"", ",", " ", "\"\<2024-07-01\>\""}], 
         "]"}]}], " ", "//", "\n", "  ", 
       RowBox[{"GEEFilterBounds", "[", 
        RowBox[{"{", 
         RowBox[{
         "139.5", ",", " ", "35.4", ",", " ", "140.1", ",", " ", "35.9"}], 
         "}"}], "]"}]}], " ", "//", "\n", "  ", 
      RowBox[{"GEESelectBands", "[", 
       RowBox[{"{", "\"\<avg_rad\>\"", "}"}], "]"}]}], " ", "//", "\n", "  ", 
     "GEEMedian"}]}], ";"}], "\n"}], "\n", 
 RowBox[{"GEEImage", "[", "\n", "  ", 
  RowBox[{
   RowBox[{"Entity", "[", 
    RowBox[{"\"\<City\>\"", ",", " ", 
     RowBox[{"{", 
      RowBox[{"\"\<Tokyo\>\"", ",", " ", "\"\<Tokyo\>\"", ",", 
       " ", "\"\<Japan\>\""}], "}"}]}], "]"}], ",", "\n", "  ", "tokyoLights",
    ",", "\n", "  ", 
   RowBox[{"GeoRange", " ", "->", " ", 
    RowBox[{"Quantity", "[", 
     RowBox[{"60", ",", " ", "\"\<Kilometers\>\""}], "]"}]}], ",", "\n", "  ", 
   RowBox[{"RasterSize", " ", "->", " ", 
    RowBox[{"{", 
     RowBox[{"1024", ",", " ", "1024"}], "}"}]}], ",", "\n", "  ", 
   RowBox[{"\"\<VisParams\>\"", " ", "->", " ", 
    RowBox[{"<|", 
     RowBox[{
      RowBox[{"\"\<min\>\"", " ", "->", " ", "0"}], ",", " ", 
      RowBox[{"\"\<max\>\"", " ", "->", " ", "80"}], ",", "\n", "    ", 
      RowBox[{"\"\<palette\>\"", " ", "->", " ", 
       RowBox[{"{", 
        RowBox[{"\"\<#000000\>\"", ",", " ", "\"\<#0d0887\>\"", ",", 
         " ", "\"\<#7e03a8\>\"", ",", "\n", "      ", "\"\<#cc4778\>\"", ",", 
         " ", "\"\<#f89540\>\"", ",", " ", "\"\<#f0f921\>\""}], "}"}]}]}], 
     "|>"}]}]}], "\n", "]"}]}], "Input",ExpressionUUID->"4c60d0cc-5832-6740-\
afa9-73906e7a35b4"],

Cell["\<\
The palette runs from black (no light) through purple and orange to bright \
yellow, giving a sense of the radiance gradient from rural periphery to the \
dense urban core. The median composite over six months reduces noise from \
cloud contamination and transient light sources.\
\>", "Text",ExpressionUUID->"5480e5f7-9fa5-0741-a6f2-7d739ef29229"],

Cell[TextData[StyleBox["Compare nightlight radiance across multiple cities:",
 FontWeight->Bold]], "Text",ExpressionUUID->"a29cd7e8-63b5-b34e-88bf-\
91bb9342741a"],

Cell[TextData[{
 "To quantify differences between cities, extract the mean radiance over each \
urban footprint with ",
 Cell["GEEReduceRegion", "InlineCode",ExpressionUUID->
  "e65562e0-c469-f14b-a45f-d436d1f93c55"],
 " and compile results into a ",
 Cell["Dataset", "InlineCode",ExpressionUUID->
  "b0455353-e5a3-ac4e-b691-4660618629a0"],
 "."
}], "Text",ExpressionUUID->"6c1da732-09d0-1846-9021-c88749cbb3b4"],

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"cities", " ", "=", " ", 
    RowBox[{"<|", "\n", "  ", 
     RowBox[{
      RowBox[{"\"\<Tokyo\>\"", "    ", "->", " ", 
       RowBox[{"{", 
        RowBox[{
        "139.5", ",", " ", "35.5", ",", " ", "140.0", ",", " ", "35.85"}], 
        "}"}]}], ",", "\n", "  ", 
      RowBox[{"\"\<New York\>\"", " ", "->", " ", 
       RowBox[{"{", 
        RowBox[{
         RowBox[{"-", "74.1"}], ",", " ", "40.6", ",", " ", 
         RowBox[{"-", "73.7"}], ",", " ", "40.9"}], "}"}]}], ",", "\n", "  ", 
      RowBox[{"\"\<London\>\"", "   ", "->", " ", 
       RowBox[{"{", 
        RowBox[{
         RowBox[{"-", "0.3"}], ",", " ", "51.35", ",", " ", "0.1", ",", " ", 
         "51.6"}], "}"}]}], ",", "\n", "  ", 
      RowBox[{"\"\<Mumbai\>\"", "   ", "->", " ", 
       RowBox[{"{", 
        RowBox[{
        "72.75", ",", " ", "18.9", ",", " ", "73.05", ",", " ", "19.2"}], 
        "}"}]}], ",", "\n", "  ", 
      RowBox[{"\"\<Lagos\>\"", "    ", "->", " ", 
       RowBox[{"{", 
        RowBox[{"3.2", ",", " ", "6.35", ",", " ", "3.55", ",", " ", "6.65"}],
         "}"}]}]}], "\n", "|>"}]}], ";"}], "\n"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"viirs", " ", "=", " ", 
    RowBox[{
     RowBox[{
      RowBox[{
       RowBox[{
       "GEECollection", "[", "\"\<NOAA/VIIRS/DNB/MONTHLY_V1/VCMSLCFG\>\"", 
        "]"}], " ", "//", "\n", "  ", 
       RowBox[{"GEEFilterDate", "[", 
        RowBox[{"\"\<2024-01-01\>\"", ",", " ", "\"\<2024-07-01\>\""}], 
        "]"}]}], " ", "//", "\n", "  ", 
      RowBox[{"GEESelectBands", "[", 
       RowBox[{"{", "\"\<avg_rad\>\"", "}"}], "]"}]}], " ", "//", "\n", "  ", 
     "GEEMedian"}]}], ";"}], "\n"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"radiance", " ", "=", " ", 
    RowBox[{"Association", " ", "@", " ", 
     RowBox[{"KeyValueMap", "[", "\n", "  ", 
      RowBox[{
       RowBox[{"Function", "[", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{"name", ",", " ", "bbox"}], "}"}], ",", "\n", "    ", 
         RowBox[{"name", " ", "->", " ", 
          RowBox[{"First", " ", "@", " ", 
           RowBox[{"Values", " ", "@", " ", 
            RowBox[{"GEECompute", "[", "\n", "      ", 
             RowBox[{"viirs", " ", "//", " ", 
              RowBox[{"GEEReduceRegion", "[", 
               RowBox[{
                RowBox[{"GEEGeometry", "[", "bbox", "]"}], ",", 
                " ", "\"\<mean\>\"", ",", " ", "500"}], "]"}]}], "\n", "    ",
              "]"}]}]}]}]}], "\n", "  ", "]"}], ",", "\n", "  ", "cities"}], 
      "\n", "]"}]}]}], ";"}], "\n"}], "\n", 
 RowBox[{"BarChart", "[", "\n", "  ", 
  RowBox[{
   RowBox[{"Values", "[", "radiance", "]"}], ",", "\n", "  ", 
   RowBox[{"ChartLabels", " ", "->", " ", 
    RowBox[{"Keys", "[", "radiance", "]"}]}], ",", "\n", "  ", 
   RowBox[{"AxesLabel", " ", "->", " ", 
    RowBox[{"{", 
     RowBox[{
     "None", ",", " ", "\"\<Mean Radiance (nW/cm\[ThinSpace]2/sr)\>\""}], 
     "}"}]}], ",", "\n", "  ", 
   RowBox[{
   "PlotLabel", " ", "->", 
    " ", "\"\<VIIRS Mean Nightlight Radiance (Jan-Jun 2024)\>\""}], ",", "\n",
    "  ", 
   RowBox[{"ChartStyle", " ", "->", " ", "\"\<DarkRainbow\>\""}]}], "\n", 
  "]"}]}], "Input",ExpressionUUID->"c66d3f97-547d-e64d-966b-b4edf5e28ac6"],

Cell["\<\
The resulting bar chart provides an immediate visual comparison. Cities like \
Tokyo and New York typically show significantly higher radiance than rapidly \
growing cities like Lagos, where large portions of the metropolitan area \
still lack continuous electrification.\
\>", "Text",ExpressionUUID->"0eaeece8-7210-d44d-8f74-4b89d8501844"]
}, Open  ]],

Cell[CellGroupData[{

Cell["DMSP-OLS Historical Nightlights (1992--2013)", "Section",ExpressionUUID->"c339b3c5-4f1c-6841-8189-9ecea6a82755"],

Cell[TextData[{
 "For long-term urbanization studies, the DMSP-OLS (Defense Meteorological \
Satellite Program) nightlights dataset provides annual composites spanning \
over two decades. The ",
 Cell["stable_lights", "InlineCode",ExpressionUUID->
  "4acc075e-e399-cb4c-b8e9-a140cc819c3b"],
 " band contains a 0--63 digital number representing relative light intensity."
}], "Text",ExpressionUUID->"f5168e74-127f-fb41-8f80-e92139519509"],

Cell[TextData[StyleBox["Track urbanization growth in Shenzhen over two \
decades:",
 FontWeight->Bold]], "Text",ExpressionUUID->"c1e957d2-b633-bb4e-a51d-\
355f8d8e4f42"],

Cell["\<\
Shenzhen transformed from a small town to a megacity in a single generation. \
DMSP nightlights capture this expansion.\
\>", "Text",ExpressionUUID->"dca1100c-3e56-4346-8058-cf9ff49d1db6"],

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"years", " ", "=", " ", 
    RowBox[{"{", 
     RowBox[{"1992", ",", " ", "2002", ",", " ", "2013"}], "}"}]}], ";"}], 
  "\n"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"shenzhenBBox", " ", "=", " ", 
    RowBox[{"{", 
     RowBox[{"113.7", ",", " ", "22.4", ",", " ", "114.4", ",", " ", "22.7"}],
      "}"}]}], ";"}], "\n"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"images", " ", "=", " ", 
    RowBox[{"Association", " ", "@", " ", 
     RowBox[{"Map", "[", "\n", "  ", 
      RowBox[{
       RowBox[{"Function", "[", 
        RowBox[{"year", ",", "\n", "    ", 
         RowBox[{"year", " ", "->", " ", 
          RowBox[{"(", "\n", "      ", 
           RowBox[{
            RowBox[{
             RowBox[{
              RowBox[{
              "GEECollection", "[", "\"\<NOAA/DMSP-OLS/NIGHTTIME_LIGHTS\>\"", 
               "]"}], " ", "//", "\n", "        ", 
              RowBox[{"GEEFilterDate", "[", "\n", "          ", 
               RowBox[{
                RowBox[{"DateString", "[", 
                 RowBox[{
                  RowBox[{"{", 
                   RowBox[{"year", ",", " ", "1", ",", " ", "1"}], "}"}], ",",
                   " ", "\"\<ISODate\>\""}], "]"}], ",", "\n", "          ", 
                RowBox[{"DateString", "[", 
                 RowBox[{
                  RowBox[{"{", 
                   RowBox[{
                    RowBox[{"year", " ", "+", " ", "1"}], ",", " ", "1", ",", 
                    " ", "1"}], "}"}], ",", " ", "\"\<ISODate\>\""}], "]"}]}],
                "]"}]}], " ", "//", "\n", "        ", 
             RowBox[{"GEESelectBands", "[", 
              RowBox[{"{", "\"\<stable_lights\>\"", "}"}], "]"}]}], " ", "//",
             "\n", "        ", "GEEMedian"}], "\n", "    ", ")"}]}]}], "\n", 
        "  ", "]"}], ",", "\n", "  ", "years"}], "\n", "]"}]}]}], ";"}], 
  "\n"}], "\n", 
 RowBox[{"Grid", "[", 
  RowBox[{"{", "\n", "  ", 
   RowBox[{
    RowBox[{"Map", "[", "\n", "    ", 
     RowBox[{
      RowBox[{
       RowBox[{"GEEImage", "[", "\n", "      ", 
        RowBox[{
         RowBox[{"GeoPosition", "[", 
          RowBox[{"{", 
           RowBox[{"22.55", ",", " ", "114.05"}], "}"}], "]"}], ",", " ", 
         RowBox[{"images", "[", "#", "]"}], ",", "\n", "      ", 
         RowBox[{"GeoRange", " ", "->", " ", 
          RowBox[{"Quantity", "[", 
           RowBox[{"40", ",", " ", "\"\<Kilometers\>\""}], "]"}]}], ",", "\n",
          "      ", 
         RowBox[{"RasterSize", " ", "->", " ", 
          RowBox[{"{", 
           RowBox[{"512", ",", " ", "512"}], "}"}]}], ",", "\n", "      ", 
         RowBox[{"\"\<VisParams\>\"", " ", "->", " ", 
          RowBox[{"<|", 
           RowBox[{
            RowBox[{"\"\<min\>\"", " ", "->", " ", "0"}], ",", " ", 
            RowBox[{"\"\<max\>\"", " ", "->", " ", "63"}], ",", "\n", 
            "        ", 
            RowBox[{"\"\<palette\>\"", " ", "->", " ", 
             RowBox[{"{", 
              
              RowBox[{"\"\<#000000\>\"", ",", " ", "\"\<#ffff00\>\"", ",", 
               " ", "\"\<#ffffff\>\""}], "}"}]}]}], "|>"}]}]}], "\n", "    ", 
        "]"}], " ", "&"}], ",", "\n", "    ", "years"}], "\n", "  ", "]"}], ",",
     "\n", "  ", 
    RowBox[{"Map", "[", 
     RowBox[{
      RowBox[{
       RowBox[{"Style", "[", 
        RowBox[{
         RowBox[{"ToString", "[", "#", "]"}], ",", " ", "Bold", ",", " ", 
         "14"}], "]"}], " ", "&"}], ",", " ", "years"}], "]"}]}], "\n", "}"}],
   "]"}]}], "Input",ExpressionUUID->"bd48fef8-c387-0349-8187-b096501bf304"],

Cell["\<\
The three panels show the progressive brightening and spatial expansion of \
Shenzhen's lit area, a hallmark of rapid urbanization.\
\>", "Text",ExpressionUUID->"282ae9ad-899e-364f-934c-4d3020fc19ad"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Wolfram Integration: GeoRegionValuePlot", "Section",ExpressionUUID->"1a8ebebb-734e-eb48-a162-6f8ce421c615"],

Cell["\<\
Combine GEE-extracted radiance statistics with Wolfram's built-in geographic \
visualization to produce a choropleth map of nightlight intensity by country \
or state.\
\>", "Text",ExpressionUUID->"6eb222d4-ef0d-3342-9b75-c0749218f7fc"],

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"states", " ", "=", " ", 
    RowBox[{"{", 
     RowBox[{"\"\<California\>\"", ",", " ", "\"\<Texas\>\"", ",", 
      " ", "\"\<NewYork\>\"", ",", " ", "\"\<Florida\>\"", ",", 
      " ", "\"\<Illinois\>\""}], "}"}]}], ";"}], "\n"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"stateBoxes", " ", "=", " ", 
    RowBox[{"<|", "\n", "  ", 
     RowBox[{
      RowBox[{"\"\<California\>\"", " ", "->", " ", 
       RowBox[{"{", 
        RowBox[{
         RowBox[{"-", "124.5"}], ",", " ", "32.5", ",", " ", 
         RowBox[{"-", "114.1"}], ",", " ", "42.0"}], "}"}]}], ",", "\n", "  ", 
      RowBox[{"\"\<Texas\>\"", "      ", "->", " ", 
       RowBox[{"{", 
        RowBox[{
         RowBox[{"-", "106.7"}], ",", " ", "25.8", ",", " ", 
         RowBox[{"-", "93.5"}], ",", " ", "36.5"}], "}"}]}], ",", "\n", "  ", 
      RowBox[{"\"\<NewYork\>\"", "    ", "->", " ", 
       RowBox[{"{", 
        RowBox[{
         RowBox[{"-", "79.8"}], ",", " ", "40.5", ",", " ", 
         RowBox[{"-", "71.8"}], ",", " ", "45.0"}], "}"}]}], ",", "\n", "  ", 
      RowBox[{"\"\<Florida\>\"", "    ", "->", " ", 
       RowBox[{"{", 
        RowBox[{
         RowBox[{"-", "87.6"}], ",", " ", "24.5", ",", " ", 
         RowBox[{"-", "80.0"}], ",", " ", "31.0"}], "}"}]}], ",", "\n", "  ", 
      RowBox[{"\"\<Illinois\>\"", "   ", "->", " ", 
       RowBox[{"{", 
        RowBox[{
         RowBox[{"-", "91.5"}], ",", " ", "36.9", ",", " ", 
         RowBox[{"-", "87.0"}], ",", " ", "42.5"}], "}"}]}]}], "\n", "|>"}]}],
    ";"}], "\n"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"viirs", " ", "=", " ", 
    RowBox[{
     RowBox[{
      RowBox[{
       RowBox[{
       "GEECollection", "[", "\"\<NOAA/VIIRS/DNB/MONTHLY_V1/VCMSLCFG\>\"", 
        "]"}], " ", "//", "\n", "  ", 
       RowBox[{"GEEFilterDate", "[", 
        RowBox[{"\"\<2024-01-01\>\"", ",", " ", "\"\<2024-07-01\>\""}], 
        "]"}]}], " ", "//", "\n", "  ", 
      RowBox[{"GEESelectBands", "[", 
       RowBox[{"{", "\"\<avg_rad\>\"", "}"}], "]"}]}], " ", "//", "\n", "  ", 
     "GEEMedian"}]}], ";"}], "\n"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"stateRadiance", " ", "=", " ", 
    RowBox[{"KeyValueMap", "[", "\n", "  ", 
     RowBox[{
      RowBox[{"Function", "[", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{"state", ",", " ", "bbox"}], "}"}], ",", "\n", "    ", 
        RowBox[{
         RowBox[{"Entity", "[", 
          RowBox[{"\"\<AdministrativeDivision\>\"", ",", " ", 
           RowBox[{"{", 
            RowBox[{"state", ",", " ", "\"\<UnitedStates\>\""}], "}"}]}], 
          "]"}], " ", "->", "\n", "      ", 
         RowBox[{"First", " ", "@", " ", 
          RowBox[{"Values", " ", "@", " ", 
           RowBox[{"GEECompute", "[", "\n", "        ", 
            RowBox[{"viirs", " ", "//", " ", 
             RowBox[{"GEEReduceRegion", "[", 
              RowBox[{
               RowBox[{"GEEGeometry", "[", "bbox", "]"}], ",", 
               " ", "\"\<mean\>\"", ",", " ", "1000"}], "]"}]}], "\n", 
            "      ", "]"}]}]}]}]}], "\n", "  ", "]"}], ",", "\n", "  ", 
      "stateBoxes"}], "\n", "]"}]}], ";"}], "\n"}], "\n", 
 RowBox[{"GeoRegionValuePlot", "[", 
  RowBox[{"stateRadiance", ",", "\n", "  ", 
   RowBox[{
   "PlotLabel", " ", "->", " ", "\"\<Mean Nightlight Radiance by State\>\""}],
    ",", "\n", "  ", 
   RowBox[{"ColorFunction", " ", "->", " ", "\"\<SunsetColors\>\""}], ",", 
   "\n", "  ", 
   RowBox[{"GeoRange", " ", "->", " ", "\"\<UnitedStates\>\""}]}], "\n", 
  "]"}]}], "Input",ExpressionUUID->"f9520f1b-2fb5-8549-93cb-1d15f3a37442"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Logarithmic Scaling for High Dynamic Range", "Section",ExpressionUUID->"132cfbf4-d7a5-0c40-9874-2018bae70753"],

Cell["\<\
Nighttime radiance spans several orders of magnitude. Applying a log \
transform server-side compresses the dynamic range before visualization, \
revealing detail in both dim rural areas and saturated urban cores.\
\>", "Text",ExpressionUUID->"d793033d-4044-d648-8bf7-0a23b09834f5"],

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"viirs", " ", "=", " ", 
    RowBox[{
     RowBox[{
      RowBox[{
       RowBox[{
        RowBox[{
         RowBox[{
          RowBox[{
          "GEECollection", "[", "\"\<NOAA/VIIRS/DNB/MONTHLY_V1/VCMSLCFG\>\"", 
           "]"}], " ", "//", "\n", "  ", 
          RowBox[{"GEEFilterDate", "[", 
           RowBox[{"\"\<2024-01-01\>\"", ",", " ", "\"\<2024-07-01\>\""}], 
           "]"}]}], " ", "//", "\n", "  ", 
         RowBox[{"GEEFilterBounds", "[", 
          RowBox[{"{", 
           RowBox[{
            RowBox[{"-", "74.3"}], ",", " ", "40.4", ",", " ", 
            RowBox[{"-", "73.6"}], ",", " ", "41.0"}], "}"}], "]"}]}], " ", "//",
         "\n", "  ", 
        RowBox[{"GEESelectBands", "[", 
         RowBox[{"{", "\"\<avg_rad\>\"", "}"}], "]"}]}], " ", "//", "\n", 
       "  ", "GEEMedian"}], " ", "//", "\n", "  ", 
      RowBox[{"GEEAdd", "[", "1", "]"}]}], " ", "//", "       ", 
     RowBox[{"(*", " ", 
      RowBox[{"shift", " ", "to", " ", "avoid", " ", "log", 
       RowBox[{"(", "0", ")"}]}], " ", "*)"}], "\n", "  ", "GEELog10"}]}], 
   ";"}], "\n"}], "\n", 
 RowBox[{"GEEImage", "[", "\n", "  ", 
  RowBox[{
   RowBox[{"GeoPosition", "[", 
    RowBox[{"{", 
     RowBox[{"40.7", ",", " ", 
      RowBox[{"-", "73.95"}]}], "}"}], "]"}], ",", "\n", "  ", "viirs", ",", 
   "\n", "  ", 
   RowBox[{"GeoRange", " ", "->", " ", 
    RowBox[{"Quantity", "[", 
     RowBox[{"50", ",", " ", "\"\<Kilometers\>\""}], "]"}]}], ",", "\n", "  ", 
   RowBox[{"RasterSize", " ", "->", " ", 
    RowBox[{"{", 
     RowBox[{"1024", ",", " ", "1024"}], "}"}]}], ",", "\n", "  ", 
   RowBox[{"\"\<VisParams\>\"", " ", "->", " ", 
    RowBox[{"<|", 
     RowBox[{
      RowBox[{"\"\<min\>\"", " ", "->", " ", "0"}], ",", " ", 
      RowBox[{"\"\<max\>\"", " ", "->", " ", "2.5"}], ",", "\n", "    ", 
      RowBox[{"\"\<palette\>\"", " ", "->", " ", 
       RowBox[{"{", 
        RowBox[{"\"\<#000004\>\"", ",", " ", "\"\<#51127c\>\"", ",", 
         " ", "\"\<#b73779\>\"", ",", "\n", "      ", "\"\<#fc8961\>\"", ",", 
         " ", "\"\<#fcfdbf\>\""}], "}"}]}]}], "|>"}]}]}], "\n", 
  "]"}]}], "Input",ExpressionUUID->"027719cb-e05c-a94d-83bf-773ed6e2a8b9"],

Cell[TextData[{
 "Adding 1 before taking ",
 Cell["GEELog10", "InlineCode",ExpressionUUID->
  "777ed290-fe1d-864c-acfa-df168867fff4"],
 " avoids undefined values at zero-radiance pixels. The resulting image \
reveals suburban structure that would otherwise be invisible against the \
bright Manhattan core."
}], "Text",ExpressionUUID->"8ba6a044-25a0-964c-b836-df710f9d7352"],

Cell["", "Text",
 CellFrame->{{0, 0}, {0, 
  1}},ExpressionUUID->"51be24fe-7eef-be4c-888b-c6d259d49e1e"]
}, Open  ]]
}, Open  ]],

Cell[CellGroupData[{

Cell["7.2 Urban Heat Island Effect", "Chapter",ExpressionUUID->"da198a57-f9b9-b24b-a897-8d7a22f0f10e"],

Cell["\<\
Urban surfaces -- asphalt, concrete, and rooftops -- absorb and re-emit solar \
radiation far more efficiently than vegetation, creating the urban heat \
island (UHI) effect. Satellite-derived land surface temperature (LST) is the \
primary tool for mapping this phenomenon.\
\>", "Text",ExpressionUUID->"b537b340-153f-d042-95a9-3e207ed15066"],

Cell[CellGroupData[{

Cell["Landsat 8 Surface Temperature", "Section",ExpressionUUID->"1c78fd0f-7f14-8a42-b801-0e02d44e24ee"],

Cell[TextData[{
 "Landsat 8 Collection 2 Level 2 provides a thermal band (",
 Cell["ST_B10", "InlineCode",ExpressionUUID->
  "20780e4d-aa58-8f4b-b202-76e6f08f3cb1"],
 ") with a linear scale factor. The conversion pipeline transforms raw \
digital numbers to degrees Celsius. For the general treatment of \
satellite-derived land surface temperature including MODIS LST and \
ground-station validation, see Sections 3.1 and 3.1.3."
}], "Text",ExpressionUUID->"9e9bab36-de0a-914a-a2f1-a028af7bfe51"],

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"lstCelsius", " ", "=", " ", 
    RowBox[{
     RowBox[{
      RowBox[{
       RowBox[{
        RowBox[{
         RowBox[{
          RowBox[{
           RowBox[{
            RowBox[{
            "GEECollection", "[", "\"\<LANDSAT/LC08/C02/T1_L2\>\"", "]"}], 
            " ", "//", "\n", "  ", 
            RowBox[{"GEEFilterDate", "[", 
             RowBox[{"\"\<2023-06-01\>\"", ",", " ", "\"\<2023-09-01\>\""}], 
             "]"}]}], " ", "//", "\n", "  ", 
           RowBox[{"GEEFilterBounds", "[", 
            RowBox[{"{", 
             RowBox[{
              RowBox[{"-", "77.2"}], ",", " ", "38.75", ",", " ", 
              RowBox[{"-", "76.8"}], ",", " ", "39.05"}], "}"}], "]"}]}], " ",
           "//", "\n", "  ", 
          RowBox[{"GEEFilterProperty", "[", 
           
           RowBox[{"\"\<CLOUD_COVER\>\"", ",", " ", "\"\<LessThan\>\"", ",", 
            " ", "20"}], "]"}]}], " ", "//", "\n", "  ", 
         RowBox[{"GEESelectBands", "[", 
          RowBox[{"{", "\"\<ST_B10\>\"", "}"}], "]"}]}], " ", "//", "\n", 
        "  ", "GEEMedian"}], " ", "//", "\n", "  ", 
       RowBox[{"GEEMultiply", "[", "0.00341802", "]"}]}], " ", "//", "   ", 
      RowBox[{"(*", " ", 
       RowBox[{"scale", " ", "factor"}], " ", "*)"}], "\n", "  ", 
      RowBox[{"GEEAdd", "[", "149.0", "]"}]}], " ", "//", "             ", 
     RowBox[{"(*", " ", 
      RowBox[{"offset", " ", "to", " ", "Kelvin"}], " ", "*)"}], "\n", "  ", 
     RowBox[{"GEEAdd", "[", 
      RowBox[{"-", "273.15"}], "]"}]}]}], ";"}], "            ", 
  RowBox[{"(*", " ", 
   RowBox[{"Kelvin", " ", "to", " ", "Celsius"}], " ", "*)"}], "\n"}], "\n", 
 RowBox[{"GEEImage", "[", "\n", "  ", 
  RowBox[{
   RowBox[{"GeoPosition", "[", 
    RowBox[{"{", 
     RowBox[{"38.9", ",", " ", 
      RowBox[{"-", "77.0"}]}], "}"}], "]"}], ",", "\n", "  ", "lstCelsius", ",",
    "\n", "  ", 
   RowBox[{"GeoRange", " ", "->", " ", 
    RowBox[{"Quantity", "[", 
     RowBox[{"30", ",", " ", "\"\<Kilometers\>\""}], "]"}]}], ",", "\n", "  ", 
   RowBox[{"RasterSize", " ", "->", " ", 
    RowBox[{"{", 
     RowBox[{"1024", ",", " ", "1024"}], "}"}]}], ",", "\n", "  ", 
   RowBox[{"\"\<VisParams\>\"", " ", "->", " ", 
    RowBox[{"<|", 
     RowBox[{
      RowBox[{"\"\<min\>\"", " ", "->", " ", "25"}], ",", " ", 
      RowBox[{"\"\<max\>\"", " ", "->", " ", "50"}], ",", "\n", "    ", 
      RowBox[{"\"\<palette\>\"", " ", "->", " ", 
       RowBox[{"{", 
        RowBox[{"\"\<#313695\>\"", ",", " ", "\"\<#4575b4\>\"", ",", 
         " ", "\"\<#abd9e9\>\"", ",", "\n", "      ", "\"\<#fee090\>\"", ",", 
         " ", "\"\<#f46d43\>\"", ",", " ", "\"\<#a50026\>\""}], "}"}]}]}], 
     "|>"}]}]}], "\n", "]"}]}], "Input",ExpressionUUID->"c35d35b0-93bf-bf45-\
8f71-917c4c6096f9"],

Cell["\<\
This produces a surface temperature map of Washington, D.C., where the \
National Mall, downtown corridors, and parking lots appear as hot spots \
against the cooler green spaces of Rock Creek Park and the Potomac River \
margins.\
\>", "Text",ExpressionUUID->"2777d590-b941-2841-b168-c6ff509e4b22"]
}, Open  ]],

Cell[CellGroupData[{

Cell["MODIS Land Surface Temperature", "Section",ExpressionUUID->"4d602989-4143-944f-a7c0-caaace97b311"],

Cell[TextData[{
 "For broader-scale or time-series UHI analysis, MODIS provides 8-day LST \
composites (",
 Cell["MOD11A2", "InlineCode",ExpressionUUID->
  "401e703d-2aa3-4a41-a174-1cfc68e5fb54"],
 ") at 1 km resolution. The ",
 Cell["LST_Day_1km", "InlineCode",ExpressionUUID->
  "7c213a96-2ba7-7447-80e5-ed6d9c5c9691"],
 " band requires multiplication by 0.02 to convert to Kelvin."
}], "Text",ExpressionUUID->"4e2d3a4c-79e2-e348-a176-d94c464f3f8e"],

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"modisLST", " ", "=", " ", 
    RowBox[{
     RowBox[{
      RowBox[{
       RowBox[{
        RowBox[{
         RowBox[{
          RowBox[{"GEECollection", "[", "\"\<MODIS/061/MOD11A2\>\"", "]"}], 
          " ", "//", "\n", "  ", 
          RowBox[{"GEEFilterDate", "[", 
           RowBox[{"\"\<2023-06-01\>\"", ",", " ", "\"\<2023-09-01\>\""}], 
           "]"}]}], " ", "//", "\n", "  ", 
         RowBox[{"GEEFilterBounds", "[", 
          RowBox[{"{", 
           RowBox[{
            RowBox[{"-", "88.0"}], ",", " ", "41.6", ",", " ", 
            RowBox[{"-", "87.4"}], ",", " ", "42.1"}], "}"}], "]"}]}], " ", "//",
         "\n", "  ", 
        RowBox[{"GEESelectBands", "[", 
         RowBox[{"{", "\"\<LST_Day_1km\>\"", "}"}], "]"}]}], " ", "//", "\n", 
       "  ", "GEEMedian"}], " ", "//", "\n", "  ", 
      RowBox[{"GEEMultiply", "[", "0.02", "]"}]}], " ", "//", "        ", 
     RowBox[{"(*", " ", 
      RowBox[{"scale", " ", "to", " ", "Kelvin"}], " ", "*)"}], "\n", "  ", 
     RowBox[{"GEEAdd", "[", 
      RowBox[{"-", "273.15"}], "]"}]}]}], ";"}], "           ", 
  RowBox[{"(*", " ", 
   RowBox[{"to", " ", "Celsius"}], " ", "*)"}], "\n"}], "\n", 
 RowBox[{"GEEImage", "[", "\n", "  ", 
  RowBox[{
   RowBox[{"Entity", "[", 
    RowBox[{"\"\<City\>\"", ",", " ", 
     RowBox[{"{", 
      RowBox[{"\"\<Chicago\>\"", ",", " ", "\"\<Illinois\>\"", ",", 
       " ", "\"\<UnitedStates\>\""}], "}"}]}], "]"}], ",", "\n", "  ", 
   "modisLST", ",", "\n", "  ", 
   RowBox[{"GeoRange", " ", "->", " ", 
    RowBox[{"Quantity", "[", 
     RowBox[{"40", ",", " ", "\"\<Kilometers\>\""}], "]"}]}], ",", "\n", "  ", 
   RowBox[{"RasterSize", " ", "->", " ", 
    RowBox[{"{", 
     RowBox[{"512", ",", " ", "512"}], "}"}]}], ",", "\n", "  ", 
   RowBox[{"\"\<VisParams\>\"", " ", "->", " ", 
    RowBox[{"<|", 
     RowBox[{
      RowBox[{"\"\<min\>\"", " ", "->", " ", "25"}], ",", " ", 
      RowBox[{"\"\<max\>\"", " ", "->", " ", "45"}], ",", "\n", "    ", 
      RowBox[{"\"\<palette\>\"", " ", "->", " ", 
       RowBox[{"{", 
        RowBox[{"\"\<#2166ac\>\"", ",", " ", "\"\<#67a9cf\>\"", ",", 
         " ", "\"\<#d1e5f0\>\"", ",", "\n", "      ", "\"\<#fddbc7\>\"", ",", 
         " ", "\"\<#ef8a62\>\"", ",", " ", "\"\<#b2182b\>\""}], "}"}]}]}], 
     "|>"}]}]}], "\n", "]"}]}], "Input",ExpressionUUID->"9fcb6f67-e6b4-2241-\
a3bb-8b2099927fb7"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Quantifying UHI Intensity", "Section",ExpressionUUID->"11cbee54-eb00-714b-b82e-a8ff661faefb"],

Cell["\<\
UHI intensity is defined as the difference in surface temperature between the \
urban core and a nearby rural reference. Extract mean LST for two geometries \
and compute the differential.\
\>", "Text",ExpressionUUID->"f6cf604c-9377-e449-90c7-e5fa0870c9f4"],

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"lstCelsius", " ", "=", " ", 
    RowBox[{
     RowBox[{
      RowBox[{
       RowBox[{
        RowBox[{
         RowBox[{
          RowBox[{
           RowBox[{
            RowBox[{
            "GEECollection", "[", "\"\<LANDSAT/LC08/C02/T1_L2\>\"", "]"}], 
            " ", "//", "\n", "  ", 
            RowBox[{"GEEFilterDate", "[", 
             RowBox[{"\"\<2023-06-01\>\"", ",", " ", "\"\<2023-09-01\>\""}], 
             "]"}]}], " ", "//", "\n", "  ", 
           RowBox[{"GEEFilterBounds", "[", 
            RowBox[{"{", 
             RowBox[{
              RowBox[{"-", "74.1"}], ",", " ", "40.6", ",", " ", 
              RowBox[{"-", "73.7"}], ",", " ", "40.9"}], "}"}], "]"}]}], " ", 
          "//", "\n", "  ", 
          RowBox[{"GEEFilterProperty", "[", 
           
           RowBox[{"\"\<CLOUD_COVER\>\"", ",", " ", "\"\<LessThan\>\"", ",", 
            " ", "15"}], "]"}]}], " ", "//", "\n", "  ", 
         RowBox[{"GEESelectBands", "[", 
          RowBox[{"{", "\"\<ST_B10\>\"", "}"}], "]"}]}], " ", "//", "\n", 
        "  ", "GEEMedian"}], " ", "//", "\n", "  ", 
       RowBox[{"GEEMultiply", "[", "0.00341802", "]"}]}], " ", "//", "\n", 
      "  ", 
      RowBox[{"GEEAdd", "[", "149.0", "]"}]}], " ", "//", "\n", "  ", 
     RowBox[{"GEEAdd", "[", 
      RowBox[{"-", "273.15"}], "]"}]}]}], ";"}], "\n", "\n", 
  RowBox[{"(*", " ", 
   RowBox[{"Urban", " ", 
    RowBox[{"core", ":", " ", 
     RowBox[{"Midtown", " ", "Manhattan"}]}]}], " ", "*)"}]}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"urbanGeom", " ", "=", " ", 
    RowBox[{"GEEGeometry", "[", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"-", "73.99"}], ",", " ", "40.74", ",", " ", 
       RowBox[{"-", "73.96"}], ",", " ", "40.76"}], "}"}], "]"}]}], ";"}], 
  "\n", "\n", 
  RowBox[{"(*", " ", 
   RowBox[{"Rural", " ", 
    RowBox[{"reference", ":", " ", 
     RowBox[{
     "farmland", " ", "in", " ", "northern", " ", "New", " ", "Jersey"}]}]}], 
   " ", "*)"}]}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"ruralGeom", " ", "=", " ", 
    RowBox[{"GEEGeometry", "[", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"-", "74.55"}], ",", " ", "40.85", ",", " ", 
       RowBox[{"-", "74.45"}], ",", " ", "40.95"}], "}"}], "]"}]}], ";"}], 
  "\n"}], "\n", 
 RowBox[{
  RowBox[{"urbanLST", " ", "=", " ", 
   RowBox[{"First", " ", "@", " ", 
    RowBox[{"Values", " ", "@", " ", 
     RowBox[{"GEECompute", "[", "\n", "  ", 
      RowBox[{"lstCelsius", " ", "//", " ", 
       RowBox[{"GEEReduceRegion", "[", 
        RowBox[{"urbanGeom", ",", " ", "\"\<mean\>\"", ",", " ", "30"}], 
        "]"}]}], "\n", "]"}]}]}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"ruralLST", " ", "=", " ", 
    RowBox[{"First", " ", "@", " ", 
     RowBox[{"Values", " ", "@", " ", 
      RowBox[{"GEECompute", "[", "\n", "  ", 
       RowBox[{"lstCelsius", " ", "//", " ", 
        RowBox[{"GEEReduceRegion", "[", 
         RowBox[{"ruralGeom", ",", " ", "\"\<mean\>\"", ",", " ", "30"}], 
         "]"}]}], "\n", "]"}]}]}]}], ";"}], "\n"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"uhiIntensity", " ", "=", " ", 
    RowBox[{"urbanLST", " ", "-", " ", "ruralLST"}]}], ";"}], "\n"}], "\n", 
 RowBox[{"Dataset", "[", 
  RowBox[{"<|", "\n", "  ", 
   RowBox[{
    RowBox[{"\"\<Urban Mean LST\>\"", " ", "->", " ", 
     RowBox[{"Quantity", "[", 
      RowBox[{
       RowBox[{"Round", "[", 
        RowBox[{"urbanLST", ",", " ", "0.1"}], "]"}], ",", 
       " ", "\"\<DegreesCelsius\>\""}], "]"}]}], ",", "\n", "  ", 
    RowBox[{"\"\<Rural Mean LST\>\"", " ", "->", " ", 
     RowBox[{"Quantity", "[", 
      RowBox[{
       RowBox[{"Round", "[", 
        RowBox[{"ruralLST", ",", " ", "0.1"}], "]"}], ",", 
       " ", "\"\<DegreesCelsius\>\""}], "]"}]}], ",", "\n", "  ", 
    RowBox[{"\"\<UHI Intensity\>\"", "  ", "->", " ", 
     RowBox[{"Quantity", "[", 
      RowBox[{
       RowBox[{"Round", "[", 
        RowBox[{"uhiIntensity", ",", " ", "0.1"}], "]"}], ",", 
       " ", "\"\<DegreesCelsius\>\""}], "]"}]}]}], "\n", "|>"}], 
  "]"}]}], "Input",ExpressionUUID->"52e5955f-6f66-cc46-bcaf-22c37c6ecba8"],

Cell["\<\
A typical summertime UHI intensity for New York City is 4--8 degrees Celsius, \
depending on the reference site and atmospheric conditions.\
\>", "Text",ExpressionUUID->"4aa41c50-9f34-6145-a454-b05975e37e75"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Overlay Temperature on GeoGraphics", "Section",ExpressionUUID->"b1709b95-ea7b-154a-8da0-d0b5d2558328"],

Cell[TextData[{
 "Use ",
 Cell["GEEGeoGraphics", "InlineCode",ExpressionUUID->
  "65fe990e-0d8d-7843-9444-9d5b86c44813"],
 " to overlay urban boundary annotations on a thermal basemap."
}], "Text",ExpressionUUID->"61b60396-903c-5c40-a59b-a3ccde24a2c6"],

Cell[BoxData[
 RowBox[{"GEEGeoGraphics", "[", "\n", "  ", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{
     RowBox[{"EdgeForm", "[", 
      RowBox[{"{", 
       RowBox[{"Thick", ",", " ", "White"}], "}"}], "]"}], ",", " ", 
     RowBox[{"FaceForm", "[", "None", "]"}], ",", "\n", "   ", 
     RowBox[{"GeoPolygon", "[", 
      RowBox[{"{", "\n", "     ", 
       RowBox[{
        RowBox[{"GeoPosition", "[", 
         RowBox[{"{", 
          RowBox[{"40.76", ",", " ", 
           RowBox[{"-", "73.99"}]}], "}"}], "]"}], ",", " ", 
        RowBox[{"GeoPosition", "[", 
         RowBox[{"{", 
          RowBox[{"40.76", ",", " ", 
           RowBox[{"-", "73.96"}]}], "}"}], "]"}], ",", "\n", "     ", 
        RowBox[{"GeoPosition", "[", 
         RowBox[{"{", 
          RowBox[{"40.74", ",", " ", 
           RowBox[{"-", "73.96"}]}], "}"}], "]"}], ",", " ", 
        RowBox[{"GeoPosition", "[", 
         RowBox[{"{", 
          RowBox[{"40.74", ",", " ", 
           RowBox[{"-", "73.99"}]}], "}"}], "]"}]}], "\n", "   ", "}"}], 
      "]"}], ",", "\n", "   ", "White", ",", " ", 
     RowBox[{"GeoMarker", "[", 
      RowBox[{
       RowBox[{"GeoPosition", "[", 
        RowBox[{"{", 
         RowBox[{"40.75", ",", " ", 
          RowBox[{"-", "73.975"}]}], "}"}], "]"}], ",", "\n", "     ", 
       RowBox[{"\"\<Label\>\"", " ", "->", " ", "\"\<Urban Core\>\""}]}], 
      "]"}]}], "}"}], ",", "\n", "  ", "lstCelsius", ",", "\n", "  ", 
   RowBox[{"GeoRange", " ", "->", " ", 
    RowBox[{"Quantity", "[", 
     RowBox[{"25", ",", " ", "\"\<Kilometers\>\""}], "]"}]}], ",", "\n", "  ", 
   RowBox[{"RasterSize", " ", "->", " ", 
    RowBox[{"{", 
     RowBox[{"800", ",", " ", "800"}], "}"}]}], ",", "\n", "  ", 
   RowBox[{"\"\<VisParams\>\"", " ", "->", " ", 
    RowBox[{"<|", 
     RowBox[{
      RowBox[{"\"\<min\>\"", " ", "->", " ", "28"}], ",", " ", 
      RowBox[{"\"\<max\>\"", " ", "->", " ", "48"}], ",", "\n", "    ", 
      RowBox[{"\"\<palette\>\"", " ", "->", " ", 
       RowBox[{"{", 
        RowBox[{"\"\<#313695\>\"", ",", " ", "\"\<#fee090\>\"", ",", 
         " ", "\"\<#a50026\>\""}], "}"}]}]}], "|>"}]}]}], "\n", 
  "]"}]], "Input",ExpressionUUID->"bf5d62e8-b624-7442-8950-0eeca27c6952"],

Cell["", "Text",
 CellFrame->{{0, 0}, {0, 
  1}},ExpressionUUID->"a619cf43-ba5d-7d4a-bd07-bf0aeeeda219"]
}, Open  ]]
}, Open  ]],

Cell[CellGroupData[{

Cell["7.3 Built-Up Area and Impervious Surface", "Chapter",ExpressionUUID->"7a8efd7b-2a3c-1941-8e63-630152679a4a"],

Cell["\<\
Impervious surfaces -- roads, buildings, and pavement -- are the physical \
manifestation of urbanization. Mapping their extent and growth is fundamental \
to urban planning, hydrology, and climate adaptation studies.\
\>", "Text",ExpressionUUID->"6c6fed18-e8df-1648-bc43-1b36cbc2450f"],

Cell[CellGroupData[{

Cell["Normalized Difference Built-Up Index (NDBI)", "Section",ExpressionUUID->"fac8759b-ffe7-a142-b5c2-248369d7625e"],

Cell["\<\
NDBI exploits the higher reflectance of built-up surfaces in the short-wave \
infrared (SWIR) relative to the near-infrared (NIR). For Sentinel-2, NDBI is \
computed as (B11 - B8) / (B11 + B8). Positive values indicate built-up areas.\
\>", "Text",ExpressionUUID->"40f0d91e-37a6-454a-ba1e-7b48db69d3ab"],

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"ndbi", " ", "=", " ", 
    RowBox[{
     RowBox[{
      RowBox[{
       RowBox[{
        RowBox[{
         RowBox[{
         "GEECollection", "[", "\"\<COPERNICUS/S2_SR_HARMONIZED\>\"", "]"}], 
         " ", "//", "\n", "  ", 
         RowBox[{"GEEFilterDate", "[", 
          RowBox[{"\"\<2024-03-01\>\"", ",", " ", "\"\<2024-06-01\>\""}], 
          "]"}]}], " ", "//", "\n", "  ", 
        RowBox[{"GEEFilterBounds", "[", 
         RowBox[{"{", 
          RowBox[{
          "77.0", ",", " ", "28.4", ",", " ", "77.4", ",", " ", "28.8"}], 
          "}"}], "]"}]}], " ", "//", "\n", "  ", 
       RowBox[{"GEEFilterProperty", "[", 
        RowBox[{"\"\<CLOUDY_PIXEL_PERCENTAGE\>\"", ",", 
         " ", "\"\<LessThan\>\"", ",", " ", "10"}], "]"}]}], " ", "//", "\n", 
      "  ", "GEEMedian"}], " ", "//", "\n", "  ", 
     RowBox[{"GEENormalizedDifference", "[", 
      RowBox[{"{", 
       RowBox[{"\"\<B11\>\"", ",", " ", "\"\<B8\>\""}], "}"}], "]"}]}]}], 
   ";"}], "\n"}], "\n", 
 RowBox[{"GEEImage", "[", "\n", "  ", 
  RowBox[{
   RowBox[{"Entity", "[", 
    RowBox[{"\"\<City\>\"", ",", " ", 
     RowBox[{"{", 
      RowBox[{"\"\<NewDelhi\>\"", ",", " ", "\"\<Delhi\>\"", ",", 
       " ", "\"\<India\>\""}], "}"}]}], "]"}], ",", "\n", "  ", "ndbi", ",", 
   "\n", "  ", 
   RowBox[{"GeoRange", " ", "->", " ", 
    RowBox[{"Quantity", "[", 
     RowBox[{"30", ",", " ", "\"\<Kilometers\>\""}], "]"}]}], ",", "\n", "  ", 
   RowBox[{"RasterSize", " ", "->", " ", 
    RowBox[{"{", 
     RowBox[{"1024", ",", " ", "1024"}], "}"}]}], ",", "\n", "  ", 
   RowBox[{"\"\<VisParams\>\"", " ", "->", " ", 
    RowBox[{"<|", 
     RowBox[{
      RowBox[{"\"\<min\>\"", " ", "->", " ", 
       RowBox[{"-", "0.3"}]}], ",", " ", 
      RowBox[{"\"\<max\>\"", " ", "->", " ", "0.3"}], ",", "\n", "    ", 
      RowBox[{"\"\<palette\>\"", " ", "->", " ", 
       RowBox[{"{", 
        RowBox[{"\"\<#1a9850\>\"", ",", " ", "\"\<#ffffbf\>\"", ",", 
         " ", "\"\<#d73027\>\""}], "}"}]}]}], "|>"}]}]}], "\n", 
  "]"}]}], "Input",ExpressionUUID->"0e2cfa98-b43b-a942-a930-c9b7893bdf51"],

Cell["\<\
Green tones represent vegetated areas (negative NDBI), yellow marks the \
transition zone, and red highlights dense built-up land. The sharp contrast \
between Old Delhi's compact urban fabric and the surrounding agricultural \
belt is clearly visible.\
\>", "Text",ExpressionUUID->"797fbe6c-e453-2a4b-b4e9-13af8591e8f6"]
}, Open  ]],

Cell[CellGroupData[{

Cell["ESA WorldCover Built-Up Class", "Section",ExpressionUUID->"e3f03d12-18bd-f941-aee7-1e8a5219531b"],

Cell[TextData[{
 "ESA WorldCover is a 10 m resolution global land cover product derived from \
Sentinel-1 and Sentinel-2. Class 50 represents built-up areas. By isolating \
this class and combining it with ",
 Cell["GEEPixelArea", "InlineCode",ExpressionUUID->
  "51005381-53ea-9045-8e91-76be0e990fac"],
 ", you can compute the total built-up area within any polygon."
}], "Text",ExpressionUUID->"5c6187c7-5988-7949-9ba7-1e84da8a581c"],

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"worldCover", " ", "=", " ", 
    RowBox[{
     RowBox[{
      RowBox[{
       RowBox[{"GEECollection", "[", "\"\<ESA/WorldCover/v200\>\"", "]"}], 
       " ", "//", "\n", "  ", 
       RowBox[{"GEEFilterDate", "[", 
        RowBox[{"\"\<2021-01-01\>\"", ",", " ", "\"\<2022-01-01\>\""}], 
        "]"}]}], " ", "//", "\n", "  ", "GEEMosaic"}], " ", "//", "\n", "  ", 
     RowBox[{"GEESelectBands", "[", 
      RowBox[{"{", "\"\<Map\>\"", "}"}], "]"}]}]}], ";"}], "\n", "\n", 
  RowBox[{"(*", " ", 
   RowBox[{
    RowBox[{"Create", " ", "a", " ", "binary", " ", 
     RowBox[{"mask", ":", " ", 
      RowBox[{
       RowBox[{"1", " ", "where", " ", "built"}], "-", "up"}]}]}], ",", " ", 
    RowBox[{"0", " ", "elsewhere"}]}], " ", "*)"}]}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"builtUp", " ", "=", " ", 
    RowBox[{"worldCover", " ", "//", " ", 
     RowBox[{"GEEEquals", "[", "50", "]"}]}]}], ";"}], "\n", "\n", 
  RowBox[{"(*", " ", 
   RowBox[{
    RowBox[{"Visualize", " ", "built"}], "-", 
    RowBox[{"up", " ", "footprint", " ", "over", " ", "Sao", " ", "Paulo"}]}],
    " ", "*)"}]}], "\n", 
 RowBox[{"GEEImage", "[", "\n", "  ", 
  RowBox[{
   RowBox[{"Entity", "[", 
    RowBox[{"\"\<City\>\"", ",", " ", 
     RowBox[{"{", 
      RowBox[{"\"\<SaoPaulo\>\"", ",", " ", "\"\<SaoPaulo\>\"", ",", 
       " ", "\"\<Brazil\>\""}], "}"}]}], "]"}], ",", "\n", "  ", "builtUp", ",",
    "\n", "  ", 
   RowBox[{"GeoRange", " ", "->", " ", 
    RowBox[{"Quantity", "[", 
     RowBox[{"50", ",", " ", "\"\<Kilometers\>\""}], "]"}]}], ",", "\n", "  ", 
   RowBox[{"RasterSize", " ", "->", " ", 
    RowBox[{"{", 
     RowBox[{"1024", ",", " ", "1024"}], "}"}]}], ",", "\n", "  ", 
   RowBox[{"\"\<VisParams\>\"", " ", "->", " ", 
    RowBox[{"<|", 
     RowBox[{
      RowBox[{"\"\<min\>\"", " ", "->", " ", "0"}], ",", " ", 
      RowBox[{"\"\<max\>\"", " ", "->", " ", "1"}], ",", "\n", "    ", 
      RowBox[{"\"\<palette\>\"", " ", "->", " ", 
       RowBox[{"{", 
        RowBox[{"\"\<#e0e0e0\>\"", ",", " ", "\"\<#d7191c\>\""}], "}"}]}]}], 
     "|>"}]}]}], "\n", "]"}]}], "Input",ExpressionUUID->"68cf688c-9b0a-5e44-\
9e0c-e0f64d69335e"],

Cell[TextData[StyleBox["Compute built-up area percentage for a city:",
 FontWeight->Bold]], "Text",ExpressionUUID->"5a452dc7-2bab-724c-bb0b-\
03578989f96c"],

Cell[BoxData[{
 RowBox[{
  RowBox[{"cityBBox", " ", "=", " ", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"-", "46.8"}], ",", " ", 
     RowBox[{"-", "23.7"}], ",", " ", 
     RowBox[{"-", "46.4"}], ",", " ", 
     RowBox[{"-", "23.4"}]}], "}"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"cityGeom", " ", "=", " ", 
    RowBox[{"GEEGeometry", "[", "cityBBox", "]"}]}], ";"}], "\n"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"builtUpArea", " ", "=", " ", 
    RowBox[{
     RowBox[{"builtUp", " ", "//", "\n", "  ", 
      RowBox[{"GEEMultiply", "[", 
       RowBox[{"GEEPixelArea", "[", "]"}], "]"}]}], " ", "//", "\n", "  ", 
     RowBox[{"GEEReduceRegion", "[", 
      RowBox[{"cityGeom", ",", " ", "\"\<sum\>\"", ",", " ", "10"}], 
      "]"}]}]}], ";"}], "\n"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"totalArea", " ", "=", " ", 
    RowBox[{
     RowBox[{
      RowBox[{"GEEPixelArea", "[", "]"}], " ", "//", "\n", "  ", 
      RowBox[{"GEEClip", "[", "cityGeom", "]"}]}], " ", "//", "\n", "  ", 
     RowBox[{"GEEReduceRegion", "[", 
      RowBox[{"cityGeom", ",", " ", "\"\<sum\>\"", ",", " ", "10"}], 
      "]"}]}]}], ";"}], "\n"}], "\n", 
 RowBox[{
  RowBox[{"builtUpM2", " ", "=", " ", 
   RowBox[{"First", " ", "@", " ", 
    RowBox[{"Values", " ", "@", " ", 
     RowBox[{"GEECompute", "[", "builtUpArea", "]"}]}]}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"totalM2", " ", "=", " ", 
    RowBox[{"First", " ", "@", " ", 
     RowBox[{"Values", " ", "@", " ", 
      RowBox[{"GEECompute", "[", "totalArea", "]"}]}]}]}], ";"}], "\n"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"builtUpPct", " ", "=", " ", 
    RowBox[{"100.0", " ", "*", " ", 
     RowBox[{"builtUpM2", " ", "/", " ", "totalM2"}]}]}], ";"}], "\n"}], "\n", 
 RowBox[{"StringForm", "[", 
  RowBox[{"\"\<Built-up area: ``% of the ```` km\[ThinSpace]2 region\>\"", ",",
    "\n", "  ", 
   RowBox[{"Round", "[", 
    RowBox[{"builtUpPct", ",", " ", "0.1"}], "]"}], ",", "\n", "  ", 
   RowBox[{"Round", "[", 
    RowBox[{
     RowBox[{"totalM2", " ", "/", " ", 
      RowBox[{"10", "^", "6"}]}], ",", " ", "1"}], "]"}]}], "\n", 
  "]"}]}], "Input",ExpressionUUID->"afa0d998-0c82-f84d-96d0-f881c751a9c3"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Global Human Settlement Layer (GHSL)", "Section",ExpressionUUID->"2fd9018d-24e8-e747-9f8e-530a1e7901a9"],

Cell["\<\
The JRC Global Human Settlement Layer provides built-up surface area \
estimates at multiple epochs (1975, 1990, 2000, 2015, 2020), enabling \
historical analysis of urban expansion.\
\>", "Text",ExpressionUUID->"5381850c-60c6-6d4a-b386-1a4d630e4b57"],

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"epochs", " ", "=", " ", 
    RowBox[{"{", 
     RowBox[{"1975", ",", " ", "1990", ",", " ", "2000", ",", " ", "2015"}], 
     "}"}]}], ";"}], "\n"}], "\n", 
 RowBox[{
  RowBox[{"lagosBox", " ", "=", " ", 
   RowBox[{"{", 
    RowBox[{"3.1", ",", " ", "6.3", ",", " ", "3.7", ",", " ", "6.7"}], 
    "}"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"lagosGeom", " ", "=", " ", 
    RowBox[{"GEEGeometry", "[", "lagosBox", "]"}]}], ";"}], "\n"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"builtUpByEpoch", " ", "=", " ", 
    RowBox[{"Association", " ", "@", " ", 
     RowBox[{"Map", "[", "\n", "  ", 
      RowBox[{
       RowBox[{"Function", "[", 
        RowBox[{"year", ",", "\n", "    ", 
         RowBox[{"Module", "[", 
          RowBox[{
           RowBox[{"{", 
            RowBox[{"img", ",", " ", "result"}], "}"}], ",", "\n", "      ", 
           RowBox[{
            RowBox[{"img", " ", "=", " ", 
             RowBox[{
              RowBox[{
               RowBox[{
                RowBox[{
                "GEECollection", "[", "\"\<JRC/GHSL/P2023A/GHS_BUILT_S\>\"", 
                 "]"}], " ", "//", "\n", "        ", 
                RowBox[{"GEEFilterDate", "[", "\n", "          ", 
                 RowBox[{
                  RowBox[{"DateString", "[", 
                   RowBox[{
                    RowBox[{"{", 
                    RowBox[{"year", ",", " ", "1", ",", " ", "1"}], "}"}], ",",
                     " ", "\"\<ISODate\>\""}], "]"}], ",", "\n", "          ", 
                  RowBox[{"DateString", "[", 
                   RowBox[{
                    RowBox[{"{", 
                    RowBox[{
                    RowBox[{"year", " ", "+", " ", "1"}], ",", " ", "1", ",", 
                    " ", "1"}], "}"}], ",", " ", "\"\<ISODate\>\""}], "]"}]}],
                  "]"}]}], " ", "//", "\n", "        ", "GEEMosaic"}], " ", "//",
               "\n", "        ", 
              RowBox[{"GEESelectBands", "[", 
               RowBox[{"{", "\"\<built_surface_nres\>\"", "}"}], "]"}]}]}], ";",
             "\n", "      ", 
            RowBox[{"result", " ", "=", " ", 
             RowBox[{"GEECompute", "[", "\n", "        ", 
              RowBox[{"img", " ", "//", " ", 
               RowBox[{"GEEReduceRegion", "[", 
                RowBox[{
                "lagosGeom", ",", " ", "\"\<sum\>\"", ",", " ", "100"}], 
                "]"}]}], "\n", "      ", "]"}]}], ";", "\n", "      ", 
            RowBox[{"year", " ", "->", " ", 
             RowBox[{
              RowBox[{"First", "[", 
               RowBox[{"Values", "[", "result", "]"}], "]"}], " ", "/", " ", 
              RowBox[{"10", "^", "6"}]}]}]}]}], "  ", 
          RowBox[{"(*", " ", 
           RowBox[{"m2", " ", "to", " ", "km2"}], " ", "*)"}], "\n", "    ", 
          "]"}]}], "\n", "  ", "]"}], ",", "\n", "  ", "epochs"}], "\n", 
      "]"}]}]}], ";"}], "\n"}], "\n", 
 RowBox[{"ListLinePlot", "[", "\n", "  ", 
  RowBox[{"builtUpByEpoch", ",", "\n", "  ", 
   RowBox[{"PlotMarkers", " ", "->", " ", "Automatic"}], ",", "\n", "  ", 
   RowBox[{"AxesLabel", " ", "->", " ", 
    RowBox[{"{", 
     RowBox[{"\"\<Year\>\"", ",", 
      " ", "\"\<Built-Up Area (km\[ThinSpace]2)\>\""}], "}"}]}], ",", "\n", 
   "  ", 
   RowBox[{
   "PlotLabel", " ", "->", " ", "\"\<Lagos: Built-Up Surface Expansion\>\""}],
    ",", "\n", "  ", 
   RowBox[{"PlotStyle", " ", "->", " ", 
    RowBox[{"Directive", "[", 
     RowBox[{"Thick", ",", " ", 
      RowBox[{"RGBColor", "[", 
       RowBox[{"0.8", ",", " ", "0.2", ",", " ", "0.2"}], "]"}]}], "]"}]}], ",",
    "\n", "  ", 
   RowBox[{"Filling", " ", "->", " ", "Axis"}]}], "\n", "]"}]}], "Input",Expre\
ssionUUID->"45196fc2-44c2-574b-bf22-f122926fe8d4"],

Cell["\<\
This plot reveals the exponential growth trajectory that characterizes many \
cities in Sub-Saharan Africa.\
\>", "Text",ExpressionUUID->"f950bed7-bb8a-d543-8d2f-06828f926cb9"],

Cell["", "Text",
 CellFrame->{{0, 0}, {0, 
  1}},ExpressionUUID->"805b3bf7-a7d6-dc48-874b-6fc886188637"]
}, Open  ]]
}, Open  ]],

Cell[CellGroupData[{

Cell["7.4 Urban Sprawl and Change Detection", "Chapter",ExpressionUUID->"6c82f474-5ca7-da45-9164-a0e34639e189"],

Cell["\<\
Urbanization is not a static condition but an ongoing process. Change \
detection techniques compare imagery from different time periods to identify \
where land use transitions have occurred.\
\>", "Text",ExpressionUUID->"4226685e-a950-5a4e-a352-a9ae4a4c4e70"],

Cell[CellGroupData[{

Cell["Land Cover Change Between Two Periods", "Section",ExpressionUUID->"a35ca6c4-aff9-f84b-aa4c-9400e5fcb2ae"],

Cell["\<\
Compare ESA WorldCover products from 2020 and 2021 to find pixels that \
transitioned from vegetation (classes 10, 20, 30) to built-up (class 50).\
\>", "Text",ExpressionUUID->"328ec3a8-7f10-084b-9803-5d0715ed301b"],

Cell[TextData[{
 StyleBox["Caveat:",
  FontWeight->Bold],
 " Differences between WorldCover v100 and v200 may reflect classifier \
improvements rather than actual land cover change. For robust change \
detection, use a consistent product across years (e.g., MODIS MCD12Q1) or \
apply the same classifier to multi-temporal imagery."
}], "Text",
 CellFrame->{{True, False}, {
   False, False}},ExpressionUUID->"684ab1fa-cffd-174b-af82-ce240055a2a1"],

Cell[BoxData[{
 RowBox[{
  RowBox[{"lc2020", " ", "=", " ", 
   RowBox[{
    RowBox[{
     RowBox[{
      RowBox[{"GEECollection", "[", "\"\<ESA/WorldCover/v100\>\"", "]"}], " ",
       "//", "\n", "  ", 
      RowBox[{"GEEFilterDate", "[", 
       RowBox[{"\"\<2020-01-01\>\"", ",", " ", "\"\<2021-01-01\>\""}], 
       "]"}]}], " ", "//", "\n", "  ", "GEEMosaic"}], " ", "//", "\n", "  ", 
    RowBox[{"GEESelectBands", "[", 
     RowBox[{"{", "\"\<Map\>\"", "}"}], "]"}]}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"lc2021", " ", "=", " ", 
    RowBox[{
     RowBox[{
      RowBox[{
       RowBox[{"GEECollection", "[", "\"\<ESA/WorldCover/v200\>\"", "]"}], 
       " ", "//", "\n", "  ", 
       RowBox[{"GEEFilterDate", "[", 
        RowBox[{"\"\<2021-01-01\>\"", ",", " ", "\"\<2022-01-01\>\""}], 
        "]"}]}], " ", "//", "\n", "  ", "GEEMosaic"}], " ", "//", "\n", "  ", 
     RowBox[{"GEESelectBands", "[", 
      RowBox[{"{", "\"\<Map\>\"", "}"}], "]"}]}]}], ";"}], "\n", "\n", 
  RowBox[{"(*", " ", 
   RowBox[{
    RowBox[{
     RowBox[{"Classes", " ", "<", " ", "40"}], ":", " ", 
     RowBox[{"tree", " ", "cover"}]}], ",", " ", "shrubland", ",", " ", 
    "grassland", " ", "\[LongDash]", " ", 
    RowBox[{"cropland", " ", 
     RowBox[{"(", "40", ")"}], " ", "excluded"}]}], " ", "*)"}]}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"veg2020", " ", "=", " ", 
    RowBox[{"lc2020", " ", "//", " ", 
     RowBox[{"GEELessThan", "[", "40", "]"}]}]}], ";"}], "\n", "\n", 
  RowBox[{"(*", " ", 
   RowBox[{"Built", "-", 
    RowBox[{"up", " ", "in", " ", "2021"}]}], " ", "*)"}]}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"built2021", " ", "=", " ", 
    RowBox[{"lc2021", " ", "//", " ", 
     RowBox[{"GEEEquals", "[", "50", "]"}]}]}], ";"}], "\n", "\n", 
  RowBox[{"(*", " ", 
   RowBox[{
    RowBox[{
    "Pixels", " ", "that", " ", "changed", " ", "from", " ", "vegetation", " ",
      "to", " ", "built"}], "-", "up"}], " ", "*)"}]}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"vegToBuilt", " ", "=", " ", 
    RowBox[{
     RowBox[{"veg2020", " ", "//", " ", 
      RowBox[{"GEEAnd", "[", "built2021", "]"}]}], " ", "//", " ", 
     "GEESelfMask"}]}], ";"}], "\n"}], "\n", 
 RowBox[{"GEEImage", "[", "\n", "  ", 
  RowBox[{
   RowBox[{"GeoPosition", "[", 
    RowBox[{"{", 
     RowBox[{"30.05", ",", " ", "31.25"}], "}"}], "]"}], ",", "   ", 
   RowBox[{"(*", " ", "Cairo", " ", "*)"}], "\n", "  ", "vegToBuilt", ",", 
   "\n", "  ", 
   RowBox[{"GeoRange", " ", "->", " ", 
    RowBox[{"Quantity", "[", 
     RowBox[{"50", ",", " ", "\"\<Kilometers\>\""}], "]"}]}], ",", "\n", "  ", 
   RowBox[{"RasterSize", " ", "->", " ", 
    RowBox[{"{", 
     RowBox[{"1024", ",", " ", "1024"}], "}"}]}], ",", "\n", "  ", 
   RowBox[{"\"\<VisParams\>\"", " ", "->", " ", 
    RowBox[{"<|", 
     RowBox[{
      RowBox[{"\"\<min\>\"", " ", "->", " ", "0"}], ",", " ", 
      RowBox[{"\"\<max\>\"", " ", "->", " ", "1"}], ",", "\n", "    ", 
      RowBox[{"\"\<palette\>\"", " ", "->", " ", 
       RowBox[{"{", "\"\<#ff0000\>\"", "}"}]}]}], "|>"}]}]}], "\n", 
  "]"}]}], "Input",ExpressionUUID->"6f1f147a-5802-584c-964f-df68c9bd1149"],

Cell["\<\
Red pixels indicate locations where agricultural or natural vegetation was \
replaced by built-up surface. In rapidly urbanizing regions like the Nile \
Delta fringe, this pattern is clearly visible.\
\>", "Text",ExpressionUUID->"3f424e2c-edc4-5941-bbb2-513f878e54cf"]
}, Open  ]],

Cell[CellGroupData[{

Cell["NDVI Loss as Urbanization Proxy", "Section",ExpressionUUID->"7e8e8f91-12fc-8246-ba48-693c8aa5d2ff"],

Cell["\<\
Normalized Difference Vegetation Index (NDVI) decline between two dates \
serves as a reliable proxy for land conversion. Areas experiencing \
significant NDVI loss are likely undergoing urbanization or deforestation. \
For the fundamentals of NDVI computation and interpretation, see Section \
5.1.1.\
\>", "Text",ExpressionUUID->"b1071b91-0690-5c4b-8d19-55bd35eb29f1"],

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"makeNDVI", " ", "=", " ", 
    RowBox[{"Function", "[", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{"startDate", ",", " ", "endDate"}], "}"}], ",", "\n", "  ", 
      RowBox[{
       RowBox[{
        RowBox[{
         RowBox[{
          RowBox[{
           RowBox[{
           "GEECollection", "[", "\"\<COPERNICUS/S2_SR_HARMONIZED\>\"", "]"}],
            " ", "//", "\n", "    ", 
           RowBox[{"GEEFilterDate", "[", 
            RowBox[{"startDate", ",", " ", "endDate"}], "]"}]}], " ", "//", 
          "\n", "    ", 
          RowBox[{"GEEFilterBounds", "[", 
           RowBox[{"{", 
            RowBox[{
            "116.1", ",", " ", "39.7", ",", " ", "116.7", ",", " ", "40.1"}], 
            "}"}], "]"}]}], " ", "//", "\n", "    ", 
         RowBox[{"GEEFilterProperty", "[", 
          
          RowBox[{"\"\<CLOUDY_PIXEL_PERCENTAGE\>\"", ",", 
           " ", "\"\<LessThan\>\"", ",", " ", "10"}], "]"}]}], " ", "//", 
        "\n", "    ", "GEEMedian"}], " ", "//", "\n", "    ", 
       RowBox[{"GEENormalizedDifference", "[", 
        RowBox[{"{", 
         RowBox[{"\"\<B8\>\"", ",", " ", "\"\<B4\>\""}], "}"}], "]"}]}]}], 
     "\n", "]"}]}], ";"}], "\n"}], "\n", 
 RowBox[{
  RowBox[{"ndvi2019", " ", "=", " ", 
   RowBox[{"makeNDVI", "[", 
    RowBox[{"\"\<2019-06-01\>\"", ",", " ", "\"\<2019-09-01\>\""}], "]"}]}], 
  ";"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"ndvi2024", " ", "=", " ", 
    RowBox[{"makeNDVI", "[", 
     RowBox[{"\"\<2024-06-01\>\"", ",", " ", "\"\<2024-09-01\>\""}], "]"}]}], 
   ";"}], "\n", "\n", 
  RowBox[{"(*", " ", 
   RowBox[{
    RowBox[{"Negative", " ", "difference"}], " ", "=", " ", 
    RowBox[{"vegetation", " ", "loss"}]}], " ", "*)"}]}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"ndviChange", " ", "=", " ", 
    RowBox[{"ndvi2024", " ", "//", " ", 
     RowBox[{"GEESubtract", "[", "ndvi2019", "]"}]}]}], ";"}], "\n", "\n", 
  RowBox[{"(*", " ", 
   RowBox[{"Threshold", ":", " ", 
    RowBox[{
    "significant", " ", "loss", " ", "where", " ", "NDVI", " ", "dropped", " ",
      "by", " ", "more", " ", "than", " ", "0.2"}]}], " ", "*)"}]}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"significantLoss", " ", "=", " ", 
    RowBox[{
     RowBox[{"ndviChange", " ", "//", " ", 
      RowBox[{"GEELessThan", "[", 
       RowBox[{"-", "0.2"}], "]"}]}], " ", "//", " ", "GEESelfMask"}]}], 
   ";"}], "\n"}], "\n", 
 RowBox[{"GEEImage", "[", "\n", "  ", 
  RowBox[{
   RowBox[{"GeoPosition", "[", 
    RowBox[{"{", 
     RowBox[{"39.9", ",", " ", "116.4"}], "}"}], "]"}], ",", "   ", 
   RowBox[{"(*", " ", "Beijing", " ", "*)"}], "\n", "  ", "significantLoss", ",",
    "\n", "  ", 
   RowBox[{"GeoRange", " ", "->", " ", 
    RowBox[{"Quantity", "[", 
     RowBox[{"40", ",", " ", "\"\<Kilometers\>\""}], "]"}]}], ",", "\n", "  ", 
   RowBox[{"RasterSize", " ", "->", " ", 
    RowBox[{"{", 
     RowBox[{"1024", ",", " ", "1024"}], "}"}]}], ",", "\n", "  ", 
   RowBox[{"\"\<VisParams\>\"", " ", "->", " ", 
    RowBox[{"<|", 
     RowBox[{
      RowBox[{"\"\<min\>\"", " ", "->", " ", "0"}], ",", " ", 
      RowBox[{"\"\<max\>\"", " ", "->", " ", "1"}], ",", "\n", "    ", 
      RowBox[{"\"\<palette\>\"", " ", "->", " ", 
       RowBox[{"{", "\"\<#e31a1c\>\"", "}"}]}]}], "|>"}]}]}], "\n", 
  "]"}]}], "Input",ExpressionUUID->"a9be1936-03c1-a04c-ac9c-1abcb4ed92b1"],

Cell["\<\
Note: A decrease of 0.2 or more in NDVI is a commonly used threshold in the \
literature, though the optimal value depends on the land cover context and \
the time span between observations.\
\>", "Text",ExpressionUUID->"cb9ce95e-e65a-8a48-9e73-4a44777455b7"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Visualizing Change with a Continuous Map", "Section",ExpressionUUID->"f4159779-7669-9e4c-9a33-cad309bccfc6"],

Cell["\<\
Rather than a binary threshold, displaying the full range of NDVI change \
reveals both areas of vegetation loss and gain.\
\>", "Text",ExpressionUUID->"b5cd9f70-b3f1-7141-a8ad-6e55aa73316c"],

Cell[BoxData[
 RowBox[{"GEEImage", "[", "\n", "  ", 
  RowBox[{
   RowBox[{"GeoPosition", "[", 
    RowBox[{"{", 
     RowBox[{"39.9", ",", " ", "116.4"}], "}"}], "]"}], ",", "\n", "  ", 
   "ndviChange", ",", "\n", "  ", 
   RowBox[{"GeoRange", " ", "->", " ", 
    RowBox[{"Quantity", "[", 
     RowBox[{"40", ",", " ", "\"\<Kilometers\>\""}], "]"}]}], ",", "\n", "  ", 
   RowBox[{"RasterSize", " ", "->", " ", 
    RowBox[{"{", 
     RowBox[{"1024", ",", " ", "1024"}], "}"}]}], ",", "\n", "  ", 
   RowBox[{"\"\<VisParams\>\"", " ", "->", " ", 
    RowBox[{"<|", 
     RowBox[{
      RowBox[{"\"\<min\>\"", " ", "->", " ", 
       RowBox[{"-", "0.4"}]}], ",", " ", 
      RowBox[{"\"\<max\>\"", " ", "->", " ", "0.4"}], ",", "\n", "    ", 
      RowBox[{"\"\<palette\>\"", " ", "->", " ", 
       RowBox[{"{", 
        RowBox[{"\"\<#d73027\>\"", ",", " ", "\"\<#fc8d59\>\"", ",", 
         " ", "\"\<#fee08b\>\"", ",", "\n", "      ", "\"\<#d9ef8b\>\"", ",", 
         " ", "\"\<#91cf60\>\"", ",", " ", "\"\<#1a9850\>\""}], "}"}]}]}], 
     "|>"}]}]}], "\n", "]"}]], "Input",ExpressionUUID->"435c0b3e-57c5-a243-\
909d-cf3526d7fcbc"],

Cell["\<\
Red tones indicate vegetation loss (potential urbanization), while green \
tones indicate vegetation gain (reforestation or agricultural expansion).\
\>", "Text",ExpressionUUID->"6fb9326a-8990-4e4c-9b15-b0f7d7b8b838"],

Cell["", "Text",
 CellFrame->{{0, 0}, {0, 
  1}},ExpressionUUID->"222f2959-6c21-6a4e-85ac-3e7fddb5ddb0"]
