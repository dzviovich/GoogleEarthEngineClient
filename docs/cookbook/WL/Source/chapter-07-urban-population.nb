Cell[CellGroupData[{

Cell["7.7 Infrastructure and Transportation", "Chapter",ExpressionUUID->"c4f13cf0-f458-0c44-8ad4-6b0b2184b2a6"],

Cell["\<\
Urban infrastructure -- roads, buildings, and utilities -- shapes the spatial \
structure of cities. While dedicated vector datasets (e.g., OpenStreetMap) \
provide the most precise infrastructure maps, satellite imagery offers \
complementary information through texture and spectral analysis.\
\>", "Text",ExpressionUUID->"91d81d8f-1bf1-af46-91d8-e6dca0f896e2"],

Cell[CellGroupData[{

Cell["Texture Analysis with NAIP Imagery", "Section",ExpressionUUID->"1bcbf10b-b239-ca46-947f-0773a9cba1e7"],

Cell[TextData[{
 "The National Agriculture Imagery Program (NAIP) provides 1 m resolution \
aerial imagery for the continental United States. The ",
 Cell["GEEEntropy", "InlineCode",ExpressionUUID->
  "6c8e894b-a413-0d42-9b37-666f2d481650"],
 " function computes local Shannon entropy within a neighborhood, \
highlighting areas of high spatial complexity such as road networks, building \
edges, and industrial facilities."
}], "Text",ExpressionUUID->"e78873bf-d6f5-e64d-ba80-4a2f740a0458"],

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"naip", " ", "=", " ", 
    RowBox[{
     RowBox[{
      RowBox[{
       RowBox[{
        RowBox[{"GEECollection", "[", "\"\<USDA/NAIP/DOQQ\>\"", "]"}], " ", "//",
         "\n", "  ", 
        RowBox[{"GEEFilterDate", "[", 
         RowBox[{"\"\<2021-01-01\>\"", ",", " ", "\"\<2022-01-01\>\""}], 
         "]"}]}], " ", "//", "\n", "  ", 
       RowBox[{"GEEFilterBounds", "[", 
        RowBox[{"{", 
         RowBox[{
          RowBox[{"-", "122.45"}], ",", " ", "37.75", ",", " ", 
          RowBox[{"-", "122.38"}], ",", " ", "37.80"}], "}"}], "]"}]}], " ", "//",
       "\n", "  ", 
      RowBox[{"GEESelectBands", "[", 
       RowBox[{"{", "\"\<R\>\"", "}"}], "]"}]}], " ", "//", "\n", "  ", 
     "GEEMosaic"}]}], ";"}], "\n"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"entropy", " ", "=", " ", 
    RowBox[{
     RowBox[{"naip", " ", "//", " ", "GEEToInt"}], " ", "//", " ", 
     RowBox[{"GEEEntropy", "[", "30", "]"}]}]}], ";"}], "\n"}], "\n", 
 RowBox[{"GEEImage", "[", "\n", "  ", 
  RowBox[{
   RowBox[{"GeoPosition", "[", 
    RowBox[{"{", 
     RowBox[{"37.775", ",", " ", 
      RowBox[{"-", "122.415"}]}], "}"}], "]"}], ",", "\n", "  ", "entropy", ",",
    "\n", "  ", 
   RowBox[{"GeoRange", " ", "->", " ", 
    RowBox[{"Quantity", "[", 
     RowBox[{"5", ",", " ", "\"\<Kilometers\>\""}], "]"}]}], ",", "\n", "  ", 
   RowBox[{"RasterSize", " ", "->", " ", 
    RowBox[{"{", 
     RowBox[{"1024", ",", " ", "1024"}], "}"}]}], ",", "\n", "  ", 
   RowBox[{"\"\<VisParams\>\"", " ", "->", " ", 
    RowBox[{"<|", 
     RowBox[{
      RowBox[{"\"\<min\>\"", " ", "->", " ", "2"}], ",", " ", 
      RowBox[{"\"\<max\>\"", " ", "->", " ", "5"}], ",", "\n", "    ", 
      RowBox[{"\"\<palette\>\"", " ", "->", " ", 
       RowBox[{"{", 
        RowBox[{"\"\<#f7f7f7\>\"", ",", " ", "\"\<#969696\>\"", ",", 
         " ", "\"\<#252525\>\""}], "}"}]}]}], "|>"}]}]}], "\n", 
  "]"}]}], "Input",ExpressionUUID->"375ae223-7bb0-2742-8502-861eb9aeb206"],

Cell["\<\
High-entropy pixels (dark) correspond to complex texture: building clusters, \
freeway interchanges, and commercial districts. Low-entropy regions (light) \
correspond to uniform surfaces: water, parks, and open fields.\
\>", "Text",ExpressionUUID->"e41d2227-d0ef-6244-8db3-e13dec2c1a56"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Querying Feature Collections", "Section",ExpressionUUID->"29205c43-e86f-474f-b1d4-4560ad89d997"],

Cell[TextData[{
 "GEE hosts vector datasets as FeatureCollections. The ",
 Cell["GEEComputeFeatures", "InlineCode",ExpressionUUID->
  "24eb6ae1-e07d-9f48-9a93-f6472139ab7e"],
 " function queries these tables with spatial and attribute filters."
}], "Text",ExpressionUUID->"9fa7fddd-c73c-a149-b4a8-5a8e30ca5376"],

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{
   "Query", " ", "US", " ", "state", " ", "boundaries", " ", "for", " ", 
    "California"}], " ", "*)"}], "\n", 
  RowBox[{
   RowBox[{
    RowBox[{"features", " ", "=", " ", 
     RowBox[{"GEEComputeFeatures", "[", "\n", "  ", 
      RowBox[{"\"\<TIGER/2018/States\>\"", ",", "\n", 
       "  ", "\"\<NAME = 'California'\>\"", ",", "\n", "  ", 
       RowBox[{"\"\<MaxFeatures\>\"", " ", "->", " ", "1"}]}], "\n", "]"}]}], 
    ";"}], "\n", "\n", 
   RowBox[{"(*", " ", 
    RowBox[{
    "Extract", " ", "the", " ", "geometry", " ", "for", " ", "further", " ", 
     "analysis"}], " ", "*)"}], "\n", 
   RowBox[{"caGeometry", " ", "=", " ", 
    RowBox[{
     RowBox[{"features", "[", 
      RowBox[{"[", "1", "]"}], "]"}], "[", "\"\<geometry\>\"", 
     "]"}]}]}]}]], "Input",ExpressionUUID->"3c87feda-4ea3-654f-ac3d-\
08851409ee7f"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Wolfram Integration: GeoPath and GeoDistance", "Section",ExpressionUUID->"df0748b4-adab-a141-bfbd-0f59352f1915"],

Cell[TextData[{
 "For transportation analysis, Wolfram Language's ",
 Cell["GeoPath", "InlineCode",ExpressionUUID->
  "db3aaf57-858f-8643-bc34-b064672f275d"],
 " and ",
 Cell["GeoDistance", "InlineCode",ExpressionUUID->
  "8f926aa8-203c-ac4e-877e-b89eedf94616"],
 " provide geodesic routing and distance calculations that complement \
satellite-derived infrastructure maps."
}], "Text",ExpressionUUID->"f86bb1b5-bc85-484a-b844-3aadc1bd8fa4"],

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{"Great", "-", 
    RowBox[{
    "circle", " ", "path", " ", "and", " ", "distance", " ", "between", " ", 
     "two", " ", "urban", " ", "centers"}]}], " ", "*)"}], "\n", 
  RowBox[{
   RowBox[{
    RowBox[{"path", " ", "=", " ", 
     RowBox[{"GeoPath", "[", 
      RowBox[{"{", "\n", "  ", 
       RowBox[{
        RowBox[{"Entity", "[", 
         RowBox[{"\"\<City\>\"", ",", " ", 
          RowBox[{"{", 
           
           RowBox[{"\"\<LosAngeles\>\"", ",", " ", "\"\<California\>\"", ",", 
            " ", "\"\<UnitedStates\>\""}], "}"}]}], "]"}], ",", "\n", "  ", 
        RowBox[{"Entity", "[", 
         RowBox[{"\"\<City\>\"", ",", " ", 
          RowBox[{"{", 
           
           RowBox[{"\"\<SanFrancisco\>\"", ",", " ", "\"\<California\>\"", ",",
             " ", "\"\<UnitedStates\>\""}], "}"}]}], "]"}]}], "\n", "}"}], 
      "]"}]}], ";"}], "\n", "\n", 
   RowBox[{
    RowBox[{"dist", " ", "=", " ", 
     RowBox[{"GeoDistance", "[", "\n", "  ", 
      RowBox[{
       RowBox[{"Entity", "[", 
        RowBox[{"\"\<City\>\"", ",", " ", 
         RowBox[{"{", 
          
          RowBox[{"\"\<LosAngeles\>\"", ",", " ", "\"\<California\>\"", ",", 
           " ", "\"\<UnitedStates\>\""}], "}"}]}], "]"}], ",", "\n", "  ", 
       RowBox[{"Entity", "[", 
        RowBox[{"\"\<City\>\"", ",", " ", 
         RowBox[{"{", 
          
          RowBox[{"\"\<SanFrancisco\>\"", ",", " ", "\"\<California\>\"", ",",
            " ", "\"\<UnitedStates\>\""}], "}"}]}], "]"}]}], "\n", "]"}]}], 
    ";"}], "\n", "\n", 
   RowBox[{"GeoGraphics", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"Thick", ",", " ", "Red", ",", " ", "path"}], "}"}], ",", "\n", 
     "  ", 
     RowBox[{"GeoRange", " ", "->", " ", "\"\<California\>\""}], ",", "\n", 
     "  ", 
     RowBox[{"GeoBackground", " ", "->", " ", "\"\<StreetMap\>\""}]}], "\n", 
    "]"}]}]}]], "Input",ExpressionUUID->"b813eb9f-4bae-ef41-b56c-\
26cb71f59aa8"],

