Cell[TextData[StyleBox["Step 5: Apply the classifier to new locations.",
 FontWeight->Bold]], "Text",ExpressionUUID->"7e39e807-a93d-b74b-9377-\
e4d7b0fa894e"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"newPoints", " ", "=", " ", 
    RowBox[{"{", "\n", "  ", 
     RowBox[{
      RowBox[{"GeoPosition", "[", 
       RowBox[{"{", 
        RowBox[{"45.50", ",", " ", "12.00"}], "}"}], "]"}], ",", "\n", "  ", 
      RowBox[{"GeoPosition", "[", 
       RowBox[{"{", 
        RowBox[{"46.10", ",", " ", "11.20"}], "}"}], "]"}], ",", "\n", "  ", 
      RowBox[{"GeoPosition", "[", 
       RowBox[{"{", 
        RowBox[{"45.00", ",", " ", "11.90"}], "}"}], "]"}]}], "\n", "}"}]}], 
   ";"}], "\n"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"newSamples", " ", "=", " ", 
    RowBox[{"GEEGetSamples", "[", 
     RowBox[{"newPoints", ",", " ", "sentinel2", ",", "\n", "  ", 
      RowBox[{
       RowBox[{
        RowBox[{"\"\<Bands\>\"", " ", "->", " ", 
         RowBox[{"(", 
          RowBox[{"#", "<>", "\"\<_median\>\""}], ")"}]}], "&"}], "/@", 
       RowBox[{"{", 
        RowBox[{"\"\<B2\>\"", ",", " ", "\"\<B3\>\"", ",", " ", "\"\<B4\>\"", 
         ",", " ", "\"\<B5\>\"", ",", " ", "\"\<B6\>\"", ",", 
         " ", "\"\<B7\>\"", ",", " ", "\"\<B8\>\"", ",", " ", "\"\<B8A\>\"", ",",
          "\n", "    ", "\"\<B11\>\"", ",", " ", "\"\<B12\>\""}], "}"}]}]}], 
     "]"}]}], ";"}], "\n"}], "\n", 
 RowBox[{"predictions", " ", "=", " ", 
  RowBox[{"classifier", " ", "/@", " ", 
   RowBox[{"(", 
    RowBox[{"newSamples", "[", 
     RowBox[{"[", 
      RowBox[{"All", ",", " ", "\"\<Values\>\""}], "]"}], "]"}], ")"}]}]}], "\n", 
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{"e", ".", "g", ".", " ", 
    RowBox[{"{", 
     RowBox[{"\"\<Water\>\"", ",", " ", "\"\<Forest\>\"", ",", 
      " ", "\"\<Crop\>\""}], "}"}]}], " ", "*)"}]}]}], "Input",
 CellChangeTimes->{3.9871896419197083`*^9},
 CellLabel->"In[24]:=",ExpressionUUID->"edd8b921-57a9-1442-ab67-0caaad8e7ead"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{"\<\"Bare\"\>", ",", "\<\"Forest\"\>", ",", "\<\"Bare\"\>"}], 
  "}"}]], "Output",
 CellChangeTimes->{3.987189644235018*^9, 3.987495546378927*^9},
 CellLabel->"Out[26]=",ExpressionUUID->"8f4bc887-b338-8642-83b2-f4aeae6f5e73"]
}, Open  ]]
}, Open  ]],

Cell[CellGroupData[{

Cell["Unsupervised Clustering", "Section",ExpressionUUID->"d68a9912-9819-234b-8cb1-170a7ccd5ff9"],

Cell[TextData[{
 "When you do not have labeled training data, ",
 Cell["FindClusters", "InlineCode",ExpressionUUID->
  "301702c8-3a3a-334d-a1d8-1f9c38809354"],
 " can discover natural groupings in spectral space. This is useful for \
exploratory analysis to understand what surface types exist in a scene."
}], "Text",ExpressionUUID->"6e8c732e-6b95-d64d-8167-5af46d18f3ad"],

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{
   "Sample", " ", "a", " ", "grid", " ", "of", " ", "points", " ", "across", " ",
     "a", " ", "region"}], " ", "*)"}], "\n", 
  RowBox[{
   RowBox[{
    RowBox[{"gridPoints", " ", "=", " ", 
     RowBox[{"Flatten", "[", "\n", "  ", 
      RowBox[{"Table", "[", "\n", "    ", 
       RowBox[{
        RowBox[{"GeoPosition", "[", 
         RowBox[{"{", 
          RowBox[{"lat", ",", " ", "lon"}], "}"}], "]"}], ",", "\n", "    ", 
        RowBox[{"{", 
         RowBox[{
         "lat", ",", " ", "45.0", ",", " ", "45.5", ",", " ", "0.05"}], "}"}],
         ",", "\n", "    ", 
        RowBox[{"{", 
         RowBox[{
         "lon", ",", " ", "11.0", ",", " ", "11.5", ",", " ", "0.05"}], 
         "}"}]}], "\n", "  ", "]"}], "\n", "]"}]}], ";"}], "\n", "\n", 
   RowBox[{
    RowBox[{"gridSamples", " ", "=", " ", 
     RowBox[{"GEEGetSamples", "[", 
      RowBox[{"gridPoints", ",", " ", "sentinel2", ",", "\n", "  ", 
       RowBox[{
        RowBox[{
         RowBox[{"\"\<Bands\>\"", " ", "->", " ", 
          RowBox[{"(", 
           RowBox[{"#", "<>", "\"\<_median\>\""}], ")"}]}], "&"}], "/@", 
        RowBox[{"{", 
         RowBox[{"\"\<B2\>\"", ",", " ", "\"\<B3\>\"", ",", " ", "\"\<B4\>\"",
           ",", " ", "\"\<B5\>\"", ",", " ", "\"\<B6\>\"", ",", 
          " ", "\"\<B7\>\"", ",", " ", "\"\<B8\>\"", ",", " ", "\"\<B11\>\"", 
          ",", " ", "\"\<B12\>\""}], "}"}]}]}], "]"}]}], ";"}], "\n", "\n", 
   RowBox[{
    RowBox[{"spectralVectors", " ", "=", " ", 
     RowBox[{"gridSamples", "[", 
      RowBox[{"[", 
       RowBox[{"All", ",", " ", "\"\<Values\>\""}], "]"}], "]"}]}], ";"}], 
   "\n", "\n", 
   RowBox[{"(*", " ", 
    RowBox[{"Cluster", " ", "into", " ", "5", " ", "groups"}], " ", "*)"}], "\n", 
   RowBox[{
    RowBox[{"clusters", " ", "=", " ", 
     RowBox[{"FindClusters", "[", 
      RowBox[{"spectralVectors", ",", " ", "5", ",", " ", 
       RowBox[{"Method", " ", "->", " ", "\"\<KMeans\>\""}]}], "]"}]}], 
    ";"}]}]}]], "Input",
 CellChangeTimes->{3.9871896554091682`*^9},
 CellLabel->"In[27]:=",ExpressionUUID->"175ee68c-6b2e-f04a-9b20-1948969e1504"],

Cell[TextData[StyleBox["Visualize the spectral space with dimensionality \
reduction.",
 FontWeight->Bold]], "Text",ExpressionUUID->"ef565a88-e9b6-6943-b123-\
d0e8560eb9fe"],

Cell["\<\
Reducing to 2 or 3 dimensions helps you see whether the clusters are well \
separated, which indicates distinct surface types.\
\>", "Text",ExpressionUUID->"504d70af-232e-3d41-b1c3-800df3a18493"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"reduced", " ", "=", " ", 
    RowBox[{"DimensionReduce", "[", 
     RowBox[{"spectralVectors", ",", " ", "2", ",", "\n", "  ", 
      RowBox[{
      "Method", " ", "->", " ", "\"\<PrincipalComponentsAnalysis\>\""}]}], 
     "]"}]}], ";"}], "\n", "\n", 
  RowBox[{"(*", " ", 
   RowBox[{
   "Assign", " ", "cluster", " ", "labels", " ", "to", " ", "each", " ", 
    "point"}], " ", "*)"}]}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"clusterLabels", " ", "=", " ", 
    RowBox[{"FindClusters", "[", "\n", "  ", 
     RowBox[{
      RowBox[{"spectralVectors", " ", "->", " ", 
       RowBox[{"Range", "[", 
        RowBox[{"Length", "[", "spectralVectors", "]"}], "]"}]}], ",", " ", 
      "5"}], "\n", "]"}]}], ";"}], "\n", 
  RowBox[{"(*", " ", 
   RowBox[{
    RowBox[{
    "clusterLabels", " ", "is", " ", "a", " ", "list", " ", "of", " ", 
     "groups", " ", "of", " ", 
     RowBox[{"indices", " ", "--"}], " ", "flatten", " ", "to", " ", "per"}], 
    "-", 
    RowBox[{"point", " ", "labels"}]}], " ", "*)"}]}], "\n", 
 RowBox[{
  RowBox[{"pointLabels", " ", "=", " ", 
   RowBox[{"ConstantArray", "[", 
    RowBox[{"0", ",", " ", 
     RowBox[{"Length", "[", "spectralVectors", "]"}]}], "]"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"Do", "[", "\n", "  ", 
    RowBox[{
     RowBox[{
      RowBox[{
       RowBox[{"(", 
        RowBox[{
         RowBox[{"pointLabels", "[", 
          RowBox[{"[", "#", "]"}], "]"}], " ", "=", " ", "k"}], ")"}], " ", 
       "&"}], " ", "/@", " ", 
      RowBox[{"clusterLabels", "[", 
       RowBox[{"[", "k", "]"}], "]"}]}], ",", "\n", "  ", 
     RowBox[{"{", 
      RowBox[{"k", ",", " ", 
       RowBox[{"Length", "[", "clusterLabels", "]"}]}], "}"}]}], "\n", "]"}], 
   ";"}], "\n", "\n", 
  RowBox[{"(*", " ", 
   RowBox[{
    RowBox[{"Note", ":", " ", 
     RowBox[{"This", " ", "is", " ", "a", " ", "conceptual", " ", 
      RowBox[{"sketch", ".", " ", "FindClusters"}], " ", "returns", " ", 
      "groups", " ", "of", " ", "indices"}]}], ",", "\n", "   ", 
    RowBox[{
     RowBox[{"not", " ", "per"}], "-", 
     RowBox[{"point", " ", 
      RowBox[{"labels", ".", " ", "The"}], " ", "loop", " ", "above", " ", 
      "converts", " ", "groups", " ", "to", " ", "per"}], "-", 
     RowBox[{"point", " ", "labels", "\n", "   ", "for", " ", 
      RowBox[{"plotting", "."}]}]}]}], " ", "*)"}], "\n"}], "\n", 
 RowBox[{"ListPlot", "[", "\n", "  ", 
  RowBox[{
   RowBox[{"Table", "[", "\n", "    ", 
    RowBox[{
     RowBox[{"Pick", "[", 
      RowBox[{"reduced", ",", " ", "pointLabels", ",", " ", "k"}], "]"}], ",",
      "\n", "    ", 
     RowBox[{"{", 
      RowBox[{"k", ",", " ", 
       RowBox[{"Length", "[", "clusterLabels", "]"}]}], "}"}]}], "\n", "  ", 
    "]"}], ",", "\n", "  ", 
   RowBox[{"PlotLabel", " ", "->", " ", "\"\<Spectral Space (PCA)\>\""}], ",",
    "\n", "  ", 
   RowBox[{"FrameLabel", " ", "->", " ", 
    RowBox[{"{", 
     RowBox[{"\"\<PC1\>\"", ",", " ", "\"\<PC2\>\""}], "}"}]}], ",", "\n", 
   "  ", 
   RowBox[{"PlotLegends", " ", "->", " ", 
    RowBox[{"Range", "[", 
     RowBox[{"Length", "[", "clusterLabels", "]"}], "]"}]}]}], "\n", 
  "]"}]}], "Input",
 CellChangeTimes->{{3.9871913123966465`*^9, 3.9871913380530434`*^9}},
 CellLabel->"In[31]:=",ExpressionUUID->"62cf58af-5d5a-e44b-bf4d-f839e489cf03"],

