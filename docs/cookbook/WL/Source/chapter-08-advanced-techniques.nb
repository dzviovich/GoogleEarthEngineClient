Cell[TextData[{
 StyleBox["Note:",
  FontWeight->Bold],
 " This minimal training set (5 points per class, 25 total) is for \
illustration only. Production classifications require 50+ samples per class \
with stratified sampling."
}], "Text",
 CellFrame->{{True, False}, {False, False}},
 CellChangeTimes->{{3.987495474478174*^9, 
  3.9874954806632614`*^9}},ExpressionUUID->"7057c65d-a406-d841-bdec-\
4730590e9262"],

Cell[TextData[StyleBox["Step 2: Build a cloud-free Sentinel-2 composite and \
extract spectral values.",
 FontWeight->Bold]], "Text",ExpressionUUID->"8e617298-3bfc-6143-b49c-\
918f920a32c8"],

Cell["\<\
The pipeline selects bands B2 through B12 (visible, red edge, NIR, SWIR) \
because these carry the spectral information that distinguishes land cover \
types.\
\>", "Text",ExpressionUUID->"3614328d-b093-fd48-8b81-871199ceb721"],

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"sentinel2", " ", "=", "\n", "  ", 
    RowBox[{
     RowBox[{
      RowBox[{
       RowBox[{
        RowBox[{
        "GEECollection", "[", "\"\<COPERNICUS/S2_SR_HARMONIZED\>\"", "]"}], 
        " ", "//", "\n", "    ", 
        RowBox[{"GEEFilterDate", "[", 
         RowBox[{"\"\<2024-06-01\>\"", ",", " ", "\"\<2024-09-01\>\""}], 
         "]"}]}], " ", "//", "\n", "    ", 
       RowBox[{"GEEFilterProperty", "[", 
        RowBox[{"\"\<CLOUDY_PIXEL_PERCENTAGE\>\"", ",", 
         " ", "\"\<LessThan\>\"", ",", " ", "10"}], "]"}]}], " ", "//", "\n", 
      "    ", 
      RowBox[{"GEESelectBands", "[", 
       RowBox[{"{", 
        RowBox[{"\"\<B2\>\"", ",", " ", "\"\<B3\>\"", ",", " ", "\"\<B4\>\"", 
         ",", " ", "\"\<B5\>\"", ",", " ", "\"\<B6\>\"", ",", 
         " ", "\"\<B7\>\"", ",", " ", "\"\<B8\>\"", ",", " ", "\"\<B8A\>\"", ",",
          "\n", "      ", "\"\<B11\>\"", ",", " ", "\"\<B12\>\""}], "}"}], 
       "]"}]}], " ", "//", "\n", "    ", "GEEMedian"}]}], ";"}], "\n", "\n", 
  RowBox[{"(*", " ", 
   RowBox[{
   "Extract", " ", "band", " ", "values", " ", "at", " ", "all", " ", 
    "training", " ", "points"}], " ", "*)"}]}], "\n", 
 RowBox[{
  RowBox[{"samples", " ", "=", " ", 
   RowBox[{"GEEGetSamples", "[", "\n", "  ", 
    RowBox[{
     RowBox[{"trainingPoints", "[", 
      RowBox[{"[", 
       RowBox[{"All", ",", " ", "1"}], "]"}], "]"}], ",", "\n", "  ", 
     "sentinel2", ",", "\n", "  ", 
     RowBox[{
      RowBox[{
       RowBox[{"\"\<Bands\>\"", " ", "->", 
        RowBox[{"(", 
         RowBox[{"#", "<>", "\"\<_median\>\""}], ")"}]}], "&"}], "/@", " ", 
      RowBox[{"{", 
       RowBox[{"\"\<B2\>\"", ",", " ", "\"\<B3\>\"", ",", " ", "\"\<B4\>\"", ",",
         " ", "\"\<B5\>\"", ",", " ", "\"\<B6\>\"", ",", " ", "\"\<B7\>\"", ",",
         " ", "\"\<B8\>\"", ",", " ", "\"\<B8A\>\"", ",", "\n", 
        "    ", "\"\<B11\>\"", ",", " ", "\"\<B12\>\""}], "}"}]}]}], "\n", 
    "]"}]}], ";"}]}], "Input",
 CellChangeTimes->{
  3.987189610119627*^9, {3.9874945963697033`*^9, 3.9874946138844547`*^9}, 
   3.9874946626769924`*^9},
 CellLabel->"In[16]:=",ExpressionUUID->"a0210742-d6e9-324c-a9d7-a206f67a4711"],

Cell[TextData[StyleBox["Step 3: Build training data and train a classifier.",
 FontWeight->Bold]], "Text",ExpressionUUID->"6acc548a-073e-e74e-8296-\
1cebe215dbce"],

Cell[TextData[{
 "The ",
 Cell["Classify", "InlineCode",ExpressionUUID->
  "4a4e2f44-236e-094f-90c0-6424a28b819c"],
 " function accepts training data as ",
 Cell["{feature -> label, ...}", "InlineCode",ExpressionUUID->
  "6b1c55c4-fcc8-d64f-88ab-cfde03fe9857"],
 " rules. Each feature vector is the list of band values for that pixel."
}], "Text",ExpressionUUID->"61bcebee-2116-aa46-a8bf-6ef2c5f3cff8"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{"Pair", " ", "each", " ", 
    RowBox[{"sample", "'"}], "s", " ", "spectral", " ", "values", " ", "with",
     " ", "its", " ", "label"}], " ", "*)"}], "\n", 
  RowBox[{
   RowBox[{
    RowBox[{"trainingData", " ", "=", " ", 
     RowBox[{"MapThread", "[", "\n", "  ", 
      RowBox[{
       RowBox[{
        RowBox[{
         RowBox[{"#1", "[", "\"\<Values\>\"", "]"}], " ", "->", " ", "#2"}], 
        " ", "&"}], ",", "\n", "  ", 
       RowBox[{"{", 
        RowBox[{"samples", ",", " ", 
         RowBox[{"trainingPoints", "[", 
          RowBox[{"[", 
           RowBox[{"All", ",", " ", "2"}], "]"}], "]"}]}], "}"}]}], "\n", 
      "]"}]}], ";"}], "\n", "\n", 
   RowBox[{"(*", " ", 
    RowBox[{"Train", " ", "with", " ", "Random", " ", "Forest"}], " ", "*)"}],
    "\n", 
   RowBox[{"classifier", " ", "=", " ", 
    RowBox[{"Classify", "[", 
     RowBox[{"trainingData", ",", " ", 
      RowBox[{"Method", " ", "->", " ", "\"\<RandomForest\>\""}]}], 
     "]"}]}]}]}]], "Input",
 CellChangeTimes->{{3.987494865797127*^9, 3.987494886306652*^9}},
 CellLabel->"In[18]:=",ExpressionUUID->"a48677c2-6b29-0f49-86d0-d8b3be9c66c9"],

