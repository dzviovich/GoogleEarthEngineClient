 ", and ",
 Cell["FindClusters", "InlineCode",ExpressionUUID->
  "3ea522e3-0073-3140-8c60-aadb80e6c01a"],
 " applied to spectral data extracted via ",
 Cell["GEEGetSamples", "InlineCode",ExpressionUUID->
  "cf582203-464f-a94c-a546-da8135d4a539"],
 "."
}], "Item",ExpressionUUID->"91eb829b-92e5-b542-be4e-0bb28d817734"],

