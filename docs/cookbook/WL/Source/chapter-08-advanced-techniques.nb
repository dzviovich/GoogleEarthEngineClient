 StyleBox["Reproducible notebooks",
  FontWeight->Bold],
 " structured with clear sections for setup, parameters, acquisition, \
analysis, visualization, and export."
}], "Item",ExpressionUUID->"9fc25d16-5605-5e41-834b-ed63cb0b3c3a"],

