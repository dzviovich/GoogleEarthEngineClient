Cell[CellGroupData[{

Cell["Regression: Predicting Biomass from Spectral Indices", "Section",ExpressionUUID->"ea1abcfc-0b6d-8e48-83fe-e1e75396b8dd"],

Cell[TextData[{
 "For continuous target variables such as biomass, crop yield, or soil \
moisture, use ",
 Cell["Predict", "InlineCode",ExpressionUUID->
  "bcf943ef-44a3-5348-a965-0af9d335d534"],
 " instead of ",
 Cell["Classify", "InlineCode",ExpressionUUID->
  "d7e01132-d236-6b4b-acd2-51e5b57b213c"],
 "."
}], "Text",ExpressionUUID->"fcace796-497a-6649-adac-d1c838d714f7"],

