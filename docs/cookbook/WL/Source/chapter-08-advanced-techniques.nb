Cell["\<\
To extract the spectral indices from GEE for the prediction input:\
\>", "Text",ExpressionUUID->"7cca0b21-5b7e-144e-bfc1-52e9006eb786"],

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"ndviImage", " ", "=", "\n", "  ", 
    RowBox[{
     RowBox[{"sentinel2", " ", "//", "\n", "    ", 
      RowBox[{"GEENormalizedDifference", "[", 
       RowBox[{"{", 
        RowBox[{"\"\<B8_median\>\"", ",", " ", "\"\<B4_median\>\""}], "}"}], 
       "]"}]}], " ", "//", "\n", "    ", 
     RowBox[{"GEERename", "[", 
      RowBox[{"{", "\"\<NDVI\>\"", "}"}], "]"}]}]}], ";"}], "\n"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"eviImage", " ", "=", "\n", "  ", 
    RowBox[{
     RowBox[{"sentinel2", " ", "//", "\n", "    ", 
      RowBox[{"GEEExpression", "[", "\n", "      ", 
       RowBox[{"\"\<2.5 * ((NIR - RED) / (NIR + 6 * RED - 7.5 * BLUE + \
1))\>\"", ",", "\n", "      ", 
        RowBox[{"<|", 
         RowBox[{
          RowBox[{"\"\<NIR\>\"", " ", "->", " ", "\"\<B8_median\>\""}], ",", 
          " ", 
          RowBox[{"\"\<RED\>\"", " ", "->", " ", "\"\<B4_median\>\""}], ",", 
          " ", 
          RowBox[{"\"\<BLUE\>\"", " ", "->", " ", "\"\<B2_median\>\""}]}], 
         "|>"}]}], "\n", "    ", "]"}]}], " ", "//", "\n", "    ", 
     RowBox[{"GEERename", "[", 
      RowBox[{"{", "\"\<EVI\>\"", "}"}], "]"}]}]}], ";"}], "\n"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"ndwiImage", " ", "=", "\n", "  ", 
    RowBox[{
     RowBox[{"sentinel2", " ", "//", "\n", "    ", 
      RowBox[{"GEENormalizedDifference", "[", 
       RowBox[{"{", 
        RowBox[{"\"\<B3_median\>\"", ",", " ", "\"\<B8_median\>\""}], "}"}], 
       "]"}]}], " ", "//", "\n", "    ", 
     RowBox[{"GEERename", "[", 
      RowBox[{"{", "\"\<NDWI\>\"", "}"}], "]"}]}]}], ";"}], "\n"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"indexStack", " ", "=", "\n", "  ", 
    RowBox[{
     RowBox[{"ndviImage", " ", "//", "\n", "    ", 
      RowBox[{"GEEAddBands", "[", "eviImage", "]"}]}], " ", "//", "\n", 
     "    ", 
     RowBox[{"GEEAddBands", "[", "ndwiImage", "]"}]}]}], ";"}], "\n", 
  "\[IndentingNewLine]", 
  RowBox[{"(*", 
   RowBox[{
   "Create", " ", "a", " ", "dense", " ", "sampling", " ", "grid", " ", 
    "within", " ", "a", " ", "field"}], "*)"}]}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"fieldPoints", "=", 
    RowBox[{"Flatten", "[", 
     RowBox[{
      RowBox[{"Table", "[", 
       RowBox[{
        RowBox[{"GeoPosition", "[", 
         RowBox[{"{", 
          RowBox[{"lat", ",", "lon"}], "}"}], "]"}], ",", 
        RowBox[{"{", 
         RowBox[{"lat", ",", "32.92", ",", "32.97", ",", "0.005"}], "}"}], ",", 
        RowBox[{"{", 
         RowBox[{"lon", ",", 
          RowBox[{"-", "84.1"}], ",", 
          RowBox[{"-", "84.02"}], ",", "0.005"}], "}"}]}], "]"}], ",", "1"}], 
     "]"}]}], ";"}], "\n"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"fieldSamples", " ", "=", " ", 
    RowBox[{"GEEGetSamples", "[", 
     RowBox[{"fieldPoints", ",", " ", "indexStack", ",", "\n", "  ", 
      RowBox[{"\"\<Bands\>\"", " ", "->", " ", 
       RowBox[{"{", 
        RowBox[{"\"\<NDVI\>\"", ",", " ", "\"\<EVI\>\"", ",", 
         " ", "\"\<NDWI\>\""}], "}"}]}]}], "]"}]}], ";"}], 
  "\n"}], "\n"}], "Input",
 CellChangeTimes->{{3.9871919549462795`*^9, 3.987191984343178*^9}, {
   3.9871930016351624`*^9, 3.987193012345804*^9}, {3.987193587398945*^9, 
   3.987193695707199*^9}, {3.987497514299837*^9, 3.987497547570402*^9}, {
   3.987498038971216*^9, 3.9874983805371017`*^9}, {3.9874984744392395`*^9, 
