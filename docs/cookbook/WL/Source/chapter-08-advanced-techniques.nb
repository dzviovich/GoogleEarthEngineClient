Cell[CellGroupData[{

Cell["Summary", "Chapter",ExpressionUUID->"8d10f1c2-3f72-4749-a214-6e0afe8912e7"],

Cell["\<\
This chapter demonstrated how GEE data acquisition and the Wolfram Language's \
analytical capabilities combine to support end-to-end scientific workflows:\
\>", "Text",ExpressionUUID->"a26c5c77-c552-564c-9bfb-7441ddc44e2d"],

Cell[TextData[{
 StyleBox["Machine learning",
  FontWeight->Bold],
 " with ",
 Cell["Classify", "InlineCode",ExpressionUUID->
  "8c5ca3bb-8744-fd40-8595-8c7e449fa330"],
 ", ",
