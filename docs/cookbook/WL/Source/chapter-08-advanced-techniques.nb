Cell[CellGroupData[{

Cell["8.4 Geographic Visualization", "Chapter",ExpressionUUID->"f73cb94f-d390-e643-b2b3-28d48b1491e6"],

Cell["\<\
The Wolfram Language's geographic visualization functions integrate naturally \
with GEE data, enabling everything from simple point overlays to interactive \
multi-panel dashboards.\
\>", "Text",ExpressionUUID->"027efdc6-2787-9d41-b232-53a046a3245d"],

Cell[CellGroupData[{

Cell["GeoGraphics and GEEGeoGraphics", "Section",ExpressionUUID->"dfd93ac0-f63f-0443-8c84-5050efaebf55"],

Cell[TextData[{
 Cell["GEEGeoGraphics", "InlineCode",ExpressionUUID->
  "e4f0ab6e-0bf8-3344-9028-8876cf4bdff1"],
 " places Wolfram Language geographic primitives on top of a GEE satellite \
basemap instead of the default map tiles."
}], "Text",ExpressionUUID->"7106f206-8cdf-9142-94b7-fdb1ab419c10"],

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{
   "Sample", " ", "points", " ", "overlaid", " ", "on", " ", "a", " ", "GEE", 
    " ", "satellite", " ", "background"}], " ", "*)"}], "\n", 
  RowBox[{
   RowBox[{
    RowBox[{"sampleLocations", " ", "=", " ", 
     RowBox[{"{", "\n", "  ", 
      RowBox[{
       RowBox[{"GeoPosition", "[", 
        RowBox[{"{", 
         RowBox[{"40.42", ",", " ", 
          RowBox[{"-", "3.70"}]}], "}"}], "]"}], ",", "\n", "  ", 
       RowBox[{"GeoPosition", "[", 
        RowBox[{"{", 
         RowBox[{"40.45", ",", " ", 
          RowBox[{"-", "3.68"}]}], "}"}], "]"}], ",", "\n", "  ", 
       RowBox[{"GeoPosition", "[", 
        RowBox[{"{", 
         RowBox[{"40.40", ",", " ", 
          RowBox[{"-", "3.72"}]}], "}"}], "]"}]}], "\n", "}"}]}], ";"}], "\n",
    "\n", 
   RowBox[{"GEEGeoGraphics", "[", "\n", "  ", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"Red", ",", " ", 
       RowBox[{"PointSize", "[", "Large", "]"}], ",", " ", 
       RowBox[{"Point", " ", "/@", " ", "sampleLocations"}]}], "}"}], ",", 
     "\n", "  ", 
     RowBox[{
      RowBox[{
       RowBox[{
        RowBox[{
         RowBox[{
          RowBox[{
          "GEECollection", "[", "\"\<COPERNICUS/S2_SR_HARMONIZED\>\"", "]"}], 
          " ", "//", "\n", "    ", 
          RowBox[{"GEEFilterDate", "[", 
           RowBox[{"\"\<2024-06-01\>\"", ",", " ", "\"\<2024-08-31\>\""}], 
           "]"}]}], " ", "//", "\n", "    ", 
         RowBox[{"GEEFilterProperty", "[", 
          
          RowBox[{"\"\<CLOUDY_PIXEL_PERCENTAGE\>\"", ",", 
           " ", "\"\<LessThan\>\"", ",", " ", "10"}], "]"}]}], " ", "//", 
        "\n", "    ", 
        RowBox[{"GEESelectBands", "[", 
         RowBox[{"{", 
          
          RowBox[{"\"\<B4\>\"", ",", " ", "\"\<B3\>\"", ",", 
           " ", "\"\<B2\>\""}], "}"}], "]"}]}], " ", "//", "\n", "    ", 
       "GEEMedian"}], " ", "//", "\n", "    ", 
      RowBox[{"GEEVisualize", "[", 
       RowBox[{"<|", 
        RowBox[{
         RowBox[{"\"\<min\>\"", " ", "->", " ", "0"}], ",", " ", 
         RowBox[{"\"\<max\>\"", " ", "->", " ", "3000"}]}], "|>"}], "]"}]}], ",",
      "\n", "  ", 
     RowBox[{"GeoRange", " ", "->", " ", 
      RowBox[{"Quantity", "[", 
       RowBox[{"15", ",", " ", "\"\<Kilometers\>\""}], "]"}]}], ",", "\n", 
     "  ", 
     RowBox[{"GeoCenter", " ", "->", " ", 
      RowBox[{"GeoPosition", "[", 
       RowBox[{"{", 
        RowBox[{"40.42", ",", " ", 
         RowBox[{"-", "3.70"}]}], "}"}], "]"}]}], ",", "\n", "  ", 
     RowBox[{"ImageSize", " ", "->", " ", "600"}]}], "\n", "]"}]}]}]], "Input",\
ExpressionUUID->"26ce0af6-477b-9a4c-b210-9abbbadb9b68"],

Cell[TextData[{
 "For standard basemaps (without GEE imagery), use the built-in ",
 Cell["GeoGraphics", "InlineCode",ExpressionUUID->
  "12736eaf-bdaa-2847-a1e5-4d1f32e89748"],
 ":"
}], "Text",ExpressionUUID->"23b4d378-5acb-7c48-ba59-0ded3c0ba678"],

Cell[BoxData[
 RowBox[{"GeoGraphics", "[", "\n", "  ", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{"Red", ",", " ", 
     RowBox[{"PointSize", "[", "Large", "]"}], ",", " ", 
     RowBox[{"Point", " ", "/@", " ", "sampleLocations"}], ",", "\n", "   ", 
     RowBox[{"EdgeForm", "[", 
      RowBox[{"{", 
       RowBox[{"Thick", ",", " ", "Blue"}], "}"}], "]"}], ",", " ", 
     RowBox[{"FaceForm", "[", "None", "]"}], ",", "\n", "   ", 
     RowBox[{"Polygon", "[", 
      RowBox[{"GeoPosition", "[", 
       RowBox[{"{", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{"40.41", ",", " ", 
           RowBox[{"-", "3.71"}]}], "}"}], ",", " ", 
         RowBox[{"{", 
          RowBox[{"40.43", ",", " ", 
           RowBox[{"-", "3.71"}]}], "}"}], ",", "\n", "     ", 
         RowBox[{"{", 
          RowBox[{"40.43", ",", " ", 
           RowBox[{"-", "3.69"}]}], "}"}], ",", " ", 
         RowBox[{"{", 
          RowBox[{"40.41", ",", " ", 
           RowBox[{"-", "3.69"}]}], "}"}]}], "}"}], "]"}], "]"}]}], "\n", 
    "  ", "}"}], ",", "\n", "  ", 
   RowBox[{"GeoRange", " ", "->", " ", 
    RowBox[{"Quantity", "[", 
     RowBox[{"10", ",", " ", "\"\<Kilometers\>\""}], "]"}]}], ",", "\n", "  ", 
   RowBox[{"GeoCenter", " ", "->", " ", 
    RowBox[{"GeoPosition", "[", 
     RowBox[{"{", 
      RowBox[{"40.42", ",", " ", 
       RowBox[{"-", "3.70"}]}], "}"}], "]"}]}]}], "\n", "]"}]], "Input",Expres\
sionUUID->"07b73d56-30b0-714c-ac00-64c15d9cbfd6"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Thematic Mapping: Choropleth and Bubble Charts", "Section",ExpressionUUID->"6c64096b-559c-874e-ba5f-e57904ddb109"],

Cell[TextData[{
 Cell["GeoRegionValuePlot", "InlineCode",ExpressionUUID->
  "5573175b-5fa9-544b-a667-96f26d84e6c7"],
 " creates choropleth maps from named geographic entities. This is powerful \
when combined with ",
 Cell["GEEReduceRegion", "InlineCode",ExpressionUUID->
  "f3bcd5ae-8b51-a242-aefa-59565e221e09"],
 " or ",
 Cell["GEEComputeFeatures", "InlineCode",ExpressionUUID->
  "69cb5330-c1b1-0d46-a80c-142046f90788"],
 " to extract per-region statistics."
}], "Text",ExpressionUUID->"b8e45ede-8820-584d-ad69-d1c4013f7c8c"],

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{
   "Compute", " ", "mean", " ", "NDVI", " ", "per", " ", "US", " ", "state"}],
    " ", "*)"}], "\n", 
  RowBox[{
   RowBox[{
    RowBox[{"states", " ", "=", " ", 
     RowBox[{"EntityList", "[", 
      RowBox[{"EntityClass", "[", 
       RowBox[{"\"\<AdministrativeDivision\>\"", ",", 
        " ", "\"\<USStatesKind\>\""}], "]"}], "]"}]}], ";"}], "\n", "\n", 
   RowBox[{
    RowBox[{"stateNDVI", " ", "=", " ", 
     RowBox[{"Table", "[", "\n", "  ", 
      RowBox[{
       RowBox[{"Module", "[", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{
          "gb", ",", " ", "bbox", ",", " ", "pipeline", ",", " ", "result"}], 
          "}"}], ",", "\n", "    ", 
         RowBox[{
          RowBox[{"gb", " ", "=", " ", 
           RowBox[{"GeoBoundingBox", "[", "state", "]"}]}], ";", "\n", "    ", 
          RowBox[{"(*", " ", 
           RowBox[{"Extract", " ", 
            RowBox[{"{", 
             RowBox[{
             "west", ",", " ", "south", ",", " ", "east", ",", " ", "north"}],
              "}"}], " ", "from", " ", "the", " ", "bounding", " ", "box"}], 
           " ", "*)"}], "\n", "    ", 
          RowBox[{"bbox", " ", "=", " ", 
           RowBox[{"{", 
            RowBox[{
             RowBox[{"gb", "[", 
              RowBox[{"[", 
               RowBox[{"1", ",", " ", "2"}], "]"}], "]"}], ",", " ", 
             RowBox[{"gb", "[", 
              RowBox[{"[", 
               RowBox[{"1", ",", " ", "1"}], "]"}], "]"}], ",", " ", 
             RowBox[{"gb", "[", 
              RowBox[{"[", 
               RowBox[{"2", ",", " ", "2"}], "]"}], "]"}], ",", " ", 
             RowBox[{"gb", "[", 
              RowBox[{"[", 
               RowBox[{"2", ",", " ", "1"}], "]"}], "]"}]}], "}"}]}], ";", 
          "\n", "    ", 
          RowBox[{"pipeline", " ", "=", "\n", "      ", 
           RowBox[{
            RowBox[{
             RowBox[{
              RowBox[{
               RowBox[{
                RowBox[{
                "GEECollection", "[", "\"\<MODIS/061/MOD13A2\>\"", "]"}], " ",
                 "//", "\n", "        ", 
                RowBox[{"GEEFilterDate", "[", 
                 
                 RowBox[{"\"\<2024-06-01\>\"", ",", 
                  " ", "\"\<2024-08-31\>\""}], "]"}]}], " ", "//", "\n", 
               "        ", 
               RowBox[{"GEESelectBands", "[", 
                RowBox[{"{", "\"\<NDVI\>\"", "}"}], "]"}]}], " ", "//", "\n", 
              "        ", "GEEMean"}], " ", "//", "\n", "        ", 
             RowBox[{"GEEMultiply", "[", "0.0001", "]"}]}], " ", "//", "\n", 
            "        ", 
            RowBox[{"GEEReduceRegion", "[", "\n", "          ", 
             RowBox[{
              RowBox[{"GEEGeometry", "[", "bbox", "]"}], ",", "\n", 
              "          ", "\"\<mean\>\"", ",", " ", "5000"}], "\n", 
             "        ", "]"}]}]}], ";", "\n", "    ", 
          RowBox[{"result", " ", "=", " ", 
           RowBox[{"GEECompute", "[", "pipeline", "]"}]}], ";", "\n", "    ", 
          RowBox[{"state", " ", "->", " ", 
           RowBox[{"result", "[", "\"\<NDVI\>\"", "]"}]}]}]}], "\n", "  ", 
        "]"}], ",", "\n", "  ", 
       RowBox[{"{", 
        RowBox[{"state", ",", " ", "states"}], "}"}]}], "\n", "]"}]}], ";"}], 
   "\n", "\n", 
   RowBox[{"GeoRegionValuePlot", "[", 
    RowBox[{"stateNDVI", ",", "\n", "  ", 
     RowBox[{
     "PlotLabel", " ", "->", 
      " ", "\"\<Mean Summer NDVI by US State (2024)\>\""}], ",", "\n", "  ", 
     RowBox[{"ColorFunction", " ", "->", " ", "\"\<GreenBrownTerrain\>\""}], ",",
      "\n", "  ", 
     RowBox[{"PlotLegends", " ", "->", " ", "Automatic"}]}], "\n", 
    "]"}]}]}]], "Input",ExpressionUUID->"8dc48d4c-a017-ad4f-8566-\
ef7da29ef47d"],

Cell[TextData[{
 Cell["GeoBubbleChart", "InlineCode",ExpressionUUID->
  "a21d2f0a-a1e4-ae41-8a1e-6610277a451a"],
 " displays proportional symbols, useful for showing point-based measurements \
with magnitude."
}], "Text",ExpressionUUID->"f515b661-6fa8-bd41-b108-8d5a5d2dfd2d"],

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{
   "Bubble", " ", "chart", " ", "of", " ", "NDVI", " ", "at", " ", "field", " ",
     "sites"}], " ", "*)"}], "\n", 
  RowBox[{
   RowBox[{
    RowBox[{"fieldData", " ", "=", " ", 
     RowBox[{"{", "\n", "  ", 
      RowBox[{
       RowBox[{
        RowBox[{"GeoPosition", "[", 
         RowBox[{"{", 
          RowBox[{"38.9", ",", " ", 
           RowBox[{"-", "77.0"}]}], "}"}], "]"}], " ", "->", " ", "0.65"}], ",",
        "\n", "  ", 
       RowBox[{
        RowBox[{"GeoPosition", "[", 
         RowBox[{"{", 
          RowBox[{"34.0", ",", " ", 
           RowBox[{"-", "118.2"}]}], "}"}], "]"}], " ", "->", " ", "0.32"}], ",",
        "\n", "  ", 
       RowBox[{
        RowBox[{"GeoPosition", "[", 
         RowBox[{"{", 
          RowBox[{"41.8", ",", " ", 
           RowBox[{"-", "87.6"}]}], "}"}], "]"}], " ", "->", " ", "0.48"}], ",",
        "\n", "  ", 
       RowBox[{
        RowBox[{"GeoPosition", "[", 
         RowBox[{"{", 
          RowBox[{"29.7", ",", " ", 
           RowBox[{"-", "95.3"}]}], "}"}], "]"}], " ", "->", " ", "0.55"}]}], 
      "\n", "}"}]}], ";"}], "\n", "\n", 
   RowBox[{"GeoBubbleChart", "[", 
    RowBox[{"fieldData", ",", "\n", "  ", 
     RowBox[{"PlotLabel", " ", "->", " ", "\"\<Field Site NDVI\>\""}], ",", 
     "\n", "  ", 
     RowBox[{"BubbleSizes", " ", "->", " ", 
      RowBox[{"{", 
       RowBox[{"0.02", ",", " ", "0.06"}], "}"}]}]}], "\n", 
    "]"}]}]}]], "Input",ExpressionUUID->"b18809e1-0837-1e40-ac69-\
b4ee54040761"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Multi-Panel Layouts", "Section",ExpressionUUID->"8f610469-947f-6443-974c-3c9ddc000fc6"],

Cell["\<\
Side-by-side comparison is essential for seasonal analysis, before/after \
studies, and multi-band visualization.\
\>", "Text",ExpressionUUID->"8c650d09-e245-2148-8ed8-8e3c299d3b47"],

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{"Four", "-", 
    RowBox[{"season", " ", "comparison"}]}], " ", "*)"}], "\n", 
  RowBox[{
   RowBox[{
    RowBox[{"seasons", " ", "=", " ", 
     RowBox[{"{", "\n", "  ", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{"\"\<2024-01-01\>\"", ",", " ", "\"\<2024-03-31\>\"", ",", 
         " ", "\"\<Winter\>\""}], "}"}], ",", "\n", "  ", 
       RowBox[{"{", 
        RowBox[{"\"\<2024-04-01\>\"", ",", " ", "\"\<2024-06-30\>\"", ",", 
         " ", "\"\<Spring\>\""}], "}"}], ",", "\n", "  ", 
       RowBox[{"{", 
        RowBox[{"\"\<2024-07-01\>\"", ",", " ", "\"\<2024-09-30\>\"", ",", 
         " ", "\"\<Summer\>\""}], "}"}], ",", "\n", "  ", 
       RowBox[{"{", 
        RowBox[{"\"\<2024-10-01\>\"", ",", " ", "\"\<2024-12-31\>\"", ",", 
         " ", "\"\<Fall\>\""}], "}"}]}], "\n", "}"}]}], ";"}], "\n", "\n", 
   RowBox[{
    RowBox[{"bbox", " ", "=", " ", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"-", "122.5"}], ",", " ", "37.7", ",", " ", 
       RowBox[{"-", "122.3"}], ",", " ", "37.9"}], "}"}]}], ";"}], "\n", "\n", 
   RowBox[{
    RowBox[{"seasonImages", " ", "=", " ", 
     RowBox[{"Table", "[", "\n", "  ", 
      RowBox[{
       RowBox[{
        RowBox[{"GEEComputePixels", "[", 
         RowBox[{"bbox", ",", "\n", "    ", 
          RowBox[{
           RowBox[{
            RowBox[{
             RowBox[{
              RowBox[{
               RowBox[{
                RowBox[{
                "GEECollection", "[", "\"\<COPERNICUS/S2_SR_HARMONIZED\>\"", 
                 "]"}], " ", "//", "\n", "      ", 
                RowBox[{"GEEFilterDate", "[", 
                 RowBox[{
                  RowBox[{"s", "[", 
                   RowBox[{"[", "1", "]"}], "]"}], ",", " ", 
                  RowBox[{"s", "[", 
                   RowBox[{"[", "2", "]"}], "]"}]}], "]"}]}], " ", "//", "\n",
                "      ", 
               RowBox[{"GEEFilterBounds", "[", "bbox", "]"}]}], " ", "//", 
              "\n", "      ", 
              RowBox[{"GEEFilterProperty", "[", 
               
               RowBox[{"\"\<CLOUDY_PIXEL_PERCENTAGE\>\"", ",", 
                " ", "\"\<LessThan\>\"", ",", " ", "20"}], "]"}]}], " ", "//",
              "\n", "      ", 
             RowBox[{"GEESelectBands", "[", 
              RowBox[{"{", 
               
               RowBox[{"\"\<B4\>\"", ",", " ", "\"\<B3\>\"", ",", 
                " ", "\"\<B2\>\""}], "}"}], "]"}]}], " ", "//", "\n", 
            "      ", "GEEMedian"}], " ", "//", "\n", "      ", 
           RowBox[{"GEEVisualize", "[", 
            RowBox[{"<|", 
             RowBox[{
              RowBox[{"\"\<min\>\"", " ", "->", " ", "0"}], ",", " ", 
              RowBox[{"\"\<max\>\"", " ", "->", " ", "3000"}]}], "|>"}], 
            "]"}]}], ",", "\n", "    ", 
          RowBox[{"\"\<ImageSize\>\"", " ", "->", " ", "256"}]}], "\n", "  ", 
         "]"}], " ", "->", " ", 
        RowBox[{"s", "[", 
         RowBox[{"[", "3", "]"}], "]"}]}], ",", "\n", "  ", 
       RowBox[{"{", 
        RowBox[{"s", ",", " ", "seasons"}], "}"}]}], "\n", "]"}]}], ";"}], 
   "\n", "\n", 
   RowBox[{"GraphicsGrid", "[", "\n", "  ", 
    RowBox[{
     RowBox[{"Partition", "[", "\n", "    ", 
      RowBox[{
       RowBox[{
        RowBox[{
         RowBox[{"Labeled", "[", 
          RowBox[{
           RowBox[{"#", "[", 
            RowBox[{"[", "1", "]"}], "]"}], ",", " ", 
           RowBox[{"#", "[", 
            RowBox[{"[", "2", "]"}], "]"}], ",", " ", "Top"}], "]"}], " ", 
         "&"}], " ", "/@", " ", "seasonImages"}], ",", "\n", "    ", "2"}], 
      "\n", "  ", "]"}], ",", "\n", "  ", 
     RowBox[{"ImageSize", " ", "->", " ", "800"}]}], "\n", "]"}]}]}]], "Input",\
ExpressionUUID->"b3fb330c-9a57-e741-9d16-161bb21c288a"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Interactive Exploration", "Section",ExpressionUUID->"40481a92-c5a3-7a43-9e01-d16330a4887f"],

Cell[TextData[{
 Cell["Manipulate", "InlineCode",ExpressionUUID->
  "54abec90-7fce-bb4b-8aac-084c24885d9b"],
 " lets you build interactive controls that dynamically change GEE query \
parameters. This is particularly useful during exploratory analysis."
}], "Text",ExpressionUUID->"a8c66447-43ff-6c44-91bd-8b3ca1636780"],

Cell[BoxData[
 RowBox[{"Manipulate", "[", "\n", "  ", 
  RowBox[{
   RowBox[{"GEEComputePixels", "[", "\n", "    ", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
       RowBox[{"-", "122.5"}], ",", " ", "37.7", ",", " ", 
       RowBox[{"-", "122.3"}], ",", " ", "37.9"}], "}"}], ",", "\n", "    ", 
     RowBox[{
      RowBox[{
       RowBox[{
        RowBox[{
         RowBox[{
          RowBox[{
          "GEECollection", "[", "\"\<COPERNICUS/S2_SR_HARMONIZED\>\"", "]"}], 
          " ", "//", "\n", "      ", 
          RowBox[{"GEEFilterDate", "[", "\n", "        ", 
           RowBox[{
            RowBox[{"DateString", "[", 
             RowBox[{"startDate", ",", " ", 
              RowBox[{"{", 
               
               RowBox[{"\"\<Year\>\"", ",", " ", "\"\<-\>\"", ",", 
                " ", "\"\<Month\>\"", ",", " ", "\"\<-\>\"", ",", 
                " ", "\"\<Day\>\""}], "}"}]}], "]"}], ",", "\n", "        ", 
            RowBox[{"DateString", "[", 
             RowBox[{
              RowBox[{"DatePlus", "[", 
               RowBox[{"startDate", ",", " ", 
                RowBox[{"{", 
                 RowBox[{"3", ",", " ", "\"\<Month\>\""}], "}"}]}], "]"}], ",",
               "\n", "          ", 
              RowBox[{"{", 
               
               RowBox[{"\"\<Year\>\"", ",", " ", "\"\<-\>\"", ",", 
                " ", "\"\<Month\>\"", ",", " ", "\"\<-\>\"", ",", 
                " ", "\"\<Day\>\""}], "}"}]}], "]"}]}], "\n", "      ", 
           "]"}]}], " ", "//", "\n", "      ", 
         RowBox[{"GEEFilterProperty", "[", 
          
          RowBox[{"\"\<CLOUDY_PIXEL_PERCENTAGE\>\"", ",", 
           " ", "\"\<LessThan\>\"", ",", " ", "cloudMax"}], "]"}]}], " ", "//",
         "\n", "      ", 
        RowBox[{"GEESelectBands", "[", 
         RowBox[{"{", 
          
          RowBox[{"\"\<B4\>\"", ",", " ", "\"\<B3\>\"", ",", 
           " ", "\"\<B2\>\""}], "}"}], "]"}]}], " ", "//", "\n", "      ", 
       "GEEMedian"}], " ", "//", "\n", "      ", 
      RowBox[{"GEEVisualize", "[", 
       RowBox[{"<|", 
        RowBox[{
         RowBox[{"\"\<min\>\"", " ", "->", " ", "0"}], ",", " ", 
         RowBox[{"\"\<max\>\"", " ", "->", " ", "maxReflectance"}]}], "|>"}], 
       "]"}]}], ",", "\n", "    ", 
     RowBox[{"\"\<ImageSize\>\"", " ", "->", " ", "512"}]}], "\n", "  ", 
    "]"}], ",", "\n", "  ", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"startDate", ",", " ", 
       RowBox[{"DateObject", "[", 
        RowBox[{"{", 
         RowBox[{"2024", ",", " ", "1", ",", " ", "1"}], "}"}], "]"}], ",", 
       " ", "\"\<Start Date\>\""}], "}"}], ",", "\n", "    ", 
     RowBox[{"DateObject", "[", 
      RowBox[{"{", 
       RowBox[{"2020", ",", " ", "1", ",", " ", "1"}], "}"}], "]"}], ",", " ", 
     RowBox[{"DateObject", "[", 
      RowBox[{"{", 
       RowBox[{"2024", ",", " ", "10", ",", " ", "1"}], "}"}], "]"}]}], "}"}],
    ",", "\n", "  ", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"cloudMax", ",", " ", "15", ",", " ", "\"\<Max Cloud %\>\""}], 
      "}"}], ",", " ", "1", ",", " ", "50", ",", " ", "1"}], "}"}], ",", "\n",
    "  ", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
      "maxReflectance", ",", " ", "3000", ",", 
       " ", "\"\<Max Reflectance\>\""}], "}"}], ",", " ", "500", ",", " ", 
     "6000", ",", " ", "100"}], "}"}]}], "\n", "]"}]], "Input",ExpressionUUID->\
"0612377c-cee9-8f48-9ef1-898a85456b82"],

Cell[TextData[{
 "For more complex dashboards, ",
 Cell["DynamicModule", "InlineCode",ExpressionUUID->
  "d490bd05-24db-2247-85d1-45989296b081"],
 " provides full control over state management, letting you combine multiple \
controls (popup menus, sliders, checkboxes) with dynamically updated GEE \
imagery and plots."
}], "Text",ExpressionUUID->"1a156c73-68f3-154a-a11e-b69f98eaa499"],

