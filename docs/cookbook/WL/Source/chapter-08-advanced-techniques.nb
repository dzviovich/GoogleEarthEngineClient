Cell[CellGroupData[{

Cell["Trend Detection", "Section",ExpressionUUID->"7160489b-e472-d542-b92a-337e02f99e65"],

Cell[TextData[{
 "A linear fit to the time series reveals whether vegetation is greening \
(positive slope) or browning (negative slope) over the study period. For \
non-linear dynamics, ",
 Cell["FindFit", "InlineCode",ExpressionUUID->
  "fb41b8f2-4783-1647-88a4-36dc0182095c"],
 " can model logistic growth, exponential decay, or other functional forms."
}], "Text",ExpressionUUID->"3a3ab655-3c19-a44e-960f-30616fd52a9c"],

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{
   "Convert", " ", "dates", " ", "to", " ", "numeric", " ", "values", " ", 
    "for", " ", "fitting"}], " ", "*)"}], "\n", 
  RowBox[{
   RowBox[{
    RowBox[{"numericDates", " ", "=", " ", 
     RowBox[{"AbsoluteTime", " ", "/@", " ", 
      RowBox[{"ndviTimeSeries", "[", 
       RowBox[{"[", 
        RowBox[{"All", ",", " ", "1"}], "]"}], "]"}]}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"ndviValues", " ", "=", " ", 
     RowBox[{"ndviTimeSeries", "[", 
      RowBox[{"[", 
       RowBox[{"All", ",", " ", "2"}], "]"}], "]"}]}], ";"}], "\n", "\n", 
   RowBox[{"(*", " ", 
    RowBox[{"Linear", " ", "trend"}], " ", "*)"}], "\n", 
   RowBox[{
    RowBox[{"lm", " ", "=", " ", 
     RowBox[{"LinearModelFit", "[", "\n", "  ", 
      RowBox[{
       RowBox[{"Transpose", "[", 
        RowBox[{"{", 
         RowBox[{"numericDates", ",", " ", "ndviValues"}], "}"}], "]"}], ",", 
       "\n", "  ", "x", ",", " ", "x"}], "\n", "]"}]}], ";"}], "\n", "\n", 
   RowBox[{"(*", " ", 
    RowBox[{
    "Slope", " ", "tells", " ", "you", " ", "the", " ", "rate", " ", "of", " ",
      "change"}], " ", "*)"}], "\n", 
   RowBox[{
    RowBox[{"slope", " ", "=", " ", 
     RowBox[{
      RowBox[{"lm", "[", "\"\<BestFitParameters\>\"", "]"}], "[", 
      RowBox[{"[", "2", "]"}], "]"}]}], ";"}], "\n", 
   RowBox[{"Print", "[", 
    RowBox[{"\"\<NDVI trend: \>\"", ",", " ", 
     RowBox[{"slope", " ", "*", " ", 
      RowBox[{"(", 
       RowBox[{"365.25", " ", "*", " ", "86400"}], ")"}]}], ",", 
     " ", "\"\< per year\>\""}], "]"}], "\n", "\n", 
   RowBox[{"(*", " ", 
    RowBox[{"Nonlinear", " ", 
     RowBox[{"fit", ":", " ", 
      RowBox[{"logistic", " ", "recovery", " ", "model"}]}]}], " ", "*)"}], "\n", 
   RowBox[{
    RowBox[{"logisticModel", " ", "=", " ", 
     RowBox[{"FindFit", "[", "\n", "  ", 
      RowBox[{
       RowBox[{"Transpose", "[", 
        RowBox[{"{", 
         RowBox[{
          RowBox[{"numericDates", " ", "-", " ", 
           RowBox[{"Min", "[", "numericDates", "]"}]}], ",", " ", 
          "ndviValues"}], "}"}], "]"}], ",", "\n", "  ", 
       RowBox[{"k", " ", "/", " ", 
        RowBox[{"(", 
         RowBox[{"1", " ", "+", " ", 
          RowBox[{"a", " ", "*", " ", 
           RowBox[{"Exp", "[", 
            RowBox[{
             RowBox[{"-", "r"}], " ", "*", " ", "t"}], "]"}]}]}], ")"}]}], ",",
        "\n", "  ", 
       RowBox[{"{", 
        RowBox[{"k", ",", " ", "a", ",", " ", "r"}], "}"}], ",", " ", "t"}], 
      "\n", "]"}]}], ";"}], "\n", "\n", 
   RowBox[{"Show", "[", "\n", "  ", 
    RowBox[{
     RowBox[{"ListPlot", "[", 
      RowBox[{"Transpose", "[", 
       RowBox[{"{", 
        RowBox[{"numericDates", ",", " ", "ndviValues"}], "}"}], "]"}], "]"}],
      ",", "\n", "  ", 
     RowBox[{"Plot", "[", 
      RowBox[{
       RowBox[{"lm", "[", "x", "]"}], ",", " ", 
       RowBox[{"{", 
        RowBox[{"x", ",", " ", 
         RowBox[{"Min", "[", "numericDates", "]"}], ",", " ", 
         RowBox[{"Max", "[", "numericDates", "]"}]}], "}"}], ",", " ", 
       RowBox[{"PlotStyle", " ", "->", " ", "Red"}]}], "]"}], ",", "\n", "  ", 
     RowBox[{"PlotLabel", " ", "->", " ", "\"\<NDVI Trend Detection\>\""}]}], 
    "\n", "]"}]}]}]], "Input",ExpressionUUID->"bd4a99e9-b1aa-474c-ae8e-\
0b8c004f3b3f"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Seasonal Decomposition", "Section",ExpressionUUID->"943da0e0-3aa0-8f44-a629-26efe2cdee81"],

Cell["\<\
Fourier analysis separates the time series into its constituent frequencies, \
letting you isolate the annual cycle from multi-year trends and short-term \
noise.\
\>", "Text",ExpressionUUID->"20addd28-c0e9-164e-a951-acb20bb19a6c"],

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{
   "Fourier", " ", "transform", " ", "of", " ", "NDVI", " ", "series"}], " ", 
   "*)"}], "\n", 
  RowBox[{
   RowBox[{
    RowBox[{"ft", " ", "=", " ", 
     RowBox[{"Fourier", "[", "ndviValues", "]"}]}], ";"}], "\n", "\n", 
   RowBox[{"(*", " ", 
    RowBox[{
    "Periodogram", " ", "reveals", " ", "dominant", " ", "frequencies"}], " ",
     "*)"}], "\n", 
   RowBox[{"Periodogram", "[", 
    RowBox[{"ndviValues", ",", "\n", "  ", 
     RowBox[{"PlotLabel", " ", "->", " ", "\"\<NDVI Frequency Spectrum\>\""}],
      ",", "\n", "  ", 
     RowBox[{"SampleRate", " ", "->", " ", "12"}]}], "  ", 
    RowBox[{"(*", " ", 
     RowBox[{
      RowBox[{"monthly", " ", "data"}], " ", "=", " ", 
      RowBox[{"12", " ", 
       RowBox[{"samples", "/", "year"}]}]}], " ", "*)"}], "\n", "]"}], "\n", 
   "\n", 
   RowBox[{"(*", " ", 
    RowBox[{
    "Isolate", " ", "seasonal", " ", "component", " ", "using", " ", 
     "bandpass", " ", "filter"}], " ", "*)"}], "\n", 
   RowBox[{"(*", " ", 
    RowBox[{"Pass", " ", "frequencies", " ", "near", " ", "1", " ", 
     RowBox[{"cycle", "/", "year"}]}], " ", "*)"}], "\n", 
   RowBox[{
    RowBox[{"seasonalComponent", " ", "=", " ", 
     RowBox[{"BandpassFilter", "[", 
      RowBox[{"ndviValues", ",", " ", 
       RowBox[{"{", 
        RowBox[{
         RowBox[{"0.8", "/", "12"}], ",", " ", 
         RowBox[{"1.2", "/", "12"}]}], "}"}]}], "]"}]}], ";"}], "\n", "\n", 
   RowBox[{"(*", " ", 
    RowBox[{"Trend", ":", " ", 
     RowBox[{"low", "-", 
      RowBox[{"pass", " ", "filter"}]}]}], " ", "*)"}], "\n", 
   RowBox[{
    RowBox[{"trendComponent", " ", "=", " ", 
     RowBox[{"LowpassFilter", "[", 
      RowBox[{"ndviValues", ",", " ", 
       RowBox[{"0.5", "/", "12"}]}], "]"}]}], ";"}], "\n", "\n", 
   RowBox[{"(*", " ", 
    RowBox[{"Residual", " ", "=", " ", 
     RowBox[{
     "original", " ", "-", " ", "trend", " ", "-", " ", "seasonal"}]}], " ", 
    "*)"}], "\n", 
   RowBox[{
    RowBox[{"residualComponent", " ", "=", " ", 
     RowBox[{
     "ndviValues", " ", "-", " ", "trendComponent", " ", "-", " ", 
      "seasonalComponent"}]}], ";"}], "\n", "\n", 
   RowBox[{"GraphicsRow", "[", 
    RowBox[{
     RowBox[{"{", "\n", "  ", 
      RowBox[{
       RowBox[{"ListLinePlot", "[", 
        RowBox[{"trendComponent", ",", " ", 
         RowBox[{"PlotLabel", " ", "->", " ", "\"\<Trend\>\""}]}], "]"}], ",",
        "\n", "  ", 
       RowBox[{"ListLinePlot", "[", 
        RowBox[{"seasonalComponent", ",", " ", 
         RowBox[{"PlotLabel", " ", "->", " ", "\"\<Seasonal\>\""}]}], "]"}], ",",
        "\n", "  ", 
       RowBox[{"ListLinePlot", "[", 
        RowBox[{"residualComponent", ",", " ", 
         RowBox[{"PlotLabel", " ", "->", " ", "\"\<Residual\>\""}]}], "]"}]}],
       "\n", "}"}], ",", " ", 
     RowBox[{"ImageSize", " ", "->", " ", "Large"}]}], "]"}]}]}]], "Input",Exp\
ressionUUID->"435ffe74-0598-6945-a9d9-b7e2668935ec"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Anomaly Detection", "Section",ExpressionUUID->"2f9238a8-7ac1-5a49-b39b-5c1a6c5e17fc"],

Cell["\<\
Anomalies are months where observed NDVI deviates significantly from the \
long-term climatological mean for that calendar month. This approach can flag \
drought, flooding, or land use change events.\
\>", "Text",ExpressionUUID->"3eec9239-f6ce-6449-bdd7-61d8f8aafa70"],

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{"Group", " ", "values", " ", "by", " ", "calendar", " ", "month"}],
    " ", "*)"}], "\n", 
  RowBox[{
   RowBox[{
    RowBox[{"monthlyGroups", " ", "=", " ", 
     RowBox[{"GroupBy", "[", "\n", "  ", 
      RowBox[{"ndviTimeSeries", ",", "\n", "  ", 
       RowBox[{
        RowBox[{"DateValue", "[", 
         RowBox[{
          RowBox[{"#", "[", 
           RowBox[{"[", "1", "]"}], "]"}], ",", " ", "\"\<Month\>\""}], "]"}],
         " ", "&"}], ",", "\n", "  ", 
       RowBox[{
        RowBox[{"#", "[", 
         RowBox[{"[", 
          RowBox[{"All", ",", " ", "2"}], "]"}], "]"}], " ", "&"}]}], "\n", 
      "]"}]}], ";"}], "\n", "\n", 
   RowBox[{"(*", " ", 
    RowBox[{
    "Compute", " ", "climatological", " ", "mean", " ", "and", " ", 
     "standard", " ", "deviation", " ", "per", " ", "month"}], " ", "*)"}], "\n", 
   RowBox[{
    RowBox[{"climatology", " ", "=", " ", 
     RowBox[{"Association", " ", "@", " ", 
      RowBox[{"Table", "[", "\n", "  ", 
       RowBox[{
        RowBox[{"month", " ", "->", " ", 
         RowBox[{"<|", "\n", "    ", 
          RowBox[{
           RowBox[{"\"\<Mean\>\"", " ", "->", " ", 
            RowBox[{"Mean", "[", 
             RowBox[{"monthlyGroups", "[", "month", "]"}], "]"}]}], ",", "\n",
            "    ", 
           RowBox[{"\"\<StdDev\>\"", " ", "->", " ", 
            RowBox[{"StandardDeviation", "[", 
             RowBox[{"monthlyGroups", "[", "month", "]"}], "]"}]}]}], "\n", 
          "  ", "|>"}]}], ",", "\n", "  ", 
        RowBox[{"{", 
         RowBox[{"month", ",", " ", 
          RowBox[{"Keys", "[", "monthlyGroups", "]"}]}], "}"}]}], "\n", 
       "]"}]}]}], ";"}], "\n", "\n", 
   RowBox[{"(*", " ", 
    RowBox[{"Flag", " ", 
     RowBox[{"anomalies", ":", " ", 
      RowBox[{
      "months", " ", "deviating", " ", "more", " ", "than", " ", "2", " ", 
       "sigma"}]}]}], " ", "*)"}], "\n", 
   RowBox[{
    RowBox[{"anomalies", " ", "=", " ", 
     RowBox[{"Select", "[", 
      RowBox[{"ndviTimeSeries", ",", "\n", "  ", 
       RowBox[{
        RowBox[{"Module", "[", 
         RowBox[{
          RowBox[{"{", 
           RowBox[{"month", ",", " ", "val", ",", " ", "clim"}], "}"}], ",", 
          "\n", "    ", 
          RowBox[{
           RowBox[{"month", " ", "=", " ", 
            RowBox[{"DateValue", "[", 
             RowBox[{
              RowBox[{"#", "[", 
               RowBox[{"[", "1", "]"}], "]"}], ",", " ", "\"\<Month\>\""}], 
             "]"}]}], ";", "\n", "    ", 
           RowBox[{"val", " ", "=", " ", 
            RowBox[{"#", "[", 
             RowBox[{"[", "2", "]"}], "]"}]}], ";", "\n", "    ", 
           RowBox[{"clim", " ", "=", " ", 
            RowBox[{"climatology", "[", "month", "]"}]}], ";", "\n", "    ", 
           RowBox[{
            RowBox[{"Abs", "[", 
             RowBox[{"val", " ", "-", " ", 
              RowBox[{"clim", "[", "\"\<Mean\>\"", "]"}]}], "]"}], " ", ">", 
            " ", 
            RowBox[{"2", " ", "*", " ", 
             RowBox[{"clim", "[", "\"\<StdDev\>\"", "]"}]}]}]}]}], "\n", "  ",
          "]"}], " ", "&"}]}], "\n", "]"}]}], ";"}], "\n", "\n", 
   RowBox[{"Print", "[", 
    RowBox[{"\"\<Detected \>\"", ",", " ", 
     RowBox[{"Length", "[", "anomalies", "]"}], ",", 
     " ", "\"\< anomalous months\>\""}], "]"}], "\n", 
   RowBox[{"Print", "[", 
    RowBox[{"\"\<Anomaly dates: \>\"", ",", " ", 
     RowBox[{"anomalies", "[", 
      RowBox[{"[", 
       RowBox[{"All", ",", " ", "1"}], "]"}], "]"}]}], "]"}]}]}]], "Input",Exp\
ressionUUID->"a0ee50f6-35f2-c94d-9071-11bc6a499be3"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Forecasting", "Section",ExpressionUUID->"941be18b-26f2-3c4b-a999-d750c9623fb9"],

Cell[TextData[{
 Cell["TimeSeriesForecast", "InlineCode",ExpressionUUID->
  "e366f8f9-53b6-8b4d-9cda-bc5e8ce336f8"],
 " uses the structure it detects in the historical data (trend, seasonality, \
autocorrelation) to project forward."
}], "Text",ExpressionUUID->"452857ec-f23e-a24c-ae55-2502fd3a16de"],

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{"Forecast", " ", "the", " ", "next", " ", "12", " ", "months"}], 
   " ", "*)"}], "\n", 
  RowBox[{
   RowBox[{
    RowBox[{"forecast", " ", "=", " ", 
     RowBox[{"TimeSeriesForecast", "[", 
      RowBox[{"ndviTS", ",", " ", 
       RowBox[{"{", "12", "}"}]}], "]"}]}], ";"}], "\n", "\n", 
   RowBox[{"DateListPlot", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"ndviTS", ",", " ", "forecast"}], "}"}], ",", "\n", "  ", 
     RowBox[{
     "PlotLabel", " ", "->", " ", "\"\<NDVI Forecast (12 months)\>\""}], ",", 
     "\n", "  ", 
     RowBox[{"PlotLegends", " ", "->", " ", 
      RowBox[{"{", 
       RowBox[{"\"\<Historical\>\"", ",", " ", "\"\<Forecast\>\""}], "}"}]}], 
     ",", "\n", "  ", 
     RowBox[{"FrameLabel", " ", "->", " ", 
      RowBox[{"{", 
       RowBox[{"\"\<Date\>\"", ",", " ", "\"\<NDVI\>\""}], "}"}]}]}], "\n", 
    "]"}]}]}]], "Input",ExpressionUUID->"6059f6d1-b6a7-7c43-98cc-\
fdfcc9007fe0"],

Cell["", "Text",
 CellFrame->{{0, 0}, {0, 
  1}},ExpressionUUID->"74de45cf-1eac-d241-9a5a-ddf5eb40d882"]
