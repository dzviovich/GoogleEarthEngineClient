Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{
    RowBox[{"Note", ":", " ", 
     RowBox[{
     "Evaluating", " ", "on", " ", "the", " ", "training", " ", "set", " ", 
      "overstates", " ", 
      RowBox[{"accuracy", ".", " ", "For"}], " ", "rigorous", "\n", "   ", 
      "evaluation"}]}], ",", " ", 
    RowBox[{
     RowBox[{
     "split", " ", "data", " ", "into", " ", "training", " ", "and", " ", 
      "test", " ", "sets", " ", "or", " ", "use", " ", "cross"}], "-", 
     RowBox[{"validation", "."}]}]}], " ", "*)"}], "\n", 
  RowBox[{
   RowBox[{
    RowBox[{"cm", " ", "=", " ", 
     RowBox[{"ClassifierMeasurements", "[", 
      RowBox[{"classifier", ",", " ", "trainingData"}], "]"}]}], ";"}], "\n", 
   "\n", 
   RowBox[{"(*", " ", 
    RowBox[{"Overall", " ", "accuracy"}], " ", "*)"}], "\n", 
   RowBox[{"cm", "[", "\"\<Accuracy\>\"", "]"}], "\n", "\n", 
   RowBox[{"(*", " ", 
    RowBox[{"Confusion", " ", 
     RowBox[{"matrix", " ", "--"}], " ", "shows", " ", "where", " ", 
     "classes", " ", "are", " ", "being", " ", "mixed"}], " ", "*)"}], "\n", 
   RowBox[{"cm", "[", "\"\<ConfusionMatrixPlot\>\"", "]"}], "\n", "\n", 
   RowBox[{"(*", " ", 
    RowBox[{"Per", "-", 
     RowBox[{"class", " ", "F1", " ", "score"}]}], " ", "*)"}], "\n", 
   RowBox[{"cm", "[", "\"\<F1Score\>\"", "]"}]}]}]], "Input",
