Cell[CellGroupData[{

Cell["8.6 Physical Units and Quantities", "Chapter",ExpressionUUID->"41cdcc9c-4d94-574d-8d71-8fecbe967d56"],

Cell[TextData[{
 "The Wolfram Language ",
 Cell["Quantity", "InlineCode",ExpressionUUID->
  "d1a84ec8-4f16-6348-a3d4-5deb0331625b"],
 " system ensures unit-aware calculations, eliminating a common source of \
error when converting between measurement systems. Solar geometry functions \
add physical context to satellite observations."
}], "Text",ExpressionUUID->"9c1951fd-ac85-6d49-aace-764ab698ff3e"],

Cell[CellGroupData[{

Cell["Unit-Aware Area Calculations", "Section",ExpressionUUID->"be3eb560-594f-7548-a4bd-bee1b9f71561"],

Cell[TextData[{
 Cell["GEEArea", "InlineCode",ExpressionUUID->
  "452687f3-8919-2d4d-8bcf-cbd259e64ba7"],
 " returns values in square meters. Converting to more practical units is \
straightforward with ",
 Cell["Quantity", "InlineCode",ExpressionUUID->
  "06498f11-cdec-2e47-b71f-c501528940ca"],
 " and ",
 Cell["UnitConvert", "InlineCode",ExpressionUUID->
  "8166d6cd-ad5a-ee49-b941-1cb6accf8ec5"],
 "."
}], "Text",ExpressionUUID->"de598894-0e86-324c-b62c-82806acf2428"],

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{
   "Compute", " ", "the", " ", "area", " ", "of", " ", "a", " ", "study", " ",
     "region"}], " ", "*)"}], "\n", 
  RowBox[{
   RowBox[{
    RowBox[{"regionPoly", " ", "=", " ", 
     RowBox[{"GEEPolygon", "[", 
      RowBox[{"{", "\n", "  ", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{
          RowBox[{"-", "73.0"}], ",", " ", "4.0"}], "}"}], ",", " ", 
        RowBox[{"{", 
         RowBox[{
          RowBox[{"-", "72.5"}], ",", " ", "4.0"}], "}"}], ",", " ", 
        RowBox[{"{", 
         RowBox[{
          RowBox[{"-", "72.5"}], ",", " ", "4.5"}], "}"}], ",", "\n", "  ", 
        RowBox[{"{", 
         RowBox[{
          RowBox[{"-", "73.0"}], ",", " ", "4.5"}], "}"}], ",", " ", 
        RowBox[{"{", 
         RowBox[{
          RowBox[{"-", "73.0"}], ",", " ", "4.0"}], "}"}]}], "\n", "}"}], 
      "]"}]}], ";"}], "\n", "\n", 
   RowBox[{
    RowBox[{"areaM2", " ", "=", " ", 
     RowBox[{"GEECompute", "[", 
      RowBox[{"GEEArea", "[", "regionPoly", "]"}], "]"}]}], ";"}], "\n", "\n", 
   RowBox[{"(*", " ", 
    RowBox[{"Convert", " ", "to", " ", "practical", " ", "units"}], " ", 
    "*)"}], "\n", 
   RowBox[{"areaKm2", " ", "=", " ", 
    RowBox[{"UnitConvert", "[", 
     RowBox[{
      RowBox[{"Quantity", "[", 
       RowBox[{"areaM2", ",", " ", "\"\<SquareMeters\>\""}], "]"}], ",", 
      " ", "\"\<SquareKilometers\>\""}], "]"}]}], "\n", 
   RowBox[{"areaHectares", " ", "=", " ", 
    RowBox[{"UnitConvert", "[", 
     RowBox[{
      RowBox[{"Quantity", "[", 
       RowBox[{"areaM2", ",", " ", "\"\<SquareMeters\>\""}], "]"}], ",", 
      " ", "\"\<Hectares\>\""}], "]"}]}], "\n", "\n", 
   RowBox[{"Print", "[", 
    RowBox[{"\"\<Study area: \>\"", ",", " ", "areaKm2"}], "]"}], "\n", 
   RowBox[{"Print", "[", 
    RowBox[{"\"\<Study area: \>\"", ",", " ", "areaHectares"}], 
    "]"}]}]}]], "Input",ExpressionUUID->"16217e34-b612-8347-b522-\
d876cf21802b"],

Cell[TextData[{
 StyleBox["Pixel-level area computation with ",
  FontWeight->Bold],
 Cell["GEEPixelArea", "InlineCode",ExpressionUUID->
  "d6a65f19-2ba8-e247-b3f9-61d8b4bc5d6f"],
 StyleBox[":",
  FontWeight->Bold]
}], "Text",ExpressionUUID->"b34110d0-c68e-d247-abc5-8f7209284b95"],

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{
    RowBox[{
    "Compute", " ", "total", " ", "vegetated", " ", "area", " ", "using", " ",
      "pixel"}], "-", 
    RowBox[{"area", " ", "weighting"}]}], " ", "*)"}], "\n", 
  RowBox[{
   RowBox[{
    RowBox[{"vegetatedArea", " ", "=", "\n", "  ", 
     RowBox[{
      RowBox[{
       RowBox[{
        RowBox[{
         RowBox[{
          RowBox[{
           RowBox[{
           "GEECollection", "[", "\"\<COPERNICUS/S2_SR_HARMONIZED\>\"", "]"}],
            " ", "//", "\n", "    ", 
           RowBox[{"GEEFilterDate", "[", 
            RowBox[{"\"\<2024-06-01\>\"", ",", " ", "\"\<2024-08-31\>\""}], 
            "]"}]}], " ", "//", "\n", "    ", "GEEMedian"}], " ", "//", "\n", 
         "    ", 
         RowBox[{"GEENormalizedDifference", "[", 
          RowBox[{"{", 
           RowBox[{"\"\<B8\>\"", ",", " ", "\"\<B4\>\""}], "}"}], "]"}]}], 
        " ", "//", "\n", "    ", 
        RowBox[{"GEEGreaterThan", "[", "0.4", "]"}]}], " ", "//", 
       "            ", 
       RowBox[{"(*", " ", 
        RowBox[{"vegetation", " ", 
         RowBox[{"mask", ":", " ", 
          RowBox[{
           RowBox[{"1", " ", "where", " ", "NDVI"}], " ", ">", " ", 
           "0.4"}]}]}], " ", "*)"}], "\n", "    ", 
       RowBox[{"GEEMultiply", "[", 
        RowBox[{"GEEPixelArea", "[", "]"}], "]"}]}], " ", "//", "    ", 
      RowBox[{"(*", " ", 
       RowBox[{
       "multiply", " ", "mask", " ", "by", " ", "pixel", " ", "area", " ", 
        "in", " ", "m2"}], " ", "*)"}], "\n", "    ", 
      RowBox[{"GEEReduceRegion", "[", 
       RowBox[{"regionPoly", ",", " ", "\"\<sum\>\"", ",", " ", "10"}], 
       "]"}]}]}], ";"}], "\n", "\n", 
   RowBox[{
    RowBox[{"totalVegetatedM2", " ", "=", " ", 
     RowBox[{"GEECompute", "[", "vegetatedArea", "]"}]}], ";"}], "\n", "\n", 
   RowBox[{"vegetatedKm2", " ", "=", " ", 
    RowBox[{"UnitConvert", "[", "\n", "  ", 
     RowBox[{
      RowBox[{"Quantity", "[", 
       RowBox[{
        RowBox[{"totalVegetatedM2", "[", "\"\<nd\>\"", "]"}], ",", 
        " ", "\"\<SquareMeters\>\""}], "]"}], ",", "\n", 
      "  ", "\"\<SquareKilometers\>\""}], "\n", "]"}]}]}]}]], "Input",Expressi\
onUUID->"3873cf4b-3f0a-7e40-9444-487eb3f4ef38"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Solar Geometry", "Section",ExpressionUUID->"6b32c5c9-cb74-954c-8b4c-d8ba0be5e129"],

Cell[TextData[{
 Cell["SunPosition", "InlineCode",ExpressionUUID->
  "c05b136f-0050-b943-8c5c-985bdcccb506"],
 " computes the sun's elevation and azimuth at any point and time, which is \
essential for normalizing reflectance values to account for illumination \
differences between acquisition dates."
}], "Text",ExpressionUUID->"e4c7c016-98d1-c546-84c9-c5c60fd35cf9"],

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{
   "Compute", " ", "solar", " ", "zenith", " ", "angle", " ", "at", " ", 
    "satellite", " ", "overpass", " ", "time"}], " ", "*)"}], "\n", 
  RowBox[{
   RowBox[{
    RowBox[{"overpassTime", " ", "=", " ", 
     RowBox[{"DateObject", "[", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{
        "2024", ",", " ", "7", ",", " ", "15", ",", " ", "10", ",", " ", "30",
          ",", " ", "0"}], "}"}], ",", " ", 
       RowBox[{"TimeZone", " ", "->", " ", "0"}]}], "]"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"location", " ", "=", " ", 
     RowBox[{"GeoPosition", "[", 
      RowBox[{"{", 
       RowBox[{"45.0", ",", " ", "11.0"}], "}"}], "]"}]}], ";"}], "\n", "\n", 
   RowBox[{
    RowBox[{"sunPos", " ", "=", " ", 
     RowBox[{"SunPosition", "[", 
      RowBox[{"location", ",", " ", "overpassTime"}], "]"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"solarElevation", " ", "=", " ", 
     RowBox[{"QuantityMagnitude", "[", 
      RowBox[{"sunPos", "[", 
       RowBox[{"[", "1", "]"}], "]"}], "]"}]}], ";"}], "  ", 
   RowBox[{"(*", " ", "degrees", " ", "*)"}], "\n", 
   RowBox[{
    RowBox[{"solarZenith", " ", "=", " ", 
     RowBox[{"90", " ", "-", " ", "solarElevation"}]}], ";"}], "\n", "\n", 
   RowBox[{"Print", "[", 
    RowBox[{"\"\<Solar zenith angle: \>\"", ",", " ", "solarZenith", ",", 
     " ", "\"\< degrees\>\""}], "]"}], "\n", "\n", 
   RowBox[{"(*", " ", 
    RowBox[{"Cosine", " ", "correction", " ", "factor"}], " ", "*)"}], "\n", 
   RowBox[{
    RowBox[{"cosFactor", " ", "=", " ", 
     RowBox[{"Cos", "[", 
      RowBox[{"solarZenith", " ", "*", " ", "Degree"}], "]"}]}], ";"}], "\n", 
   RowBox[{"Print", "[", 
    RowBox[{"\"\<Cosine correction factor: \>\"", ",", " ", "cosFactor"}], 
    "]"}]}]}]], "Input",ExpressionUUID->"bfca67e8-6c97-b84d-9aab-\
e126286a549f"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Day Length and Phenology", "Section",ExpressionUUID->"37713e32-7e55-a845-a590-e697eee68c5f"],

Cell["\<\
Correlating day length with vegetation phenology helps explain why plants \
green up and senesce at particular times of year.\
\>", "Text",ExpressionUUID->"21d010df-582c-cb43-a052-dffffdacacd1"],

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{
   "Compute", " ", "day", " ", "length", " ", "throughout", " ", "the", " ", 
    "year"}], " ", "*)"}], "\n", 
  RowBox[{
   RowBox[{
    RowBox[{"location", " ", "=", " ", 
     RowBox[{"GeoPosition", "[", 
      RowBox[{"{", 
       RowBox[{"48.0", ",", " ", "11.0"}], "}"}], "]"}]}], ";"}], "  ", 
   RowBox[{"(*", " ", "Munich", " ", "*)"}], "\n", "\n", 
   RowBox[{
    RowBox[{"dayLengths", " ", "=", " ", 
     RowBox[{"Table", "[", "\n", "  ", 
      RowBox[{
       RowBox[{"Module", "[", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{
          "date", ",", " ", "rise", ",", " ", "set", ",", " ", "hours"}], 
          "}"}], ",", "\n", "    ", 
         RowBox[{
          RowBox[{"date", " ", "=", " ", 
           RowBox[{
            RowBox[{"DateObject", "[", 
             RowBox[{"{", 
              RowBox[{"2024", ",", " ", "1", ",", " ", "1"}], "}"}], "]"}], 
            " ", "+", " ", 
            RowBox[{"Quantity", "[", 
             RowBox[{"d", ",", " ", "\"\<Days\>\""}], "]"}]}]}], ";", "\n", 
          "    ", 
          RowBox[{"rise", " ", "=", " ", 
           RowBox[{"Sunrise", "[", 
            RowBox[{"location", ",", " ", "date"}], "]"}]}], ";", "\n", 
          "    ", 
          RowBox[{"set", " ", "=", " ", 
           RowBox[{"Sunset", "[", 
            RowBox[{"location", ",", " ", "date"}], "]"}]}], ";", "\n", 
          "    ", 
          RowBox[{"hours", " ", "=", " ", 
           RowBox[{"QuantityMagnitude", "[", 
            RowBox[{"DateDifference", "[", 
             RowBox[{"rise", ",", " ", "set", ",", " ", "\"\<Hours\>\""}], 
             "]"}], "]"}]}], ";", "\n", "    ", 
          RowBox[{"{", 
           RowBox[{"d", ",", " ", "hours"}], "}"}]}]}], "\n", "  ", "]"}], ",",
        "\n", "  ", 
       RowBox[{"{", 
        RowBox[{"d", ",", " ", "0", ",", " ", "364"}], "}"}]}], "\n", "]"}]}],
     ";"}], "\n", "\n", 
   RowBox[{"(*", " ", 
    RowBox[{
    "Plot", " ", "day", " ", "length", " ", "alongside", " ", "NDVI", " ", 
     "time", " ", "series"}], " ", "*)"}], "\n", 
   RowBox[{"Show", "[", "\n", "  ", 
    RowBox[{
     RowBox[{"ListLinePlot", "[", 
      RowBox[{"dayLengths", ",", "\n", "    ", 
       RowBox[{"PlotStyle", " ", "->", " ", "Orange"}], ",", "\n", "    ", 
       RowBox[{"PlotLegends", " ", "->", " ", 
        RowBox[{"{", "\"\<Day Length (hours)\>\"", "}"}]}], ",", "\n", "    ", 
       RowBox[{"ScalingFunctions", " ", "->", " ", 
        RowBox[{"{", 
         RowBox[{"None", ",", " ", "None"}], "}"}]}]}], "\n", "  ", "]"}], ",",
      "\n", "  ", 
     RowBox[{"PlotLabel", " ", "->", " ", "\"\<Day Length at 48N\>\""}]}], 
    "\n", "]"}]}]}]], "Input",ExpressionUUID->"a4ec4ec5-229a-1e47-8174-\
95069bbccd5e"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Coordinate Bands with GEEPixelLonLat", "Section",ExpressionUUID->"beeaa2ef-0ed4-4c4d-93a1-5806fd4c67f1"],

Cell[TextData[{
 Cell["GEEPixelLonLat", "InlineCode",ExpressionUUID->
  "81ab5f24-b919-174b-a11d-21680cf9ade6"],
 " creates an image whose pixel values are the geographic coordinates, useful \
for latitude-dependent corrections or masking."
}], "Text",ExpressionUUID->"278137c0-6738-004f-8fe2-fcee860d8463"],

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{
    RowBox[{"Mask", " ", "to", " ", "only", " ", "southern"}], "-", 
    RowBox[{"hemisphere", " ", "pixels"}]}], " ", "*)"}], "\n", 
  RowBox[{
   RowBox[{
    RowBox[{"lonlat", " ", "=", " ", 
     RowBox[{"GEEPixelLonLat", "[", "]"}]}], ";"}], "\n", "\n", 
   RowBox[{
    RowBox[{"southernMask", " ", "=", "\n", "  ", 
     RowBox[{
      RowBox[{"lonlat", " ", "//", "\n", "    ", 
       RowBox[{"GEESelectBands", "[", 
        RowBox[{"{", "\"\<latitude\>\"", "}"}], "]"}]}], " ", "//", "\n", 
      "    ", 
      RowBox[{"GEELessThan", "[", "0", "]"}]}]}], ";"}], "\n", "\n", 
   RowBox[{"(*", " ", 
    RowBox[{"Apply", " ", "to", " ", "a", " ", "global", " ", "dataset"}], 
    " ", "*)"}], "\n", 
   RowBox[{
    RowBox[{"maskedImage", " ", "=", "\n", "  ", 
     RowBox[{
      RowBox[{
       RowBox[{
       "GEELoadImage", "[", "\"\<MODIS/061/MOD13A2/2024_06_01\>\"", "]"}], 
       " ", "//", "\n", "    ", 
       RowBox[{"GEESelectBands", "[", 
        RowBox[{"{", "\"\<NDVI\>\"", "}"}], "]"}]}], " ", "//", "\n", "    ", 
      RowBox[{"GEEUpdateMask", "[", "southernMask", "]"}]}]}], 
    ";"}]}]}]], "Input",ExpressionUUID->"6f2e521e-aaa3-274f-8c25-\
c1857ea6d72c"],

Cell["", "Text",
 CellFrame->{{0, 0}, {0, 
  1}},ExpressionUUID->"55f65a85-9bb8-c542-9c33-9d73e93a47fb"]
