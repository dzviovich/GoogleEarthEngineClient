Cell[CellGroupData[{

Cell["8.3 Image Processing Pipeline", "Chapter",ExpressionUUID->"e9fbd54e-ac58-6145-b407-056c75ab5d5d"],

Cell[TextData[{
 "The paclet delivers GEE raster data as Wolfram ",
 Cell["Image", "InlineCode",ExpressionUUID->
  "4dd73d45-7cdf-f34a-91ef-02efaf361b7b"],
 " objects. Once client-side, the full power of the Wolfram Language image \
processing stack is available for enhancement, segmentation, edge detection, \
and change analysis."
}], "Text",ExpressionUUID->"2c1904d0-474e-f047-83ff-484c6f1fe71b"],

Cell[CellGroupData[{

Cell["Enhancement for Publication-Quality Output", "Section",ExpressionUUID->"7779de92-7f39-5543-adb9-f59fc0a37acd"],

Cell["\<\
Raw satellite imagery often needs contrast adjustment and color balancing \
before it is suitable for publication or reports.\
\>", "Text",ExpressionUUID->"550eed0e-730b-f647-9f2a-568bd8166c11"],

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{
    RowBox[{"Fetch", " ", "a", " ", "Sentinel"}], "-", 
    RowBox[{"2", " ", "true"}], "-", 
    RowBox[{"color", " ", "image"}]}], " ", "*)"}], "\n", 
  RowBox[{
   RowBox[{
    RowBox[{"rawImage", " ", "=", " ", 
     RowBox[{"GEEComputePixels", "[", "\n", "  ", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{
        "12.4", ",", " ", "41.8", ",", " ", "12.6", ",", " ", "42.0"}], "}"}],
        ",", "\n", "  ", 
       RowBox[{
        RowBox[{
         RowBox[{
          RowBox[{
           RowBox[{
            RowBox[{
            "GEECollection", "[", "\"\<COPERNICUS/S2_SR_HARMONIZED\>\"", 
             "]"}], " ", "//", "\n", "    ", 
            RowBox[{"GEEFilterDate", "[", 
             RowBox[{"\"\<2024-06-01\>\"", ",", " ", "\"\<2024-08-31\>\""}], 
             "]"}]}], " ", "//", "\n", "    ", 
           RowBox[{"GEEFilterProperty", "[", 
            
            RowBox[{"\"\<CLOUDY_PIXEL_PERCENTAGE\>\"", ",", 
             " ", "\"\<LessThan\>\"", ",", " ", "5"}], "]"}]}], " ", "//", 
          "\n", "    ", 
          RowBox[{"GEESelectBands", "[", 
           RowBox[{"{", 
            
            RowBox[{"\"\<B4\>\"", ",", " ", "\"\<B3\>\"", ",", 
             " ", "\"\<B2\>\""}], "}"}], "]"}]}], " ", "//", "\n", "    ", 
         "GEEMedian"}], " ", "//", "\n", "    ", 
        RowBox[{"GEEVisualize", "[", 
         RowBox[{"<|", 
          RowBox[{
           RowBox[{"\"\<min\>\"", " ", "->", " ", "0"}], ",", " ", 
           RowBox[{"\"\<max\>\"", " ", "->", " ", "3000"}]}], "|>"}], "]"}]}],
        ",", "\n", "  ", 
       RowBox[{"\"\<ImageSize\>\"", " ", "->", " ", "1024"}]}], "\n", "]"}]}],
     ";"}], "\n", "\n", 
   RowBox[{"(*", " ", "Enhance", " ", "*)"}], "\n", 
   RowBox[{
    RowBox[{"enhanced", " ", "=", "\n", "  ", 
     RowBox[{
      RowBox[{
       RowBox[{"rawImage", " ", "//", "\n", "    ", 
        RowBox[{
         RowBox[{"ImageAdjust", "[", 
          RowBox[{"#", ",", " ", 
           RowBox[{"{", 
            RowBox[{"0.1", ",", " ", "0.2"}], "}"}]}], "]"}], " ", "&"}]}], 
       " ", "//", "   ", 
       RowBox[{"(*", " ", 
        RowBox[{"Contrast", " ", "and", " ", "brightness"}], " ", "*)"}], 
       "\n", "    ", 
       RowBox[{
        RowBox[{"Sharpen", "[", 
         RowBox[{"#", ",", " ", "2"}], "]"}], " ", "&"}]}], " ", "//", 
      "                 ", 
      RowBox[{"(*", " ", 
       RowBox[{"Edge", " ", "enhancement"}], " ", "*)"}], "\n", "    ", 
      "ColorBalance"}]}], ";"}], "                       ", 
   RowBox[{"(*", " ", 
    RowBox[{"White", " ", "balance", " ", "correction"}], " ", "*)"}], "\n", 
   "\n", 
   RowBox[{"(*", " ", 
    RowBox[{
    "Match", " ", "a", " ", "reference", " ", "histogram", " ", "for", " ", 
     "consistent", " ", "styling"}], " ", "*)"}], "\n", 
   RowBox[{
    RowBox[{"referenceImage", " ", "=", " ", 
     RowBox[{"Import", "[", "\"\<reference_scene.png\>\"", "]"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"matched", " ", "=", " ", 
     RowBox[{"HistogramTransform", "[", 
      RowBox[{"enhanced", ",", " ", "referenceImage"}], "]"}]}], ";"}], "\n", 
   "\n", 
   RowBox[{"GraphicsRow", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"rawImage", ",", " ", "enhanced", ",", " ", "matched"}], "}"}], 
     ",", "\n", "  ", 
     RowBox[{"ImageSize", " ", "->", " ", "Large"}], ",", "\n", "  ", 
     RowBox[{"PlotLabel", " ", "->", " ", 
      RowBox[{"{", 
       RowBox[{"\"\<Raw\>\"", ",", " ", "\"\<Enhanced\>\"", ",", 
        " ", "\"\<Histogram Matched\>\""}], "}"}]}]}], "\n", 
    "]"}]}]}]], "Input",ExpressionUUID->"aeb8d7d7-86b2-4c41-ac40-\
783d64c622f3"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Segmentation: Counting Crop Fields", "Section",ExpressionUUID->"4d37f6e8-4b06-4545-9b33-d88c5425479c"],

Cell["\<\
Thresholding an NDVI image and analyzing connected components lets you count \
and measure individual features such as crop fields or water bodies.\
\>", "Text",ExpressionUUID->"944cddc1-5ee5-2d4a-9652-3ecbb5bcd850"],

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{"Compute", " ", "NDVI", " ", "image"}], " ", "*)"}], "\n", 
  RowBox[{
   RowBox[{
    RowBox[{"ndviRaster", " ", "=", " ", 
     RowBox[{"GEEComputePixels", "[", "\n", "  ", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{
        "11.0", ",", " ", "44.8", ",", " ", "11.4", ",", " ", "45.0"}], "}"}],
        ",", "\n", "  ", 
       RowBox[{
        RowBox[{
         RowBox[{
          RowBox[{
           RowBox[{
            RowBox[{
            "GEECollection", "[", "\"\<COPERNICUS/S2_SR_HARMONIZED\>\"", 
             "]"}], " ", "//", "\n", "    ", 
            RowBox[{"GEEFilterDate", "[", 
             RowBox[{"\"\<2024-07-01\>\"", ",", " ", "\"\<2024-08-31\>\""}], 
             "]"}]}], " ", "//", "\n", "    ", 
           RowBox[{"GEEFilterProperty", "[", 
            
            RowBox[{"\"\<CLOUDY_PIXEL_PERCENTAGE\>\"", ",", 
             " ", "\"\<LessThan\>\"", ",", " ", "10"}], "]"}]}], " ", "//", 
          "\n", "    ", "GEEMedian"}], " ", "//", "\n", "    ", 
         RowBox[{"GEENormalizedDifference", "[", 
          RowBox[{"{", 
           RowBox[{"\"\<B8\>\"", ",", " ", "\"\<B4\>\""}], "}"}], "]"}]}], 
        " ", "//", "\n", "    ", 
        RowBox[{"GEEVisualize", "[", 
         RowBox[{"<|", 
          RowBox[{
           RowBox[{"\"\<min\>\"", " ", "->", " ", 
            RowBox[{"-", "0.2"}]}], ",", " ", 
           RowBox[{"\"\<max\>\"", " ", "->", " ", "0.9"}], ",", "\n", 
           "      ", 
           RowBox[{"\"\<palette\>\"", " ", "->", " ", 
            RowBox[{"{", 
             
             RowBox[{"\"\<brown\>\"", ",", " ", "\"\<yellow\>\"", ",", 
              " ", "\"\<green\>\"", ",", " ", "\"\<darkgreen\>\""}], 
             "}"}]}]}], "|>"}], "]"}]}], ",", "\n", "  ", 
       RowBox[{"\"\<ImageSize\>\"", " ", "->", " ", "512"}]}], "\n", "]"}]}], 
    ";"}], "\n", "\n", 
   RowBox[{"(*", " ", 
    RowBox[{
     RowBox[{"Threshold", " ", "to", " ", "isolate", " ", "high"}], "-", 
     RowBox[{"NDVI", " ", "vegetation"}]}], " ", "*)"}], "\n", 
   RowBox[{
    RowBox[{"binary", " ", "=", " ", 
     RowBox[{"Binarize", "[", 
      RowBox[{"ndviRaster", ",", " ", "0.5"}], "]"}]}], ";"}], "\n", "\n", 
   RowBox[{"(*", " ", 
    RowBox[{"Identify", " ", "connected", " ", "components"}], " ", "*)"}], "\n", 
   RowBox[{
    RowBox[{"components", " ", "=", " ", 
     RowBox[{"MorphologicalComponents", "[", "binary", "]"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"nFields", " ", "=", " ", 
     RowBox[{"Max", "[", "components", "]"}]}], ";"}], "\n", "\n", 
   RowBox[{"(*", " ", 
    RowBox[{"Measure", " ", "each", " ", "component"}], " ", "*)"}], "\n", 
   RowBox[{
    RowBox[{"measurements", " ", "=", " ", 
     RowBox[{"ComponentMeasurements", "[", 
      RowBox[{"components", ",", "\n", "  ", 
       RowBox[{"{", 
        RowBox[{"\"\<Area\>\"", ",", " ", "\"\<Centroid\>\"", ",", 
         " ", "\"\<EquivalentDiskRadius\>\"", ",", " ", "\"\<Perimeter\>\""}],
         "}"}]}], "\n", "]"}]}], ";"}], "\n", "\n", 
   RowBox[{"Print", "[", 
    RowBox[{"\"\<Detected \>\"", ",", " ", "nFields", ",", 
     " ", "\"\< crop fields\>\""}], "]"}], "\n", "\n", 
   RowBox[{"(*", " ", 
    RowBox[{
    "Filter", " ", "by", " ", "minimum", " ", "area", " ", "to", " ", 
     "remove", " ", "noise"}], " ", "*)"}], "\n", 
   RowBox[{
    RowBox[{"significantFields", " ", "=", " ", 
     RowBox[{"Select", "[", 
      RowBox[{"measurements", ",", " ", 
       RowBox[{
        RowBox[{
         RowBox[{"#", "[", 
          RowBox[{"[", 
           RowBox[{"2", ",", " ", "1"}], "]"}], "]"}], " ", ">", " ", "100"}],
         " ", "&"}]}], "]"}]}], ";"}], "\n", 
   RowBox[{"Print", "[", 
    RowBox[{"\"\<Significant fields (>100 pixels): \>\"", ",", " ", 
     RowBox[{"Length", "[", "significantFields", "]"}]}], "]"}]}]}]], "Input",\
ExpressionUUID->"5c283933-f067-0144-8103-11b4f73ca2fd"],

Cell[TextData[{
 "The same segmentation workflow applies to water detection: compute NDWI (",
 Cell["GEENormalizedDifference[{\"B3\", \"B8\"}]", "InlineCode",
  ExpressionUUID->"f4d985ac-f8ac-404e-b390-e1b02ecf917b"],
 "), threshold, and run ",
 Cell["MorphologicalComponents", "InlineCode",ExpressionUUID->
  "dd81e898-5c28-464f-bd11-6b87314bd0ca"],
 " and ",
 Cell["ComponentMeasurements", "InlineCode",ExpressionUUID->
  "9d161806-7fc1-054a-8ade-24c580835195"],
 " to count and measure individual water bodies."
}], "Text",ExpressionUUID->"b14146e5-dc98-fa4c-9a7f-ab99e480bc2f"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Edge Detection: Coastline Extraction", "Section",ExpressionUUID->"efc85ddc-2216-d841-93ee-9731d1638089"],

Cell[TextData[{
 Cell["EdgeDetect", "InlineCode",ExpressionUUID->
  "83311d4c-e1fc-a14f-91ce-859cca2c5d05"],
 " finds boundaries in an image, which is useful for extracting coastlines, \
field boundaries, or urban edges."
}], "Text",ExpressionUUID->"68aca842-7405-6b4b-b3ea-957b1671b7eb"],

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{"NDWI", "-", 
    RowBox[{
    "based", " ", "water", " ", "mask", " ", "for", " ", "a", " ", "coastal", 
     " ", "area"}]}], " ", "*)"}], "\n", 
  RowBox[{
   RowBox[{
    RowBox[{"coastalNDWI", " ", "=", " ", 
     RowBox[{"GEEComputePixels", "[", "\n", "  ", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{
         RowBox[{"-", "5.0"}], ",", " ", "36.7", ",", " ", 
         RowBox[{"-", "4.8"}], ",", " ", "36.9"}], "}"}], ",", "\n", "  ", 
       RowBox[{
        RowBox[{
         RowBox[{
          RowBox[{
           RowBox[{
            RowBox[{
            "GEECollection", "[", "\"\<COPERNICUS/S2_SR_HARMONIZED\>\"", 
             "]"}], " ", "//", "\n", "    ", 
            RowBox[{"GEEFilterDate", "[", 
             RowBox[{"\"\<2024-05-01\>\"", ",", " ", "\"\<2024-08-31\>\""}], 
             "]"}]}], " ", "//", "\n", "    ", 
           RowBox[{"GEEFilterProperty", "[", 
            
            RowBox[{"\"\<CLOUDY_PIXEL_PERCENTAGE\>\"", ",", 
             " ", "\"\<LessThan\>\"", ",", " ", "10"}], "]"}]}], " ", "//", 
          "\n", "    ", "GEEMedian"}], " ", "//", "\n", "    ", 
         RowBox[{"GEENormalizedDifference", "[", 
          RowBox[{"{", 
           RowBox[{"\"\<B3\>\"", ",", " ", "\"\<B8\>\""}], "}"}], "]"}]}], 
        " ", "//", "\n", "    ", 
        RowBox[{"GEEVisualize", "[", 
         RowBox[{"<|", 
          RowBox[{
           RowBox[{"\"\<min\>\"", " ", "->", " ", 
            RowBox[{"-", "0.5"}]}], ",", " ", 
           RowBox[{"\"\<max\>\"", " ", "->", " ", "0.5"}]}], "|>"}], "]"}]}], 
       ",", "\n", "  ", 
       RowBox[{"\"\<ImageSize\>\"", " ", "->", " ", "512"}]}], "\n", "]"}]}], 
    ";"}], "\n", "\n", 
   RowBox[{
    RowBox[{"coastline", " ", "=", " ", 
     RowBox[{"EdgeDetect", "[", 
      RowBox[{"Binarize", "[", 
       RowBox[{"coastalNDWI", ",", " ", "0.2"}], "]"}], "]"}]}], ";"}], "\n", 
   "\n", 
   RowBox[{"(*", " ", 
    RowBox[{"Extract", " ", "linear", " ", "features"}], " ", "*)"}], "\n", 
   RowBox[{
    RowBox[{"lines", " ", "=", " ", 
     RowBox[{"ImageLines", "[", 
      RowBox[{"coastline", ",", " ", "0.1", ",", " ", 
       RowBox[{"Method", " ", "->", " ", "\"\<Hough\>\""}]}], "]"}]}], ";"}], 
   "\n", "\n", 
   RowBox[{"Show", "[", 
    RowBox[{"coastalNDWI", ",", " ", 
     RowBox[{"Graphics", "[", 
      RowBox[{"{", 
       RowBox[{"Red", ",", " ", "Thick", ",", " ", 
        RowBox[{"Line", " ", "/@", " ", "lines"}]}], "}"}], "]"}]}], 
    "]"}]}]}]], "Input",ExpressionUUID->"2a19514f-baf3-e446-8dbd-\
858323b52d46"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Change Detection with Image Differencing", "Section",ExpressionUUID->"d7f6d74f-f9b6-cb4a-ab52-cea28fdeae37"],

Cell["\<\
Comparing images from two dates reveals changes in land cover, urban growth, \
deforestation, or flood extent.\
\>", "Text",ExpressionUUID->"6c3183ac-8c95-5c4c-aa90-7969280b6890"],

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{"Before", " ", "image"}], " ", "*)"}], "\n", 
  RowBox[{
   RowBox[{
    RowBox[{"beforeImage", " ", "=", " ", 
     RowBox[{"GEEComputePixels", "[", "\n", "  ", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{
        "116.3", ",", " ", "39.8", ",", " ", "116.5", ",", " ", "40.0"}], 
        "}"}], ",", "\n", "  ", 
       RowBox[{
        RowBox[{
         RowBox[{
          RowBox[{
           RowBox[{
            RowBox[{
            "GEECollection", "[", "\"\<COPERNICUS/S2_SR_HARMONIZED\>\"", 
             "]"}], " ", "//", "\n", "    ", 
            RowBox[{"GEEFilterDate", "[", 
             RowBox[{"\"\<2020-06-01\>\"", ",", " ", "\"\<2020-08-31\>\""}], 
             "]"}]}], " ", "//", "\n", "    ", 
           RowBox[{"GEEFilterProperty", "[", 
            
            RowBox[{"\"\<CLOUDY_PIXEL_PERCENTAGE\>\"", ",", 
             " ", "\"\<LessThan\>\"", ",", " ", "10"}], "]"}]}], " ", "//", 
          "\n", "    ", "GEEMedian"}], " ", "//", "\n", "    ", 
         RowBox[{"GEENormalizedDifference", "[", 
          RowBox[{"{", 
           RowBox[{"\"\<B8\>\"", ",", " ", "\"\<B4\>\""}], "}"}], "]"}]}], 
        " ", "//", "\n", "    ", 
        RowBox[{"GEEVisualize", "[", 
         RowBox[{"<|", 
          RowBox[{
           RowBox[{"\"\<min\>\"", " ", "->", " ", 
            RowBox[{"-", "0.2"}]}], ",", " ", 
           RowBox[{"\"\<max\>\"", " ", "->", " ", "0.8"}]}], "|>"}], "]"}]}], 
       ",", "\n", "  ", 
       RowBox[{"\"\<ImageSize\>\"", " ", "->", " ", "512"}]}], "\n", "]"}]}], 
    ";"}], "\n", "\n", 
   RowBox[{"(*", " ", 
    RowBox[{"After", " ", "image"}], " ", "*)"}], "\n", 
   RowBox[{
    RowBox[{"afterImage", " ", "=", " ", 
     RowBox[{"GEEComputePixels", "[", "\n", "  ", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{
        "116.3", ",", " ", "39.8", ",", " ", "116.5", ",", " ", "40.0"}], 
        "}"}], ",", "\n", "  ", 
       RowBox[{
        RowBox[{
         RowBox[{
          RowBox[{
           RowBox[{
            RowBox[{
            "GEECollection", "[", "\"\<COPERNICUS/S2_SR_HARMONIZED\>\"", 
             "]"}], " ", "//", "\n", "    ", 
            RowBox[{"GEEFilterDate", "[", 
             RowBox[{"\"\<2024-06-01\>\"", ",", " ", "\"\<2024-08-31\>\""}], 
             "]"}]}], " ", "//", "\n", "    ", 
           RowBox[{"GEEFilterProperty", "[", 
            
            RowBox[{"\"\<CLOUDY_PIXEL_PERCENTAGE\>\"", ",", 
             " ", "\"\<LessThan\>\"", ",", " ", "10"}], "]"}]}], " ", "//", 
          "\n", "    ", "GEEMedian"}], " ", "//", "\n", "    ", 
         RowBox[{"GEENormalizedDifference", "[", 
          RowBox[{"{", 
           RowBox[{"\"\<B8\>\"", ",", " ", "\"\<B4\>\""}], "}"}], "]"}]}], 
        " ", "//", "\n", "    ", 
        RowBox[{"GEEVisualize", "[", 
         RowBox[{"<|", 
          RowBox[{
           RowBox[{"\"\<min\>\"", " ", "->", " ", 
            RowBox[{"-", "0.2"}]}], ",", " ", 
           RowBox[{"\"\<max\>\"", " ", "->", " ", "0.8"}]}], "|>"}], "]"}]}], 
       ",", "\n", "  ", 
       RowBox[{"\"\<ImageSize\>\"", " ", "->", " ", "512"}]}], "\n", "]"}]}], 
    ";"}], "\n", "\n", 
   RowBox[{"(*", " ", 
    RowBox[{"Pixel", "-", 
     RowBox[{"wise", " ", "difference"}]}], " ", "*)"}], "\n", 
   RowBox[{
    RowBox[{"changeImage", " ", "=", " ", 
     RowBox[{"ImageDifference", "[", 
      RowBox[{"afterImage", ",", " ", "beforeImage"}], "]"}]}], ";"}], "\n", 
   "\n", 
   RowBox[{"(*", " ", 
    RowBox[{"Emphasize", " ", "changes"}], " ", "*)"}], "\n", 
   RowBox[{
    RowBox[{"emphasizedChange", " ", "=", " ", 
     RowBox[{
      RowBox[{"changeImage", " ", "//", " ", "ImageAdjust"}], " ", "//", " ", 
      "ColorNegate"}]}], ";"}], "\n", "\n", 
   RowBox[{"GraphicsRow", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
      "beforeImage", ",", " ", "afterImage", ",", " ", "emphasizedChange"}], 
      "}"}], ",", "\n", "  ", 
     RowBox[{"PlotLabel", " ", "->", " ", 
      RowBox[{"{", 
       RowBox[{"\"\<2020\>\"", ",", " ", "\"\<2024\>\"", ",", 
        " ", "\"\<Change\>\""}], "}"}]}]}], "\n", "]"}]}]}]], "Input",Expressi\
onUUID->"4ccbbbf4-8f03-3c49-bb65-eb057dc0ae61"],

Cell["", "Text",
 CellFrame->{{0, 0}, {0, 
  1}},ExpressionUUID->"92daeffa-5abd-8146-9289-a7a0fd048d46"]
