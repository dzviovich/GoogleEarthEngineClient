Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{"Training", " ", 
    RowBox[{"data", ":", " ", 
     RowBox[{
      RowBox[{
      "spectral", " ", "indices", " ", "paired", " ", "with", " ", "field"}], 
      "-", 
      RowBox[{"measured", " ", "biomass", " ", 
       RowBox[{"(", 
        RowBox[{"kg", "/", 
         RowBox[{"m", "^", "2"}]}], ")"}]}]}]}]}], " ", "*)"}], "\n", 
  RowBox[{
   RowBox[{
    RowBox[{"biomassTraining", " ", "=", " ", 
     RowBox[{"{", "\n", "     ", 
      RowBox[{"(*", " ", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{"NDVI", ",", " ", "EVI", ",", " ", "NDWI"}], "}"}], " ", "->",
         " ", "biomass"}], " ", "*)"}], "\n", "  ", 
      RowBox[{
       RowBox[{
        RowBox[{"{", 
         RowBox[{"2.080762759394279`", ",", "0.6593601895734598`", ",", 
          RowBox[{"-", "0.6332361516034986`"}]}], "}"}], "->", "283"}], ",", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{"0.932815241915267`", ",", "0.45639641849625906`", ",", 
          RowBox[{"-", "0.5277920741121976`"}]}], "}"}], "->", "8"}], ",", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{"2.683884988298228`", ",", "0.8882434301521438`", ",", 
          RowBox[{"-", "0.7864433394399372`"}]}], "}"}], "->", "184"}]}], 
      "\n", "}"}]}], ";"}], "\n", "\n", 
   RowBox[{"biomassPredictor", " ", "=", " ", 
    RowBox[{"Predict", "[", 
     RowBox[{"biomassTraining", ",", " ", 
      RowBox[{"Method", " ", "->", " ", "\"\<RandomForest\>\""}]}], "]"}]}], 
   "\n", "\n", 
   RowBox[{"(*", " ", 
    RowBox[{
    "Predict", " ", "biomass", " ", "for", " ", "new", " ", "spectral", " ", 
     "measurements"}], " ", "*)"}], "\n", 
   RowBox[{"biomassPredictor", "[", 
    RowBox[{"{", 
     RowBox[{"0.65", ",", " ", "0.30", ",", " ", "0.17"}], "}"}], 
    "]"}]}]}]], "Input",
