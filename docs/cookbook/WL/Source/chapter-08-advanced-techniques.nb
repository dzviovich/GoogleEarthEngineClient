   3.987499073104683*^9, {3.987500077025299*^9, 3.9875001265537453`*^9}, 
   3.98750019252499*^9, {3.987500373075035*^9, 3.987500461282345*^9}, 
   3.9875007674006157`*^9},ExpressionUUID->"b5087895-ad19-7d45-bdc7-\
1cfbb3b0ad60"],

