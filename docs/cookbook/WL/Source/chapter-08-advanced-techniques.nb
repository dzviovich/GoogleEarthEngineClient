Cell[CellGroupData[{

Cell["8.2 Time Series Analysis", "Chapter",ExpressionUUID->"c805bc44-e2e7-9344-a065-1f2325c9f658"],

Cell["\<\
You have seen the monthly-loop pattern in earlier chapters. This section \
focuses on what to do after you have the time series -- trend detection, \
anomaly flagging, and forecasting.\
\>", "Text",ExpressionUUID->"6acb715d-190b-7f48-9787-7f6688dbf821"],

Cell[CellGroupData[{

Cell["Building Multi-Year Time Series", "Section",ExpressionUUID->"bc71f475-ced1-b943-94d1-9d0f0970e78e"],

Cell[TextData[{
 "The general pattern is to iterate over time windows, compute a regional \
statistic for each window using ",
 Cell["GEECompute", "InlineCode",ExpressionUUID->
  "b64c6122-2122-b14f-ae3b-149731349e42"],
 " with ",
 Cell["GEEReduceRegion", "InlineCode",ExpressionUUID->
  "263eaab1-603b-864b-8db3-a3f146087387"],
 ", and assemble the results into a ",
 Cell["TimeSeries", "InlineCode",ExpressionUUID->
  "bd488e20-f4ff-5742-9af6-b693598f6192"],
 " object."
}], "Text",ExpressionUUID->"4ee9fb1e-b813-d444-a6a6-3006ad74ecf1"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{"Define", " ", "region", " ", "of", " ", 
    RowBox[{"interest", ":", " ", 
     RowBox[{"a", " ", "forest", " ", "polygon"}]}]}], " ", "*)"}], "\n", 
  RowBox[{
   RowBox[{
    RowBox[{"forestPolygon", " ", "=", " ", 
     RowBox[{"GEEPolygon", "[", 
      RowBox[{"{", "\n", "  ", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{
          RowBox[{"-", "72.5"}], ",", " ", 
          RowBox[{"-", "13.0"}]}], "}"}], ",", " ", 
        RowBox[{"{", 
         RowBox[{
          RowBox[{"-", "72.3"}], ",", " ", 
          RowBox[{"-", "13.0"}]}], "}"}], ",", " ", 
        RowBox[{"{", 
         RowBox[{
          RowBox[{"-", "72.3"}], ",", " ", 
          RowBox[{"-", "12.8"}]}], "}"}], ",", "\n", "  ", 
        RowBox[{"{", 
         RowBox[{
          RowBox[{"-", "72.5"}], ",", " ", 
          RowBox[{"-", "12.8"}]}], "}"}], ",", " ", 
        RowBox[{"{", 
         RowBox[{
          RowBox[{"-", "72.5"}], ",", " ", 
          RowBox[{"-", "13.0"}]}], "}"}]}], "\n", "}"}], "]"}]}], ";"}], "\n",
    "\n", 
   RowBox[{"(*", " ", 
    RowBox[{
    "Generate", " ", "monthly", " ", "date", " ", "ranges", " ", "over", " ", 
     "5", " ", "years"}], " ", "*)"}], "\n", 
   RowBox[{
    RowBox[{"dateRanges", " ", "=", " ", 
     RowBox[{
      RowBox[{"Table", "[", "\n", "  ", 
       RowBox[{
        RowBox[{"{", "\n", "    ", 
         RowBox[{
          RowBox[{"DateString", "[", 
           RowBox[{
            RowBox[{"DateObject", "[", 
             RowBox[{"{", 
              RowBox[{"year", ",", " ", "month", ",", " ", "1"}], "}"}], 
             "]"}], ",", " ", 
            RowBox[{"{", 
             
             RowBox[{"\"\<Year\>\"", ",", " ", "\"\<-\>\"", ",", 
              " ", "\"\<Month\>\"", ",", " ", "\"\<-\>\"", ",", 
              " ", "\"\<Day\>\""}], "}"}]}], "]"}], ",", "\n", "    ", 
          RowBox[{"DateString", "[", "\n", "      ", 
           RowBox[{
            RowBox[{"DatePlus", "[", 
             RowBox[{
              RowBox[{"DateObject", "[", 
               RowBox[{"{", 
                RowBox[{"year", ",", " ", "month", ",", " ", "1"}], "}"}], 
               "]"}], ",", " ", 
              RowBox[{"{", 
               RowBox[{"1", ",", " ", "\"\<Month\>\""}], "}"}]}], "]"}], ",", 
            "\n", "      ", 
            RowBox[{"{", 
             
             RowBox[{"\"\<Year\>\"", ",", " ", "\"\<-\>\"", ",", 
              " ", "\"\<Month\>\"", ",", " ", "\"\<-\>\"", ",", 
              " ", "\"\<Day\>\""}], "}"}]}], "\n", "    ", "]"}]}], "\n", 
         "  ", "}"}], ",", "\n", "  ", 
        RowBox[{"{", 
         RowBox[{"year", ",", " ", "2019", ",", " ", "2023"}], "}"}], ",", 
        "\n", "  ", 
        RowBox[{"{", 
         RowBox[{"month", ",", " ", "1", ",", " ", "12"}], "}"}]}], "\n", 
       "]"}], " ", "//", " ", 
      RowBox[{
       RowBox[{"Flatten", "[", 
        RowBox[{"#", ",", " ", "1"}], "]"}], " ", "&"}]}]}], ";"}], "\n", 
   "\n", 
   RowBox[{"(*", " ", 
    RowBox[{
    "Extract", " ", "mean", " ", "NDVI", " ", "for", " ", "each", " ", 
     "month"}], " ", "*)"}], "\n", 
   RowBox[{
    RowBox[{"ndviTimeSeries", " ", "=", " ", 
     RowBox[{"Table", "[", "\n", "  ", 
      RowBox[{
       RowBox[{"Module", "[", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{"pipeline", ",", " ", "result"}], "}"}], ",", "\n", "    ", 
         RowBox[{
          RowBox[{"pipeline", " ", "=", "\n", "      ", 
           RowBox[{
            RowBox[{
             RowBox[{
              RowBox[{
               RowBox[{
                RowBox[{
                "GEECollection", "[", "\"\<MODIS/061/MOD13A2\>\"", "]"}], " ",
                 "//", "\n", "        ", 
                RowBox[{"GEEFilterDate", "[", 
                 RowBox[{
                  RowBox[{"dates", "[", 
                   RowBox[{"[", "1", "]"}], "]"}], ",", " ", 
                  RowBox[{"dates", "[", 
                   RowBox[{"[", "2", "]"}], "]"}]}], "]"}]}], " ", "//", "\n",
                "        ", 
               RowBox[{"GEESelectBands", "[", 
                RowBox[{"{", "\"\<NDVI\>\"", "}"}], "]"}]}], " ", "//", "\n", 
              "        ", "GEEMean"}], " ", "//", "\n", "        ", 
             RowBox[{"GEEMultiply", "[", "0.0001", "]"}]}], " ", "//", "  ", 
            RowBox[{"(*", " ", 
             RowBox[{"Apply", " ", "MODIS", " ", "scale", " ", "factor"}], 
             " ", "*)"}], "\n", "        ", 
            RowBox[{"GEEReduceRegion", "[", 
             RowBox[{
             "forestPolygon", ",", " ", "\"\<mean\>\"", ",", " ", "1000"}], 
             "]"}]}]}], ";", "\n", "    ", 
          RowBox[{"result", " ", "=", " ", 
           RowBox[{"GEECompute", "[", "pipeline", "]"}]}], ";", "\n", "    ", 
          RowBox[{"{", 
           RowBox[{
            RowBox[{"DateObject", "[", 
             RowBox[{"dates", "[", 
              RowBox[{"[", "1", "]"}], "]"}], "]"}], ",", " ", "result"}], 
           "}"}]}]}], "\n", "  ", "]"}], ",", "\n", "  ", 
       RowBox[{"{", 
        RowBox[{"dates", ",", " ", "dateRanges"}], "}"}]}], "\n", "]"}]}], 
    ";"}], "\n", "\n", 
   RowBox[{"(*", " ", 
    RowBox[{"Build", " ", "a", " ", "TimeSeries", " ", "object"}], " ", 
    "*)"}], "\n", 
   RowBox[{
    RowBox[{"ndviTS", " ", "=", " ", 
     RowBox[{"TimeSeries", "[", "\n", "  ", 
      RowBox[{
       RowBox[{"ndviTimeSeries", "[", 
        RowBox[{"[", 
         RowBox[{"All", ",", " ", "2"}], "]"}], "]"}], ",", "\n", "  ", 
       RowBox[{"{", 
        RowBox[{"ndviTimeSeries", "[", 
         RowBox[{"[", 
          RowBox[{"All", ",", " ", "1"}], "]"}], "]"}], "}"}]}], "\n", 
      "]"}]}], ";"}], "\n", "\n", 
   RowBox[{"DateListPlot", "[", 
    RowBox[{"ndviTS", ",", "\n", "  ", 
     RowBox[{
     "PlotLabel", " ", "->", " ", "\"\<Monthly Mean NDVI (2019-2023)\>\""}], ",",
      "\n", "  ", 
     RowBox[{"FrameLabel", " ", "->", " ", 
      RowBox[{"{", 
       RowBox[{"\"\<Date\>\"", ",", " ", "\"\<NDVI\>\""}], "}"}]}], ",", "\n",
      "  ", 
     RowBox[{"Filling", " ", "->", " ", "Axis"}]}], "\n", "]"}]}]}]], "Input",
 CellChangeTimes->{3.9871944757854557`*^9},
 CellLabel->
  "In[120]:=",ExpressionUUID->"dec9d139-3a59-e947-a9d9-cf980b61ecb7"],

