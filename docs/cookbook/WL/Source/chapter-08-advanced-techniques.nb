Cell[CellGroupData[{

Cell["8.7 Parallel and Batch Processing", "Chapter",ExpressionUUID->"55b272d5-cff4-cb44-9f4f-fdaa2e9cbe8c"],

Cell["\<\
When analyzing many regions or time steps, parallel execution can \
dramatically reduce wall-clock time.\
\>", "Text",ExpressionUUID->"ade6c9e2-8d73-c441-a942-cc5e2ec784bf"],

Cell[CellGroupData[{

Cell["Parallel Multi-Region Analysis", "Section",ExpressionUUID->"cff910ad-e824-034f-b0d9-2ef89e81163a"],

Cell[TextData[{
 Cell["ParallelMap", "InlineCode",ExpressionUUID->
  "be831830-8dd0-8646-8a40-c25e067826d6"],
 " distributes computations across available kernels. Each kernel needs its \
own authenticated connection."
}], "Text",ExpressionUUID->"ca4eb942-0743-394f-953b-2148e972d728"],

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{"Define", " ", "field", " ", "polygons"}], " ", "*)"}], "\n", 
  RowBox[{
   RowBox[{
    RowBox[{"fieldGeometries", " ", "=", " ", 
     RowBox[{
      RowBox[{"Table", "[", "\n", "  ", 
       RowBox[{
        RowBox[{"GEEPolygon", "[", 
         RowBox[{"{", "\n", "    ", 
          RowBox[{
           RowBox[{"{", 
            RowBox[{"lon", ",", " ", "lat"}], "}"}], ",", " ", 
           RowBox[{"{", 
            RowBox[{
             RowBox[{"lon", " ", "+", " ", "0.01"}], ",", " ", "lat"}], "}"}],
            ",", " ", 
           RowBox[{"{", 
            RowBox[{
             RowBox[{"lon", " ", "+", " ", "0.01"}], ",", " ", 
             RowBox[{"lat", " ", "+", " ", "0.01"}]}], "}"}], ",", "\n", 
           "    ", 
           RowBox[{"{", 
            RowBox[{"lon", ",", " ", 
             RowBox[{"lat", " ", "+", " ", "0.01"}]}], "}"}], ",", " ", 
           RowBox[{"{", 
            RowBox[{"lon", ",", " ", "lat"}], "}"}]}], "\n", "  ", "}"}], 
         "]"}], ",", "\n", "  ", 
        RowBox[{"{", 
         RowBox[{
         "lat", ",", " ", "45.0", ",", " ", "45.49", ",", " ", "0.01"}], 
         "}"}], ",", "\n", "  ", 
        RowBox[{"{", 
         RowBox[{
         "lon", ",", " ", "11.0", ",", " ", "11.49", ",", " ", "0.01"}], 
         "}"}]}], "\n", "]"}], " ", "//", " ", "Flatten"}]}], ";"}], "\n", "\n", 
   RowBox[{"Print", "[", 
    RowBox[{"\"\<Processing \>\"", ",", " ", 
     RowBox[{"Length", "[", "fieldGeometries", "]"}], ",", 
     " ", "\"\< field polygons\>\""}], "]"}], "\n", "\n", 
   RowBox[{"(*", " ", 
    RowBox[{
    "Ensure", " ", "parallel", " ", "kernels", " ", "are", " ", "loaded"}], 
    " ", "*)"}], "\n", 
   RowBox[{
    RowBox[{"LaunchKernels", "[", "]"}], ";"}], "\n", "\n", 
   RowBox[{
    RowBox[{"ParallelEvaluate", "[", "\n", "  ", 
     RowBox[{
      RowBox[{"Needs", "[", "\"\<GoogleEarthEngineClient`\>\"", "]"}], ";", 
      "\n", "  ", 
      RowBox[{
      "GEEConnect", "[", "\"\</path/to/service-account-key.json\>\"", "]"}], 
      ";"}], "\n", "]"}], ";"}], "\n", "\n", 
   RowBox[{"(*", " ", 
    RowBox[{"Build", " ", "the", " ", "pipeline", " ", 
     RowBox[{"once", " ", "--"}], " ", "it", " ", "is", " ", "just", " ", "a",
      " ", "symbolic", " ", "expression"}], " ", "*)"}], "\n", 
   RowBox[{
    RowBox[{"ndviPipeline", " ", "=", "\n", "  ", 
     RowBox[{
      RowBox[{
       RowBox[{
        RowBox[{
         RowBox[{
         "GEECollection", "[", "\"\<COPERNICUS/S2_SR_HARMONIZED\>\"", "]"}], 
         " ", "//", "\n", "    ", 
         RowBox[{"GEEFilterDate", "[", 
          RowBox[{"\"\<2024-06-01\>\"", ",", " ", "\"\<2024-08-31\>\""}], 
          "]"}]}], " ", "//", "\n", "    ", 
        RowBox[{"GEEFilterProperty", "[", 
         RowBox[{"\"\<CLOUDY_PIXEL_PERCENTAGE\>\"", ",", 
          " ", "\"\<LessThan\>\"", ",", " ", "15"}], "]"}]}], " ", "//", "\n",
        "    ", "GEEMedian"}], " ", "//", "\n", "    ", 
      RowBox[{"GEENormalizedDifference", "[", 
       RowBox[{"{", 
        RowBox[{"\"\<B8\>\"", ",", " ", "\"\<B4\>\""}], "}"}], "]"}]}]}], 
    ";"}], "\n", "\n", 
   RowBox[{"(*", " ", 
    RowBox[{
    "Extract", " ", "mean", " ", "NDVI", " ", "per", " ", "field", " ", "in", 
     " ", "parallel"}], " ", "*)"}], "\n", 
   RowBox[{
    RowBox[{"fieldNDVI", " ", "=", " ", 
     RowBox[{"ParallelMap", "[", "\n", "  ", 
      RowBox[{
       RowBox[{"Function", "[", 
        RowBox[{"geom", ",", "\n", "    ", 
         RowBox[{"GEECompute", "[", "\n", "      ", 
          RowBox[{"ndviPipeline", " ", "//", " ", 
           RowBox[{"GEEReduceRegion", "[", 
            RowBox[{"geom", ",", " ", "\"\<mean\>\"", ",", " ", "10"}], 
            "]"}]}], "\n", "    ", "]"}]}], "\n", "  ", "]"}], ",", "\n", 
       "  ", "fieldGeometries"}], "\n", "]"}]}], ";"}]}]}]], "Input",Expressio\
nUUID->"7d3761db-f85b-124a-8c4a-2f93d6f50d2a"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Server-Side Multi-Region Reduction with GEEReduceRegions", "Section",ExpressionUUID->"3f3e1fca-dcb3-1c4e-8bed-5bd51297e55c"],

Cell[TextData[{
 "For moderate numbers of regions, ",
 Cell["GEEReduceRegions", "InlineCode",ExpressionUUID->
  "d3bdb513-6407-7a4f-9200-aad46d01ee32"],
 " is more efficient because it sends a single request to GEE rather than one \
per region."
}], "Text",ExpressionUUID->"e861a902-4776-084b-bda6-ce9042432fb1"],

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{
   "Load", " ", "a", " ", "FeatureCollection", " ", "of", " ", 
    "administrative", " ", "boundaries"}], " ", "*)"}], "\n", 
  RowBox[{
   RowBox[{
    RowBox[{"adminBoundaries", " ", "=", " ", 
     RowBox[{
     "GEEFeatureCollection", "[", "\"\<FAO/GAUL/2015/level1\>\"", "]"}]}], 
    ";"}], "\n", "\n", 
   RowBox[{"(*", " ", 
    RowBox[{
     RowBox[{"Reduce", " ", "NDVI", " ", "over", " ", "all", " ", "sub"}], "-", 
     RowBox[{"national", " ", "regions", " ", "at", " ", "once"}]}], " ", 
    "*)"}], "\n", 
   RowBox[{
    RowBox[{"regionStats", " ", "=", "\n", "  ", 
     RowBox[{"ndviPipeline", " ", "//", "\n", "    ", 
      RowBox[{"GEEReduceRegions", "[", 
       RowBox[{"adminBoundaries", ",", " ", "\"\<mean\>\"", ",", " ", "500"}],
        "]"}]}]}], ";"}], "\n", "\n", 
   RowBox[{
    RowBox[{"results", " ", "=", " ", 
     RowBox[{"GEECompute", "[", "regionStats", "]"}]}], ";"}]}]}]], "Input",Ex\
pressionUUID->"5026583b-ab7a-7f4e-ae1b-4faefe191135"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Batch Temporal Extraction", "Section",ExpressionUUID->"c1a8938d-49a0-294a-a1f6-da7fd63e0da3"],

Cell[TextData[{
 "For multi-year monthly statistics, ",
 Cell["Table", "InlineCode",ExpressionUUID->
  "c404185c-c09b-be44-9305-4dc967f095c9"],
 " generates the full set of queries and ",
 Cell["ParallelTable", "InlineCode",ExpressionUUID->
  "f78df72b-b1a5-1e41-8251-c175e661c139"],
 " speeds up execution."
}], "Text",ExpressionUUID->"3fa6e1ac-f5f8-8140-96d2-28531a528bbc"],

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{
    RowBox[{"Monthly", " ", "NDVI", " ", "for", " ", "5", " ", "years"}], ",",
     " ", "parallelized"}], " ", "*)"}], "\n", 
  RowBox[{
   RowBox[{
    RowBox[{"monthlyStats", " ", "=", " ", 
     RowBox[{
      RowBox[{"ParallelTable", "[", "\n", "  ", 
       RowBox[{
        RowBox[{"Module", "[", 
         RowBox[{
          RowBox[{"{", 
           RowBox[{"startDate", ",", " ", "endDate", ",", " ", "pipeline"}], 
           "}"}], ",", "\n", "    ", 
          RowBox[{
           RowBox[{"startDate", " ", "=", " ", 
            RowBox[{"DateString", "[", 
             RowBox[{
              RowBox[{"DateObject", "[", 
               RowBox[{"{", 
                RowBox[{"year", ",", " ", "month", ",", " ", "1"}], "}"}], 
               "]"}], ",", "\n", "      ", 
              RowBox[{"{", 
               
               RowBox[{"\"\<Year\>\"", ",", " ", "\"\<-\>\"", ",", 
                " ", "\"\<Month\>\"", ",", " ", "\"\<-\>\"", ",", 
                " ", "\"\<Day\>\""}], "}"}]}], "]"}]}], ";", "\n", "    ", 
           RowBox[{"endDate", " ", "=", " ", 
            RowBox[{"DateString", "[", 
             RowBox[{
              RowBox[{"DatePlus", "[", 
               RowBox[{
                RowBox[{"DateObject", "[", 
                 RowBox[{"{", 
                  RowBox[{"year", ",", " ", "month", ",", " ", "1"}], "}"}], 
                 "]"}], ",", " ", 
                RowBox[{"{", 
                 RowBox[{"1", ",", " ", "\"\<Month\>\""}], "}"}]}], "]"}], ",",
               "\n", "      ", 
              RowBox[{"{", 
               
               RowBox[{"\"\<Year\>\"", ",", " ", "\"\<-\>\"", ",", 
                " ", "\"\<Month\>\"", ",", " ", "\"\<-\>\"", ",", 
                " ", "\"\<Day\>\""}], "}"}]}], "]"}]}], ";", "\n", "    ", 
           RowBox[{"pipeline", " ", "=", "\n", "      ", 
            RowBox[{
             RowBox[{
              RowBox[{
               RowBox[{
                RowBox[{
                 RowBox[{
                 "GEECollection", "[", "\"\<MODIS/061/MOD13A2\>\"", "]"}], 
                 " ", "//", "\n", "        ", 
                 RowBox[{"GEEFilterDate", "[", 
                  RowBox[{"startDate", ",", " ", "endDate"}], "]"}]}], " ", "//",
                 "\n", "        ", 
                RowBox[{"GEESelectBands", "[", 
                 RowBox[{"{", "\"\<NDVI\>\"", "}"}], "]"}]}], " ", "//", "\n",
                "        ", "GEEMean"}], " ", "//", "\n", "        ", 
              RowBox[{"GEEMultiply", "[", "0.0001", "]"}]}], " ", "//", "\n", 
             "        ", 
             RowBox[{"GEEReduceRegion", "[", 
              RowBox[{
              "forestPolygon", ",", " ", "\"\<mean\>\"", ",", " ", "1000"}], 
              "]"}]}]}], ";", "\n", "    ", 
           RowBox[{"<|", 
            RowBox[{
             RowBox[{"\"\<Year\>\"", " ", "->", " ", "year"}], ",", " ", 
             RowBox[{"\"\<Month\>\"", " ", "->", " ", "month"}], ",", "\n", 
             "      ", 
             RowBox[{"\"\<NDVI\>\"", " ", "->", " ", 
              RowBox[{
               RowBox[{"GEECompute", "[", "pipeline", "]"}], 
               "[", "\"\<NDVI\>\"", "]"}]}]}], "|>"}]}]}], "\n", "  ", "]"}], 
        ",", "\n", "  ", 
        RowBox[{"{", 
         RowBox[{"year", ",", " ", "2019", ",", " ", "2023"}], "}"}], ",", 
        "\n", "  ", 
        RowBox[{"{", 
         RowBox[{"month", ",", " ", "1", ",", " ", "12"}], "}"}]}], "\n", 
       "]"}], " ", "//", " ", "Flatten"}]}], ";"}], "\n", "\n", 
   RowBox[{
    RowBox[{"monthlyDataset", " ", "=", " ", 
     RowBox[{"Dataset", "[", "monthlyStats", "]"}]}], ";"}]}]}]], "Input",Expr\
essionUUID->"892334b3-4cb2-ce48-9340-9ac06a3a1f7e"],

Cell["", "Text",
 CellFrame->{{0, 0}, {0, 
  1}},ExpressionUUID->"bad8a86b-e9bf-d04c-bde9-b6f8d5f88026"]
}, Open  ]]
}, Open  ]],

Cell[CellGroupData[{

Cell["8.8 Reproducible Research Workflows", "Chapter",ExpressionUUID->"7076dd2d-f93a-3e49-8be1-3e70175b81e3"],

Cell["\<\
A well-structured Mathematica notebook serves as both the analysis script and \
the research narrative. This section outlines a template for reproducible \
workflows that combine GEE data acquisition, analysis, and reporting.\
\>", "Text",ExpressionUUID->"4b82e5f5-7e48-1a4b-b891-e700e15b60b1"],

Cell[CellGroupData[{

Cell["Notebook Structure Template", "Section",ExpressionUUID->"a3a5457b-e97c-ea42-9b9b-0c80107c32cc"],

Cell["\<\
A reproducible analysis notebook should follow this general structure. Each \
section is a separate cell group in the notebook.\
\>", "Text",ExpressionUUID->"ad8a5ea9-80ea-e44c-b838-3e491890a515"],

Cell[TextData[StyleBox["Section 1: Setup and Authentication",
 FontWeight->Bold]], "Text",ExpressionUUID->"848ba10a-420b-1b46-8e8c-\
168815a9cfa4"],

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{"===", " ", "SETUP", " ", "==="}], " ", "*)"}], "\n", 
  RowBox[{
   RowBox[{"Needs", "[", "\"\<GoogleEarthEngineClient`\>\"", "]"}], "\n", 
   "\n", 
   RowBox[{"(*", " ", "Authenticate", " ", "*)"}], "\n", 
   RowBox[{"conn", " ", "=", " ", 
    RowBox[{
    "GEEConnect", "[", "\"\</path/to/service-account-key.json\>\"", "]"}]}], 
   "\n", "\n", 
   RowBox[{"(*", " ", 
    RowBox[{"Verify", " ", "connection"}], " ", "*)"}], "\n", 
   "$GEEConnection", "\n", "\n", 
   RowBox[{"(*", " ", 
    RowBox[{
    "List", " ", "available", " ", "assets", " ", "to", " ", "confirm", " ", 
     "access"}], " ", "*)"}], "\n", 
   RowBox[{"GEEListAssets", "[", 
    RowBox[{"\"\<projects/earthengine-public/assets/COPERNICUS\>\"", ",", 
     "\n", "  ", 
     RowBox[{"\"\<MaxResults\>\"", " ", "->", " ", "5"}]}], 
    "]"}]}]}]], "Input",ExpressionUUID->"987b355f-baa2-2542-9e91-\
6cf796dcc0aa"],

Cell[TextData[StyleBox["Section 2: Parameters and Configuration",
 FontWeight->Bold]], "Text",ExpressionUUID->"f239d745-5e8d-7b46-9344-\
bac474fd6294"],

Cell["\<\
Centralizing all parameters in one cell makes the analysis easy to rerun with \
different settings.\
\>", "Text",ExpressionUUID->"4c4e1449-ec8f-5f4f-b63a-b8efb2af1117"],

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{"===", " ", "PARAMETERS", " ", "==="}], " ", "*)"}], "\n", 
  RowBox[{
   RowBox[{
    RowBox[{"studyRegion", " ", "=", " ", 
     RowBox[{"GEEPolygon", "[", 
      RowBox[{"{", "\n", "  ", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{
          RowBox[{"-", "72.5"}], ",", " ", 
          RowBox[{"-", "13.0"}]}], "}"}], ",", " ", 
        RowBox[{"{", 
         RowBox[{
          RowBox[{"-", "72.0"}], ",", " ", 
          RowBox[{"-", "13.0"}]}], "}"}], ",", " ", 
        RowBox[{"{", 
         RowBox[{
          RowBox[{"-", "72.0"}], ",", " ", 
          RowBox[{"-", "12.5"}]}], "}"}], ",", "\n", "  ", 
        RowBox[{"{", 
         RowBox[{
          RowBox[{"-", "72.5"}], ",", " ", 
          RowBox[{"-", "12.5"}]}], "}"}], ",", " ", 
        RowBox[{"{", 
         RowBox[{
          RowBox[{"-", "72.5"}], ",", " ", 
          RowBox[{"-", "13.0"}]}], "}"}]}], "\n", "}"}], "]"}]}], ";"}], "\n",
    "\n", 
   RowBox[{
    RowBox[{"studyBBox", " ", "=", " ", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"-", "72.5"}], ",", " ", 
       RowBox[{"-", "13.0"}], ",", " ", 
       RowBox[{"-", "72.0"}], ",", " ", 
       RowBox[{"-", "12.5"}]}], "}"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"startDate", " ", "=", " ", "\"\<2020-01-01\>\""}], ";"}], "\n", 
   RowBox[{
    RowBox[{"endDate", " ", "=", " ", "\"\<2024-12-31\>\""}], ";"}], "\n", 
   RowBox[{
    RowBox[{"cloudThreshold", " ", "=", " ", "15"}], ";"}], "\n", 
   RowBox[{
    RowBox[{"ndviThreshold", " ", "=", " ", "0.4"}], ";"}], "\n", 
   RowBox[{
    RowBox[{"targetScale", " ", "=", " ", "30"}], ";"}], "  ", 
   RowBox[{"(*", " ", "meters", " ", "*)"}]}]}]], "Input",ExpressionUUID->\
"88750fcc-0de9-1641-9f7c-354d6a7d80db"],

Cell[TextData[StyleBox["Section 3: Data Acquisition",
 FontWeight->Bold]], "Text",ExpressionUUID->"24b39c2b-3896-dd45-9f55-\
9b3a5deb354f"],

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{"===", " ", 
    RowBox[{"DATA", " ", "ACQUISITION"}], " ", "==="}], " ", "*)"}], "\n", 
  "\n", 
  RowBox[{"(*", " ", 
   RowBox[{"Check", " ", "asset", " ", "metadata"}], " ", "*)"}], "\n", 
  RowBox[{
   RowBox[{
    RowBox[{"assetInfo", " ", "=", " ", 
     RowBox[{
     "GEEGetAssetInfo", "[", "\"\<COPERNICUS/S2_SR_HARMONIZED\>\"", "]"}]}], 
    ";"}], "\n", 
   RowBox[{"Print", "[", 
    RowBox[{"\"\<Asset type: \>\"", ",", " ", 
     RowBox[{"assetInfo", "[", "\"\<Type\>\"", "]"}]}], "]"}], "\n", 
   RowBox[{"Print", "[", 
    RowBox[{"\"\<Available bands: \>\"", ",", " ", 
     RowBox[{
      RowBox[{"assetInfo", "[", "\"\<Bands\>\"", "]"}], "[", 
      RowBox[{"[", 
       RowBox[{"All", ",", " ", "\"\<Name\>\""}], "]"}], "]"}]}], "]"}], "\n",
    "\n", 
   RowBox[{"(*", " ", 
    RowBox[{"Build", " ", "the", " ", "base", " ", "collection"}], " ", 
    "*)"}], "\n", 
   RowBox[{
    RowBox[{"s2Collection", " ", "=", "\n", "  ", 
     RowBox[{
      RowBox[{
       RowBox[{
        RowBox[{
        "GEECollection", "[", "\"\<COPERNICUS/S2_SR_HARMONIZED\>\"", "]"}], 
        " ", "//", "\n", "    ", 
        RowBox[{"GEEFilterDate", "[", 
         RowBox[{"startDate", ",", " ", "endDate"}], "]"}]}], " ", "//", "\n",
        "    ", 
       RowBox[{"GEEFilterBounds", "[", "studyBBox", "]"}]}], " ", "//", "\n", 
      "    ", 
      RowBox[{"GEEFilterProperty", "[", 
       RowBox[{"\"\<CLOUDY_PIXEL_PERCENTAGE\>\"", ",", " ", "\"\<LessThan\>\"",
         ",", " ", "cloudThreshold"}], "]"}]}]}], ";"}], "\n", "\n", 
   RowBox[{"(*", " ", 
    RowBox[{"Cloud", "-", 
     RowBox[{"masked", " ", "NDVI", " ", "composite"}]}], " ", "*)"}], "\n", 
   RowBox[{
    RowBox[{"ndviComposite", " ", "=", "\n", "  ", 
     RowBox[{
      RowBox[{"s2Collection", " ", "//", "\n", "    ", "GEEMedian"}], " ", "//",
       "\n", "    ", 
      RowBox[{"GEENormalizedDifference", "[", 
       RowBox[{"{", 
        RowBox[{"\"\<B8\>\"", ",", " ", "\"\<B4\>\""}], "}"}], "]"}]}]}], 
    ";"}], "\n", "\n", 
   RowBox[{"(*", " ", 
    RowBox[{"Fetch", " ", "the", " ", "NDVI", " ", "image"}], " ", "*)"}], "\n", 
   RowBox[{
    RowBox[{"ndviImage", " ", "=", " ", 
     RowBox[{"GEEComputePixels", "[", 
      RowBox[{"studyBBox", ",", " ", 
       RowBox[{"ndviComposite", " ", "//", "\n", "  ", 
        RowBox[{"GEEVisualize", "[", 
         RowBox[{"<|", 
          RowBox[{
           RowBox[{"\"\<min\>\"", " ", "->", " ", "0"}], ",", " ", 
           RowBox[{"\"\<max\>\"", " ", "->", " ", "0.8"}], ",", "\n", "    ", 
           RowBox[{"\"\<palette\>\"", " ", "->", " ", 
            RowBox[{"{", 
             
             RowBox[{"\"\<brown\>\"", ",", " ", "\"\<yellow\>\"", ",", 
              " ", "\"\<green\>\"", ",", " ", "\"\<darkgreen\>\""}], 
             "}"}]}]}], "|>"}], "]"}]}], ",", "\n", "  ", 
       RowBox[{"\"\<ImageSize\>\"", " ", "->", " ", "512"}]}], "\n", "]"}]}], 
    ";"}], "\n", "\n", 
   RowBox[{"(*", " ", 
    RowBox[{"True", "-", 
     RowBox[{"color", " ", "composite"}]}], " ", "*)"}], "\n", 
   RowBox[{
    RowBox[{"rgbComposite", " ", "=", "\n", "  ", 
     RowBox[{
      RowBox[{
       RowBox[{"s2Collection", " ", "//", "\n", "    ", 
        RowBox[{"GEESelectBands", "[", 
         RowBox[{"{", 
          
          RowBox[{"\"\<B4\>\"", ",", " ", "\"\<B3\>\"", ",", 
           " ", "\"\<B2\>\""}], "}"}], "]"}]}], " ", "//", "\n", "    ", 
       "GEEMedian"}], " ", "//", "\n", "    ", 
      RowBox[{"GEEVisualize", "[", 
       RowBox[{"<|", 
        RowBox[{
         RowBox[{"\"\<min\>\"", " ", "->", " ", "0"}], ",", " ", 
         RowBox[{"\"\<max\>\"", " ", "->", " ", "3000"}]}], "|>"}], "]"}]}]}],
     ";"}], "\n", "\n", 
   RowBox[{
    RowBox[{"rgbImage", " ", "=", " ", 
     RowBox[{"GEEComputePixels", "[", 
      RowBox[{"studyBBox", ",", " ", "rgbComposite", ",", " ", 
       RowBox[{"\"\<ImageSize\>\"", " ", "->", " ", "512"}]}], "]"}]}], ";"}],
    "\n", "\n", 
   RowBox[{"(*", " ", 
    RowBox[{"Geo", "-", 
     RowBox[{"tagged", " ", "image", " ", "with", " ", 
      RowBox[{"GEEImage", " ", "--"}], " ", "returns", " ", "image", " ", 
      "with", " ", "geo", " ", "metadata"}]}], " ", "*)"}], "\n", 
   RowBox[{
    RowBox[{"geoTaggedNDVI", " ", "=", " ", 
     RowBox[{"GEEImage", "[", "\n", "  ", 
      RowBox[{
       RowBox[{"GeoPosition", "[", 
        RowBox[{"{", 
         RowBox[{
          RowBox[{"-", "12.75"}], ",", " ", 
          RowBox[{"-", "72.25"}]}], "}"}], "]"}], ",", "\n", "  ", 
       "ndviComposite", ",", "\n", "  ", 
       RowBox[{"GeoRange", " ", "->", " ", 
        RowBox[{"Quantity", "[", 
         RowBox[{"20", ",", " ", "\"\<Kilometers\>\""}], "]"}]}], ",", "\n", 
       "  ", 
       RowBox[{"ImageSize", " ", "->", " ", "512"}]}], "\n", "]"}]}], ";"}], 
   "\n", "\n", 
   RowBox[{"(*", " ", 
    RowBox[{
    "Fetch", " ", "a", " ", "single", " ", "map", " ", "tile", " ", "with", " ",
      "GEEGetTile"}], " ", "*)"}], "\n", 
   RowBox[{
    RowBox[{"tile", " ", "=", " ", 
     RowBox[{"GEEGetTile", "[", 
      RowBox[{"rgbComposite", ",", " ", 
       RowBox[{"GeoPosition", "[", 
        RowBox[{"{", 
         RowBox[{
          RowBox[{"-", "12.75"}], ",", " ", 
          RowBox[{"-", "72.25"}]}], "}"}], "]"}], ",", " ", "12"}], "]"}]}], 
    ";"}], "\n", "\n", 
   RowBox[{"(*", " ", 
    RowBox[{"Elevation", " ", "data"}], " ", "*)"}], "\n", 
   RowBox[{
    RowBox[{"elevation", " ", "=", " ", 
     RowBox[{"GEELoadImage", "[", "\"\<USGS/SRTMGL1_003\>\"", "]"}]}], ";"}], 
   "\n", 
   RowBox[{
    RowBox[{"terrainData", " ", "=", " ", 
     RowBox[{"elevation", " ", "//", " ", "GEETerrain"}]}], ";"}], "\n", "\n", 
   RowBox[{"(*", " ", 
    RowBox[{
    "Identify", " ", "pixel", " ", "values", " ", "at", " ", "key", " ", 
     "points"}], " ", "*)"}], "\n", 
   RowBox[{
    RowBox[{"centralPoint", " ", "=", " ", 
     RowBox[{"GeoPosition", "[", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"-", "12.75"}], ",", " ", 
        RowBox[{"-", "72.25"}]}], "}"}], "]"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"elevationAtCenter", " ", "=", " ", 
     RowBox[{"GEEIdentify", "[", 
      RowBox[{"centralPoint", ",", " ", "elevation"}], "]"}]}], ";"}], "\n", 
   RowBox[{"Print", "[", 
    RowBox[{"\"\<Elevation at center: \>\"", ",", " ", 
     RowBox[{"elevationAtCenter", "[", "\"\<Values\>\"", "]"}], ",", 
     " ", "\"\< m\>\""}], "]"}]}]}]], "Input",ExpressionUUID->"c1591a08-da79-\
9844-8722-0e66bcf9921c"],

Cell[TextData[StyleBox["Section 4: Analysis",
 FontWeight->Bold]], "Text",ExpressionUUID->"30fb9c15-6a87-8b4b-85c2-1bb6cac2caff"],

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{"===", " ", "ANALYSIS", " ", "==="}], " ", "*)"}], "\n", "\n", 
  RowBox[{"(*", " ", 
   RowBox[{"Regional", " ", "statistics"}], " ", "*)"}], "\n", 
  RowBox[{
   RowBox[{
    RowBox[{"meanNDVI", " ", "=", " ", 
     RowBox[{"GEECompute", "[", "\n", "  ", 
      RowBox[{"ndviComposite", " ", "//", " ", 
       RowBox[{"GEEReduceRegion", "[", 
        RowBox[{
        "studyRegion", ",", " ", "\"\<mean\>\"", ",", " ", "targetScale"}], 
        "]"}]}], "\n", "]"}]}], ";"}], "\n", "\n", 
   RowBox[{"(*", " ", 
    RowBox[{"Per", "-", 
     RowBox[{
     "pixel", " ", "temporal", " ", "standard", " ", "deviation", " ", 
      "across", " ", "the", " ", "collection"}]}], " ", "*)"}], "\n", 
   RowBox[{
    RowBox[{"stdNDVI", " ", "=", " ", 
     RowBox[{"GEECompute", "[", "\n", "  ", 
      RowBox[{
       RowBox[{
        RowBox[{"s2Collection", " ", "//", "\n", "    ", 
         RowBox[{"GEECollectionMap", "[", 
          RowBox[{"Function", "[", 
           RowBox[{"img", ",", "\n", "      ", 
            RowBox[{"img", " ", "//", " ", 
             RowBox[{"GEENormalizedDifference", "[", 
              RowBox[{"{", 
               RowBox[{"\"\<B8\>\"", ",", " ", "\"\<B4\>\""}], "}"}], 
              "]"}]}]}], "\n", "    ", "]"}], "]"}]}], " ", "//", "\n", 
        "    ", "GEEReduceStdDev"}], " ", "//", "\n", "    ", 
       RowBox[{"GEEReduceRegion", "[", 
        RowBox[{
        "studyRegion", ",", " ", "\"\<mean\>\"", ",", " ", "targetScale"}], 
        "]"}]}], "\n", "]"}]}], ";"}], "\n", "\n", 
   RowBox[{"(*", " ", 
    RowBox[{"Vegetation", " ", "area", " ", "calculation"}], " ", "*)"}], "\n", 
   RowBox[{
    RowBox[{"vegMask", " ", "=", " ", 
     RowBox[{"ndviComposite", " ", "//", " ", 
      RowBox[{"GEEGreaterThan", "[", "ndviThreshold", "]"}]}]}], ";"}], "\n", 
   "\n", 
   RowBox[{
    RowBox[{"vegArea", " ", "=", " ", 
     RowBox[{"GEECompute", "[", "\n", "  ", 
      RowBox[{
       RowBox[{"vegMask", " ", "//", "\n", "    ", 
        RowBox[{"GEEMultiply", "[", 
         RowBox[{"GEEPixelArea", "[", "]"}], "]"}]}], " ", "//", "\n", "    ", 
       RowBox[{"GEEReduceRegion", "[", 
        RowBox[{
        "studyRegion", ",", " ", "\"\<sum\>\"", ",", " ", "targetScale"}], 
        "]"}]}], "\n", "]"}]}], ";"}], "\n", "\n", 
   RowBox[{
    RowBox[{"totalArea", " ", "=", " ", 
     RowBox[{"GEECompute", "[", 
      RowBox[{"GEEArea", "[", "studyRegion", "]"}], "]"}]}], ";"}], "\n", "\n", 
   RowBox[{
    RowBox[{"vegFraction", " ", "=", " ", 
     RowBox[{
      RowBox[{"vegArea", "[", "\"\<nd\>\"", "]"}], " ", "/", " ", 
      "totalArea"}]}], ";"}], "\n", "\n", 
   RowBox[{"Print", "[", 
    RowBox[{"\"\<Vegetation fraction: \>\"", ",", " ", 
     RowBox[{"NumberForm", "[", 
      RowBox[{
       RowBox[{"vegFraction", " ", "*", " ", "100"}], ",", " ", "3"}], "]"}], 
     ",", " ", "\"\<%\>\""}], "]"}], "\n", "\n", 
   RowBox[{"(*", " ", 
    RowBox[{"Elevation", "-", 
     RowBox[{"NDVI", " ", "relationship"}]}], " ", "*)"}], "\n", 
   RowBox[{
    RowBox[{"combinedImage", " ", "=", "\n", "  ", 
     RowBox[{
      RowBox[{"ndviComposite", " ", "//", "\n", "    ", 
       RowBox[{"GEERename", "[", 
        RowBox[{"{", "\"\<NDVI\>\"", "}"}], "]"}]}], " ", "//", "\n", "    ", 
      RowBox[{"GEEAddBands", "[", 
       RowBox[{"elevation", " ", "//", " ", 
        RowBox[{"GEESelectBands", "[", 
         RowBox[{"{", "\"\<elevation\>\"", "}"}], "]"}]}], "]"}]}]}], ";"}], 
   "\n", "\n", 
   RowBox[{
    RowBox[{"sampledData", " ", "=", " ", 
     RowBox[{"GEESample", "[", 
      RowBox[{
      "combinedImage", ",", " ", "studyRegion", ",", " ", "targetScale"}], 
      "]"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"sampleResults", " ", "=", " ", 
     RowBox[{"GEECompute", "[", "sampledData", "]"}]}], ";"}], "\n", "\n", 
   RowBox[{"(*", " ", 
    RowBox[{"Statistical", " ", "percentiles"}], " ", "*)"}], "\n", 
   RowBox[{
    RowBox[{"percentileResult", " ", "=", " ", 
     RowBox[{"GEECompute", "[", "\n", "  ", 
      RowBox[{
       RowBox[{
        RowBox[{"s2Collection", " ", "//", "\n", "    ", 
         RowBox[{"GEECollectionMap", "[", 
          RowBox[{"Function", "[", 
           RowBox[{"img", ",", "\n", "      ", 
            RowBox[{"img", " ", "//", " ", 
             RowBox[{"GEENormalizedDifference", "[", 
              RowBox[{"{", 
               RowBox[{"\"\<B8\>\"", ",", " ", "\"\<B4\>\""}], "}"}], 
              "]"}]}]}], "\n", "    ", "]"}], "]"}]}], " ", "//", "\n", 
        "    ", 
        RowBox[{"GEEReducePercentile", "[", 
         RowBox[{"{", 
          RowBox[{
          "10", ",", " ", "25", ",", " ", "50", ",", " ", "75", ",", " ", 
           "90"}], "}"}], "]"}]}], " ", "//", "\n", "    ", 
       RowBox[{"GEEReduceRegion", "[", 
        RowBox[{
        "studyRegion", ",", " ", "\"\<mean\>\"", ",", " ", "targetScale"}], 
        "]"}]}], "\n", "]"}]}], ";"}], "\n", "\n", 
   RowBox[{"Print", "[", 
    RowBox[{"\"\<NDVI percentiles: \>\"", ",", " ", "percentileResult"}], 
    "]"}]}]}]], "Input",ExpressionUUID->"1f072832-3496-204b-acef-\
2e52e12c2b7d"],

Cell[TextData[StyleBox["Section 5: Advanced Processing",
 FontWeight->Bold]], "Text",ExpressionUUID->"87593608-2be4-814c-8c63-\
240af6165aed"],

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{"===", " ", 
    RowBox[{"ADVANCED", " ", "PROCESSING"}], " ", "==="}], " ", "*)"}], "\n", 
  "\n", 
  RowBox[{"(*", " ", 
   RowBox[{
   "Spatial", " ", "filtering", " ", "for", " ", "noise", " ", "reduction"}], 
   " ", "*)"}], "\n", 
  RowBox[{
   RowBox[{
    RowBox[{"smoothedNDVI", " ", "=", "\n", "  ", 
     RowBox[{
      RowBox[{"ndviComposite", " ", "//", "\n", "    ", 
       RowBox[{"GEEFocalMean", "[", "90", "]"}]}], " ", "//", "      ", 
      RowBox[{"(*", " ", 
       RowBox[{"90", "-", 
        RowBox[{"meter", " ", "radius", " ", "smoothing"}]}], " ", "*)"}], 
      "\n", "    ", 
      RowBox[{"GEEVisualize", "[", 
       RowBox[{"<|", 
        RowBox[{
         RowBox[{"\"\<min\>\"", " ", "->", " ", "0"}], ",", " ", 
         RowBox[{"\"\<max\>\"", " ", "->", " ", "0.8"}]}], "|>"}], "]"}]}]}], 
    ";"}], "\n", "\n", 
   RowBox[{"(*", " ", 
    RowBox[{"Texture", " ", "analysis", " ", "via", " ", 
     RowBox[{"entropy", " ", "--"}], " ", "requires", " ", "integer", " ", 
     "input"}], " ", "*)"}], "\n", 
   RowBox[{
    RowBox[{"textureImage", " ", "=", "\n", "  ", 
     RowBox[{
      RowBox[{
       RowBox[{
        RowBox[{"s2Collection", " ", "//", "\n", "    ", "GEEMedian"}], " ", "//",
         "\n", "    ", 
        RowBox[{"GEESelectBands", "[", 
         RowBox[{"{", "\"\<B8\>\"", "}"}], "]"}]}], " ", "//", "\n", "    ", 
       "GEEToInt"}], " ", "//", "\n", "    ", 
      RowBox[{"GEEEntropy", "[", "30", "]"}]}]}], ";"}], "\n", "\n", 
   RowBox[{"(*", " ", 
    RowBox[{"Gradient", " ", "for", " ", "edge", " ", "detection"}], " ", 
    "*)"}], "\n", 
   RowBox[{
    RowBox[{"gradientImage", " ", "=", "\n", "  ", 
     RowBox[{
      RowBox[{
       RowBox[{"s2Collection", " ", "//", "\n", "    ", "GEEMedian"}], " ", "//",
        "\n", "    ", 
       RowBox[{"GEESelectBands", "[", 
        RowBox[{"{", "\"\<B8\>\"", "}"}], "]"}]}], " ", "//", "\n", "    ", 
      "GEEGradient"}]}], ";"}], "\n", "\n", 
   RowBox[{"(*", " ", 
    RowBox[{"Type", " ", "casting", " ", "for", " ", "computation"}], " ", 
    "*)"}], "\n", 
   RowBox[{
    RowBox[{"intImage", " ", "=", "\n", "  ", 
     RowBox[{
      RowBox[{"ndviComposite", " ", "//", "\n", "    ", 
       RowBox[{"GEEMultiply", "[", "10000", "]"}]}], " ", "//", "\n", "    ", 
      "GEEToInt"}]}], ";"}], "\n", "\n", 
   RowBox[{
    RowBox[{"floatImage", " ", "=", "\n", "  ", 
     RowBox[{
      RowBox[{"GEELoadImage", "[", "\"\<USGS/SRTMGL1_003\>\"", "]"}], " ", "//",
       "\n", "    ", "GEEToFloat"}]}], ";"}], "\n", "\n", 
   RowBox[{"(*", " ", 
    RowBox[{"Band", " ", "math", " ", "with", " ", "GEEExpression"}], " ", 
    "*)"}], "\n", 
   RowBox[{
    RowBox[{"enhancedVeg", " ", "=", "\n", "  ", 
     RowBox[{
      RowBox[{"s2Collection", " ", "//", "\n", "    ", "GEEMedian"}], " ", "//",
       "\n", "    ", 
      RowBox[{"GEEExpression", "[", "\n", "      ", 
       RowBox[{"\"\<(NIR - RED) / (NIR + RED + 0.5) * 1.5\>\"", ",", "\n", 
        "      ", 
        RowBox[{"<|", 
         RowBox[{
          RowBox[{"\"\<NIR\>\"", " ", "->", " ", "\"\<B8\>\""}], ",", " ", 
          RowBox[{"\"\<RED\>\"", " ", "->", " ", "\"\<B4\>\""}]}], "|>"}]}], 
       "\n", "    ", "]"}]}]}], ";"}], "\n", "\n", 
   RowBox[{"(*", " ", 
    RowBox[{"Mathematical", " ", "operations"}], " ", "*)"}], "\n", 
   RowBox[{
    RowBox[{"logTransformed", " ", "=", "\n", "  ", 
     RowBox[{
      RowBox[{
       RowBox[{"ndviComposite", " ", "//", "\n", "    ", "GEEAbs"}], " ", "//",
        "                 ", 
       RowBox[{"(*", " ", 
        RowBox[{"Ensure", " ", "positive", " ", "values"}], " ", "*)"}], "\n",
        "    ", 
       RowBox[{"GEEAdd", "[", "0.001", "]"}]}], " ", "//", "          ", 
      RowBox[{"(*", " ", 
       RowBox[{"Avoid", " ", "log", 
        RowBox[{"(", "0", ")"}]}], " ", "*)"}], "\n", "    ", "GEELog"}]}], 
    ";"}], "\n", "\n", 
   RowBox[{
    RowBox[{"sqrtTransformed", " ", "=", "\n", "  ", 
     RowBox[{
      RowBox[{"ndviComposite", " ", "//", "\n", "    ", "GEEAbs"}], " ", "//",
       "\n", "    ", "GEESqrt"}]}], ";"}], "\n", "\n", 
   RowBox[{"(*", " ", 
    RowBox[{"Conditional", " ", "replacement"}], " ", "*)"}], "\n", 
   RowBox[{
    RowBox[{"correctedNDVI", " ", "=", "\n", "  ", 
     RowBox[{"ndviComposite", " ", "//", "\n", "    ", 
      RowBox[{"GEEWhere", "[", "\n", "      ", 
       RowBox[{
        RowBox[{"ndviComposite", " ", "//", " ", 
         RowBox[{"GEELessThan", "[", 
          RowBox[{"-", "0.1"}], "]"}]}], ",", "  ", 
        RowBox[{"(*", " ", 
         RowBox[{"test", ":", " ", 
          RowBox[{"negative", " ", "anomalies"}]}], " ", "*)"}], "\n", 
        "      ", 
        RowBox[{"GEEConstant", "[", "0", "]"}]}], "                        ", 
       RowBox[{"(*", " ", 
        RowBox[{"replace", " ", "with", " ", "zero"}], " ", "*)"}], "\n", 
       "    ", "]"}]}]}], ";"}], "\n", "\n", 
   RowBox[{"(*", " ", 
    RowBox[{"Reprojection", " ", "and", " ", "resampling"}], " ", "*)"}], "\n", 
   RowBox[{
    RowBox[{"reprojected", " ", "=", "\n", "  ", 
     RowBox[{
      RowBox[{"ndviComposite", " ", "//", "\n", "    ", 
       RowBox[{"GEEResample", "[", "\"\<bilinear\>\"", "]"}]}], " ", "//", 
      "\n", "    ", 
      RowBox[{"GEEReproject", "[", 
       RowBox[{"\"\<EPSG:32632\>\"", ",", " ", "20"}], "]"}]}]}], ";"}], "  ", 
   RowBox[{"(*", " ", 
    RowBox[{
     RowBox[{"UTM", " ", "zone", " ", "32", "N"}], ",", " ", 
     RowBox[{"20", "m", " ", "resolution"}]}], " ", "*)"}], "\n", "\n", 
   RowBox[{"(*", " ", 
    RowBox[{
     RowBox[{"Focal", " ", 
      RowBox[{"statistics", ":", " ", 
       RowBox[{"local", " ", "range"}]}]}], " ", "=", " ", 
     RowBox[{"local", " ", "max", " ", "minus", " ", "local", " ", "min"}]}], 
    " ", "*)"}], "\n", 
   RowBox[{
    RowBox[{"localRange", " ", "=", "\n", "  ", 
     RowBox[{
      RowBox[{"(", 
       RowBox[{"ndviComposite", " ", "//", " ", 
        RowBox[{"GEEFocalMax", "[", "150", "]"}]}], ")"}], " ", "//", "\n", 
      "    ", 
      RowBox[{"GEESubtract", "[", 
       RowBox[{"ndviComposite", " ", "//", " ", 
        RowBox[{"GEEFocalMin", "[", "150", "]"}]}], "]"}]}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"localMedian", " ", "=", " ", 
     RowBox[{"ndviComposite", " ", "//", " ", 
      RowBox[{"GEEFocalMedian", "[", "150", "]"}]}]}], ";"}], "\n", "\n", 
   RowBox[{"(*", " ", 
    RowBox[{
    "Kernel", " ", "convolution", " ", "for", " ", "edge", " ", "detection"}],
     " ", "*)"}], "\n", 
   RowBox[{
    RowBox[{"edgeKernel", " ", "=", " ", 
     RowBox[{"<|", 
      RowBox[{"\"\<functionInvocationValue\>\"", " ", "->", " ", 
       RowBox[{"<|", "\n", "  ", 
        RowBox[{
         RowBox[{"\"\<functionName\>\"", " ", "->", 
          " ", "\"\<Kernel.fixed\>\""}], ",", "\n", "  ", 
         RowBox[{"\"\<arguments\>\"", " ", "->", " ", 
          RowBox[{"<|", "\n", "    ", 
           RowBox[{
            RowBox[{"\"\<width\>\"", " ", "->", " ", 
             RowBox[{"<|", 
              RowBox[{"\"\<constantValue\>\"", " ", "->", " ", "3"}], 
              "|>"}]}], ",", "\n", "    ", 
            RowBox[{"\"\<height\>\"", " ", "->", " ", 
             RowBox[{"<|", 
              RowBox[{"\"\<constantValue\>\"", " ", "->", " ", "3"}], 
              "|>"}]}], ",", "\n", "    ", 
            RowBox[{"\"\<weights\>\"", " ", "->", " ", 
             RowBox[{"<|", 
              RowBox[{"\"\<constantValue\>\"", " ", "->", " ", 
               RowBox[{"{", 
                RowBox[{
                 RowBox[{"{", 
                  RowBox[{
                   RowBox[{"-", "1"}], ",", " ", 
                   RowBox[{"-", "1"}], ",", " ", 
                   RowBox[{"-", "1"}]}], "}"}], ",", " ", 
                 RowBox[{"{", 
                  RowBox[{
                   RowBox[{"-", "1"}], ",", " ", "8", ",", " ", 
                   RowBox[{"-", "1"}]}], "}"}], ",", " ", 
                 RowBox[{"{", 
                  RowBox[{
                   RowBox[{"-", "1"}], ",", " ", 
                   RowBox[{"-", "1"}], ",", " ", 
                   RowBox[{"-", "1"}]}], "}"}]}], "}"}]}], "|>"}]}], ",", 
            "\n", "    ", 
            RowBox[{"\"\<normalize\>\"", " ", "->", " ", 
             RowBox[{"<|", 
              RowBox[{"\"\<constantValue\>\"", " ", "->", " ", "False"}], 
              "|>"}]}]}], "\n", "  ", "|>"}]}]}], "\n", "|>"}]}], "|>"}]}], 
    ";"}], "\n", 
   RowBox[{
    RowBox[{"edgeDetected", " ", "=", " ", 
     RowBox[{
      RowBox[{
       RowBox[{"s2Collection", " ", "//", " ", "GEEMedian"}], " ", "//", " ", 
       RowBox[{"GEESelectBands", "[", 
        RowBox[{"{", "\"\<B8\>\"", "}"}], "]"}]}], " ", "//", " ", 
      RowBox[{"GEEConvolve", "[", "edgeKernel", "]"}]}]}], ";"}], "\n", "\n", 
   RowBox[{"(*", " ", 
    RowBox[{
     RowBox[{"Math", " ", 
      RowBox[{"operations", ":", " ", "power"}]}], ",", " ", "modulo", ",", 
     " ", "exponential", ",", " ", "log10"}], " ", "*)"}], "\n", 
   RowBox[{
    RowBox[{"powerImage", " ", "=", " ", 
     RowBox[{"ndviComposite", " ", "//", " ", 
      RowBox[{"GEEPow", "[", "2", "]"}]}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"modImage", " ", "=", " ", 
     RowBox[{"intImage", " ", "//", " ", 
      RowBox[{"GEEMod", "[", "100", "]"}]}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"expImage", " ", "=", " ", 
     RowBox[{"ndviComposite", " ", "//", " ", "GEEExp"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"log10Image", " ", "=", " ", 
     RowBox[{
      RowBox[{
       RowBox[{"ndviComposite", " ", "//", " ", "GEEAbs"}], " ", "//", " ", 
       RowBox[{"GEEAdd", "[", "0.001", "]"}]}], " ", "//", " ", 
      "GEELog10"}]}], ";"}]}]}]], "Input",ExpressionUUID->"e67ebaa9-07e3-bf46-\
b16f-509d8de84644"],

Cell[TextData[StyleBox["Section 6: Collection Operations and Joins",
 FontWeight->Bold]], "Text",ExpressionUUID->"ab50d4ce-d91b-5944-92ea-\
8e33e165d868"],

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{"===", " ", 
    RowBox[{"COLLECTION", " ", "OPERATIONS"}], " ", "==="}], " ", "*)"}], 
  "\n", "\n", 
  RowBox[{"(*", " ", 
   RowBox[{"Quality", " ", 
    RowBox[{"mosaic", ":", " ", 
     RowBox[{
     "select", " ", "best", " ", "pixels", " ", "by", " ", "NDVI"}]}]}], " ", 
   "*)"}], "\n", 
  RowBox[{
   RowBox[{
    RowBox[{"qualityComposite", " ", "=", "\n", "  ", 
     RowBox[{
      RowBox[{"s2Collection", " ", "//", "\n", "    ", 
       RowBox[{"GEECollectionMap", "[", 
        RowBox[{"Function", "[", 
         RowBox[{"img", ",", "\n", "      ", 
          RowBox[{"img", " ", "//", "\n", "        ", 
           RowBox[{"GEEAddBands", "[", "\n", "          ", 
            RowBox[{
             RowBox[{"img", " ", "//", " ", 
              RowBox[{"GEENormalizedDifference", "[", 
               RowBox[{"{", 
                RowBox[{"\"\<B8\>\"", ",", " ", "\"\<B4\>\""}], "}"}], 
               "]"}]}], " ", "//", " ", 
             RowBox[{"GEERename", "[", 
              RowBox[{"{", "\"\<NDVI\>\"", "}"}], "]"}]}], "\n", "        ", 
            "]"}]}]}], "\n", "    ", "]"}], "]"}]}], " ", "//", "\n", "    ", 
      RowBox[{"GEEQualityMosaic", "[", "\"\<NDVI\>\"", "]"}]}]}], ";"}], "\n",
    "\n", 
   RowBox[{"(*", " ", 
    RowBox[{"Collection", "-", 
     RowBox[{"level", " ", "statistics"}]}], " ", "*)"}], "\n", 
   RowBox[{
    RowBox[{"collectionMax", " ", "=", " ", 
     RowBox[{
      RowBox[{"s2Collection", " ", "//", " ", 
       RowBox[{"GEESelectBands", "[", 
        RowBox[{"{", "\"\<B8\>\"", "}"}], "]"}]}], " ", "//", " ", 
      "GEECollectionMax"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"collectionMin", " ", "=", " ", 
     RowBox[{
      RowBox[{"s2Collection", " ", "//", " ", 
       RowBox[{"GEESelectBands", "[", 
        RowBox[{"{", "\"\<B8\>\"", "}"}], "]"}]}], " ", "//", " ", 
      "GEECollectionMin"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"collectionSum", " ", "=", " ", 
     RowBox[{
      RowBox[{"s2Collection", " ", "//", " ", 
       RowBox[{"GEESelectBands", "[", 
        RowBox[{"{", "\"\<B8\>\"", "}"}], "]"}]}], " ", "//", " ", 
      "GEECollectionSum"}]}], ";"}], "\n", "\n", 
   RowBox[{"(*", " ", 
    RowBox[{"Reduce", " ", "to", " ", 
     RowBox[{"count", ":", " ", 
      RowBox[{
      "how", " ", "many", " ", "clear", " ", "observations", " ", "per", " ", 
       "pixel"}]}]}], " ", "*)"}], "\n", 
   RowBox[{
    RowBox[{"observationCount", " ", "=", "\n", "  ", 
     RowBox[{
      RowBox[{"s2Collection", " ", "//", "\n", "    ", 
       RowBox[{"GEESelectBands", "[", 
        RowBox[{"{", "\"\<B8\>\"", "}"}], "]"}]}], " ", "//", "\n", "    ", 
      "GEEReduceCount"}]}], ";"}], "\n", "\n", 
   RowBox[{"(*", " ", 
    RowBox[{
     RowBox[{"Stack", " ", "collection", " ", "into", " ", "multi"}], "-", 
     RowBox[{"band", " ", "image"}]}], " ", "*)"}], "\n", 
   RowBox[{
    RowBox[{"stacked", " ", "=", "\n", "  ", 
     RowBox[{
      RowBox[{
       RowBox[{"s2Collection", " ", "//", "\n", "    ", 
        RowBox[{"GEELimit", "[", "6", "]"}]}], " ", "//", "\n", "    ", 
       RowBox[{"GEESelectBands", "[", 
        RowBox[{"{", "\"\<B8\>\"", "}"}], "]"}]}], " ", "//", "\n", "    ", 
      "GEEToBands"}]}], ";"}], "\n", "\n", 
   RowBox[{"(*", " ", 
    RowBox[{
    "Sort", " ", "collection", " ", "and", " ", "get", " ", "first", " ", 
     "image"}], " ", "*)"}], "\n", 
   RowBox[{
    RowBox[{"bestImage", " ", "=", "\n", "  ", 
     RowBox[{
      RowBox[{"s2Collection", " ", "//", "\n", "    ", 
       RowBox[{"GEESort", "[", "\"\<CLOUDY_PIXEL_PERCENTAGE\>\"", "]"}]}], 
      " ", "//", "\n", "    ", "GEEFirst"}]}], ";"}], "\n", "\n", 
   RowBox[{"(*", " ", 
    RowBox[{"Get", " ", "metadata", " ", "from", " ", "an", " ", "image"}], 
    " ", "*)"}], "\n", 
   RowBox[{
    RowBox[{"imageDate", " ", "=", " ", 
     RowBox[{"GEECompute", "[", 
      RowBox[{"bestImage", " ", "//", " ", "GEEDate"}], "]"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"cloudPct", " ", "=", " ", 
     RowBox[{"GEECompute", "[", 
      RowBox[{"bestImage", " ", "//", " ", 
       RowBox[{"GEEGet", "[", "\"\<CLOUDY_PIXEL_PERCENTAGE\>\"", "]"}]}], 
      "]"}]}], ";"}], "\n", "\n", 
   RowBox[{"(*", " ", 
    RowBox[{"Set", " ", "metadata"}], " ", "*)"}], "\n", 
   RowBox[{
    RowBox[{"taggedImage", " ", "=", "\n", "  ", 
     RowBox[{"ndviComposite", " ", "//", "\n", "    ", 
      RowBox[{"GEESet", "[", 
       RowBox[{"<|", 
        RowBox[{
         RowBox[{"\"\<analysis\>\"", " ", "->", 
          " ", "\"\<summer_composite\>\""}], ",", " ", 
         RowBox[{"\"\<threshold\>\"", " ", "->", " ", "0.4"}]}], "|>"}], 
       "]"}]}]}], ";"}], "\n", "\n", 
   RowBox[{"(*", " ", 
    RowBox[{"Merge", " ", "two", " ", "collections"}], " ", "*)"}], "\n", 
   RowBox[{
    RowBox[{"s2Spring", " ", "=", "\n", "  ", 
     RowBox[{
      RowBox[{
       RowBox[{
       "GEECollection", "[", "\"\<COPERNICUS/S2_SR_HARMONIZED\>\"", "]"}], 
       " ", "//", "\n", "    ", 
       RowBox[{"GEEFilterDate", "[", 
        RowBox[{"\"\<2024-03-01\>\"", ",", " ", "\"\<2024-05-31\>\""}], 
        "]"}]}], " ", "//", "\n", "    ", 
      RowBox[{"GEEFilterBounds", "[", "studyBBox", "]"}]}]}], ";"}], "\n", "\n", 
   RowBox[{
    RowBox[{"s2Fall", " ", "=", "\n", "  ", 
     RowBox[{
      RowBox[{
       RowBox[{
       "GEECollection", "[", "\"\<COPERNICUS/S2_SR_HARMONIZED\>\"", "]"}], 
       " ", "//", "\n", "    ", 
       RowBox[{"GEEFilterDate", "[", 
        RowBox[{"\"\<2024-09-01\>\"", ",", " ", "\"\<2024-11-30\>\""}], 
        "]"}]}], " ", "//", "\n", "    ", 
      RowBox[{"GEEFilterBounds", "[", "studyBBox", "]"}]}]}], ";"}], "\n", "\n", 
   RowBox[{
    RowBox[{"mergedCollection", " ", "=", " ", 
     RowBox[{"s2Spring", " ", "//", " ", 
      RowBox[{"GEEMerge", "[", "s2Fall", "]"}]}]}], ";"}], "\n", "\n", 
   RowBox[{"(*", " ", 
    RowBox[{"Cast", " ", "band", " ", "types"}], " ", "*)"}], "\n", 
   RowBox[{
    RowBox[{"castImage", " ", "=", "\n", "  ", 
     RowBox[{"ndviComposite", " ", "//", "\n", "    ", 
      RowBox[{"GEECast", "[", 
       RowBox[{"<|", 
        RowBox[{"\"\<nd\>\"", " ", "->", " ", "\"\<float\>\""}], "|>"}], 
       "]"}]}]}], ";"}], "\n", "\n", 
   RowBox[{"(*", " ", 
    RowBox[{"Joins", ":", " ", 
     RowBox[{
      RowBox[{"match", " ", "Landsat", " ", "and", " ", "Sentinel"}], "-", 
      RowBox[{
      "2", " ", "scenes", " ", "acquired", " ", "within", " ", "1", " ", 
       "day"}]}]}], " ", "*)"}], "\n", 
   RowBox[{
    RowBox[{"landsat", " ", "=", " ", 
     RowBox[{
      RowBox[{
       RowBox[{"GEECollection", "[", "\"\<LANDSAT/LC09/C02/T1_L2\>\"", "]"}], 
       " ", "//", "\n", "  ", 
       RowBox[{"GEEFilterDate", "[", 
        RowBox[{"\"\<2024-06-01\>\"", ",", " ", "\"\<2024-08-31\>\""}], 
        "]"}]}], " ", "//", " ", 
      RowBox[{"GEEFilterBounds", "[", "studyBBox", "]"}]}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"sentinel", " ", "=", " ", 
     RowBox[{
      RowBox[{
       RowBox[{
       "GEECollection", "[", "\"\<COPERNICUS/S2_SR_HARMONIZED\>\"", "]"}], 
       " ", "//", "\n", "  ", 
       RowBox[{"GEEFilterDate", "[", 
        RowBox[{"\"\<2024-06-01\>\"", ",", " ", "\"\<2024-08-31\>\""}], 
        "]"}]}], " ", "//", " ", 
      RowBox[{"GEEFilterBounds", "[", "studyBBox", "]"}]}]}], ";"}], "\n", "\n", 
   RowBox[{
    RowBox[{"cond", " ", "=", " ", 
     RowBox[{"<|", 
      RowBox[{"\"\<functionInvocationValue\>\"", " ", "->", " ", 
       RowBox[{"<|", "\n", "  ", 
        RowBox[{
         RowBox[{"\"\<functionName\>\"", " ", "->", 
          " ", "\"\<Filter.maxDifference\>\""}], ",", "\n", "  ", 
         RowBox[{"\"\<arguments\>\"", " ", "->", " ", 
          RowBox[{"<|", "\n", "    ", 
           RowBox[{
            RowBox[{"\"\<difference\>\"", " ", "->", " ", 
             RowBox[{"<|", 
              RowBox[{"\"\<constantValue\>\"", " ", "->", " ", "86400000"}], 
              "|>"}]}], ",", "\n", "    ", 
            RowBox[{"\"\<leftField\>\"", " ", "->", " ", 
             RowBox[{"<|", 
              
              RowBox[{"\"\<constantValue\>\"", " ", "->", 
               " ", "\"\<system:time_start\>\""}], "|>"}]}], ",", "\n", 
            "    ", 
            RowBox[{"\"\<rightField\>\"", " ", "->", " ", 
             RowBox[{"<|", 
              
              RowBox[{"\"\<constantValue\>\"", " ", "->", 
               " ", "\"\<system:time_start\>\""}], "|>"}]}]}], "\n", "  ", 
           "|>"}]}]}], "\n", "|>"}]}], "|>"}]}], ";"}], "\n", "\n", 
   RowBox[{
    RowBox[{"joined", " ", "=", " ", 
     RowBox[{"GEEJoinSimple", "[", 
      RowBox[{"landsat", ",", " ", "sentinel", ",", " ", "cond"}], "]"}]}], 
    ";"}], "\n", 
   RowBox[{
    RowBox[{"innerJoined", " ", "=", " ", 
     RowBox[{"GEEJoinInner", "[", 
      RowBox[{"landsat", ",", " ", "sentinel", ",", " ", "cond"}], "]"}]}], 
    ";"}], "\n", 
   RowBox[{
    RowBox[{"bestMatched", " ", "=", " ", 
     RowBox[{"GEEJoinSaveBest", "[", 
      RowBox[{
      "landsat", ",", " ", "sentinel", ",", " ", "cond", ",", 
       " ", "\"\<closest_sentinel\>\""}], "]"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"allMatched", " ", "=", " ", 
     RowBox[{"GEEJoinSaveAll", "[", 
      RowBox[{
      "landsat", ",", " ", "sentinel", ",", " ", "cond", ",", 
       " ", "\"\<matching_sentinel\>\""}], "]"}]}], ";"}]}]}]], "Input",Expres\
sionUUID->"2aba63b5-2208-a54e-aa8a-8c1d04766585"],

Cell[TextData[StyleBox["Section 7: Masking, Geometry, and Vectorization",
 FontWeight->Bold]], "Text",ExpressionUUID->"bf0205bf-be6a-d741-8861-\
56a467a1dac6"],

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{"===", " ", 
    RowBox[{"MASKING", " ", "AND", " ", "GEOMETRY"}], " ", "==="}], " ", 
   "*)"}], "\n", "\n", 
  RowBox[{"(*", " ", 
   RowBox[{"Self", "-", 
    RowBox[{"mask", ":", " ", 
     RowBox[{
      RowBox[{"remove", " ", "zero"}], "-", 
      RowBox[{"value", " ", "pixels"}]}]}]}], " ", "*)"}], "\n", 
  RowBox[{
   RowBox[{
    RowBox[{"selfMasked", " ", "=", " ", 
     RowBox[{"ndviComposite", " ", "//", " ", "GEESelfMask"}]}], ";"}], "\n", 
   "\n", 
   RowBox[{"(*", " ", 
    RowBox[{"Unmask", ":", " ", 
     RowBox[{
     "fill", " ", "masked", " ", "areas", " ", "with", " ", "a", " ", 
      "constant"}]}], " ", "*)"}], "\n", 
   RowBox[{
    RowBox[{"filledNDVI", " ", "=", " ", 
     RowBox[{"ndviComposite", " ", "//", " ", 
      RowBox[{"GEEUnmask", "[", 
       RowBox[{"-", "9999"}], "]"}]}]}], ";"}], "\n", "\n", 
   RowBox[{"(*", " ", 
    RowBox[{
    "Boolean", " ", "logic", " ", "for", " ", "complex", " ", "masks"}], " ", 
    "*)"}], "\n", 
   RowBox[{
    RowBox[{"vegetationMask", " ", "=", " ", 
     RowBox[{"ndviComposite", " ", "//", " ", 
      RowBox[{"GEEGreaterThan", "[", "0.3", "]"}]}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"waterMask", " ", "=", " ", 
     RowBox[{"ndviComposite", " ", "//", " ", 
      RowBox[{"GEELessThan", "[", 
       RowBox[{"-", "0.1"}], "]"}]}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"notWater", " ", "=", " ", 
     RowBox[{"waterMask", " ", "//", " ", "GEENot"}]}], ";"}], "\n", "\n", 
   RowBox[{"(*", " ", 
    RowBox[{"Combine", " ", 
     RowBox[{"masks", ":", " ", 
      RowBox[{
       RowBox[{"vegetation", " ", "AND", " ", "not"}], "-", "water"}]}]}], 
    " ", "*)"}], "\n", 
   RowBox[{
    RowBox[{"combinedMask", " ", "=", " ", 
     RowBox[{"vegetationMask", " ", "//", " ", 
      RowBox[{"GEEAnd", "[", "notWater", "]"}]}]}], ";"}], "\n", "\n", 
   RowBox[{"(*", " ", 
    RowBox[{"Test", " ", "equality", " ", "and", " ", "inequality"}], " ", 
    "*)"}], "\n", 
   RowBox[{
    RowBox[{"equalsMask", " ", "=", " ", 
     RowBox[{"intImage", " ", "//", " ", 
      RowBox[{"GEEEquals", "[", "5000", "]"}]}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"notEqualsMask", " ", "=", " ", 
     RowBox[{"intImage", " ", "//", " ", 
      RowBox[{"GEENotEquals", "[", "0", "]"}]}]}], ";"}], "\n", "\n", 
   RowBox[{"(*", " ", 
    RowBox[{"Logical", " ", "OR"}], " ", "*)"}], "\n", 
   RowBox[{
    RowBox[{"anyVegetation", " ", "=", " ", 
     RowBox[{"vegetationMask", " ", "//", " ", 
      RowBox[{"GEEOr", "[", "\n", "  ", 
       RowBox[{"ndviComposite", " ", "//", " ", 
        RowBox[{"GEEGreaterThan", "[", "0.2", "]"}]}], "\n", "]"}]}]}], ";"}],
    "\n", "\n", 
   RowBox[{"(*", " ", 
    RowBox[{"Geometry", " ", "operations"}], " ", "*)"}], "\n", 
   RowBox[{
    RowBox[{"bufferZone", " ", "=", " ", 
     RowBox[{"studyRegion", " ", "//", " ", 
      RowBox[{"GEEBuffer", "[", "5000", "]"}]}]}], ";"}], "  ", 
   RowBox[{"(*", " ", 
    RowBox[{"5", " ", "km", " ", "buffer"}], " ", "*)"}], "\n", 
   RowBox[{
    RowBox[{"centroid", " ", "=", " ", 
     RowBox[{"GEECentroid", "[", "studyRegion", "]"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"bounds", " ", "=", " ", 
     RowBox[{"GEEBounds", "[", "studyRegion", "]"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"area", " ", "=", " ", 
     RowBox[{"GEECompute", "[", 
      RowBox[{"GEEArea", "[", "bufferZone", "]"}], "]"}]}], ";"}], "\n", "\n", 
   RowBox[{"(*", " ", 
    RowBox[{"Line", " ", "geometry"}], " ", "*)"}], "\n", 
   RowBox[{
    RowBox[{"transect", " ", "=", " ", 
     RowBox[{"GEELineString", "[", 
      RowBox[{"{", "\n", "  ", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{
          RowBox[{"-", "72.4"}], ",", " ", 
          RowBox[{"-", "12.9"}]}], "}"}], ",", " ", 
        RowBox[{"{", 
         RowBox[{
          RowBox[{"-", "72.2"}], ",", " ", 
          RowBox[{"-", "12.7"}]}], "}"}], ",", " ", 
        RowBox[{"{", 
         RowBox[{
          RowBox[{"-", "72.1"}], ",", " ", 
          RowBox[{"-", "12.6"}]}], "}"}]}], "\n", "}"}], "]"}]}], ";"}], "\n",
    "\n", 
   RowBox[{
    RowBox[{"transectBuffer", " ", "=", " ", 
     RowBox[{"transect", " ", "//", " ", 
      RowBox[{"GEEBuffer", "[", "500", "]"}]}]}], ";"}], "  ", 
   RowBox[{"(*", " ", 
    RowBox[{"500", "m", " ", "corridor"}], " ", "*)"}], "\n", "\n", 
   RowBox[{"(*", " ", 
    RowBox[{"Vectorize", ":", " ", 
     RowBox[{"convert", " ", "raster", " ", "to", " ", "polygons"}]}], " ", 
    "*)"}], "\n", 
   RowBox[{
    RowBox[{"vectors", " ", "=", " ", 
     RowBox[{"GEEReduceToVectors", "[", "\n", "  ", 
      RowBox[{
       RowBox[{"ndviComposite", " ", "//", " ", 
        RowBox[{"GEEGreaterThan", "[", "ndviThreshold", "]"}]}], ",", "\n", 
       "  ", "studyRegion", ",", "\n", "  ", "targetScale"}], "\n", "]"}]}], 
    ";"}], "\n", "\n", 
   RowBox[{
    RowBox[{"vectorResults", " ", "=", " ", 
     RowBox[{"GEECompute", "[", "vectors", "]"}]}], ";"}]}]}]], "Input",Expres\
sionUUID->"a48cb285-3f54-814a-8a9b-b8cdbe589778"],

Cell[TextData[StyleBox["Section 8: Visualization",
 FontWeight->Bold]], "Text",ExpressionUUID->"b25ce549-75d9-4140-9dda-\
84dacf7beb9e"],

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{"===", " ", "VISUALIZATION", " ", "==="}], " ", "*)"}], "\n", "\n", 
  RowBox[{
   RowBox[{"GraphicsRow", "[", 
    RowBox[{
     RowBox[{"{", "\n", "  ", 
      RowBox[{
       RowBox[{"Labeled", "[", 
        RowBox[{"rgbImage", ",", " ", "\"\<True Color\>\"", ",", " ", "Top"}],
         "]"}], ",", "\n", "  ", 
       RowBox[{"Labeled", "[", 
        RowBox[{"ndviImage", ",", " ", "\"\<NDVI\>\"", ",", " ", "Top"}], 
        "]"}]}], "\n", "}"}], ",", " ", 
     RowBox[{"ImageSize", " ", "->", " ", "800"}]}], "]"}], "\n", "\n", 
   RowBox[{"(*", " ", 
    RowBox[{
    "GEE", " ", "background", " ", "with", " ", "overlaid", " ", "features"}],
     " ", "*)"}], "\n", 
   RowBox[{"GEEGeoGraphics", "[", "\n", "  ", 
    RowBox[{
     RowBox[{"{", "\n", "    ", 
      RowBox[{
       RowBox[{"EdgeForm", "[", 
        RowBox[{"{", 
         RowBox[{"Thick", ",", " ", "Red"}], "}"}], "]"}], ",", " ", 
       RowBox[{"FaceForm", "[", "None", "]"}], ",", "\n", "    ", 
       RowBox[{"Polygon", "[", 
        RowBox[{"GeoPosition", "[", 
         RowBox[{"{", "\n", "      ", 
          RowBox[{
           RowBox[{"{", 
            RowBox[{
             RowBox[{"-", "13.0"}], ",", " ", 
             RowBox[{"-", "72.5"}]}], "}"}], ",", " ", 
           RowBox[{"{", 
            RowBox[{
             RowBox[{"-", "13.0"}], ",", " ", 
             RowBox[{"-", "72.0"}]}], "}"}], ",", "\n", "      ", 
           RowBox[{"{", 
            RowBox[{
             RowBox[{"-", "12.5"}], ",", " ", 
             RowBox[{"-", "72.0"}]}], "}"}], ",", " ", 
           RowBox[{"{", 
            RowBox[{
             RowBox[{"-", "12.5"}], ",", " ", 
             RowBox[{"-", "72.5"}]}], "}"}]}], "\n", "    ", "}"}], "]"}], 
        "]"}], ",", "\n", "    ", "Green", ",", " ", 
       RowBox[{"PointSize", "[", "Large", "]"}], ",", "\n", "    ", 
       RowBox[{"Point", "[", "centralPoint", "]"}]}], "\n", "  ", "}"}], ",", 
     "\n", "  ", "rgbComposite", ",", "\n", "  ", 
     RowBox[{"GeoRange", " ", "->", " ", 
      RowBox[{"Quantity", "[", 
       RowBox[{"50", ",", " ", "\"\<Kilometers\>\""}], "]"}]}], ",", "\n", 
     "  ", 
     RowBox[{"GeoCenter", " ", "->", " ", "centralPoint"}], ",", "\n", "  ", 
     RowBox[{"ImageSize", " ", "->", " ", "600"}]}], "\n", "]"}]}]}]], "Input",\
ExpressionUUID->"f58cbf8b-656e-124d-81d1-6345a805a38b"],

Cell[TextData[StyleBox["Section 9: Export",
 FontWeight->Bold]], "Text",ExpressionUUID->"bd8cbcfe-1142-5944-ab07-7f4a6456ebd9"],

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{"===", " ", "EXPORT", " ", "==="}], " ", "*)"}], "\n", "\n", 
  RowBox[{
   RowBox[{"Export", "[", 
    RowBox[{"\"\<figures/ndvi_composite.png\>\"", ",", " ", "ndviImage"}], 
    "]"}], "\n", 
   RowBox[{"Export", "[", 
    RowBox[{"\"\<figures/rgb_composite.png\>\"", ",", " ", "rgbImage"}], 
    "]"}], "\n", "\n", 
   RowBox[{"Export", "[", 
    RowBox[{"\"\<data/monthly_ndvi.csv\>\"", ",", " ", "monthlyDataset"}], 
    "]"}], "\n", 
   RowBox[{"Export", "[", 
    RowBox[{"\"\<data/field_predictions.csv\>\"", ",", " ", 
     "resultsDataset"}], "]"}], "\n", "\n", 
   RowBox[{
   "Print", "[", "\"\<Analysis complete. Outputs saved to figures/ and \
data/\>\"", "]"}]}]}]], "Input",ExpressionUUID->"06ab3ad4-8fe5-9c47-a721-\
c9cf73c10071"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Checklist for Reproducibility", "Section",ExpressionUUID->"66e876f3-05cf-0144-83b6-72078c368a40"],

Cell["\<\
Following these practices ensures that anyone (including your future self) \
can rerun the analysis and obtain the same results:\
\>", "Text",ExpressionUUID->"81b8d08d-6af8-6e47-9517-b1a152f7ee5a"],

Cell[TextData[{
 StyleBox["Pin all parameters",
  FontWeight->Bold],
 " at the top of the notebook: date ranges, thresholds, region definitions, \
scale values."
}], "ItemNumbered",ExpressionUUID->"8294d51f-ba1b-4f4d-af48-8a9756ce58eb"],

Cell[TextData[{
 StyleBox["Record the paclet version",
  FontWeight->Bold],
 ": ",
 Cell["PacletInformation[\"GoogleEarthEngineClient\"]", "InlineCode",
  ExpressionUUID->"eff6eb83-ff36-e545-b10f-38c4d3f85f9a"],
 "."
}], "ItemNumbered",ExpressionUUID->"9df7f442-05d5-334b-9b0c-bbb02629c936"],

Cell[TextData[{
 StyleBox["Use deterministic composites",
  FontWeight->Bold],
 ": ",
 Cell["GEEMedian", "InlineCode",ExpressionUUID->
  "87ffa398-0d7d-b740-96d7-aba76164b8a4"],
 " and ",
 Cell["GEEMean", "InlineCode",ExpressionUUID->
  "d9bdec9c-9aff-a84a-a6d3-d52defd91b1f"],
 " produce the same result given the same input collection. Avoid ",
 Cell["GEEMosaic", "InlineCode",ExpressionUUID->
  "c6bb0c3c-d978-2e45-a599-847959fb12ac"],
 " when reproducibility matters, because it depends on image ordering."
}], "ItemNumbered",ExpressionUUID->"c2ee6761-2af2-0647-817b-a0f1ec1ec862"],

Cell[TextData[{
 StyleBox["Export intermediate data",
  FontWeight->Bold],
 ": save extracted time series and sample values to CSV so that downstream \
analysis does not require re-querying GEE."
}], "ItemNumbered",ExpressionUUID->"8d4648ef-6538-cd46-9ca3-5ab751b3ea8f"],

Cell[TextData[{
 StyleBox["Document decisions",
  FontWeight->Bold],
 ": use text cells in the notebook to explain why specific thresholds, date \
ranges, or methods were chosen."
}], "ItemNumbered",ExpressionUUID->"82d748dd-23e2-e24b-acac-392ce86f23f7"],

Cell[TextData[{
 StyleBox["Version control",
  FontWeight->Bold],
 ": commit the notebook and its exported data to a Git repository."
}], "ItemNumbered",ExpressionUUID->"3b6b1638-ab38-c242-b0b9-932374efed5d"],

