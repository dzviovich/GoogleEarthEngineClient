Cell[CellGroupData[{

Cell["8.5 Data Import/Export and Interoperability", "Chapter",ExpressionUUID->"1a8da2e9-9bae-e742-8008-71436d8ea6fb"],

Cell["\<\
Real-world analyses rarely use GEE data in isolation. You typically combine \
satellite imagery with field measurements, climate model output, census data, \
or other geospatial layers.\
\>", "Text",ExpressionUUID->"4292425a-bfa3-c944-a71c-5576059c5f23"],

Cell[CellGroupData[{

Cell["Importing External Data", "Section",ExpressionUUID->"9487788d-32c3-fc4e-9277-703a9fcd6072"],

Cell[TextData[StyleBox["CSV tabular data:",
 FontWeight->Bold]], "Text",ExpressionUUID->"ce6ea4f3-7d1d-1146-a97f-dffbcb7e64ad"],

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{"Field", " ", "measurements", " ", "with", " ", "coordinates"}], 
   " ", "*)"}], "\n", 
  RowBox[{
   RowBox[{
    RowBox[{"fieldData", " ", "=", " ", 
     RowBox[{"Import", "[", 
      RowBox[{"\"\<field_measurements.csv\>\"", ",", " ", "\"\<Dataset\>\"", ",",
        " ", 
       RowBox[{"HeaderLines", " ", "->", " ", "1"}]}], "]"}]}], ";"}], "\n", 
   "\n", 
   RowBox[{"(*", " ", 
    RowBox[{
    "Extract", " ", "coordinates", " ", "for", " ", "GEE", " ", "sampling"}], 
    " ", "*)"}], "\n", 
   RowBox[{
    RowBox[{"fieldPoints", " ", "=", " ", 
     RowBox[{"GeoPosition", " ", "/@", " ", 
      RowBox[{"Normal", "[", 
       RowBox[{"fieldData", "[", 
        RowBox[{"All", ",", " ", 
         RowBox[{"{", 
          RowBox[{"\"\<Latitude\>\"", ",", " ", "\"\<Longitude\>\""}], 
          "}"}]}], "]"}], "]"}]}]}], ";"}]}]}]], "Input",ExpressionUUID->\
"ce7c47de-66e5-c040-b19c-2fc0b935dd0b"],

Cell[TextData[StyleBox["GeoJSON for region definitions:",
 FontWeight->Bold]], "Text",ExpressionUUID->"21d4a9a3-3fb3-be40-bbe0-\
61b10d6c65e1"],

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{
   "Parse", " ", "GeoJSON", " ", "to", " ", "extract", " ", "polygon", " ", 
    "coordinates", " ", "for", " ", "GEE"}], " ", "*)"}], "\n", 
  RowBox[{
   RowBox[{
    RowBox[{"geojson", " ", "=", " ", 
     RowBox[{"Import", "[", 
      RowBox[{"\"\<study_area.geojson\>\"", ",", " ", "\"\<RawJSON\>\""}], 
      "]"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"coords", " ", "=", " ", 
     RowBox[{
      RowBox[{
       RowBox[{
        RowBox[{
         RowBox[{"geojson", "[", "\"\<features\>\"", "]"}], "[", 
         RowBox[{"[", "1", "]"}], "]"}], "[", "\"\<geometry\>\"", "]"}], 
       "[", "\"\<coordinates\>\"", "]"}], "[", 
      RowBox[{"[", "1", "]"}], "]"}]}], ";"}], "\n", "\n", 
   RowBox[{"(*", " ", 
    RowBox[{"Convert", " ", "to", " ", "GEE", " ", 
     RowBox[{"polygon", " ", "--"}], " ", "GeoJSON", " ", "uses", " ", 
     RowBox[{"{", 
      RowBox[{"lon", ",", " ", "lat"}], "}"}], " ", "order"}], " ", "*)"}], "\n", 
   RowBox[{
    RowBox[{"studyArea", " ", "=", " ", 
     RowBox[{"GEEPolygon", "[", "coords", "]"}]}], ";"}], "\n", "\n", 
   RowBox[{"(*", " ", 
    RowBox[{
    "Use", " ", "the", " ", "polygon", " ", "to", " ", "clip", " ", "a", " ", 
     "GEE", " ", "image"}], " ", "*)"}], "\n", 
   RowBox[{
    RowBox[{"clippedImage", " ", "=", "\n", "  ", 
     RowBox[{
      RowBox[{
       RowBox[{
        RowBox[{
         RowBox[{
         "GEECollection", "[", "\"\<COPERNICUS/S2_SR_HARMONIZED\>\"", "]"}], 
         " ", "//", "\n", "    ", 
         RowBox[{"GEEFilterDate", "[", 
          RowBox[{"\"\<2024-06-01\>\"", ",", " ", "\"\<2024-08-31\>\""}], 
          "]"}]}], " ", "//", "\n", "    ", "GEEMedian"}], " ", "//", "\n", 
       "    ", 
       RowBox[{"GEESelectBands", "[", 
        RowBox[{"{", 
         RowBox[{"\"\<B4\>\"", ",", " ", "\"\<B3\>\"", ",", 
          " ", "\"\<B2\>\""}], "}"}], "]"}]}], " ", "//", "\n", "    ", 
      RowBox[{"GEEClip", "[", "studyArea", "]"}]}]}], ";"}]}]}]], "Input",Expr\
essionUUID->"4a940e38-96c7-e246-8ab3-a49914601b3e"],

Cell[TextData[{
 StyleBox["Other formats:",
  FontWeight->Bold],
 " GeoTIFF, NetCDF, and KML all import with a single call:"
}], "Text",ExpressionUUID->"ed5b654c-455f-6044-85e0-dc862a675e6c"],

Cell[BoxData[{
 RowBox[{
  RowBox[{"externalDEM", " ", "=", " ", 
   RowBox[{"Import", "[", 
    RowBox[{"\"\<local_dem.tif\>\"", ",", " ", "\"\<GeoTIFF\>\""}], "]"}]}], 
  ";"}], "\n", 
 RowBox[{
  RowBox[{"tempGrid", " ", "=", " ", 
   RowBox[{"Import", "[", 
    RowBox[{"\"\<climate_model.nc\>\"", ",", " ", 
     RowBox[{"{", 
      RowBox[{"\"\<NetCDF\>\"", ",", " ", "\"\<tas\>\""}], "}"}]}], "]"}]}], 
  ";"}], "\n", 
 RowBox[{
  RowBox[{"kmlData", " ", "=", " ", 
   RowBox[{"Import", "[", "\"\<study_sites.kml\>\"", "]"}]}], ";"}]}], "Input",\
ExpressionUUID->"ce7018b8-3db5-844f-b181-d9c7add18279"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Exporting Results", "Section",ExpressionUUID->"aef92c8e-0aab-064e-b443-582a4aa45ea6"],

Cell[TextData[StyleBox["Raster images:",
 FontWeight->Bold]], "Text",ExpressionUUID->"11c0e088-512a-7745-afb9-2c0cae7a67bc"],

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{"Save", " ", "enhanced", " ", "satellite", " ", "image"}], " ", 
   "*)"}], "\n", 
  RowBox[{
   RowBox[{"Export", "[", 
    RowBox[{"\"\<enhanced_composite.png\>\"", ",", " ", "enhanced"}], "]"}], 
   "\n", "\n", 
   RowBox[{"(*", " ", 
    RowBox[{"High", "-", 
     RowBox[{"resolution", " ", "TIFF"}]}], " ", "*)"}], "\n", 
   RowBox[{"Export", "[", 
    RowBox[{"\"\<analysis_result.tif\>\"", ",", " ", "ndviRaster"}], 
    "]"}]}]}]], "Input",ExpressionUUID->"e39ebefb-61b3-a241-9061-\
ad9f7db1f170"],

Cell[TextData[StyleBox["Tabular results:",
 FontWeight->Bold]], "Text",ExpressionUUID->"ea3e1a03-dddf-b54d-80b8-809fec513b49"],

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{"Export", " ", "sampled", " ", "data", " ", "as", " ", "CSV"}], 
   " ", "*)"}], "\n", 
  RowBox[{
   RowBox[{
    RowBox[{"resultsDataset", " ", "=", " ", 
     RowBox[{"Dataset", "[", "\n", "  ", 
      RowBox[{"MapThread", "[", "\n", "    ", 
       RowBox[{
        RowBox[{
         RowBox[{"<|", 
          RowBox[{
           RowBox[{"\"\<Lat\>\"", " ", "->", " ", 
            RowBox[{"#1", "[", 
             RowBox[{"[", 
              RowBox[{"1", ",", " ", "1"}], "]"}], "]"}]}], ",", " ", 
           RowBox[{"\"\<Lon\>\"", " ", "->", " ", 
            RowBox[{"#1", "[", 
             RowBox[{"[", 
              RowBox[{"1", ",", " ", "2"}], "]"}], "]"}]}], ",", "\n", 
           "      ", 
           RowBox[{"\"\<NDVI\>\"", " ", "->", " ", "#2"}]}], "|>"}], " ", 
         "&"}], ",", "\n", "    ", 
        RowBox[{"{", 
         RowBox[{"fieldPoints", ",", " ", "predictedBiomass"}], "}"}]}], "\n",
        "  ", "]"}], "\n", "]"}]}], ";"}], "\n", "\n", 
   RowBox[{"Export", "[", 
    RowBox[{"\"\<ndvi_results.csv\>\"", ",", " ", "resultsDataset"}], 
    "]"}]}]}]], "Input",ExpressionUUID->"ec8ea930-137a-8743-899d-\
9cbda28aef34"],

Cell[TextData[StyleBox["GeoJSON for GIS interchange:",
 FontWeight->Bold]], "Text",ExpressionUUID->"3c87ebc4-55cd-424a-8882-\
7dbd0a72109d"],

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{
   "Build", " ", "GeoJSON", " ", "from", " ", "analysis", " ", "results"}], 
   " ", "*)"}], "\n", 
  RowBox[{
   RowBox[{
    RowBox[{"features", " ", "=", " ", 
     RowBox[{
      RowBox[{"Table", "[", "\n", "  ", 
       RowBox[{
        RowBox[{"<|", "\n", "    ", 
         RowBox[{
          RowBox[{"\"\<type\>\"", " ", "->", " ", "\"\<Feature\>\""}], ",", 
          "\n", "    ", 
          RowBox[{"\"\<geometry\>\"", " ", "->", " ", 
           RowBox[{"<|", "\n", "      ", 
            RowBox[{
             RowBox[{"\"\<type\>\"", " ", "->", " ", "\"\<Point\>\""}], ",", 
             "\n", "      ", 
             RowBox[{"\"\<coordinates\>\"", " ", "->", " ", 
              RowBox[{"{", 
               RowBox[{
                RowBox[{"pt", "[", 
                 RowBox[{"[", 
                  RowBox[{"1", ",", " ", "2"}], "]"}], "]"}], ",", " ", 
                RowBox[{"pt", "[", 
                 RowBox[{"[", 
                  RowBox[{"1", ",", " ", "1"}], "]"}], "]"}]}], "}"}]}]}], 
            "  ", 
            RowBox[{"(*", " ", 
             RowBox[{"lon", ",", " ", "lat"}], " ", "*)"}], "\n", "    ", 
            "|>"}]}], ",", "\n", "    ", 
          RowBox[{"\"\<properties\>\"", " ", "->", " ", 
           RowBox[{"<|", 
            RowBox[{"\"\<ndvi\>\"", " ", "->", " ", "val"}], "|>"}]}]}], "\n",
          "  ", "|>"}], ",", "\n", "  ", 
        RowBox[{"{", 
         RowBox[{"pt", ",", " ", "fieldPoints"}], "}"}], ",", " ", 
        RowBox[{"{", 
         RowBox[{"val", ",", " ", "predictedBiomass"}], "}"}]}], "\n", "]"}], 
      " ", "//", " ", "Flatten"}]}], ";"}], "\n", "\n", 
   RowBox[{
    RowBox[{"geojsonOutput", " ", "=", " ", 
     RowBox[{"<|", "\n", "  ", 
      RowBox[{
       RowBox[{"\"\<type\>\"", " ", "->", " ", "\"\<FeatureCollection\>\""}], 
       ",", "\n", "  ", 
       RowBox[{"\"\<features\>\"", " ", "->", " ", "features"}]}], "\n", 
      "|>"}]}], ";"}], "\n", "\n", 
   RowBox[{"Export", "[", 
    RowBox[{"\"\<output.geojson\>\"", ",", " ", "geojsonOutput", ",", 
     " ", "\"\<RawJSON\>\""}], "]"}]}]}]], "Input",ExpressionUUID->"b23910b0-\
10c0-da49-a478-a4506c6d8703"]
}, Open  ]],

Cell[CellGroupData[{

Cell["KML/KMZ for Google Earth", "Section",ExpressionUUID->"e9c84f05-ee0d-9a44-b234-589b24b7feb9"],

Cell["\<\
Building KML from GEE query results lets you share findings with \
collaborators who use Google Earth.\
\>", "Text",ExpressionUUID->"181208c9-b636-4e4d-b9d1-a69e100e41a0"],

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{
   "Generate", " ", "KML", " ", "placemarks", " ", "from", " ", "sampled", " ",
     "data"}], " ", "*)"}], "\n", 
  RowBox[{
   RowBox[{
    RowBox[{"kmlPlacemarks", " ", "=", " ", 
     RowBox[{"StringJoin", " ", "@@", " ", 
      RowBox[{"Table", "[", "\n", "  ", 
       RowBox[{
        RowBox[{
         RowBox[{
         "StringTemplate", "[", "\n", 
          "    ", "\"\<<Placemark><name>Site `i`</name>\\\n     \
<description>NDVI: `val`</description>\\\n     \
<Point><coordinates>`lon`,`lat`,0</coordinates></Point>\\\n     \
</Placemark>\\n\>\"", "\n", "  ", "]"}], "[", 
         RowBox[{"<|", 
          RowBox[{
           RowBox[{"\"\<i\>\"", " ", "->", " ", "i"}], ",", " ", 
           RowBox[{"\"\<val\>\"", " ", "->", " ", 
            RowBox[{"predictedBiomass", "[", 
             RowBox[{"[", "i", "]"}], "]"}]}], ",", "\n", "      ", 
           RowBox[{"\"\<lon\>\"", " ", "->", " ", 
            RowBox[{"fieldPoints", "[", 
             RowBox[{"[", 
              RowBox[{"i", ",", " ", "1", ",", " ", "2"}], "]"}], "]"}]}], ",",
            "\n", "      ", 
           RowBox[{"\"\<lat\>\"", " ", "->", " ", 
            RowBox[{"fieldPoints", "[", 
             RowBox[{"[", 
              RowBox[{"i", ",", " ", "1", ",", " ", "1"}], "]"}], "]"}]}]}], 
          "|>"}], "]"}], ",", "\n", "  ", 
        RowBox[{"{", 
         RowBox[{"i", ",", " ", 
          RowBox[{"Length", "[", "fieldPoints", "]"}]}], "}"}]}], "\n", 
       "]"}]}]}], ";"}], "\n", "\n", 
   RowBox[{
    RowBox[{"kmlDoc", " ", "=", " ", 
     RowBox[{"\"\<<?xml version=\\\"1.0\\\"?>\\n<kml \
xmlns=\\\"http://www.opengis.net/kml/2.2\\\">\\n\\\n<Document><name>NDVI \
Samples</name>\\n\>\"", " ", "<>", " ", "kmlPlacemarks", " ", "<>", 
      " ", "\"\<</Document>\\n</kml>\>\""}]}], ";"}], "\n", "\n", 
   RowBox[{"Export", "[", 
    RowBox[{"\"\<sample_points.kml\>\"", ",", " ", "kmlDoc", ",", 
     " ", "\"\<Text\>\""}], "]"}]}]}]], "Input",ExpressionUUID->"ae7eb8b4-\
9fd8-b34a-8178-f28183cceb26"],

Cell["", "Text",
 CellFrame->{{0, 0}, {0, 
  1}},ExpressionUUID->"1e110f52-7e64-ba45-8741-766616ccab26"]
}, Open  ]]
