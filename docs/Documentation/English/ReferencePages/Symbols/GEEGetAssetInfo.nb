Cell[CellGroupData[{
Cell["GEEGetAssetInfo", "ObjectName",
 CellID->700926375,ExpressionUUID->"96e7198b-d4e4-1d43-86ed-e7c2a823a1f9"],

Cell["Fetch metadata for a Google Earth Engine asset.", "ExampleText",
 CellChangeTimes->{3.9843241416407127`*^9},
 CellID->175236338,ExpressionUUID->"e40952c5-ec4f-8040-8fd3-1a099e27bb53"],

Cell[TextData[{
 Cell["   ", "ModInfo",ExpressionUUID->"4657d23e-217e-1543-971b-05fd8fe9dd25"],
 Cell[BoxData[
  RowBox[{
   ButtonBox["GEEGetAssetInfo",
    BaseStyle->"Link",
    ButtonData->"paclet:GoogleEarthEngineClient/ref/GEEGetAssetInfo"], "[", 
   StyleBox["assetId", "TI"], "]"}]], "InlineFormula",ExpressionUUID->
  "3e6718ac-dd21-8d4f-9082-11e61f44f8f9"],
 "\[LineSeparator]fetch metadata for a Google Earth Engine asset and return \
an ",
 Cell[BoxData[
  ButtonBox["Association",
   BaseStyle->"Link"]], "InlineFormula",ExpressionUUID->
  "4e22bc4f-f12b-e742-afec-369222703aaf"],
 " with keys \
\"Type\",\"Name\",\"Title\",\"Description\",\"StartTime\",\"EndTime\",\"\
Geometry\",\"Bands\",and \"Properties\". \n",
 Cell["   ", "ModInfo",ExpressionUUID->"a022c1cd-16ce-164c-85aa-1115d1e223e7"],
 Cell[BoxData[
  RowBox[{
   ButtonBox["GEEGetAssetInfo",
    BaseStyle->"Link",
    ButtonData->"paclet:GoogleEarthEngineClient/ref/GEEGetAssetInfo"], "[", 
   RowBox[{
    StyleBox["assetId", "TI"], ",", 
    StyleBox["opts", "TI"]}], "]"}]], "InlineFormula",ExpressionUUID->
  "5cd64f9f-b79c-d744-81a3-932c2996ec65"],
 "\[LineSeparator]fetch with option \"Project\"."
}], "Usage",
 CellChangeTimes->{{3.98416731222736*^9, 3.984167312468611*^9}},
 CellID->44037936,ExpressionUUID->"456e90d0-96f8-c94c-a707-67e388e453c2"],

Cell[TextData[{
 "- ",
 StyleBox["assetId",
  FontSlant->"Italic"],
 " is a string such as \"USGS/SRTMGL1_003\" or \
\"COPERNICUS/S2_SR_HARMONIZED\".\n- Returns an Association with keys \
\"Type\", \"Name\", \"Title\", \"Description\", \"Provider\", \
\"ProviderURL\", \"StartTime\", \"EndTime\", \"Geometry\", \"Bands\", \
\"Properties\", and \"SizeBytes\".\n- Asset types include \"IMAGE\", \
\"IMAGE_COLLECTION\", \"TABLE\", and \"FOLDER\".\n- \"Title\" returns the \
human-readable dataset title (e.g., \"USGS Landsat 8 Level 2, Collection 2, \
Tier 1\").\n- \"Description\" returns the dataset description as plain text \
(HTML tags are stripped).\n- \"Provider\" and \"ProviderURL\" identify the \
data provider.\n- \"Bands\" is a list of Associations, each with keys \
\"Name\", \"DataType\", and \"Grid\". For IMAGE_COLLECTION assets, band names \
are fetched from the first image in the collection. TABLE assets have no \
bands.\n- When the GEE REST API does not return \"Title\", \"Description\", \
\"Provider\", or \"ProviderURL\" (common for IMAGE_COLLECTION and TABLE \
assets), these fields are automatically fetched from the public ",
 ButtonBox["GEE STAC catalog",
  BaseStyle->"Hyperlink",
  ButtonData->{
    URL["https://storage.googleapis.com/earthengine-stac/catalog/"], None},
  ButtonNote->"https://storage.googleapis.com/earthengine-stac/catalog/"],
 " as a fallback."
}], "Notes",
 CellChangeTimes->{{3.984305094039673*^9, 3.9843050942465687`*^9}, {
  3.984324206215719*^9, 3.9843242062162514`*^9}},
 CellID->39888410,ExpressionUUID->"9bdf8b99-9ce4-5e48-89c3-374f0c5407f7"],

Cell["The following options can be given: ", "Notes",
 CellID->442185039,ExpressionUUID->"31c4263c-5dd7-5a43-ba0f-f4d388c057e2"],

Cell[BoxData[GridBox[{
   {Cell["   ", "ModInfo",ExpressionUUID->
     "bc12f67f-20a5-ae4f-85ae-e759ab083248"], "\"\<Project\>\"", 
    ButtonBox["Automatic",
     BaseStyle->"Link"], Cell[
    "GCP project ID", "TableText",ExpressionUUID->
     "705f2adc-2b39-884a-8d70-ca8c44f4a3a5"]}
  }]], "3ColumnTableMod",
 CellChangeTimes->{{3.9843051996597652`*^9, 3.9843051996597652`*^9}},
 CellID->155554342,ExpressionUUID->"274325f9-35a4-4943-abb2-5d87222af31c"]
