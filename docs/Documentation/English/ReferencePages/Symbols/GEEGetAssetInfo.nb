Cell["Fetch metadata for the SRTM elevation dataset :", "ExampleText",
 CellChangeTimes->{{3.984305210221874*^9, 3.9843052116759224`*^9}},
 CellID->41200241,ExpressionUUID->"8baf5b42-516f-3a47-bbc2-dc777d108353"],

Cell[BoxData[{
 RowBox[{"info", "=", 
  RowBox[{"GEEGetAssetInfo", "[", "\"\<USGS/SRTMGL1_003\>\"", "]"}]}], "\n", 
 RowBox[{
  RowBox[{"info", "[", "\"\<Type\>\"", "]"}], "         ", 
  RowBox[{"(*", "\"\<IMAGE\>\"", "*)"}]}], "\n", 
 RowBox[{
  RowBox[{"info", "[", "\"\<Title\>\"", "]"}], "        ", 
  RowBox[{"(*", "\"\<NASA SRTM Digital Elevation 30m\>\"", "*)"}]}], "\n", 
 RowBox[{
  RowBox[{"info", "[", "\"\<Provider\>\"", "]"}], "     ", 
  RowBox[{"(*", "\"\<NASA / USGS / JPL-Caltech\>\"", "*)"}]}], "\n", 
 RowBox[{
  RowBox[{"info", "[", "\"\<Description\>\"", "]"}], "  ", 
  RowBox[{"(*", 
   RowBox[{
    RowBox[{"plain", " ", "text"}], ",", 
    RowBox[{"HTML", " ", "stripped"}]}], "*)"}]}], "\n", 
 RowBox[{
  RowBox[{"info", "[", "\"\<Bands\>\"", "]"}], "        ", 
  RowBox[{"(*", 
   RowBox[{"{", 
    RowBox[{"<|", 
     RowBox[{
      RowBox[{"\"\<Name\>\"", "->", "\"\<elevation\>\""}], ",", "..."}], 
     "|>"}], "}"}], "*)"}]}]}], "Input",
 CellChangeTimes->{{3.984307836017887*^9, 3.984307836017887*^9}},
 CellID->214408023,ExpressionUUID->"d4325273-5e86-454c-a574-98198f0aa79f"],

Cell["\<\
Fetch metadata for a Landsat 8 image collection (band names fetched from \
first image):\
\>", "ExampleText",
 CellChangeTimes->{3.9843078510677357`*^9},
 CellID->47189456,ExpressionUUID->"b61a86a5-afba-964f-aaa2-be270b59861b"],

Cell[BoxData[{
 RowBox[{"info", "=", 
  RowBox[{"GEEGetAssetInfo", "[", "\"\<LANDSAT/LC08/C02/T1_L2\>\"", "]"}]}], "\n", 
 RowBox[{
  RowBox[{"info", "[", "\"\<Type\>\"", "]"}], "                  ", 
  RowBox[{"(*", "\"\<IMAGE_COLLECTION\>\"", "*)"}]}], "\n", 
 RowBox[{
  RowBox[{"info", "[", "\"\<Title\>\"", "]"}], "                 ", 
  RowBox[{
  "(*", "\"\<USGS Landsat 8 Level 2, Collection 2, Tier 1\>\"", "*)"}]}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"info", "[", "\"\<Bands\>\"", "]"}], "[", 
   RowBox[{"[", 
    RowBox[{"All", ",", "\"\<Name\>\""}], "]"}], "]"}], "  ", 
  RowBox[{"(*", 
   RowBox[{"{", 
    RowBox[{"\"\<SR_B1\>\"", ",", "\"\<SR_B2\>\"", ",", "...", 
     ",", "\"\<QA_RADSAT\>\""}], "}"}], "*)"}]}]}], "Input",
 CellChangeTimes->{{3.984307855435604*^9, 3.9843078554366035`*^9}},
 CellID->152509377,ExpressionUUID->"1ca76378-99f8-834a-b4eb-e2b93771649b"],

Cell["Sentinel-2:", "ExampleText",
