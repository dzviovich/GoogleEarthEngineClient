Cell["Expression Builder Pipeline", "ExampleText",
 CellChangeTimes->{3.9843365331839066`*^9},
 CellID->139134417,ExpressionUUID->"59a9eeda-89f8-a74c-aff2-7df1438d0b4c"],

Cell["\<\
Use expression builders for full control over collection filtering. \
Cloud-filtered Sentinel-2 median composite of Barcelona:\
\>", "ExampleText",
 CellChangeTimes->{3.984336540721468*^9},
 CellID->291271915,ExpressionUUID->"26112728-3cd7-954f-bc13-0579c4dd7ac2"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"tile", "=", 
  RowBox[{"GEEGetTile", "[", 
   RowBox[{
    RowBox[{
     RowBox[{
      RowBox[{
       RowBox[{
        RowBox[{
         RowBox[{
         "GEECollection", "[", "\"\<COPERNICUS/S2_SR_HARMONIZED\>\"", "]"}], "//", 
         RowBox[{"GEEFilterDate", "[", 
          RowBox[{"\"\<2024-06-01\>\"", ",", "\"\<2024-09-01\>\""}], "]"}]}], 
        "//", 
        RowBox[{"GEEFilterBounds", "[", 
         RowBox[{"{", 
          RowBox[{"2.0", ",", "41.3", ",", "2.3", ",", "41.5"}], "}"}], 
         "]"}]}], "//", 
       RowBox[{"GEEFilterProperty", "[", 
        RowBox[{"\"\<CLOUDY_PIXEL_PERCENTAGE\>\"", ",", "\"\<LessThan\>\"", ",",
          "10"}], "]"}]}], "//", 
      RowBox[{"GEESelectBands", "[", 
       RowBox[{"{", 
        RowBox[{"\"\<B4\>\"", ",", "\"\<B3\>\"", ",", "\"\<B2\>\""}], "}"}], 
       "]"}]}], "//", "GEEMedian"}], ",", 
    RowBox[{"GeoPosition", "[", 
     RowBox[{"{", 
      RowBox[{"41.39", ",", "2.17"}], "}"}], "]"}], ",", "11", ",", 
    RowBox[{"\"\<VisParams\>\"", "->", 
     RowBox[{"<|", 
      RowBox[{
       RowBox[{"\"\<min\>\"", "->", "0"}], ",", 
       RowBox[{"\"\<max\>\"", "->", "3000"}]}], "|>"}]}]}], "]"}]}]], "Input",
 CellChangeTimes->{{3.984336544687006*^9, 3.984336544687006*^9}},
 CellLabel->"In[65]:=",
 CellID->43960726,ExpressionUUID->"2029d9b0-76f0-e84b-960e-7b2ca0e48925"],

