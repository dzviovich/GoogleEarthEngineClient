Cell["\<\
Fetch the SRTM elevation tile containing Mount Fuji at zoom level 10 (~150 km \
tile):\
\>", "ExampleText",
 CellChangeTimes->{3.984334704042742*^9, 3.98433515790382*^9},
 CellID->472944582,ExpressionUUID->"179e9479-a3d2-9a45-a263-f79676bfa56f"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"tile", "=", 
  RowBox[{"GEEGetTile", "[", 
   RowBox[{"\"\<USGS/SRTMGL1_003\>\"", ",", 
    RowBox[{"GeoPosition", "[", 
     RowBox[{"{", 
      RowBox[{"35.36", ",", "138.73"}], "}"}], "]"}], ",", "10", ",", 
    RowBox[{"\"\<VisParams\>\"", "->", 
     RowBox[{"<|", 
      RowBox[{
       RowBox[{"\"\<min\>\"", "->", "0"}], ",", 
       RowBox[{"\"\<max\>\"", "->", "3776"}], ",", 
       RowBox[{"\"\<palette\>\"", "->", 
        RowBox[{"{", 
         RowBox[{"\"\<#000033\>\"", ",", "\"\<#006600\>\"", 
          ",", "\"\<#339933\>\"", ",", "\"\<#996633\>\"", 
          ",", "\"\<#CC9966\>\"", ",", "\"\<#FFFFFF\>\""}], "}"}]}]}], 
      "|>"}]}]}], "]"}]}]], "Input",
