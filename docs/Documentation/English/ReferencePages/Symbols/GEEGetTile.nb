 CellChangeTimes->{3.9843355292709904`*^9},
 CellID->109847361,ExpressionUUID->"dbc072c7-746b-d94a-95b7-2c16612396ac"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"tile", "=", 
  RowBox[{"GEEGetTile", "[", 
   RowBox[{"\"\<COPERNICUS/S2_SR_HARMONIZED\>\"", ",", 
    RowBox[{"GeoPosition", "[", 
     RowBox[{"{", 
      RowBox[{"30.9", ",", "31.2"}], "}"}], "]"}], ",", "9", ",", 
    RowBox[{"\"\<Bands\>\"", "->", 
