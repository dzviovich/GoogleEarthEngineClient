Cell["False-Color Vegetation (NIR)", "ExampleText",
 CellChangeTimes->{{3.9843355463720226`*^9, 3.9843355485570087`*^9}},
 CellID->152453619,ExpressionUUID->"1ad083f6-dc90-a348-b094-9af006ab9d0b"],

Cell["\<\
Near-infrared false color (B8=NIR, B4=Red, B3=Green) highlights vegetation in \
bright red. Amazon rainforest near Manaus:\
\>", "ExampleText",
 CellChangeTimes->{3.984335557309025*^9},
 CellID->75296551,ExpressionUUID->"051523cf-283f-f241-8dcd-af38ed7c3aa0"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"tile", "=", 
  RowBox[{"GEEGetTile", "[", 
   RowBox[{
    RowBox[{
     RowBox[{
      RowBox[{
       RowBox[{
        RowBox[{
         RowBox[{
         "GEECollection", "[", "\"\<COPERNICUS/S2_SR_HARMONIZED\>\"", "]"}], "//", 
         RowBox[{"GEEFilterDate", "[", 
          RowBox[{"\"\<2024-06-01\>\"", ",", "\"\<2024-10-01\>\""}], "]"}]}], 
        "//", 
        RowBox[{"GEEFilterBounds", "[", 
         RowBox[{"{", 
          RowBox[{
           RowBox[{"-", "60.5"}], ",", 
           RowBox[{"-", "3.5"}], ",", 
           RowBox[{"-", "59.5"}], ",", 
           RowBox[{"-", "2.7"}]}], "}"}], "]"}]}], "//", 
       RowBox[{"GEEFilterProperty", "[", 
        RowBox[{"\"\<CLOUDY_PIXEL_PERCENTAGE\>\"", ",", "\"\<LessThan\>\"", ",",
          "15"}], "]"}]}], "//", 
      RowBox[{"GEESelectBands", "[", 
       RowBox[{"{", 
        RowBox[{"\"\<B8\>\"", ",", "\"\<B4\>\"", ",", "\"\<B3\>\""}], "}"}], 
       "]"}]}], "//", "GEEMedian"}], ",", 
    RowBox[{"GeoPosition", "[", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"-", "3.12"}], ",", 
       RowBox[{"-", "60.02"}]}], "}"}], "]"}], ",", "10", ",", 
    RowBox[{"\"\<VisParams\>\"", "->", 
     RowBox[{"<|", 
      RowBox[{
       RowBox[{"\"\<min\>\"", "->", "0"}], ",", 
       RowBox[{"\"\<max\>\"", "->", "4000"}]}], "|>"}]}]}], "]"}]}]], "Input",
 CellChangeTimes->{{3.9843355666256638`*^9, 3.9843355666256638`*^9}, 
   3.9843356299758987`*^9},
 CellLabel->"In[57]:=",
 CellID->424225560,ExpressionUUID->"c9de4b36-1c03-124c-b043-fad23c42d2f1"],

