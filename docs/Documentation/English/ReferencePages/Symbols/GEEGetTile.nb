 CellID->671992,ExpressionUUID->"0ff3a442-9c2f-7449-80f0-3cd24f150c91"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"tile", "=", 
  RowBox[{"GEEGetTile", "[", 
   RowBox[{"\"\<USGS/SRTMGL1_003\>\"", ",", 
    RowBox[{"GeoPosition", "[", 
     RowBox[{"{", 
      RowBox[{"46.85", ",", "8.23"}], "}"}], "]"}], ",", "8", ",", 
    RowBox[{"\"\<VisParams\>\"", "->", 
     RowBox[{"<|", 
      RowBox[{
