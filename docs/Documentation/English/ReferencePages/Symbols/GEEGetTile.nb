Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"tile", "=", 
  RowBox[{"GEEGetTile", "[", 
   RowBox[{
    RowBox[{
     RowBox[{
      RowBox[{
       RowBox[{"GEECollection", "[", "\"\<ESA/WorldCover/v200\>\"", "]"}], "//", 
       RowBox[{"GEEFilterDate", "[", 
        RowBox[{"\"\<2021-01-01\>\"", ",", "\"\<2022-01-01\>\""}], "]"}]}], "//", 
      RowBox[{"GEESelectBands", "[", 
       RowBox[{"{", "\"\<Map\>\"", "}"}], "]"}]}], "//", "GEEMosaic"}], ",", 
    RowBox[{"GeoPosition", "[", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"-", "1.0"}], ",", "33.0"}], "}"}], "]"}], ",", "7", ",", 
    RowBox[{"\"\<VisParams\>\"", "->", 
     RowBox[{"<|", 
      RowBox[{
       RowBox[{"\"\<min\>\"", "->", "10"}], ",", 
       RowBox[{"\"\<max\>\"", "->", "95"}], ",", 
       RowBox[{"\"\<palette\>\"", "->", 
        RowBox[{"{", 
         RowBox[{"\"\<#006400\>\"", ",", "\"\<#FFBB22\>\"", 
          ",", "\"\<#FFFF4C\>\"", ",", "\"\<#F096FF\>\"", 
          ",", "\"\<#FA0000\>\"", ",", "\"\<#B4B4B4\>\"", 
          ",", "\"\<#F0F0F0\>\"", ",", "\"\<#0064C8\>\"", 
          ",", "\"\<#0096A0\>\"", ",", "\"\<#00CF75\>\"", 
          ",", "\"\<#FAE6A0\>\""}], "}"}]}]}], "|>"}]}]}], "]"}]}]], "Input",
 CellChangeTimes->{{3.984335849072523*^9, 3.984335849072523*^9}, 
   3.984335961330366*^9},
 CellLabel->"In[64]:=",
 CellID->897335173,ExpressionUUID->"ff2c98b5-021b-8b44-a586-f3b35eba0aa2"],

