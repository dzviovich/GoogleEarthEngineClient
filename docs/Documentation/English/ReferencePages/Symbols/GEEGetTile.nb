Cell["\<\
Select emissivity band 10 from the ASTER Global Emissivity Dataset over the \
Sahara:\
\>", "ExampleText",
 CellChangeTimes->{3.984335765987648*^9},
 CellID->27318038,ExpressionUUID->"edc53cbc-e377-8c4d-88b0-41ab1d05fc2a"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"tile", "=", 
  RowBox[{"GEEGetTile", "[", 
   RowBox[{"\"\<NASA/ASTER_GED/AG100_003\>\"", ",", 
    RowBox[{"GeoPosition", "[", 
     RowBox[{"{", 
      RowBox[{"25.0", ",", "10.0"}], "}"}], "]"}], ",", "6", ",", 
    RowBox[{"\"\<Bands\>\"", "->", 
     RowBox[{"{", "\"\<emissivity_band10\>\"", "}"}]}], ",", 
    RowBox[{"\"\<VisParams\>\"", "->", 
     RowBox[{"<|", 
      RowBox[{
       RowBox[{"\"\<min\>\"", "->", "850"}], ",", 
       RowBox[{"\"\<max\>\"", "->", "990"}], ",", 
       RowBox[{"\"\<palette\>\"", "->", 
        RowBox[{"{", 
         RowBox[{"\"\<#d73027\>\"", ",", "\"\<#fc8d59\>\"", 
          ",", "\"\<#fee08b\>\"", ",", "\"\<#d9ef8b\>\"", 
          ",", "\"\<#91cf60\>\"", ",", "\"\<#1a9850\>\""}], "}"}]}]}], 
      "|>"}]}]}], "]"}]}]], "Input",
