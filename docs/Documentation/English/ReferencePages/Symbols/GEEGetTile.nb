Cell["\<\
Compare the same location at different zoom levels to see increasing detail. \
Lower zoom shows a continental overview; higher zoom resolves individual \
valleys:\
\>", "ExampleText",
 CellChangeTimes->{3.984334816078663*^9, 3.984335017697319*^9, 
  3.9843354092883453`*^9},
 CellID->640290893,ExpressionUUID->"0a623f2e-e56b-b442-8a05-6fa7584f1274"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", 
   RowBox[{
   "Grand", " ", "Canyon", " ", "at", " ", "three", " ", "zoom", " ", 
    "levels"}], "*)"}], 
  RowBox[{
   RowBox[{
    RowBox[{"vis", "=", 
     RowBox[{"<|", 
      RowBox[{
       RowBox[{"\"\<min\>\"", "->", "500"}], ",", 
       RowBox[{"\"\<max\>\"", "->", "2800"}], ",", 
       RowBox[{"\"\<palette\>\"", "->", 
        RowBox[{"{", 
         RowBox[{"\"\<#2b1a0e\>\"", ",", "\"\<#8B4513\>\"", 
          ",", "\"\<#D2691E\>\"", ",", "\"\<#F5DEB3\>\""}], "}"}]}]}], 
      "|>"}]}], ";"}], "\n", 
   RowBox[{"tiles", "=", 
    RowBox[{"Table", "[", 
     RowBox[{
      RowBox[{"GEEGetTile", "[", 
       RowBox[{"\"\<USGS/SRTMGL1_003\>\"", ",", 
        RowBox[{"GeoPosition", "[", 
         RowBox[{"{", 
          RowBox[{"36.10", ",", 
           RowBox[{"-", "112.11"}]}], "}"}], "]"}], ",", "z", ",", 
        RowBox[{"\"\<VisParams\>\"", "->", "vis"}]}], "]"}], ",", 
      RowBox[{"{", 
       RowBox[{"z", ",", 
        RowBox[{"{", 
         RowBox[{"6", ",", "10", ",", "14"}], "}"}]}], "}"}]}], 
     "]"}]}]}]}]], "Input",
 CellChangeTimes->{{3.9843348201772404`*^9, 3.984334820178236*^9}, 
   3.984335023438732*^9, 3.984335414521847*^9},
 CellLabel->"In[52]:=",
