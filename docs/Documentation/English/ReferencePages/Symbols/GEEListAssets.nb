   StyleBox["parent", "TI"], "]"}]], "InlineFormula",ExpressionUUID->
  "93d350ee-c104-8044-b62d-db912803a866"],
 "\[LineSeparator]list assets in a Google Earth Engine folder or collection \
and return a list of Associations. \n",
 Cell["   ", "ModInfo",ExpressionUUID->"c067d6a7-0fa4-c24a-9350-f648872e0a88"],
 Cell[BoxData[
  RowBox[{
   ButtonBox["GEEListAssets",
    BaseStyle->"Link",
    ButtonData->"paclet:GoogleEarthEngineClient/ref/GEEListAssets"], "[", 
   RowBox[{
    StyleBox["parent", "TI"], ",", 
    StyleBox["opts", "TI"]}], "]"}]], "InlineFormula",ExpressionUUID->
  "3e989ea6-07d5-244b-b5e6-aa1e29e176ab"],
 "\[LineSeparator]list with options \"MaxResults\" and \"Filter\"."
}], "Usage",
 CellChangeTimes->{{3.984167463279484*^9, 3.984167463417164*^9}},
 CellID->178770379,ExpressionUUID->"00ef7753-d1f3-714c-ad43-5984a655c61c"],

Cell[TextData[{
 "- ",
 StyleBox["parent",
  FontSlant->"Italic"],
 " is a folder or collection asset ID such as \"USGS\" or \"COPERNICUS\".\n- \
Returns a list of Associations, each with the same keys as GEEGetAssetInfo."
}], "Notes",
 CellChangeTimes->{{3.9843209357148514`*^9, 3.9843209357548275`*^9}},
