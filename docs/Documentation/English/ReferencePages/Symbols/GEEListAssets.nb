Cell[TextData[{
 Cell["   ", "ModInfo",ExpressionUUID->"5e120eb2-effa-3e44-9e75-d74bd65d6cd8"],
 Cell[BoxData[
  RowBox[{
   ButtonBox["GEEListAssets",
    BaseStyle->"Link",
