Cell["\<\
Query World Database on Protected Areas within 50 km of Yellowstone to find \
national parks, wilderness areas, and wildlife refuges:\
\>", "ExampleText",
 CellChangeTimes->{3.98434466673456*^9},
 CellID->311530715,ExpressionUUID->"f039f4e8-3ad9-144f-be79-82fe01eb87e0"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"features", "=", 
   RowBox[{"GEEComputeFeatures", "[", 
    RowBox[{"\"\<WCMC/WDPA/current/polygons\>\"", ",", "\"\<\>\"", ",", 
     RowBox[{"\"\<GeoBounds\>\"", "->", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"-", "111.5"}], ",", "44.0", ",", 
        RowBox[{"-", "109.5"}], ",", "45.5"}], "}"}]}], ",", 
     RowBox[{"\"\<Properties\>\"", "->", 
      RowBox[{"{", 
       RowBox[{"\"\<NAME\>\"", ",", "\"\<DESIG\>\"", ",", "\"\<REP_AREA\>\"", 
        ",", "\"\<STATUS_YR\>\""}], "}"}]}], ",", 
     RowBox[{"\"\<MaxFeatures\>\"", "->", "50"}]}], "]"}]}], ";"}], "\n", 
 RowBox[{"Dataset", "[", 
  RowBox[{"Map", "[", 
   RowBox[{
    RowBox[{
     RowBox[{"<|", 
      RowBox[{
       RowBox[{"\"\<Name\>\"", "->", 
        RowBox[{
         RowBox[{"#", "[", "\"\<Properties\>\"", "]"}], "[", "\"\<NAME\>\"", 
         "]"}]}], ",", 
       RowBox[{"\"\<Designation\>\"", "->", 
        RowBox[{
         RowBox[{"#", "[", "\"\<Properties\>\"", "]"}], "[", "\"\<DESIG\>\"", 
         "]"}]}], ",", 
       RowBox[{"\"\<Area (km\.b2)\>\"", "->", 
        RowBox[{"Round", "[", 
         RowBox[{
          RowBox[{
           RowBox[{"#", "[", "\"\<Properties\>\"", "]"}], 
           "[", "\"\<REP_AREA\>\"", "]"}], ",", "0.1"}], "]"}]}], ",", 
       RowBox[{"\"\<Year\>\"", "->", 
        RowBox[{
         RowBox[{"#", "[", "\"\<Properties\>\"", "]"}], 
         "[", "\"\<STATUS_YR\>\"", "]"}]}]}], "|>"}], "&"}], ",", 
