Cell["The following options can be given: ", "Notes",
 CellID->822899392,ExpressionUUID->"fa1d1192-f1be-b744-a982-283ec6e5274b"],

Cell[BoxData[GridBox[{
   {Cell["   ", "ModInfo",ExpressionUUID->
     "429f0f4e-3a1e-2a41-8016-3004bc1a7dd6"], "\"\<Properties\>\"", 
    ButtonBox["All",
     BaseStyle->"Link"], Cell[
    "Property names to include", "TableText",ExpressionUUID->
     "65c865a4-91bf-a549-b14f-ee7de152b210"]},
   {Cell["   ", "ModInfo",ExpressionUUID->
     "519335c4-3374-6047-a495-44e527604097"], "\"\<MaxFeatures\>\"", "1000", 
    Cell["Maximum features to return (API max: 1001)", "TableText",
