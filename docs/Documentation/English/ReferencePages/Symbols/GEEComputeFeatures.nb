Cell["\<\
Find watersheds (HUC6) that drain into the Chesapeake Bay region and list \
their names and areas:\
\>", "ExampleText",
 CellChangeTimes->{3.9843446057564983`*^9},
 CellID->162144299,ExpressionUUID->"cc93a61d-dc1e-1e4c-8113-88659caaaf40"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"features", "=", 
   RowBox[{"GEEComputeFeatures", "[", 
    RowBox[{"\"\<USGS/WBD/2017/HUC06\>\"", ",", "\"\<\>\"", ",", 
     RowBox[{"\"\<GeoBounds\>\"", "->", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"-", "77.5"}], ",", "38.5", ",", 
        RowBox[{"-", "75.5"}], ",", "39.8"}], "}"}]}], ",", 
     RowBox[{"\"\<Properties\>\"", "->", 
      RowBox[{"{", 
       RowBox[{"\"\<name\>\"", ",", "\"\<huc6\>\"", ",", "\"\<areasqkm\>\""}],
        "}"}]}], ",", 
     RowBox[{"\"\<MaxFeatures\>\"", "->", "20"}]}], "]"}]}], ";"}], "\n", 
 RowBox[{"Dataset", "[", 
  RowBox[{"Map", "[", 
   RowBox[{
    RowBox[{
     RowBox[{"<|", 
      RowBox[{
       RowBox[{"\"\<Watershed\>\"", "->", 
        RowBox[{
         RowBox[{"#", "[", "\"\<Properties\>\"", "]"}], "[", "\"\<name\>\"", 
         "]"}]}], ",", 
       RowBox[{"\"\<HUC6\>\"", "->", 
        RowBox[{
         RowBox[{"#", "[", "\"\<Properties\>\"", "]"}], "[", "\"\<huc6\>\"", 
         "]"}]}], ",", 
       RowBox[{"\"\<Area (km\.b2)\>\"", "->", 
        RowBox[{
         RowBox[{"#", "[", "\"\<Properties\>\"", "]"}], 
         "[", "\"\<areasqkm\>\"", "]"}]}]}], "|>"}], "&"}], ",", "features"}],
    "]"}], "]"}]}], "Input",
