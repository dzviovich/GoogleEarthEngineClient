Cell["List US States and Their Land Area", "ExampleText",
 CellChangeTimes->{3.984344641803358*^9},
 CellID->719192073,ExpressionUUID->"756f94d9-878a-d64b-a3e6-d912778f76ae"],

Cell["\<\
Query all US states and display names with land area. ALAND is land area in \
square meters:\
\>", "ExampleText",
 CellChangeTimes->{
  3.984344647406988*^9, {3.9843449851321335`*^9, 3.984344985136141*^9}},
 CellID->70640193,ExpressionUUID->"05991cff-4772-c040-9396-b4a361a5ea31"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"features", "=", 
   RowBox[{"GEEComputeFeatures", "[", 
    RowBox[{"\"\<TIGER/2018/States\>\"", ",", "\"\<\>\"", ",", 
     RowBox[{"\"\<Properties\>\"", "->", 
      RowBox[{"{", 
       RowBox[{"\"\<NAME\>\"", ",", "\"\<ALAND\>\""}], "}"}]}], ",", 
     RowBox[{"\"\<MaxFeatures\>\"", "->", "56"}]}], "]"}]}], ";"}], "\n", 
 RowBox[{"Dataset", "[", 
  RowBox[{"SortBy", "[", 
   RowBox[{
    RowBox[{"Map", "[", 
     RowBox[{
      RowBox[{
       RowBox[{"<|", 
        RowBox[{
         RowBox[{"\"\<State\>\"", "->", 
          RowBox[{
           RowBox[{"#", "[", "\"\<Properties\>\"", "]"}], "[", "\"\<NAME\>\"",
            "]"}]}], ",", 
         RowBox[{"\"\<Area (km\.b2)\>\"", "->", 
          RowBox[{"Round", "[", 
           RowBox[{
            RowBox[{
             RowBox[{"#", "[", "\"\<Properties\>\"", "]"}], 
             "[", "\"\<ALAND\>\"", "]"}], "/", 
            RowBox[{"10", "^", "6"}]}], "]"}]}]}], "|>"}], "&"}], ",", 
      "features"}], "]"}], ",", 
    RowBox[{
     RowBox[{"-", 
      RowBox[{"#", "[", "\"\<Area (km\.b2)\>\"", "]"}]}], "&"}]}], "]"}], 
  "]"}]}], "Input",
 CellChangeTimes->{{3.9843446507671623`*^9, 3.9843446507676926`*^9}},
 CellLabel->"In[210]:=",
 CellID->67414060,ExpressionUUID->"5ef3eb61-38b0-8e41-b043-2f34f05e3384"],

