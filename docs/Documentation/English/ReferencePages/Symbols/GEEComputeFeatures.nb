Cell["\<\
Use \"Properties\" to fetch only the fields you need, reducing response size \
and making results easier to work with:\
\>", "ExampleText",
 CellChangeTimes->{
  3.9843443706541157`*^9, {3.98434498523847*^9, 3.984344985243473*^9}},
 CellID->130742162,ExpressionUUID->"d88e9829-66ed-d543-98f3-7dde6c26c1f3"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", 
   RowBox[{
   "Only", " ", "fetch", " ", "state", " ", "name", " ", "and", " ", "FIPS", " ",
     "code"}], "*)"}], 
  RowBox[{
   RowBox[{
    RowBox[{"features", "=", 
     RowBox[{"GEEComputeFeatures", "[", 
      RowBox[{"\"\<TIGER/2018/States\>\"", ",", "\"\<\>\"", ",", 
       RowBox[{"\"\<Properties\>\"", "->", 
        RowBox[{"{", 
         RowBox[{"\"\<NAME\>\"", ",", "\"\<STATEFP\>\""}], "}"}]}], ",", 
       RowBox[{"\"\<MaxFeatures\>\"", "->", "10"}]}], "]"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"Map", "[", 
     RowBox[{
      RowBox[{
       RowBox[{"{", 
        RowBox[{
         RowBox[{
          RowBox[{"#", "[", "\"\<Properties\>\"", "]"}], "[", "\"\<NAME\>\"", 
          "]"}], ",", 
         RowBox[{
          RowBox[{"#", "[", "\"\<Properties\>\"", "]"}], 
          "[", "\"\<STATEFP\>\"", "]"}]}], "}"}], "&"}], ",", "features"}], 
     "]"}], "//", "TableForm"}]}]}]], "Input",
 CellChangeTimes->{{3.9843443845431023`*^9, 3.9843443845431023`*^9}},
 CellLabel->"In[198]:=",
 CellID->74441754,ExpressionUUID->"3ec6d409-9d8d-ca41-a482-0df426bea5d6"],

