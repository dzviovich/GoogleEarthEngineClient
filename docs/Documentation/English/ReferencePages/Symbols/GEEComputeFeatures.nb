   {Cell["   ", "ModInfo",ExpressionUUID->
     "25882a87-9e78-d24f-a0f6-0eb95cf4fa59"], "\"\<GeoBounds\>\"", 
    ButtonBox["None",
     BaseStyle->"Link"], Cell[
    "Spatial filter `{west, south, east, north}`", "TableText",ExpressionUUID->
     "d27e4c8d-72d6-e847-a447-12b34b1207c5"]},
   {Cell["   ", "ModInfo",ExpressionUUID->
     "212a61ae-ebb5-4244-9b61-c0fde1ed3e37"], "\"\<Project\>\"", 
    ButtonBox["Automatic",
     BaseStyle->"Link"], Cell[
    "GCP project ID", "TableText",ExpressionUUID->
     "ee134579-37d3-d745-9608-4e4b04e211df"]}
  }]], "3ColumnTableMod",
 CellChangeTimes->{{3.9843440709351635`*^9, 3.984344093070673*^9}},
 CellID->263460763,ExpressionUUID->"3253248a-0f5f-4446-affd-2ac98c1cabe7"],

Cell[TextData[{
 "- ",
 StyleBox["assetId",
  FontSlant->"Italic"],
 " must refer to a TABLE asset (e.g., \"TIGER/2018/States\", \
\"WCMC/WDPA/current/polygons\").\n- ",
 StyleBox["filter",
  FontSlant->"Italic"],
 " is a filter expression string. Use \"\" for no filter.\n- Returns a list \
of Associations with keys \"Properties\" and \"Geometry\".\n- \"Properties\" \
is an Association of property name-value pairs.\n- \"Geometry\" is an \
Association with a \"type\" key (e.g., \"Polygon\", \"MultiPolygon\") and \
coordinate data.\n- Supports spatial filtering via \"GeoBounds\".\n- The \
no-filter overload GEEComputeFeatures[assetId, opts] is equivalent to passing \
\"\" as the filter."
}], "ExampleText",
 CellChangeTimes->{{3.984344103328535*^9, 3.9843441086353016`*^9}},
 CellID->363579033,ExpressionUUID->"dcd7d134-8154-c444-ac5f-71419e288b63"]
}, Open  ]],

