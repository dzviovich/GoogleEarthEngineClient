Cell["Counties in a Metro Area", "ExampleText",
 CellChangeTimes->{3.9843447150230694`*^9},
 CellID->159154802,ExpressionUUID->"e218d079-5bba-284e-b192-3e922fe8cb54"],

Cell["\<\
Find all counties within the Denver metropolitan area bounding box and \
display them as a table:\
\>", "ExampleText",
 CellChangeTimes->{3.98434473417202*^9},
 CellID->3524046,ExpressionUUID->"dc2a60fe-30e7-5d4f-b76b-bbc2ca84d234"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"features", "=", 
   RowBox[{"GEEComputeFeatures", "[", 
    RowBox[{"\"\<TIGER/2018/Counties\>\"", ",", "\"\<\>\"", ",", 
     RowBox[{"\"\<GeoBounds\>\"", "->", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"-", "105.3"}], ",", "39.5", ",", 
        RowBox[{"-", "104.5"}], ",", "40.1"}], "}"}]}], ",", 
     RowBox[{"\"\<Properties\>\"", "->", 
      RowBox[{"{", 
       RowBox[{"\"\<NAME\>\"", ",", "\"\<STATEFP\>\"", ",", "\"\<ALAND\>\""}],
        "}"}]}], ",", 
     RowBox[{"\"\<MaxFeatures\>\"", "->", "20"}]}], "]"}]}], ";"}], "\n", 
 RowBox[{"TableForm", "[", 
  RowBox[{
   RowBox[{"Map", "[", 
    RowBox[{
     RowBox[{
      RowBox[{"{", 
       RowBox[{
        RowBox[{
         RowBox[{"#", "[", "\"\<Properties\>\"", "]"}], "[", "\"\<NAME\>\"", 
         "]"}], ",", 
        RowBox[{"Round", "[", 
         RowBox[{
          RowBox[{
           RowBox[{"#", "[", "\"\<Properties\>\"", "]"}], "[", "\"\<ALAND\>\"",
            "]"}], "/", 
          RowBox[{"10", "^", "6"}]}], "]"}]}], "}"}], "&"}], ",", 
     "features"}], "]"}], ",", 
   RowBox[{"TableHeadings", "->", 
    RowBox[{"{", 
     RowBox[{"None", ",", 
      RowBox[{"{", 
       RowBox[{"\"\<County\>\"", ",", "\"\<Area (km\.b2)\>\""}], "}"}]}], 
     "}"}]}]}], "]"}]}], "Input",
 CellChangeTimes->{{3.984344744461609*^9, 3.984344744461609*^9}},
 CellLabel->"In[214]:=",
 CellID->79675710,ExpressionUUID->"165046ac-b297-1c47-a3da-41c2dd9a1438"],

Cell[BoxData[
 TagBox[
  TagBox[GridBox[{
     {
      TagBox["\<\"County\"\>",
       HoldForm], 
      TagBox["\<\"Area (km\.b2)\"\>",
       HoldForm]},
     {"\<\"Boulder\"\>", "1881"},
     {"\<\"Jefferson\"\>", "1980"},
     {"\<\"Adams\"\>", "3021"},
     {"\<\"Douglas\"\>", "2176"},
     {"\<\"Elbert\"\>", "4794"},
     {"\<\"Arapahoe\"\>", "2067"},
     {"\<\"Weld\"\>", "10324"},
     {"\<\"Denver\"\>", "397"},
     {"\<\"Broomfield\"\>", "85"}
    },
    GridBoxAlignment->{"Columns" -> {{Left}}, "Rows" -> {{Baseline}}},
    GridBoxDividers->{
     "Columns" -> {{False}}, "Rows" -> {False, True, {False}, False}},
    GridBoxSpacings->{"Columns" -> {
        Offset[0.27999999999999997`], {
         Offset[2.0999999999999996`]}, 
        Offset[0.27999999999999997`]}, "Rows" -> {
        Offset[0.2], {
         Offset[0.4]}, 
        Offset[0.2]}}],
   {None, OutputFormsDump`HeadedColumns}],
  Function[BoxForm`e$, 
   TableForm[
   BoxForm`e$, 
    TableHeadings -> {None, {"County", "Area (km\.b2)"}}]]]], "Output",
 CellChangeTimes->{3.9843447462212543`*^9},
 CellLabel->"Out[215]//TableForm=",
 CellID->15344019,ExpressionUUID->"a1ab614e-7b8f-bf48-a060-22ba9de47052"]
}, Open  ]],

Cell["Visualize State Boundaries on a Map", "ExampleText",
 CellChangeTimes->{3.984344753570053*^9},
 CellID->97255924,ExpressionUUID->"6d36d030-3061-0143-856e-ddd320b6f9f6"],

Cell["\<\
Query a state boundary and convert the GeoJSON geometry to a Wolfram Polygon \
for overlay on GeoGraphics. GeoJSON coordinates are {lon, lat} pairs; use \
Reverse to convert to {lat, lon} for GeoPosition. The nesting depends on \
geometry type: Polygon has coordinates[[ring, point]], MultiPolygon has \
coordinates[[polygon, ring, point]]:\
\>", "ExampleText",
 CellChangeTimes->{
  3.9843447599589977`*^9, 3.9843449431036263`*^9, {3.9843449851441364`*^9, 
   3.984344985222948*^9}},
 CellID->298243299,ExpressionUUID->"3a764823-8001-bc48-af26-1e313f9d09b8"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"features", "=", 
   RowBox[{"GEEComputeFeatures", "[", 
    RowBox[{"\"\<TIGER/2018/States\>\"", ",", "\"\<\>\"", ",", 
     RowBox[{"\"\<GeoBounds\>\"", "->", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"-", "109.1"}], ",", "36.9", ",", 
        RowBox[{"-", "102.0"}], ",", "41.1"}], "}"}]}], ",", 
     RowBox[{"\"\<Properties\>\"", "->", 
      RowBox[{"{", "\"\<NAME\>\"", "}"}]}], ",", 
     RowBox[{"\"\<MaxFeatures\>\"", "->", "1"}]}], "]"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"geom", "=", 
    RowBox[{
     RowBox[{"features", "[", 
      RowBox[{"[", "1", "]"}], "]"}], "[", "\"\<Geometry\>\"", "]"}]}], ";"}],
   "\[IndentingNewLine]", 
  RowBox[{"(*", 
   RowBox[{
    RowBox[{"Extract", " ", "the", " ", "outer", " ", "ring"}], ",", 
    RowBox[{
    "handling", " ", "both", " ", "Polygon", " ", "and", " ", 
     "MultiPolygon"}]}], "*)"}]}], "\n", 
 RowBox[{
  RowBox[{"coords", "=", 
   RowBox[{"If", "[", 
    RowBox[{
     RowBox[{
      RowBox[{"geom", "[", "\"\<type\>\"", "]"}], 
      "===", "\"\<MultiPolygon\>\""}], ",", 
     RowBox[{
      RowBox[{"geom", "[", "\"\<coordinates\>\"", "]"}], "[", 
      RowBox[{"[", 
       RowBox[{"1", ",", "1"}], "]"}], "]"}], ",", 
     RowBox[{
      RowBox[{"geom", "[", "\"\<coordinates\>\"", "]"}], "[", 
      RowBox[{"[", "1", "]"}], "]"}]}], "]"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{"poly", "=", 
   RowBox[{"GeoPolygon", "[", 
    RowBox[{"GeoPosition", "[", 
     RowBox[{"Map", "[", 
      RowBox[{"Reverse", ",", "coords"}], "]"}], "]"}], "]"}]}], ";"}], "\n", 
 RowBox[{"GeoGraphics", "[", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{
     RowBox[{"EdgeForm", "[", "Red", "]"}], ",", 
     RowBox[{"FaceForm", "[", "None", "]"}], ",", "poly"}], "}"}], ",", 
   RowBox[{"GeoRange", "->", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{"36.5", ",", "41.5"}], "}"}], ",", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"-", "109.5"}], ",", 
        RowBox[{"-", "101.5"}]}], "}"}]}], "}"}]}], ",", 
   RowBox[{"PlotLabel", "->", 
    RowBox[{
     RowBox[{
      RowBox[{"features", "[", 
       RowBox[{"[", "1", "]"}], "]"}], "[", "\"\<Properties\>\"", "]"}], 
     "[", "\"\<NAME\>\"", "]"}]}]}], "]"}]}], "Input",
 CellChangeTimes->{{3.984344764554222*^9, 3.984344764554222*^9}, 
   3.9843449507957726`*^9},
 CellLabel->"In[3]:=",
 CellID->532194113,ExpressionUUID->"7c9f8bdd-472f-1b43-924f-a73d30e1bf31"],

