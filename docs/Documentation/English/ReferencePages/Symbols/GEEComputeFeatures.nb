Cell["GEEComputeFeatures", "ObjectName",
 CellID->623027153,ExpressionUUID->"1b6c2e11-c652-7c4b-bd13-70f7e329f1ab"],

Cell["Query features from a Google Earth Engine FeatureCollection.", \
"ExampleText",
 CellChangeTimes->{3.9843440233356647`*^9},
 CellID->27058037,ExpressionUUID->"5cdfe297-775d-b049-b020-4516ae3c2c1b"],

Cell[TextData[{
 Cell["   ", "ModInfo",ExpressionUUID->"71262999-9db6-ac4e-b6a1-43c6f613e7cd"],
 Cell[BoxData[
  RowBox[{
   ButtonBox["GEEComputeFeatures",
    BaseStyle->"Link",
    ButtonData->"paclet:GoogleEarthEngineClient/ref/GEEComputeFeatures"], "[", 
   RowBox[{
    StyleBox["assetId", "TI"], ",", 
    StyleBox["filter", "TI"]}], "]"}]], "InlineFormula",ExpressionUUID->
  "8d487b83-47a6-4e4b-ad3d-7ba16f5a60e7"],
 "\[LineSeparator]query features from a Google Earth Engine table asset \
matching the ",
 Cell[BoxData[
  StyleBox["filter", "TI"]], "InlineFormula",ExpressionUUID->
  "039f43c0-e824-9d41-bd45-0e008129dcf0"],
 ". ",
 Cell[BoxData[
  ButtonBox["Return",
   BaseStyle->"Link"]], "InlineFormula",ExpressionUUID->
  "201dddcb-1cb0-3e42-9456-bec808a6a480"],
 " a list of feature Associations. \n             ",
 Cell[BoxData[
  RowBox[{
   ButtonBox["GEEComputeFeatures",
    BaseStyle->"Link",
    ButtonData->"paclet:GoogleEarthEngineClient/ref/GEEComputeFeatures"], "[", 
   StyleBox["assetId", "TI"], 
   StyleBox["]", "TI"]}]], "InlineFormula",ExpressionUUID->
  "cc1fdc34-e45a-ed4a-af7e-46a6aa28d401"],
 "\n",
 Cell["   ", "ModInfo",ExpressionUUID->"39cc788a-649f-734c-839c-b64179f125fa"],
 Cell[BoxData[
  RowBox[{
   ButtonBox["GEEComputeFeatures",
    BaseStyle->"Link",
    ButtonData->"paclet:GoogleEarthEngineClient/ref/GEEComputeFeatures"], "[", 
   RowBox[{
    StyleBox["assetId", "TI"], ",", 
    StyleBox["filter", "TI"], ",", 
    StyleBox["opts", "TI"]}], "]"}]], "InlineFormula",ExpressionUUID->
  "c66124d4-1d6f-c34d-9ac2-4dc13c7c27cc"],
 "\[LineSeparator]query with options \"Properties\", \"MaxFeatures\", and \
\"GeoBounds\"."
}], "Usage",
 CellChangeTimes->{{3.984167541308565*^9, 3.984167541560465*^9}, {
  3.9843440407746716`*^9, 3.98434406184914*^9}},
