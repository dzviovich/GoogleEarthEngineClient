Cell["Mean Elevation of a Region", "ExampleText",
 CellChangeTimes->{3.9843454098454266`*^9},
 CellID->30845342,ExpressionUUID->"6bcb70d5-27be-584a-8a3d-c9f490df9f10"],

Cell["\<\
Compute the mean SRTM elevation over a bounding box using GEEReduceRegion and \
GEEGeometry helpers with the // pipe operator:\
\>", "ExampleText",
 CellChangeTimes->{
  3.9843454175852585`*^9, {3.98434614570586*^9, 3.9843461457308044`*^9}},
 CellID->260040550,ExpressionUUID->"a5ec1bcc-6962-8b49-a3c8-14f36a12a417"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{"result", "=", 
  RowBox[{"GEECompute", "[", 
   RowBox[{
    RowBox[{"GEELoadImage", "[", "\"\<USGS/SRTMGL1_003\>\"", "]"}], "//", 
    RowBox[{"GEEReduceRegion", "[", 
     RowBox[{
      RowBox[{"GEEGeometry", "[", 
       RowBox[{"{", 
        RowBox[{"86.8", ",", "27.8", ",", "87.2", ",", "28.2"}], "}"}], "]"}],
       ",", "\"\<mean\>\"", ",", "30"}], "]"}]}], "]"}]}], "\n", 
 RowBox[{"result", "[", "\"\<elevation\>\"", "]"}], "\n", 
 RowBox[{
  RowBox[{"(*", 
   RowBox[{
   "Mean", " ", "elevation", " ", "in", " ", "meters", " ", "for", " ", "the",
     " ", "Everest", " ", "region"}], "*)"}]}]}], "Input",
 CellChangeTimes->{{3.984345422180868*^9, 3.9843454221818733`*^9}},
 CellLabel->"In[8]:=",
 CellID->200262731,ExpressionUUID->"ac456f75-57c8-5746-86cc-fbcd8a8e3e2c"],

Cell[BoxData[
 RowBox[{"\[LeftAssociation]", 
  RowBox[{"\<\"elevation\"\>", "\[Rule]", "5638.633231380477`"}], 
  "\[RightAssociation]"}]], "Output",
 CellChangeTimes->{3.9843454239972076`*^9},
 CellLabel->"Out[8]=",
 CellID->100520838,ExpressionUUID->"6a72f59f-ed8f-9145-95cb-a2db1ebf17a7"],

