Cell["Mean Reflectance from Cloud-Filtered Sentinel-2", "ExampleText",
 CellChangeTimes->{3.984345555815798*^9},
 CellID->24301877,ExpressionUUID->"ae644f82-fe90-7240-925f-4eaffac890e3"],

Cell["\<\
Compute mean surface reflectance for RGB bands over an agricultural region to \
assess seasonal crop brightness:\
\>", "ExampleText",
 CellChangeTimes->{3.9843455612591953`*^9},
 CellID->533297373,ExpressionUUID->"a963f9ad-9fab-fa45-a45f-a8ca4f651704"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{"result", "=", 
  RowBox[{"GEECompute", "[", 
   RowBox[{
    RowBox[{
     RowBox[{
      RowBox[{
       RowBox[{
        RowBox[{
         RowBox[{
         "GEECollection", "[", "\"\<COPERNICUS/S2_SR_HARMONIZED\>\"", "]"}], "//", 
         RowBox[{"GEEFilterDate", "[", 
          RowBox[{"\"\<2024-06-01\>\"", ",", "\"\<2024-09-01\>\""}], "]"}]}], 
        "//", 
        RowBox[{"GEEFilterBounds", "[", 
         RowBox[{"{", 
          RowBox[{
           RowBox[{"-", "121.8"}], ",", "38.3", ",", 
           RowBox[{"-", "121.4"}], ",", "38.7"}], "}"}], "]"}]}], "//", 
       RowBox[{"GEEFilterProperty", "[", 
        RowBox[{"\"\<CLOUDY_PIXEL_PERCENTAGE\>\"", ",", "\"\<LessThan\>\"", ",",
          "10"}], "]"}]}], "//", 
      RowBox[{"GEESelectBands", "[", 
       RowBox[{"{", 
        RowBox[{"\"\<B4\>\"", ",", "\"\<B3\>\"", ",", "\"\<B2\>\""}], "}"}], 
       "]"}]}], "//", "GEEMedian"}], "//", 
    RowBox[{"GEEReduceRegion", "[", 
     RowBox[{
      RowBox[{"GEEGeometry", "[", 
       RowBox[{"{", 
        RowBox[{
         RowBox[{"-", "121.8"}], ",", "38.3", ",", 
         RowBox[{"-", "121.4"}], ",", "38.7"}], "}"}], "]"}], 
      ",", "\"\<mean\>\"", ",", "10"}], "]"}]}], "]"}]}], "\n", 
 RowBox[{
  RowBox[{"(*", 
   RowBox[{"<|", 
    RowBox[{
     RowBox[{"\"\<B2\>\"", "->", "..."}], ",", 
     RowBox[{"\"\<B3\>\"", "->", "..."}], ",", 
     RowBox[{"\"\<B4\>\"", "->", 
      RowBox[{"...", "|", " ", ">"}]}], " ", "\[LongDash]", 
     RowBox[{"mean", " ", "reflectance", " ", "values"}]}]}], 
   "*)"}]}]}], "Input",
 CellChangeTimes->{{3.984345564699375*^9, 3.984345564699375*^9}},
 CellLabel->"In[15]:=",
 CellID->658406752,ExpressionUUID->"b14599b7-f77b-4649-8c8f-84f8e6e5b3cc"],

