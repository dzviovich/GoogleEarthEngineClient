Cell["Count Images in a Collection", "ExampleText",
 CellChangeTimes->{3.984345513805666*^9},
 CellID->43102941,ExpressionUUID->"30f523f9-03d2-aa4c-adee-927bee2800db"],

Cell["\<\
Count how many cloud-free Sentinel-2 images exist over a date range and \
region. Useful for checking data availability before running a large \
pipeline. Use expression builders to filter, then wrap in a raw \
Collection.size call:\
\>", "ExampleText",
 CellChangeTimes->{
  3.9843455212075577`*^9, {3.984346145735811*^9, 3.984346145739807*^9}},
 CellID->736869029,ExpressionUUID->"e358cef9-bfc0-444d-9a80-798899f239d5"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"coll", "=", 
   RowBox[{
    RowBox[{
     RowBox[{
      RowBox[{
      "GEECollection", "[", "\"\<COPERNICUS/S2_SR_HARMONIZED\>\"", "]"}], "//", 
      RowBox[{"GEEFilterDate", "[", 
       RowBox[{"\"\<2024-06-01\>\"", ",", "\"\<2024-09-01\>\""}], "]"}]}], "//", 
     RowBox[{"GEEFilterBounds", "[", 
      RowBox[{"{", 
       RowBox[{"2.2", ",", "48.8", ",", "2.5", ",", "48.9"}], "}"}], "]"}]}], 
    "//", 
    RowBox[{"GEEFilterProperty", "[", 
     RowBox[{"\"\<CLOUDY_PIXEL_PERCENTAGE\>\"", ",", "\"\<LessThan\>\"", ",", 
      "10"}], "]"}]}]}], ";"}], "\n", 
 RowBox[{"GEECompute", "[", 
  RowBox[{"<|", 
   RowBox[{"\"\<functionInvocationValue\>\"", "->", 
    RowBox[{"<|", 
     RowBox[{
      RowBox[{"\"\<functionName\>\"", "->", "\"\<Collection.size\>\""}], ",", 
      RowBox[{"\"\<arguments\>\"", "->", 
       RowBox[{"<|", 
        RowBox[{"\"\<collection\>\"", "->", "coll"}], "|>"}]}]}], "|>"}]}], 
   "|>"}], "]"}], "\n", 
 RowBox[{
  RowBox[{"(*", 
   RowBox[{
    RowBox[{
     RowBox[{"Number", " ", "of", " ", "cloud"}], "-", 
     RowBox[{"free", " ", "scenes", " ", "over", " ", "Paris"}]}], ",", 
    RowBox[{"summer", " ", "2024"}]}], "*)"}]}]}], "Input",
 CellChangeTimes->{{3.9843455261171722`*^9, 3.9843455261176777`*^9}},
 CellLabel->"In[13]:=",
 CellID->18891540,ExpressionUUID->"7e43271e-3591-7948-b1ba-d566540153ef"],

Cell[BoxData["3"], "Output",
 CellChangeTimes->{3.9843455279588833`*^9},
 CellLabel->"Out[14]=",
 CellID->209216347,ExpressionUUID->"b2a2951e-3904-b042-8c05-a1e3cb14a0b3"]
}, Open  ]],

Cell["Compute Area of a Bounding Box", "ExampleText",
 CellChangeTimes->{3.98434557809569*^9},
 CellID->276605971,ExpressionUUID->"b9e6994f-3bf3-fc4e-b3f5-9f0229844b34"],

Cell["\<\
Compute the area of a geographic rectangle in square kilometers. \
Geometry.area returns square meters:\
\>", "ExampleText",
 CellChangeTimes->{
  3.984345584956026*^9, {3.9843461457458057`*^9, 3.9843461457498055`*^9}},
 CellID->524363170,ExpressionUUID->"a03e10ff-57a5-f84e-826f-e889b2b6a770"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"geom", "=", 
   RowBox[{"GEEGeometry", "[", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{"-", "73.0"}], ",", "40.7", ",", 
      RowBox[{"-", "72.0"}], ",", "41.1"}], "}"}], "]"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{"areaM2", "=", 
   RowBox[{"GEECompute", "[", 
    RowBox[{"<|", 
     RowBox[{"\"\<functionInvocationValue\>\"", "->", 
      RowBox[{"<|", 
       RowBox[{
        RowBox[{"\"\<functionName\>\"", "->", "\"\<Geometry.area\>\""}], ",", 
        RowBox[{"\"\<arguments\>\"", "->", 
         RowBox[{"<|", 
          RowBox[{"\"\<geometry\>\"", "->", "geom"}], "|>"}]}]}], "|>"}]}], 
     "|>"}], "]"}]}], ";"}], "\n", 
 RowBox[{"areaKm2", "=", 
  RowBox[{"areaM2", "/", 
   RowBox[{"10", "^", "6"}]}]}], "\n", 
 RowBox[{
  RowBox[{"(*", 
   RowBox[{
    RowBox[{
    "Area", " ", "in", " ", "km\.b2", " ", "of", " ", "a", " ", "rectangle", " ",
      "over", " ", "Long", " ", "Island"}], ",", "NY"}], "*)"}]}]}], "Input",
 CellChangeTimes->{{3.984345589079172*^9, 3.984345589079172*^9}},
 CellLabel->"In[16]:=",
 CellID->258972373,ExpressionUUID->"89e01bec-aa55-9346-a50a-e0bc2c2fbc3e"],

Cell[BoxData["3738.216848976158`"], "Output",
 CellChangeTimes->{3.9843455900271873`*^9},
 CellLabel->"Out[18]=",
 CellID->177763848,ExpressionUUID->"3b73368c-4a35-2947-b7c9-1fff2fa267be"]
}, Open  ]],

Cell["Nighttime Radiance Statistics for a City", "ExampleText",
 CellChangeTimes->{3.9843455970814934`*^9},
 CellID->342042239,ExpressionUUID->"e5bc93ea-49da-1341-b744-5528033ce1fd"],

Cell["\<\
Compute mean and max VIIRS nighttime radiance over a city to quantify light \
pollution. VIIRS is an IMAGE_COLLECTION, so filter and aggregate to a single \
image first:\
\>", "ExampleText",
 CellChangeTimes->{
  3.9843456031589394`*^9, 3.984345660314636*^9, {3.9843461457548046`*^9, 
   3.9843461457578087`*^9}},
 CellID->542367997,ExpressionUUID->"21c99e30-3bba-4a46-b191-a36e5ed45600"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"geom", "=", 
   RowBox[{"GEEGeometry", "[", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{"-", "87.75"}], ",", "41.75", ",", 
      RowBox[{"-", "87.55"}], ",", "41.95"}], "}"}], "]"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{"img", "=", 
   RowBox[{
    RowBox[{
     RowBox[{
      RowBox[{
       RowBox[{
       "GEECollection", "[", "\"\<NOAA/VIIRS/DNB/MONTHLY_V1/VCMSLCFG\>\"", 
        "]"}], "//", 
       RowBox[{"GEEFilterDate", "[", 
        RowBox[{"\"\<2024-01-01\>\"", ",", "\"\<2024-07-01\>\""}], "]"}]}], "//", 
      RowBox[{"GEEFilterBounds", "[", 
       RowBox[{"{", 
        RowBox[{
         RowBox[{"-", "87.75"}], ",", "41.75", ",", 
         RowBox[{"-", "87.55"}], ",", "41.95"}], "}"}], "]"}]}], "//", 
     RowBox[{"GEESelectBands", "[", 
      RowBox[{"{", "\"\<avg_rad\>\"", "}"}], "]"}]}], "//", "GEEMedian"}]}], 
  ";"}], "\n", 
 RowBox[{
  RowBox[{"mean", "=", 
   RowBox[{"GEECompute", "[", 
    RowBox[{"img", "//", 
     RowBox[{"GEEReduceRegion", "[", 
      RowBox[{"geom", ",", "\"\<mean\>\"", ",", "500"}], "]"}]}], "]"}]}], 
  ";"}], "\n", 
 RowBox[{
  RowBox[{"maxVal", "=", 
   RowBox[{"GEECompute", "[", 
    RowBox[{"img", "//", 
     RowBox[{"GEEReduceRegion", "[", 
      RowBox[{"geom", ",", "\"\<max\>\"", ",", "500"}], "]"}]}], "]"}]}], 
  ";"}], "\n", 
 RowBox[{"{", 
  RowBox[{
   RowBox[{"First", "[", 
    RowBox[{"Values", "[", "mean", "]"}], "]"}], ",", 
   RowBox[{"First", "[", 
    RowBox[{"Values", "[", "maxVal", "]"}], "]"}]}], "}"}], "\n", 
 RowBox[{
  RowBox[{"(*", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{"meanRadiance", ",", "maxRadiance"}], "}"}], " ", "for", " ", 
    "central", " ", "Chicago", " ", "in", " ", 
    RowBox[{
     RowBox[{"nW", "/", "cm\.b2"}], "/", "sr"}]}], "*)"}]}]}], "Input",
 CellChangeTimes->{{3.9843457205318565`*^9, 3.9843457205318565`*^9}},
 CellLabel->"In[29]:=",
 CellID->545288911,ExpressionUUID->"97ff9c82-a648-7849-9fe4-8d3b2af228ba"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{"79.298285788904`", ",", "315.364990234375`"}], "}"}]], "Output",
 CellChangeTimes->{3.9843456086566525`*^9, 3.98434566838385*^9, 
  3.98434572227532*^9},
 CellLabel->"Out[33]=",
 CellID->682331242,ExpressionUUID->"257952d1-ddb0-a644-a5ab-2cf75a869914"]
}, Open  ]],

