Cell["Compare Elevation Statistics Across Mountain Ranges", "ExampleText",
 CellChangeTimes->{3.9843454470860786`*^9},
 CellID->242202925,ExpressionUUID->"8f2ce234-1d8e-6b4e-bc38-594b9a80fa8e"],

Cell["\<\
Compute min, mean, and max elevation for different regions and display as a \
table:\
\>", "ExampleText",
 CellChangeTimes->{3.9843454537697926`*^9},
 CellID->1249435,ExpressionUUID->"d77f645b-6405-894d-a083-d0f2ae078dc2"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"ranges", "=", 
   RowBox[{"<|", 
    RowBox[{
     RowBox[{"\"\<Alps\>\"", "->", 
      RowBox[{"{", 
       RowBox[{"6.5", ",", "45.8", ",", "8.5", ",", "47.0"}], "}"}]}], ",", 
     RowBox[{"\"\<Rockies\>\"", "->", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"-", "107.0"}], ",", "38.5", ",", 
        RowBox[{"-", "105.0"}], ",", "40.0"}], "}"}]}], ",", 
     RowBox[{"\"\<Andes\>\"", "->", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"-", "70.0"}], ",", 
        RowBox[{"-", "34.0"}], ",", 
        RowBox[{"-", "69.0"}], ",", 
        RowBox[{"-", "32.5"}]}], "}"}]}], ",", 
     RowBox[{"\"\<Himalayas\>\"", "->", 
      RowBox[{"{", 
       RowBox[{"86.0", ",", "27.5", ",", "88.0", ",", "28.5"}], "}"}]}]}], 
    "|>"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{"stats", "=", 
   RowBox[{"Association", "@", 
    RowBox[{"Map", "[", 
     RowBox[{
      RowBox[{
       RowBox[{"Module", "[", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{"img", ",", "geom", ",", "mn", ",", "mx", ",", "avg"}], 
          "}"}], ",", 
         RowBox[{
          RowBox[{"img", "=", 
           RowBox[{"GEELoadImage", "[", "\"\<USGS/SRTMGL1_003\>\"", "]"}]}], ";",
           "\[IndentingNewLine]", 
          RowBox[{"geom", "=", 
           RowBox[{"GEEGeometry", "[", 
            RowBox[{"ranges", "[", "#", "]"}], "]"}]}], ";", 
          "\[IndentingNewLine]", 
          RowBox[{"mn", "=", 
           RowBox[{"GEECompute", "[", 
            RowBox[{"img", "//", 
             RowBox[{"GEEReduceRegion", "[", 
              RowBox[{"geom", ",", "\"\<min\>\"", ",", "30"}], "]"}]}], 
            "]"}]}], ";", "\[IndentingNewLine]", 
          RowBox[{"mx", "=", 
           RowBox[{"GEECompute", "[", 
            RowBox[{"img", "//", 
             RowBox[{"GEEReduceRegion", "[", 
              RowBox[{"geom", ",", "\"\<max\>\"", ",", "30"}], "]"}]}], 
            "]"}]}], ";", "\[IndentingNewLine]", 
          RowBox[{"avg", "=", 
           RowBox[{"GEECompute", "[", 
            RowBox[{"img", "//", 
             RowBox[{"GEEReduceRegion", "[", 
              RowBox[{"geom", ",", "\"\<mean\>\"", ",", "30"}], "]"}]}], 
            "]"}]}], ";", "\[IndentingNewLine]", 
          RowBox[{"#", "->", 
           RowBox[{"<|", 
            RowBox[{
             RowBox[{"\"\<Min\>\"", "->", 
              RowBox[{"mn", "[", "\"\<elevation\>\"", "]"}]}], ",", 
             RowBox[{"\"\<Mean\>\"", "->", 
              RowBox[{"Round", "[", 
               RowBox[{"avg", "[", "\"\<elevation\>\"", "]"}], "]"}]}], ",", 
             RowBox[{"\"\<Max\>\"", "->", 
              RowBox[{"mx", "[", "\"\<elevation\>\"", "]"}]}]}], "|>"}]}]}]}],
         "]"}], "&"}], ",", 
      RowBox[{"Keys", "[", "ranges", "]"}]}], "]"}]}]}], ";"}], "\n", 
 RowBox[{"Dataset", "[", "stats", "]"}]}], "Input",
 CellChangeTimes->{{3.984345458138834*^9, 3.984345458138834*^9}},
 CellLabel->"In[10]:=",
 CellID->274196508,ExpressionUUID->"a416d6c2-decc-864b-b866-01a1dac1dc66"],

