Notebook[{

Cell[CellGroupData[{
Cell["GEECompute", "ObjectName",
 CellID->98856924,ExpressionUUID->"15d26c9f-ceb7-fe4d-af91-c716a2db5e00"],

Cell["\<\
Compute an arbitrary value from a Google Earth Engine expression tree.\
\>", "ExampleText",
 CellChangeTimes->{3.98434535699016*^9},
 CellID->14806172,ExpressionUUID->"0b1f5339-650d-2545-8204-6de03772b68e"],

Cell[TextData[{
 Cell["   ", "ModInfo",ExpressionUUID->"9d84ad56-b66e-b348-82a0-d7588f71f2d6"],
 Cell[BoxData[
  RowBox[{
   ButtonBox["GEECompute",
    BaseStyle->"Link",
    ButtonData->"paclet:GoogleEarthEngineClient/ref/GEECompute"], "[", 
   StyleBox["expression", "TI"], "]"}]], "InlineFormula",ExpressionUUID->
  "6ad2a429-a129-114f-9079-b224d198d831"],
 "\[LineSeparator]compute an arbitrary value from a Google Earth Engine ",
 Cell[BoxData[
  StyleBox["expression", "TI"]], "InlineFormula",ExpressionUUID->
  "e7e48610-72b1-9240-868a-4d305c022638"],
 " and return the result. \n",
 Cell["   ", "ModInfo",ExpressionUUID->"4b9c66ab-26f8-0745-bf97-9d9450cdba5d"],
 Cell[BoxData[
  RowBox[{
   ButtonBox["GEECompute",
    BaseStyle->"Link",
    ButtonData->"paclet:GoogleEarthEngineClient/ref/GEECompute"], "[", 
   RowBox[{
    StyleBox["expression", "TI"], ",", 
    StyleBox["opts", "TI"]}], "]"}]], "InlineFormula",ExpressionUUID->
  "067cfb8d-61a7-3e46-86e0-aeb069d9c7c7"],
 "\[LineSeparator]compute with option \"Project\"."
}], "Usage",
 CellChangeTimes->{{3.9841675605835896`*^9, 3.984167560696678*^9}},
 CellID->55082745,ExpressionUUID->"aadaff74-2f70-6f45-a11c-a0aaf1d98646"],

Cell["The following options can be given: ", "Notes",
 CellID->256717742,ExpressionUUID->"02b76fec-ce96-8f45-9958-34aa75b6ba59"],

Cell[BoxData[GridBox[{
   {Cell["   ", "ModInfo",ExpressionUUID->
     "6f90a5ff-1af8-b848-a555-7ad4f9c6fece"], "\"\<Project\>\"", 
    ButtonBox["Automatic",
     BaseStyle->"Link"], Cell[
    "GCP project ID", "TableText",ExpressionUUID->
     "b9ad39bc-f743-da46-ae6f-84525206b842"]}
  }]], "3ColumnTableMod",
 CellChangeTimes->{{3.984345103617916*^9, 3.984345103617916*^9}},
 CellID->138031653,ExpressionUUID->"2765ac7f-3b03-8242-a7c7-199b93f0623b"],

Cell["\<\
- expression is an Association representing a GEE v1 expression tree.
- Expression nodes use \"functionInvocationValue\" for function calls and \
\"constantValue\" for constants.
- Returns the computed result: a number, string, list, or Association \
depending on the expression.
- Common function names include Image.load, Image.select, Image.reduceRegion, \
ImageCollection.load, Collection.loadTable, Collection.size, \
Collection.filter, GeometryConstructors.Rectangle, \
GeometryConstructors.Point, Geometry.area, Geometry.centroid, Reducer.mean, \
Reducer.min, Reducer.max, Reducer.sum, Reducer.first.
- Constant expressions (\"constantValue\") are evaluated and returned as-is.\
\>", "ExampleText",
 CellChangeTimes->{
  3.9843451117404995`*^9, {3.984345168828861*^9, 3.9843451688813076`*^9}, {
   3.9843453910574856`*^9, 3.984345395641369*^9}},
 CellID->62284265,ExpressionUUID->"00a35197-0c3c-c54c-a7d1-da950faf4e2d"]
}, Open  ]],

