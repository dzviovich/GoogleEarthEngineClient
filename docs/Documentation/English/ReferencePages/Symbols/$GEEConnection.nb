Cell[TextData[{
 "- ",
 StyleBox["$GEEConnection",
  FontWeight->"Bold"],
 " holds an Association with keys \"Project\", \"AccessToken\", \"Expiry\", \
and \"KeyFile\".\n- Set by ",
 Cell[BoxData[
  ButtonBox["GEEConnect",
   BaseStyle->"Link",
   ButtonData->"paclet:GoogleEarthEngineClient/ref/GEEConnect"]], 
  "InlineFormula",ExpressionUUID->"ddbd0d71-5fe6-8e40-b87f-1befb2f271fe"],
 "; initially Null before authentication.\n- The access token is \
automatically refreshed when it expires."
}], "Notes",
 CellChangeTimes->{{3.984262333492962*^9, 3.9842623708396873`*^9}},
 CellID->114541334,ExpressionUUID->"eda365db-4ae7-0c43-acb5-d20652a267a8"]
