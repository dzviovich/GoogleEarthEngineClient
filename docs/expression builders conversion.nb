Cell[CellGroupData[{

Cell["Pixel Area for Weighted Statistics", "Section",ExpressionUUID->"9b1395e3-bac5-9d4a-a7e8-213b09f0e980"],

Cell[TextData[{
 "Use ",
 Cell["GEEPixelArea", "InlineCode",ExpressionUUID->
  "2a973c59-7346-0c4d-8b03-4a105d041f00"],
 " with ",
 Cell["GEEMultiply", "InlineCode",ExpressionUUID->
  "864cfa68-3480-9b4a-878c-6d7ad3b4a380"],
 " to compute area-weighted sums. This accounts for pixel area distortion in \
geographic projections:"
}], "Text",ExpressionUUID->"cabcdbdb-a1a4-ec4b-9e92-d6ed7f5f4ce3"],

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"bbox", " ", "=", " ", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{"-", "62.0"}], ",", " ", 
      RowBox[{"-", "4.0"}], ",", " ", 
      RowBox[{"-", "60.0"}], ",", " ", 
      RowBox[{"-", "2.0"}]}], "}"}]}], ";"}], "  ", 
  RowBox[{"(*", " ", 
   RowBox[{"Amazon", " ", "rainforest"}], " ", "*)"}]}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"ndvi", " ", "=", " ", 
    RowBox[{
     RowBox[{
      RowBox[{
       RowBox[{
        RowBox[{
         RowBox[{
          RowBox[{
          "GEECollection", "[", "\"\<COPERNICUS/S2_SR_HARMONIZED\>\"", "]"}], 
          " ", "//", "\n", "  ", 
          RowBox[{"GEEFilterDate", "[", 
           RowBox[{"\"\<2023-07-01\>\"", ",", " ", "\"\<2023-10-01\>\""}], 
           "]"}]}], " ", "//", "\n", "  ", 
         RowBox[{"GEEFilterBounds", "[", "bbox", "]"}]}], " ", "//", "\n", 
        "  ", 
        RowBox[{"GEEFilterProperty", "[", 
         RowBox[{"\"\<CLOUDY_PIXEL_PERCENTAGE\>\"", ",", 
          " ", "\"\<LessThan\>\"", ",", " ", "20"}], "]"}]}], " ", "//", "\n",
        "  ", 
       RowBox[{"GEESelectBands", "[", 
        RowBox[{"{", 
         RowBox[{"\"\<B8\>\"", ",", " ", "\"\<B4\>\""}], "}"}], "]"}]}], " ", 
      "//", "\n", "  ", "GEEMedian"}], " ", "//", "\n", "  ", 
     RowBox[{"GEENormalizedDifference", "[", 
      RowBox[{"{", 
       RowBox[{"\"\<B8_median\>\"", ",", " ", "\"\<B4_median\>\""}], "}"}], 
      "]"}]}]}], ";"}], "\n", 
  RowBox[{"(*", " ", 
   RowBox[{"Mask", " ", "to", " ", 
    RowBox[{"vegetation", ":", " ", 
     RowBox[{"NDVI", " ", ">", " ", "0.5"}]}]}], " ", "*)"}]}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"vegMask", " ", "=", " ", 
    RowBox[{"ndvi", " ", "//", " ", 
     RowBox[{"GEEGreaterThan", "[", "0.5", "]"}]}]}], ";"}], "\n", 
  RowBox[{"(*", " ", 
   RowBox[{
   "Multiply", " ", "pixel", " ", "area", " ", "by", " ", "mask", " ", "to", " ",
     "get", " ", "vegetated", " ", "area", " ", "per", " ", "pixel"}], " ", 
   "*)"}]}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"vegArea", " ", "=", " ", 
    RowBox[{
     RowBox[{"GEEPixelArea", "[", "]"}], " ", "//", " ", 
     RowBox[{"GEEMultiply", "[", "vegMask", "]"}]}]}], ";"}], "\n", 
  RowBox[{"(*", " ", 
   RowBox[{
   "Sum", " ", "the", " ", "vegetated", " ", "area", " ", "in", " ", "square",
     " ", "meters"}], " ", "*)"}]}], "\n", 
 RowBox[{"totalVegM2", " ", "=", " ", 
  RowBox[{"GEECompute", "[", "\n", "  ", 
   RowBox[{"vegArea", " ", "//", " ", 
    RowBox[{"GEEReduceRegion", "[", 
     RowBox[{
      RowBox[{"GEEGeometry", "[", "bbox", "]"}], ",", " ", "\"\<sum\>\"", ",",
       " ", "10"}], "]"}]}], "\n", "]"}]}]}], "Input",ExpressionUUID->\
"fcd3b64a-b44a-f74d-8478-6edde34fd25b"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Constant Image for Threshold Masking", "Section",ExpressionUUID->"54867fc4-4f1c-e644-9368-b28050c3f373"],

Cell[TextData[{
 "Use ",
 Cell["GEEConstant", "InlineCode",ExpressionUUID->
  "d0fa7660-f5d4-8146-9c83-fc167fb74345"],
 " to create a fill value for replacing masked pixels:"
}], "Text",ExpressionUUID->"a3691503-d738-8e44-8a04-b2ebd288b087"],

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{
   "Replace", " ", "masked", " ", "areas", " ", "with", " ", "a", " ", 
    "constant", " ", "background", " ", "value"}], " ", "*)"}], "\n", 
  RowBox[{"filled", " ", "=", " ", 
   RowBox[{
    RowBox[{"cloudMaskedImage", " ", "//", " ", 
     RowBox[{"GEEUnmask", "[", "0", "]"}]}], " ", "//", "\n", "  ", 
    RowBox[{"GEEWhere", "[", 
     RowBox[{"cloudMask", ",", " ", 
      RowBox[{"GEEConstant", "[", 
       RowBox[{"-", "9999"}], "]"}]}], "]"}]}]}]}]], "Input",ExpressionUUID->\
"10d84514-bef6-2441-9c73-7c517f6deda5"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Type Casting for Export", "Section",ExpressionUUID->"ec9291b9-8a1d-6046-91c2-f82d1204bec7"],

Cell["\<\
Convert bands to float before performing division to avoid integer truncation:\
\>", "Text",ExpressionUUID->"3f178ec6-4ecc-ce48-8c2d-af53ae78f77c"],

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"bbox", " ", "=", " ", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{"-", "3.8"}], ",", " ", "40.3", ",", " ", 
      RowBox[{"-", "3.6"}], ",", " ", "40.5"}], "}"}]}], ";"}], "  ", 
  RowBox[{"(*", " ", "Madrid", " ", "*)"}]}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"img", " ", "=", " ", 
    RowBox[{
     RowBox[{
      RowBox[{
       RowBox[{
        RowBox[{
         RowBox[{
          RowBox[{
           RowBox[{
           "GEECollection", "[", "\"\<COPERNICUS/S2_SR_HARMONIZED\>\"", "]"}],
            " ", "//", "\n", "  ", 
           RowBox[{"GEEFilterDate", "[", 
            RowBox[{"\"\<2023-06-01\>\"", ",", " ", "\"\<2023-09-01\>\""}], 
            "]"}]}], " ", "//", "\n", "  ", 
          RowBox[{"GEEFilterBounds", "[", "bbox", "]"}]}], " ", "//", "\n", 
         "  ", 
         RowBox[{"GEEFilterProperty", "[", 
          
          RowBox[{"\"\<CLOUDY_PIXEL_PERCENTAGE\>\"", ",", 
           " ", "\"\<LessThan\>\"", ",", " ", "10"}], "]"}]}], " ", "//", 
        "\n", "  ", 
        RowBox[{"GEESelectBands", "[", 
         RowBox[{"{", 
          
          RowBox[{"\"\<B4\>\"", ",", " ", "\"\<B3\>\"", ",", 
           " ", "\"\<B2\>\""}], "}"}], "]"}]}], " ", "//", "\n", "  ", 
       "GEEMedian"}], " ", "//", "\n", "  ", "GEEToFloat"}], " ", "//", "\n", 
     "  ", 
     RowBox[{"GEEDivide", "[", "10000", "]"}]}]}], ";"}], "  ", 
  RowBox[{"(*", " ", 
   RowBox[{
    RowBox[{"Scale", " ", "to", " ", "0"}], "-", 
    RowBox[{"1", " ", "reflectance"}]}], " ", "*)"}]}], "\n", 
 RowBox[{"GEEComputePixels", "[", 
  RowBox[{"bbox", ",", " ", "img", ",", "\n", "  ", 
   RowBox[{"\"\<VisParams\>\"", " ", "->", " ", 
    RowBox[{"<|", 
     RowBox[{
      RowBox[{"\"\<min\>\"", " ", "->", " ", "0"}], ",", " ", 
      RowBox[{"\"\<max\>\"", " ", "->", " ", "0.3"}]}], "|>"}]}]}], 
  "]"}]}], "Input",ExpressionUUID->"cde56620-55f9-994f-ac18-f22c2a62f770"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Convert to Integer for Compact Export", "Section",ExpressionUUID->"06ad5696-ed73-c74a-95d6-e83ac63d3239"],

Cell["\<\
Round and cast to integer for smaller file sizes when precision is not \
critical:\
\>", "Text",ExpressionUUID->"a2fd62f5-a6e8-e249-aa42-165988c8c479"],

Cell[BoxData[{
 RowBox[{
  RowBox[{"bbox", " ", "=", " ", 
