   RowBox[{"dem", " ", "//", " ", 
    RowBox[{"GEELessThan", "[", "500", "]"}]}]}]}]], "Input",ExpressionUUID->\
"13a0661d-be3b-6940-8b32-b4b95a62d44c"]
}, Open  ]],

Cell[CellGroupData[{

Cell["GEEEquals", "Subsection",ExpressionUUID->"346e9b6d-3eee-9946-8b87-52b7960dc635"],

