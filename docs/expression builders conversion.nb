Cell[CellGroupData[{

Cell["Smoothed Elevation with Focal Mean", "Section",ExpressionUUID->"2cca9ea4-362d-8645-a979-375cd0d74978"],

Cell["\<\
Apply a focal mean filter to smooth a DEM, reducing noise while preserving \
large-scale terrain features:\
\>", "Text",ExpressionUUID->"7081463e-2422-0643-b8e6-e9d5c4b02cad"],

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"bbox", " ", "=", " ", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{"-", "112.3"}], ",", " ", "36.0", ",", " ", 
      RowBox[{"-", "111.7"}], ",", " ", "36.5"}], "}"}]}], ";"}], "  ", 
  RowBox[{"(*", " ", 
   RowBox[{"Grand", " ", "Canyon"}], " ", "*)"}]}], "\n", 
 RowBox[{
  RowBox[{"smoothDEM", " ", "=", " ", 
   RowBox[{
    RowBox[{"GEELoadImage", "[", "\"\<USGS/SRTMGL1_003\>\"", "]"}], " ", "//",
     "\n", "  ", 
    RowBox[{"GEEFocalMean", "[", "1000", "]"}]}]}], ";"}], "\n", 
 RowBox[{"GEEComputePixels", "[", 
  RowBox[{"bbox", ",", " ", "smoothDEM", ",", "\n", "  ", 
   RowBox[{"\"\<VisParams\>\"", " ", "->", " ", 
    RowBox[{"<|", 
     RowBox[{
      RowBox[{"\"\<min\>\"", " ", "->", " ", "700"}], ",", " ", 
      RowBox[{"\"\<max\>\"", " ", "->", " ", "2500"}], ",", "\n", "    ", 
      RowBox[{"\"\<palette\>\"", " ", "->", " ", 
       RowBox[{"{", 
        RowBox[{"\"\<green\>\"", ",", " ", "\"\<yellow\>\"", ",", 
         " ", "\"\<brown\>\"", ",", " ", "\"\<white\>\""}], "}"}]}]}], 
     "|>"}]}]}], "]"}]}], "Input",ExpressionUUID->"33e183c7-3ad8-2740-ace0-\
9da11013c078"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Local Relief with Focal Max/Min", "Section",ExpressionUUID->"8867c5f3-cfb3-a641-aa06-20ef6f3a69c2"],

Cell["\<\
Compute local relief (the elevation range within a neighborhood) by \
subtracting the focal minimum from the focal maximum:\
\>", "Text",ExpressionUUID->"b18b7e68-b5e0-ca40-8370-748f2c5a06e7"],

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"bbox", " ", "=", " ", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{"-", "105.5"}], ",", " ", "39.5", ",", " ", 
      RowBox[{"-", "105.0"}], ",", " ", "40.0"}], "}"}]}], ";"}], "  ", 
  RowBox[{"(*", " ", 
   RowBox[{"Colorado", " ", "Front", " ", "Range"}], " ", "*)"}]}], "\n", 
 RowBox[{
  RowBox[{"dem", " ", "=", " ", 
   RowBox[{"GEELoadImage", "[", "\"\<USGS/SRTMGL1_003\>\"", "]"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{"localRelief", " ", "=", " ", 
   RowBox[{"GEESubtract", "[", "\n", "  ", 
    RowBox[{
     RowBox[{"dem", " ", "//", " ", 
      RowBox[{"GEEFocalMax", "[", "2000", "]"}]}], ",", "\n", "  ", 
     RowBox[{"dem", " ", "//", " ", 
      RowBox[{"GEEFocalMin", "[", "2000", "]"}]}]}], "]"}]}], ";"}], "\n", 
 RowBox[{"GEEComputePixels", "[", 
  RowBox[{"bbox", ",", " ", "localRelief", ",", "\n", "  ", 
   RowBox[{"\"\<VisParams\>\"", " ", "->", " ", 
    RowBox[{"<|", 
     RowBox[{
      RowBox[{"\"\<min\>\"", " ", "->", " ", "0"}], ",", " ", 
      RowBox[{"\"\<max\>\"", " ", "->", " ", "1000"}], ",", "\n", "    ", 
      RowBox[{"\"\<palette\>\"", " ", "->", " ", 
       RowBox[{"{", 
        RowBox[{"\"\<white\>\"", ",", " ", "\"\<yellow\>\"", ",", 
         " ", "\"\<orange\>\"", ",", " ", "\"\<red\>\""}], "}"}]}]}], 
     "|>"}]}], ",", "\n", "  ", 
   RowBox[{"\"\<ImageSize\>\"", " ", "->", " ", 
    RowBox[{"{", 
     RowBox[{"1024", ",", " ", "1024"}], "}"}]}]}], "]"}], "\n", 
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{
    RowBox[{"White", " ", "=", " ", 
     RowBox[{"flat", " ", "plains"}]}], ",", " ", 
    RowBox[{"Red", " ", "=", " ", 
     RowBox[{"high", " ", "local", " ", "relief", " ", 
      RowBox[{"(", 
       RowBox[{"canyons", ",", " ", "ridgelines"}], ")"}]}]}]}], " ", 
   "*)"}]}]}], "Input",ExpressionUUID->"02e3a6f4-9235-5646-bcab-400edfc68c5a"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Terrain Gradient for Edge Detection", "Section",ExpressionUUID->"e579659f-9de2-6f43-9de2-621829cc5c96"],

Cell[TextData[{
 "Use ",
 Cell["GEEGradient", "InlineCode",ExpressionUUID->
  "d6180694-feba-d046-a72c-822452411278"],
 " to compute x/y gradients of a DEM, then combine into gradient magnitude to \
highlight ridges and valleys:"
}], "Text",ExpressionUUID->"1f89cdb6-ed69-cf44-a0a9-495514e65d5f"],

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"bbox", " ", "=", " ", 
    RowBox[{"{", 
     RowBox[{
     "138.6", ",", " ", "35.2", ",", " ", "138.9", ",", " ", "35.45"}], 
     "}"}]}], ";"}], "  ", 
  RowBox[{"(*", " ", 
   RowBox[{"Mount", " ", "Fuji"}], " ", "*)"}]}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"grad", " ", "=", " ", 
    RowBox[{
     RowBox[{"GEELoadImage", "[", "\"\<USGS/SRTMGL1_003\>\"", "]"}], " ", "//",
      " ", "GEEGradient"}]}], ";"}], "\n", 
  RowBox[{"(*", " ", 
   RowBox[{
   "The", " ", "gradient", " ", "x", " ", "and", " ", "y", " ", "bands", " ", 
    "show", " ", "the", " ", "rate", " ", "of", " ", "elevation", " ", 
    "change"}], " ", "*)"}]}], "\n", 
 RowBox[{"GEEComputePixels", "[", 
  RowBox[{"bbox", ",", " ", 
   RowBox[{"grad", " ", "//", " ", 
    RowBox[{"GEESelectBands", "[", 
     RowBox[{"{", "\"\<x\>\"", "}"}], "]"}]}], ",", "\n", "  ", 
   RowBox[{"\"\<VisParams\>\"", " ", "->", " ", 
    RowBox[{"<|", 
     RowBox[{
      RowBox[{"\"\<min\>\"", " ", "->", " ", 
       RowBox[{"-", "0.05"}]}], ",", " ", 
      RowBox[{"\"\<max\>\"", " ", "->", " ", "0.05"}], ",", "\n", "    ", 
      RowBox[{"\"\<palette\>\"", " ", "->", " ", 
       RowBox[{"{", 
        RowBox[{"\"\<blue\>\"", ",", " ", "\"\<white\>\"", ",", 
         " ", "\"\<red\>\""}], "}"}]}]}], "|>"}]}]}], "]"}], "\n", 
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{
    RowBox[{"Blue", " ", "=", " ", 
     RowBox[{"falling", " ", "westward"}]}], ",", " ", 
    RowBox[{"Red", " ", "=", " ", 
     RowBox[{"rising", " ", "eastward"}]}]}], " ", "*)"}]}]}], "Input",Express\
ionUUID->"4ac30038-d254-8744-a50f-0122baa4dce9"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Logarithmic Nightlight Visualization", "Section",ExpressionUUID->"f161892a-6d8b-9a4b-bc3c-03e8ce0fce3a"],

