        "\n", "  ", 
       RowBox[{"GEEFilterProperty", "[", 
        RowBox[{"\"\<CLOUDY_PIXEL_PERCENTAGE\>\"", ",", 
         " ", "\"\<LessThan\>\"", ",", " ", "15"}], "]"}]}], " ", "//", "\n", 
      "  ", 
      RowBox[{"GEESelectBands", "[", 
       RowBox[{"{", 
        RowBox[{"\"\<B8\>\"", ",", " ", "\"\<B4\>\""}], "}"}], "]"}]}], " ", "//",
      "\n", "  ", "GEEMedian"}], " ", "//", "\n", "  ", 
    RowBox[{"GEENormalizedDifference", "[", 
     RowBox[{"{", 
      RowBox[{"\"\<B8_median\>\"", ",", " ", "\"\<B4_median\>\""}], "}"}], 
     "]"}]}]}]}]], "Input",ExpressionUUID->"8aa4ac2e-0924-b747-be06-\
ccad99a71321"]
}, Open  ]]
}, Open  ]],

Cell[CellGroupData[{

Cell["Masking", "Section",ExpressionUUID->"0a1a1819-d230-c34c-9677-99c4a1c90dd9"],

Cell[CellGroupData[{

Cell["GEEUpdateMask", "Subsection",ExpressionUUID->"ee8c4840-c3b2-1249-a114-48a34ca278c2"],

Cell[BoxData[{
 RowBox[{"GEEUpdateMask", "[", 
  RowBox[{"image", ",", " ", "mask"}], "]"}], "\n", 
 RowBox[{
  RowBox[{"GEEUpdateMask", "[", "mask", "]"}], "                        ", 
  RowBox[{"(*", " ", 
   RowBox[{"operator", " ", "form"}], " ", "*)"}]}]}], "Input",ExpressionUUID->\
"c1f496eb-9987-8143-b66b-bc79a80237c8"],

Cell[TextData[{
 "Update the pixel mask of an image. Pixels where ",
 Cell["mask", "InlineCode",ExpressionUUID->
  "d9ff5e54-9222-1c4f-9ae9-073be12a2cbf"],
 " is zero or masked become masked in the output. Use this for cloud masking, \
water masking, or any conditional pixel removal."
}], "Text",ExpressionUUID->"78729403-5bdb-b043-a8e9-2c811b9c8216"],

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{
   "Mask", " ", "out", " ", "cloudy", " ", "pixels", " ", "using", " ", "a", " ",
     "cloud", " ", "probability", " ", "band"}], " ", "*)"}], "\n", 
  RowBox[{"cloudFree", " ", "=", " ", 
   RowBox[{"img", " ", "//", " ", 
    RowBox[{"GEEUpdateMask", "[", "cloudMask", "]"}]}]}]}]], "Input",Expressio\
nUUID->"b61250fb-978d-d947-8330-b7169ab9089d"]
}, Open  ]],

Cell[CellGroupData[{

Cell["GEEUnmask", "Subsection",ExpressionUUID->"a858129f-b3f7-3942-8f02-5c2121fd5a83"],

Cell[BoxData[{
 RowBox[{"GEEUnmask", "[", 
  RowBox[{"image", ",", " ", "value"}], "]"}], "\n", 
 RowBox[{
  RowBox[{"GEEUnmask", "[", "value", "]"}], "                           ", 
  RowBox[{"(*", " ", 
   RowBox[{"operator", " ", "form"}], " ", "*)"}]}], "\n", 
 RowBox[{
  RowBox[{"GEEUnmask", "[", "image", "]"}], "                           ", 
  RowBox[{"(*", " ", 
   RowBox[{"replace", " ", "masked", " ", "pixels", " ", "with", " ", "0"}], 
   " ", "*)"}]}]}], "Input",ExpressionUUID->"35639ac5-5498-d247-8175-\
a0fdbaea26fc"],

Cell["\<\
Replace masked (nodata) pixels with a fill value. The one-argument form \
defaults to 0.\
\>", "Text",ExpressionUUID->"2a2c877f-f47f-724a-8045-70489fb08bb1"],

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{"Fill", " ", "nodata", " ", "gaps", " ", "with", " ", "zero"}], 
   " ", "*)"}], "\n", 
  RowBox[{
   RowBox[{"filled", " ", "=", " ", 
    RowBox[{"img", " ", "//", " ", 
     RowBox[{"GEEUnmask", "[", "0", "]"}]}]}], "\n", "\n", 
   RowBox[{"(*", " ", 
    RowBox[{"Fill", " ", "with", " ", "a", " ", "sentinel", " ", "value"}], 
    " ", "*)"}], "\n", 
   RowBox[{"filled", " ", "=", " ", 
    RowBox[{"img", " ", "//", " ", 
     RowBox[{"GEEUnmask", "[", 
      RowBox[{"-", "9999"}], "]"}]}]}]}]}]], "Input",ExpressionUUID->\
"112e8728-d9fb-7443-9579-a13380f16467"]
}, Open  ]],

Cell[CellGroupData[{

Cell["GEESelfMask", "Subsection",ExpressionUUID->"ecf81b92-98ec-9b43-bf3d-a7401955050a"],

