 Cell["GEELog10", "InlineCode",ExpressionUUID->
  "beb1315d-9415-6e4a-95a2-f49af5d00caf"],
 " to compress the dynamic range for better visualization:"
}], "Text",ExpressionUUID->"3a66f18e-8d59-a84a-be8f-d3e5fa3c510d"],

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"bbox", " ", "=", " ", 
    RowBox[{"{", 
     RowBox[{
     "139.5", ",", " ", "35.5", ",", " ", "140.0", ",", " ", "35.85"}], 
     "}"}]}], ";"}], "  ", 
  RowBox[{"(*", " ", "Tokyo", " ", "*)"}]}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"radiance", " ", "=", " ", 
    RowBox[{
     RowBox[{
      RowBox[{
       RowBox[{
        RowBox[{
        "GEECollection", "[", "\"\<NOAA/VIIRS/DNB/MONTHLY_V1/VCMSLCFG\>\"", 
         "]"}], " ", "//", "\n", "  ", 
        RowBox[{"GEEFilterDate", "[", 
         RowBox[{"\"\<2024-01-01\>\"", ",", " ", "\"\<2024-07-01\>\""}], 
         "]"}]}], " ", "//", "\n", "  ", 
       RowBox[{"GEEFilterBounds", "[", "bbox", "]"}]}], " ", "//", "\n", "  ", 
      RowBox[{"GEESelectBands", "[", 
       RowBox[{"{", "\"\<avg_rad\>\"", "}"}], "]"}]}], " ", "//", "\n", "  ", 
     "GEEMedian"}]}], ";"}], "\n", 
  RowBox[{"(*", " ", 
   RowBox[{
    RowBox[{"Log10", " ", 
     RowBox[{"compression", ":", " ", 
      RowBox[{"turns", " ", "0.1"}]}]}], "\[Dash]", 
    RowBox[{
     RowBox[{"1000", " ", "range", " ", "into"}], " ", "-", 
     RowBox[{"1", " ", "to", " ", "3"}]}]}], " ", "*)"}]}], "\n", 
 RowBox[{
  RowBox[{"logRadiance", " ", "=", " ", 
   RowBox[{"radiance", " ", "//", " ", "GEELog10"}]}], ";"}], "\n", 
 RowBox[{"GEEComputePixels", "[", 
  RowBox[{"bbox", ",", " ", "logRadiance", ",", "\n", "  ", 
   RowBox[{"\"\<VisParams\>\"", " ", "->", " ", 
    RowBox[{"<|", 
     RowBox[{
      RowBox[{"\"\<min\>\"", " ", "->", " ", 
       RowBox[{"-", "1"}]}], ",", " ", 
      RowBox[{"\"\<max\>\"", " ", "->", " ", "3"}], ",", "\n", "    ", 
      RowBox[{"\"\<palette\>\"", " ", "->", " ", 
       RowBox[{"{", 
        RowBox[{"\"\<black\>\"", ",", " ", "\"\<blue\>\"", ",", 
         " ", "\"\<yellow\>\"", ",", " ", "\"\<white\>\""}], "}"}]}]}], 
     "|>"}]}], ",", "\n", "  ", 
   RowBox[{"\"\<ImageSize\>\"", " ", "->", " ", 
    RowBox[{"{", 
     RowBox[{"1024", ",", " ", "1024"}], "}"}]}]}], "]"}]}], "Input",Expressio\
nUUID->"c42f2736-47d3-ed4a-ac63-9773b1832b98"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Radar Backscatter in Decibels", "Section",ExpressionUUID->"7a8a6102-acfc-0f4d-971a-3da76e2fbacd"],

Cell[TextData[{
 "Convert Sentinel-1 SAR backscatter from linear power to decibels using ",
 Cell["GEELog10", "InlineCode",ExpressionUUID->
  "c044a314-b1a9-7f41-8840-5a8a9a97bbc9"],
 ":"
}], "Text",ExpressionUUID->"f0f18542-8978-5f4b-b279-6249f0b8bff7"],

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"bbox", " ", "=", " ", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{"-", "4.0"}], ",", " ", "40.3", ",", " ", 
      RowBox[{"-", "3.6"}], ",", " ", "40.55"}], "}"}]}], ";"}], "  ", 
  RowBox[{"(*", " ", "Madrid", " ", "*)"}]}], "\n", 
 RowBox[{
  RowBox[{"sar", " ", "=", " ", 
   RowBox[{
    RowBox[{
     RowBox[{
      RowBox[{
       RowBox[{
        RowBox[{"GEECollection", "[", "\"\<COPERNICUS/S1_GRD\>\"", "]"}], " ",
         "//", "\n", "  ", 
        RowBox[{"GEEFilterDate", "[", 
         RowBox[{"\"\<2023-06-01\>\"", ",", " ", "\"\<2023-09-01\>\""}], 
         "]"}]}], " ", "//", "\n", "  ", 
       RowBox[{"GEEFilterBounds", "[", "bbox", "]"}]}], " ", "//", "\n", "  ", 
      RowBox[{"GEEFilterProperty", "[", 
       RowBox[{"\"\<instrumentMode\>\"", ",", " ", "\"\<Equals\>\"", ",", 
        " ", "\"\<IW\>\""}], "]"}]}], " ", "//", "\n", "  ", 
     RowBox[{"GEESelectBands", "[", 
      RowBox[{"{", "\"\<VV\>\"", "}"}], "]"}]}], " ", "//", "\n", "  ", 
    "GEEMedian"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{"dB", " ", "=", " ", 
   RowBox[{
    RowBox[{"sar", " ", "//", " ", "GEELog10"}], " ", "//", " ", 
    RowBox[{"GEEMultiply", "[", "10", "]"}]}]}], ";"}], "\n", 
 RowBox[{"GEEComputePixels", "[", 
  RowBox[{"bbox", ",", " ", "dB", ",", "\n", "  ", 
   RowBox[{"\"\<VisParams\>\"", " ", "->", " ", 
    RowBox[{"<|", 
     RowBox[{
      RowBox[{"\"\<min\>\"", " ", "->", " ", 
       RowBox[{"-", "25"}]}], ",", " ", 
      RowBox[{"\"\<max\>\"", " ", "->", " ", "0"}], ",", "\n", "    ", 
      RowBox[{"\"\<palette\>\"", " ", "->", " ", 
       RowBox[{"{", 
        RowBox[{"\"\<black\>\"", ",", " ", "\"\<gray\>\"", ",", 
         " ", "\"\<white\>\""}], "}"}]}]}], "|>"}]}]}], "]"}], "\n", 
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{
    RowBox[{"Dark", " ", "=", " ", 
     RowBox[{"smooth", " ", "surfaces", " ", 
      RowBox[{"(", "water", ")"}]}]}], ",", " ", 
    RowBox[{"Bright", " ", "=", " ", 
     RowBox[{"rough", " ", "surfaces", " ", 
      RowBox[{"(", "buildings", ")"}]}]}]}], " ", "*)"}]}]}], "Input",Expressi\
onUUID->"b87a1a67-3417-ec48-87f0-59c6160f3533"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Power-Law Contrast Enhancement", "Section",ExpressionUUID->"8ae91bad-4916-c943-ace3-1cef539c3ea1"],

Cell[TextData[{
 "Use ",
 Cell["GEEPow", "InlineCode",ExpressionUUID->
  "f31943e9-7dda-7640-a47d-c7e9b18cd566"],
 " with a fractional exponent to enhance low-value contrast in nightlight \
data (gamma correction):"
}], "Text",ExpressionUUID->"fe99d1b0-428e-d549-801e-19ba8f576966"],

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"bbox", " ", "=", " ", 
    RowBox[{"{", 
     RowBox[{"55.0", ",", " ", "25.0", ",", " ", "55.5", ",", " ", "25.35"}], 
     "}"}]}], ";"}], "  ", 
  RowBox[{"(*", " ", "Dubai", " ", "*)"}]}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"radiance", " ", "=", " ", 
    RowBox[{
     RowBox[{
      RowBox[{
       RowBox[{
        RowBox[{
        "GEECollection", "[", "\"\<NOAA/VIIRS/DNB/MONTHLY_V1/VCMSLCFG\>\"", 
         "]"}], " ", "//", "\n", "  ", 
        RowBox[{"GEEFilterDate", "[", 
         RowBox[{"\"\<2024-01-01\>\"", ",", " ", "\"\<2024-07-01\>\""}], 
         "]"}]}], " ", "//", "\n", "  ", 
       RowBox[{"GEEFilterBounds", "[", "bbox", "]"}]}], " ", "//", "\n", "  ", 
      RowBox[{"GEESelectBands", "[", 
       RowBox[{"{", "\"\<avg_rad\>\"", "}"}], "]"}]}], " ", "//", "\n", "  ", 
     "GEEMedian"}]}], ";"}], "\n", 
  RowBox[{"(*", " ", 
   RowBox[{
    RowBox[{"Gamma", " ", "<", " ", 
     RowBox[{"1", " ", "brightens", " ", "dark", " ", "areas"}]}], ",", " ", 
    RowBox[{"revealing", " ", "dim", " ", "suburban", " ", "lights"}]}], " ", 
   "*)"}]}], "\n", 
 RowBox[{
  RowBox[{"enhanced", " ", "=", " ", 
   RowBox[{
    RowBox[{
     RowBox[{"radiance", " ", "//", " ", 
      RowBox[{"GEEDivide", "[", "100", "]"}]}], " ", "//", " ", 
     RowBox[{"GEEPow", "[", "0.4", "]"}]}], " ", "//", " ", 
    RowBox[{"GEEMultiply", "[", "100", "]"}]}]}], ";"}], "\n", 
 RowBox[{"GEEComputePixels", "[", 
  RowBox[{"bbox", ",", " ", "enhanced", ",", "\n", "  ", 
   RowBox[{"\"\<VisParams\>\"", " ", "->", " ", 
    RowBox[{"<|", 
     RowBox[{
      RowBox[{"\"\<min\>\"", " ", "->", " ", "0"}], ",", " ", 
      RowBox[{"\"\<max\>\"", " ", "->", " ", "100"}], ",", "\n", "    ", 
      RowBox[{"\"\<palette\>\"", " ", "->", " ", 
       RowBox[{"{", 
        RowBox[{"\"\<black\>\"", ",", " ", "\"\<purple\>\"", ",", 
         " ", "\"\<yellow\>\"", ",", " ", "\"\<white\>\""}], "}"}]}]}], 
     "|>"}]}]}], "]"}]}], "Input",ExpressionUUID->"977babd0-60a3-d14e-83fe-\
b75c1d3c7a71"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Absolute NDVI Change Detection", "Section",ExpressionUUID->"b9f6e4ab-338f-964d-b0b6-bcf0ef27a714"],

Cell[TextData[{
 "Use ",
 Cell["GEEAbs", "InlineCode",ExpressionUUID->
  "1d519f17-fe95-b84d-a8c3-1d8b91dcb190"],
 " to compute the absolute magnitude of vegetation change, regardless of \
direction:"
}], "Text",ExpressionUUID->"fdc0f5b3-af74-a54d-aead-0ccf01884483"],

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"bbox", " ", "=", " ", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{"-", "122.0"}], ",", " ", "37.0", ",", " ", 
      RowBox[{"-", "121.5"}], ",", " ", "37.5"}], "}"}]}], ";"}], "  ", 
  RowBox[{"(*", " ", 
   RowBox[{"San", " ", 
    RowBox[{"Jose", " ", "/", " ", "Santa"}], " ", "Cruz"}], " ", "*)"}]}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"buildNDVI", "[", 
    RowBox[{"start_", ",", " ", "end_"}], "]"}], " ", ":=", "\n", "  ", 
   RowBox[{
    RowBox[{
     RowBox[{
      RowBox[{
       RowBox[{
        RowBox[{
         RowBox[{
         "GEECollection", "[", "\"\<COPERNICUS/S2_SR_HARMONIZED\>\"", "]"}], 
         " ", "//", "\n", "    ", 
         RowBox[{"GEEFilterDate", "[", 
          RowBox[{"start", ",", " ", "end"}], "]"}]}], " ", "//", "\n", 
        "    ", 
        RowBox[{"GEEFilterBounds", "[", "bbox", "]"}]}], " ", "//", "\n", 
       "    ", 
       RowBox[{"GEEFilterProperty", "[", 
        RowBox[{"\"\<CLOUDY_PIXEL_PERCENTAGE\>\"", ",", 
         " ", "\"\<LessThan\>\"", ",", " ", "15"}], "]"}]}], " ", "//", "\n", 
      "    ", 
      RowBox[{"GEESelectBands", "[", 
       RowBox[{"{", 
        RowBox[{"\"\<B8\>\"", ",", " ", "\"\<B4\>\""}], "}"}], "]"}]}], " ", "//",
      "\n", "    ", "GEEMedian"}], " ", "//", "\n", "    ", 
    RowBox[{"GEENormalizedDifference", "[", 
     RowBox[{"{", 
      RowBox[{"\"\<B8_median\>\"", ",", " ", "\"\<B4_median\>\""}], "}"}], 
     "]"}]}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{"absChange", " ", "=", " ", 
   RowBox[{
    RowBox[{"GEESubtract", "[", "\n", "  ", 
     RowBox[{
      RowBox[{"buildNDVI", "[", 
       RowBox[{"\"\<2023-09-01\>\"", ",", " ", "\"\<2023-11-01\>\""}], "]"}], 
      ",", "\n", "  ", 
      RowBox[{"buildNDVI", "[", 
       RowBox[{"\"\<2023-03-01\>\"", ",", " ", "\"\<2023-05-01\>\""}], 
       "]"}]}], "]"}], " ", "//", " ", "GEEAbs"}]}], ";"}], "\n", 
 RowBox[{"GEEComputePixels", "[", 
  RowBox[{"bbox", ",", " ", "absChange", ",", "\n", "  ", 
   RowBox[{"\"\<VisParams\>\"", " ", "->", " ", 
    RowBox[{"<|", 
     RowBox[{
      RowBox[{"\"\<min\>\"", " ", "->", " ", "0"}], ",", " ", 
      RowBox[{"\"\<max\>\"", " ", "->", " ", "0.4"}], ",", "\n", "    ", 
      RowBox[{"\"\<palette\>\"", " ", "->", " ", 
       RowBox[{"{", 
        RowBox[{"\"\<white\>\"", ",", " ", "\"\<yellow\>\"", ",", 
         " ", "\"\<orange\>\"", ",", " ", "\"\<red\>\""}], "}"}]}]}], 
     "|>"}]}], ",", "\n", "  ", 
   RowBox[{"\"\<ImageSize\>\"", " ", "->", " ", 
    RowBox[{"{", 
     RowBox[{"1024", ",", " ", "1024"}], "}"}]}]}], "]"}], "\n", 
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{
    RowBox[{"White", " ", "=", " ", "stable"}], ",", " ", 
    RowBox[{"Red", " ", "=", " ", 
     RowBox[{"large", " ", "change", " ", 
      RowBox[{"(", 
       RowBox[{"gain", " ", "or", " ", "loss"}], ")"}]}]}]}], " ", 
   "*)"}]}]}], "Input",ExpressionUUID->"ccc347fc-b14f-8047-930c-1576a11364c5"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Custom Polygon Clipping", "Section",ExpressionUUID->"2beade9b-0eca-8c4d-866f-31494bbe7f0b"],

Cell["\<\
Clip a satellite image to a custom polygon boundary instead of a rectangle:\
\>", "Text",ExpressionUUID->"12c11b8c-5a8f-6e4f-b3ad-aa2b139eb8f2"],

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{
    RowBox[{"Polygon", " ", "around", " ", "Lake", " ", "Como"}], ",", " ", 
    "Italy"}], " ", "*)"}], "\n", 
  RowBox[{
   RowBox[{
    RowBox[{"lakePoly", " ", "=", " ", 
     RowBox[{"GEEPolygon", "[", 
      RowBox[{"{", "\n", "  ", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{"9.20", ",", " ", "45.98"}], "}"}], ",", " ", 
        RowBox[{"{", 
         RowBox[{"9.28", ",", " ", "46.17"}], "}"}], ",", " ", 
        RowBox[{"{", 
         RowBox[{"9.35", ",", " ", "46.20"}], "}"}], ",", "\n", "  ", 
        RowBox[{"{", 
         RowBox[{"9.42", ",", " ", "46.17"}], "}"}], ",", " ", 
        RowBox[{"{", 
         RowBox[{"9.40", ",", " ", "46.00"}], "}"}], ",", " ", 
        RowBox[{"{", 
         RowBox[{"9.30", ",", " ", "45.95"}], "}"}]}], "\n", "}"}], "]"}]}], 
    ";"}], "\n", 
   RowBox[{
    RowBox[{"img", " ", "=", " ", 
     RowBox[{
      RowBox[{
       RowBox[{
        RowBox[{
         RowBox[{
          RowBox[{
           RowBox[{
           "GEECollection", "[", "\"\<COPERNICUS/S2_SR_HARMONIZED\>\"", "]"}],
            " ", "//", "\n", "  ", 
           RowBox[{"GEEFilterDate", "[", 
            RowBox[{"\"\<2023-06-01\>\"", ",", " ", "\"\<2023-09-01\>\""}], 
            "]"}]}], " ", "//", "\n", "  ", 
          RowBox[{"GEEFilterBounds", "[", 
           RowBox[{"{", 
            RowBox[{
            "9.15", ",", " ", "45.90", ",", " ", "9.50", ",", " ", "46.25"}], 
            "}"}], "]"}]}], " ", "//", "\n", "  ", 
         RowBox[{"GEEFilterProperty", "[", 
          
          RowBox[{"\"\<CLOUDY_PIXEL_PERCENTAGE\>\"", ",", 
           " ", "\"\<LessThan\>\"", ",", " ", "15"}], "]"}]}], " ", "//", 
        "\n", "  ", 
        RowBox[{"GEESelectBands", "[", 
         RowBox[{"{", 
          
          RowBox[{"\"\<B4\>\"", ",", " ", "\"\<B3\>\"", ",", 
           " ", "\"\<B2\>\""}], "}"}], "]"}]}], " ", "//", "\n", "  ", 
       "GEEMedian"}], " ", "//", "\n", "  ", 
      RowBox[{"GEEClip", "[", "lakePoly", "]"}]}]}], ";"}], "\n", 
   RowBox[{"GEEComputePixels", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
      "9.15", ",", " ", "45.90", ",", " ", "9.50", ",", " ", "46.25"}], "}"}],
      ",", " ", "img", ",", "\n", "  ", 
     RowBox[{"\"\<VisParams\>\"", " ", "->", " ", 
      RowBox[{"<|", 
       RowBox[{
        RowBox[{"\"\<min\>\"", " ", "->", " ", "0"}], ",", " ", 
        RowBox[{"\"\<max\>\"", " ", "->", " ", "3000"}]}], "|>"}]}]}], 
    "]"}]}]}]], "Input",ExpressionUUID->"17fe0128-9a90-3a4c-984c-\
75bdf0b6bfe7"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Buffered Point Analysis", "Section",ExpressionUUID->"552d37ed-9671-554f-ab9a-b0792d3e1e10"],

Cell["\<\
Create a circular region around a point by buffering, then compute mean \
elevation:\
\>", "Text",ExpressionUUID->"dd5cff7e-f847-4340-a659-bb5fcb6416c8"],

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{
   "10", "km", " ", "buffer", " ", "around", " ", "Mount", " ", "Rainier", " ",
     "summit"}], " ", "*)"}], "\n", 
  RowBox[{
   RowBox[{
    RowBox[{"summit", " ", "=", " ", 
     RowBox[{"GEEGeometry", "[", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"-", "121.7603"}], ",", " ", "46.8523"}], "}"}], "]"}]}], 
    ";"}], "\n", 
   RowBox[{
    RowBox[{"buffer", " ", "=", " ", 
     RowBox[{"summit", " ", "//", " ", 
      RowBox[{"GEEBuffer", "[", "10000", "]"}]}]}], ";"}], "\n", 
   RowBox[{"result", " ", "=", " ", 
    RowBox[{"GEECompute", "[", "\n", "  ", 
     RowBox[{
      RowBox[{"GEELoadImage", "[", "\"\<USGS/SRTMGL1_003\>\"", "]"}], " ", "//",
       "\n", "    ", 
      RowBox[{"GEEReduceRegion", "[", 
       RowBox[{"buffer", ",", " ", "\"\<mean\>\"", ",", " ", "30"}], "]"}]}], 
     "\n", "]"}]}], "\n", 
   RowBox[{"(*", " ", 
    RowBox[{
    "Mean", " ", "elevation", " ", "within", " ", "10", "km", " ", "of", " ", 
     "Mount", " ", "Rainier", " ", "summit"}], " ", "*)"}]}]}]], "Input",Expre\
ssionUUID->"44116929-e61c-5046-9ccc-2afec7c2eaf6"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Geometry Area Computation", "Section",ExpressionUUID->"d9207675-066e-b240-9834-c806ac20a7f7"],

