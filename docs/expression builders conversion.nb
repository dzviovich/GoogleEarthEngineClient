Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"bbox", " ", "=", " ", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{"-", "9.5"}], ",", " ", "38.6", ",", " ", 
      RowBox[{"-", "9.0"}], ",", " ", "38.85"}], "}"}]}], ";"}], "  ", 
  RowBox[{"(*", " ", "Lisbon", " ", "*)"}]}], "\n", 
 RowBox[{
  RowBox[{"spring", " ", "=", " ", 
   RowBox[{
    RowBox[{
     RowBox[{
      RowBox[{
       RowBox[{
       "GEECollection", "[", "\"\<COPERNICUS/S2_SR_HARMONIZED\>\"", "]"}], 
       " ", "//", "\n", "  ", 
       RowBox[{"GEEFilterDate", "[", 
        RowBox[{"\"\<2023-03-01\>\"", ",", " ", "\"\<2023-05-01\>\""}], 
        "]"}]}], " ", "//", "\n", "  ", 
      RowBox[{"GEEFilterBounds", "[", "bbox", "]"}]}], " ", "//", "\n", "  ", 
     RowBox[{"GEEFilterProperty", "[", 
      RowBox[{"\"\<CLOUDY_PIXEL_PERCENTAGE\>\"", ",", " ", "\"\<LessThan\>\"",
        ",", " ", "15"}], "]"}]}], " ", "//", "\n", "  ", 
    RowBox[{"GEESelectBands", "[", 
     RowBox[{"{", 
      RowBox[{"\"\<B4\>\"", ",", " ", "\"\<B3\>\"", ",", " ", "\"\<B2\>\""}], 
      "}"}], "]"}]}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{"autumn", " ", "=", " ", 
   RowBox[{
    RowBox[{
     RowBox[{
      RowBox[{
       RowBox[{
       "GEECollection", "[", "\"\<COPERNICUS/S2_SR_HARMONIZED\>\"", "]"}], 
       " ", "//", "\n", "  ", 
       RowBox[{"GEEFilterDate", "[", 
        RowBox[{"\"\<2023-09-01\>\"", ",", " ", "\"\<2023-11-01\>\""}], 
        "]"}]}], " ", "//", "\n", "  ", 
      RowBox[{"GEEFilterBounds", "[", "bbox", "]"}]}], " ", "//", "\n", "  ", 
     RowBox[{"GEEFilterProperty", "[", 
      RowBox[{"\"\<CLOUDY_PIXEL_PERCENTAGE\>\"", ",", " ", "\"\<LessThan\>\"",
        ",", " ", "15"}], "]"}]}], " ", "//", "\n", "  ", 
    RowBox[{"GEESelectBands", "[", 
     RowBox[{"{", 
      RowBox[{"\"\<B4\>\"", ",", " ", "\"\<B3\>\"", ",", " ", "\"\<B2\>\""}], 
      "}"}], "]"}]}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{"merged", " ", "=", " ", 
   RowBox[{
    RowBox[{"spring", " ", "//", " ", 
     RowBox[{"GEEMerge", "[", "autumn", "]"}]}], " ", "//", " ", 
    "GEEMedian"}]}], ";"}], "\n", 
 RowBox[{"GEEComputePixels", "[", 
  RowBox[{"bbox", ",", " ", "merged", ",", "\n", "  ", 
   RowBox[{"\"\<VisParams\>\"", " ", "->", " ", 
    RowBox[{"<|", 
     RowBox[{
      RowBox[{"\"\<min\>\"", " ", "->", " ", "0"}], ",", " ", 
      RowBox[{"\"\<max\>\"", " ", "->", " ", "3000"}]}], "|>"}]}]}], 
  "]"}]}], "Input",ExpressionUUID->"092b8602-6e41-8941-a82e-6e71100a1cce"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Max Temperature Composite", "Section",ExpressionUUID->"44e9c238-dec6-274d-922a-cd70388b8394"],

Cell["\<\
Compute the maximum land surface temperature over a summer to identify heat \
hotspots:\
\>", "Text",ExpressionUUID->"6d2e5d5a-a969-1d48-a296-6a4eb70a6423"],

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"bbox", " ", "=", " ", 
