     RowBox[{"-", "3.8"}], ",", " ", "40.3", ",", " ", 
     RowBox[{"-", "3.6"}], ",", " ", "40.5"}], "}"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"ndvi", " ", "=", " ", 
    RowBox[{
     RowBox[{
      RowBox[{
       RowBox[{
        RowBox[{
         RowBox[{
          RowBox[{
           RowBox[{
            RowBox[{
            "GEECollection", "[", "\"\<COPERNICUS/S2_SR_HARMONIZED\>\"", 
             "]"}], " ", "//", "\n", "  ", 
            RowBox[{"GEEFilterDate", "[", 
             RowBox[{"\"\<2023-06-01\>\"", ",", " ", "\"\<2023-09-01\>\""}], 
             "]"}]}], " ", "//", "\n", "  ", 
           RowBox[{"GEEFilterBounds", "[", "bbox", "]"}]}], " ", "//", "\n", 
          "  ", 
          RowBox[{"GEEFilterProperty", "[", 
           
           RowBox[{"\"\<CLOUDY_PIXEL_PERCENTAGE\>\"", ",", 
            " ", "\"\<LessThan\>\"", ",", " ", "10"}], "]"}]}], " ", "//", 
         "\n", "  ", 
         RowBox[{"GEESelectBands", "[", 
          RowBox[{"{", 
           RowBox[{"\"\<B8\>\"", ",", " ", "\"\<B4\>\""}], "}"}], "]"}]}], 
        " ", "//", "\n", "  ", "GEEMedian"}], " ", "//", "\n", "  ", 
       RowBox[{"GEENormalizedDifference", "[", 
        RowBox[{"{", 
         RowBox[{"\"\<B8_median\>\"", ",", " ", "\"\<B4_median\>\""}], "}"}], 
        "]"}]}], " ", "//", "\n", "  ", 
      RowBox[{"GEEMultiply", "[", "10000", "]"}]}], " ", "//", "\n", "  ", 
     "GEEToInt"}]}], ";"}], "  ", 
  RowBox[{"(*", " ", 
   RowBox[{
    RowBox[{
     RowBox[{
      RowBox[{"NDVI", " ", "scaled", " ", "to"}], " ", "-", "10000"}], ".."}],
     "10000", " ", "as", " ", "integer"}], " ", "*)"}]}], "\n", 
 RowBox[{"GEEComputePixels", "[", 
  RowBox[{"bbox", ",", " ", "ndvi", ",", " ", 
   RowBox[{"\"\<FileFormat\>\"", " ", "->", " ", "\"\<GEO_TIFF\>\""}]}], 
  "]"}]}], "Input",ExpressionUUID->"b39a0fe2-01ee-c146-8f89-b198b5fbd633"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Entropy Texture Map", "Section",ExpressionUUID->"bc79e4a5-8457-964e-8728-d0c0f5ed1790"],

Cell["\<\
Compute spatial entropy to distinguish between homogeneous areas (farmland, \
water) and heterogeneous areas (urban, forests):\
\>", "Text",ExpressionUUID->"ce1f131c-1784-0645-b134-f8d95ad3e2bd"],

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"bbox", " ", "=", " ", 
    RowBox[{"{", 
     RowBox[{"113.8", ",", " ", "22.2", ",", " ", "114.3", ",", " ", "22.5"}],
      "}"}]}], ";"}], "  ", 
  RowBox[{"(*", " ", 
   RowBox[{"Hong", " ", "Kong"}], " ", "*)"}]}], "\n", 
 RowBox[{
  RowBox[{"img", " ", "=", " ", 
   RowBox[{
    RowBox[{
     RowBox[{
      RowBox[{
       RowBox[{
        RowBox[{
        "GEECollection", "[", "\"\<COPERNICUS/S2_SR_HARMONIZED\>\"", "]"}], 
        " ", "//", "\n", "  ", 
        RowBox[{"GEEFilterDate", "[", 
         RowBox[{"\"\<2023-01-01\>\"", ",", " ", "\"\<2023-12-01\>\""}], 
         "]"}]}], " ", "//", "\n", "  ", 
       RowBox[{"GEEFilterBounds", "[", "bbox", "]"}]}], " ", "//", "\n", "  ", 
      RowBox[{"GEEFilterProperty", "[", 
       RowBox[{"\"\<CLOUDY_PIXEL_PERCENTAGE\>\"", ",", " ", "\"\<LessThan\>\"",
         ",", " ", "10"}], "]"}]}], " ", "//", "\n", "  ", 
     RowBox[{"GEESelectBands", "[", 
      RowBox[{"{", "\"\<B4\>\"", "}"}], "]"}]}], " ", "//", "\n", "  ", 
    "GEEMedian"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{"texture", " ", "=", " ", 
   RowBox[{"img", " ", "//", " ", 
    RowBox[{"GEEEntropy", "[", "300", "]"}]}]}], ";"}], "\n", 
 RowBox[{"GEEComputePixels", "[", 
  RowBox[{"bbox", ",", " ", "texture", ",", "\n", "  ", 
   RowBox[{"\"\<VisParams\>\"", " ", "->", " ", 
    RowBox[{"<|", 
     RowBox[{
      RowBox[{"\"\<min\>\"", " ", "->", " ", "0"}], ",", " ", 
      RowBox[{"\"\<max\>\"", " ", "->", " ", "4"}], ",", "\n", "    ", 
      RowBox[{"\"\<palette\>\"", " ", "->", " ", 
       RowBox[{"{", 
        RowBox[{"\"\<blue\>\"", ",", " ", "\"\<white\>\"", ",", 
         " ", "\"\<red\>\""}], "}"}]}]}], "|>"}]}]}], "]"}], "\n", 
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{
    RowBox[{"Blue", " ", "=", " ", 
     RowBox[{"uniform", " ", 
      RowBox[{"(", 
       RowBox[{"water", ",", " ", 
        RowBox[{"bare", " ", "land"}]}], ")"}]}]}], ",", " ", 
    RowBox[{"Red", " ", "=", " ", 
     RowBox[{"high", " ", "texture", " ", 
      RowBox[{"(", 
       RowBox[{"urban", ",", " ", 
        RowBox[{"mixed", " ", "land"}]}], ")"}]}]}]}], " ", 
   "*)"}]}]}], "Input",ExpressionUUID->"d4b3192f-aa1e-aa45-8034-d2af686bdd8d"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Multi-Region Statistics with ReduceRegions", "Section",ExpressionUUID->"e456dd16-dca6-f548-93bc-b1b8c3edc906"],

Cell["\<\
Compute mean elevation across multiple US states in a single call:\
\>", "Text",ExpressionUUID->"95a0d1dc-8925-9f4c-80f9-4017b0e4c646"],

Cell[BoxData[{
 RowBox[{
  RowBox[{"states", " ", "=", " ", 
   RowBox[{"GEEFeatureCollection", "[", "\"\<TIGER/2018/States\>\"", "]"}]}], 
  ";"}], "\n", 
 RowBox[{
  RowBox[{"dem", " ", "=", " ", 
   RowBox[{"GEELoadImage", "[", "\"\<USGS/SRTMGL1_003\>\"", "]"}]}], ";"}], "\n", 
 RowBox[{"result", " ", "=", " ", 
  RowBox[{"GEECompute", "[", "\n", "  ", 
   RowBox[{"dem", " ", "//", " ", 
    RowBox[{"GEEReduceRegions", "[", 
     RowBox[{"states", ",", " ", "\"\<mean\>\"", ",", " ", "1000"}], "]"}]}], 
   "\n", "]"}]}], "\n", 
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{
   "Returns", " ", "a", " ", "FeatureCollection", " ", "with", " ", "mean", " ",
     "elevation", " ", "per", " ", "state"}], " ", "*)"}]}]}], "Input",Express\
ionUUID->"2b4445d8-afa9-3949-9f29-f32c99073ad6"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Focal Median for Salt-and-Pepper Noise Removal", "Section",ExpressionUUID->"3abc6a75-838a-7b43-b7f2-47d99fc101ee"],

Cell["\<\
Remove isolated noisy pixels from a classified image using focal median:\
\>", "Text",ExpressionUUID->"e18ee4bc-9d51-4e4b-9160-53a0c009b6aa"],

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"bbox", " ", "=", " ", 
    RowBox[{"{", 
     RowBox[{"12.4", ",", " ", "41.8", ",", " ", "12.6", ",", " ", "42.0"}], 
     "}"}]}], ";"}], "  ", 
  RowBox[{"(*", " ", "Rome", " ", "*)"}]}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"classified", " ", "=", " ", 
    RowBox[{
     RowBox[{"GEELoadImage", "[", "\"\<ESA/WorldCover/v200\>\"", "]"}], " ", "//",
      "\n", "  ", 
     RowBox[{"GEESelectBands", "[", 
      RowBox[{"{", "\"\<Map\>\"", "}"}], "]"}]}]}], ";"}], "\n", 
  RowBox[{"(*", " ", 
   RowBox[{
   "100", "m", " ", "radius", " ", "median", " ", "filter", " ", "removes", " ",
     "isolated", " ", "misclassified", " ", "pixels"}], " ", "*)"}]}], "\n", 
 RowBox[{
  RowBox[{"cleaned", " ", "=", " ", 
   RowBox[{"classified", " ", "//", " ", 
    RowBox[{"GEEFocalMedian", "[", "100", "]"}]}]}], ";"}], "\n", 
 RowBox[{"GEEComputePixels", "[", 
  RowBox[{"bbox", ",", " ", "cleaned", ",", "\n", "  ", 
   RowBox[{"\"\<VisParams\>\"", " ", "->", " ", 
    RowBox[{"<|", 
     RowBox[{
      RowBox[{"\"\<min\>\"", " ", "->", " ", "10"}], ",", " ", 
      RowBox[{"\"\<max\>\"", " ", "->", " ", "100"}], ",", "\n", "    ", 
      RowBox[{"\"\<palette\>\"", " ", "->", " ", 
       RowBox[{"{", 
        RowBox[{"\"\<green\>\"", ",", " ", "\"\<yellow\>\"", ",", 
         " ", "\"\<red\>\"", ",", " ", "\"\<blue\>\"", ",", 
         " ", "\"\<gray\>\""}], "}"}]}]}], "|>"}]}]}], "]"}]}], "Input",Expres\
sionUUID->"c2c3bbb1-6ba1-3a4c-9fb4-6f5899124300"]
}, Open  ]],

