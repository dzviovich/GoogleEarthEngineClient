 "Simple join \[LongDash] returns features from ",
 Cell["primary", "InlineCode",ExpressionUUID->
  "60dd714b-5195-1a42-9a9e-e3004ba378fb"],
 " that have at least one match in ",
 Cell["secondary", "InlineCode",ExpressionUUID->
