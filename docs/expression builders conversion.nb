          RowBox[{"GEEFilterDate", "[", 
           RowBox[{"\"\<2023-06-01\>\"", ",", " ", "\"\<2023-09-01\>\""}], 
           "]"}]}], " ", "//", "\n", "    ", 
         RowBox[{"GEEFilterBounds", "[", 
          RowBox[{"{", 
           RowBox[{
            RowBox[{"-", "3.8"}], ",", " ", "40.3", ",", " ", 
            RowBox[{"-", "3.6"}], ",", " ", "40.5"}], "}"}], "]"}]}], " ", "//",
         "\n", "    ", 
        RowBox[{"GEEFilterProperty", "[", 
         RowBox[{"\"\<CLOUDY_PIXEL_PERCENTAGE\>\"", ",", 
          " ", "\"\<LessThan\>\"", ",", " ", "10"}], "]"}]}], " ", "//", "\n",
        "    ", 
       RowBox[{"GEESort", "[", "\"\<CLOUDY_PIXEL_PERCENTAGE\>\"", "]"}]}], 
      " ", "//", "\n", "    ", 
      RowBox[{"GEELimit", "[", "5", "]"}]}], " ", "//", "\n", "    ", 
     RowBox[{"GEESelectBands", "[", 
      RowBox[{"{", 
       RowBox[{"\"\<B4\>\"", ",", " ", "\"\<B3\>\"", ",", " ", "\"\<B2\>\""}],
        "}"}], "]"}]}], " ", "//", "\n", "    ", "GEEMedian"}], ",", "\n", 
   "  ", 
   RowBox[{"\"\<VisParams\>\"", " ", "->", " ", 
    RowBox[{"<|", 
     RowBox[{
      RowBox[{"\"\<min\>\"", " ", "->", " ", "0"}], ",", " ", 
      RowBox[{"\"\<max\>\"", " ", "->", " ", "3000"}]}], "|>"}]}]}], 
  "]"}]], "Input",ExpressionUUID->"2c8e6267-6dda-d64f-a89f-07f6fcd28de6"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Server-Side NDVI Visualization", "Section",ExpressionUUID->"15b88c72-ab31-fa47-aaa5-ad8e5cd1eba8"],

Cell["\<\
Compute NDVI entirely on the server and visualize with a vegetation color \
palette. No client-side math needed:\
\>", "Text",ExpressionUUID->"028aa41f-bfab-9843-a422-4d71a98128b4"],

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"bbox", " ", "=", " ", 
    RowBox[{"{", 
     RowBox[{"11.8", ",", " ", "43.2", ",", " ", "12.4", ",", " ", "43.6"}], 
     "}"}]}], ";"}], "  ", 
  RowBox[{"(*", " ", 
   RowBox[{"Tuscany", ",", " ", "Italy"}], " ", "*)"}]}], "\n", 
 RowBox[{
  RowBox[{"ndvi", " ", "=", " ", 
   RowBox[{
    RowBox[{
     RowBox[{
      RowBox[{
       RowBox[{
        RowBox[{
         RowBox[{
         "GEECollection", "[", "\"\<COPERNICUS/S2_SR_HARMONIZED\>\"", "]"}], 
         " ", "//", "\n", "  ", 
         RowBox[{"GEEFilterDate", "[", 
          RowBox[{"\"\<2023-06-01\>\"", ",", " ", "\"\<2023-09-01\>\""}], 
          "]"}]}], " ", "//", "\n", "  ", 
        RowBox[{"GEEFilterBounds", "[", "bbox", "]"}]}], " ", "//", "\n", 
       "  ", 
       RowBox[{"GEEFilterProperty", "[", 
        RowBox[{"\"\<CLOUDY_PIXEL_PERCENTAGE\>\"", ",", 
         " ", "\"\<LessThan\>\"", ",", " ", "15"}], "]"}]}], " ", "//", "\n", 
      "  ", 
      RowBox[{"GEESelectBands", "[", 
       RowBox[{"{", 
        RowBox[{"\"\<B8\>\"", ",", " ", "\"\<B4\>\""}], "}"}], "]"}]}], " ", "//",
      "\n", "  ", "GEEMedian"}], " ", "//", "\n", "  ", 
    RowBox[{"GEENormalizedDifference", "[", 
     RowBox[{"{", 
      RowBox[{"\"\<B8_median\>\"", ",", " ", "\"\<B4_median\>\""}], "}"}], 
     "]"}]}]}], ";"}], "\n", 
 RowBox[{"GEEComputePixels", "[", 
  RowBox[{"bbox", ",", " ", "ndvi", ",", "\n", "  ", 
   RowBox[{"\"\<VisParams\>\"", " ", "->", " ", 
    RowBox[{"<|", 
     RowBox[{
      RowBox[{"\"\<min\>\"", " ", "->", " ", 
       RowBox[{"-", "0.1"}]}], ",", " ", 
      RowBox[{"\"\<max\>\"", " ", "->", " ", "0.9"}], ",", "\n", "    ", 
      RowBox[{"\"\<palette\>\"", " ", "->", " ", 
       RowBox[{"{", 
        RowBox[{"\"\<brown\>\"", ",", " ", "\"\<yellow\>\"", ",", 
         " ", "\"\<green\>\"", ",", " ", "\"\<darkgreen\>\""}], "}"}]}]}], 
     "|>"}]}], ",", "\n", "  ", 
   RowBox[{"\"\<ImageSize\>\"", " ", "->", " ", 
    RowBox[{"{", 
     RowBox[{"1024", ",", " ", "1024"}], "}"}]}]}], "]"}]}], "Input",Expressio\
nUUID->"8405da90-c4c7-5d44-8019-10f79a4e42e9"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Cloud Masking with UpdateMask", "Section",ExpressionUUID->"58109225-cff9-3045-a3fd-0b94bee4f92f"],

Cell["\<\
Use the Sentinel-2 Scene Classification Layer (SCL) to mask clouds, then \
render a clean RGB image:\
\>", "Text",ExpressionUUID->"f9833ba2-a310-0b46-8961-d3f7b9b2e5de"],

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"bbox", " ", "=", " ", 
    RowBox[{"{", 
     RowBox[{"23.6", ",", " ", "37.9", ",", " ", "23.8", ",", " ", "38.1"}], 
     "}"}]}], ";"}], "  ", 
  RowBox[{"(*", " ", 
   RowBox[{"Athens", ",", " ", "Greece"}], " ", "*)"}]}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"pipeline", " ", "=", " ", 
    RowBox[{
     RowBox[{
      RowBox[{
       RowBox[{
        RowBox[{
         RowBox[{
         "GEECollection", "[", "\"\<COPERNICUS/S2_SR_HARMONIZED\>\"", "]"}], 
         " ", "//", "\n", "  ", 
         RowBox[{"GEEFilterDate", "[", 
          RowBox[{"\"\<2023-04-01\>\"", ",", " ", "\"\<2023-10-01\>\""}], 
          "]"}]}], " ", "//", "\n", "  ", 
        RowBox[{"GEEFilterBounds", "[", "bbox", "]"}]}], " ", "//", "\n", 
       "  ", 
       RowBox[{"GEEFilterProperty", "[", 
        RowBox[{"\"\<CLOUDY_PIXEL_PERCENTAGE\>\"", ",", 
         " ", "\"\<LessThan\>\"", ",", " ", "30"}], "]"}]}], " ", "//", "\n", 
      "  ", 
      RowBox[{"GEESelectBands", "[", 
       RowBox[{"{", 
        RowBox[{"\"\<B4\>\"", ",", " ", "\"\<B3\>\"", ",", " ", "\"\<B2\>\"", 
         ",", " ", "\"\<SCL\>\""}], "}"}], "]"}]}], " ", "//", "\n", "  ", 
     "GEEMedian"}]}], ";"}], "\n", 
  RowBox[{"(*", " ", 
   RowBox[{
    RowBox[{
     RowBox[{
      RowBox[{
      "Extract", " ", "the", " ", "SCL", " ", "band", " ", "and", " ", 
       "create", " ", "a", " ", "cloud"}], "-", 
      RowBox[{"free", " ", 
       RowBox[{"mask", ":", "\n", "   ", 
        RowBox[{"SCL", " ", "values", " ", "3"}]}]}]}], "=", 
     RowBox[{"cloud", " ", "shadow"}]}], ",", " ", 
    RowBox[{"8", "=", 
     RowBox[{"cloud", " ", "medium"}]}], ",", " ", 
    RowBox[{"9", "=", 
     RowBox[{"cloud", " ", "high"}]}]}], " ", "*)"}]}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"scl", " ", "=", " ", 
    RowBox[{"pipeline", " ", "//", " ", 
     RowBox[{"GEESelectBands", "[", 
      RowBox[{"{", "\"\<SCL_median\>\"", "}"}], "]"}]}]}], ";"}], "\n", 
  RowBox[{"(*", " ", 
   RowBox[{"Apply", " ", 
    RowBox[{"mask", ":", " ", 
     RowBox[{"keep", " ", "only", " ", "clear", " ", "pixels"}]}]}], " ", 
   "*)"}]}], "\n", 
 RowBox[{
  RowBox[{"cleanRGB", " ", "=", " ", 
   RowBox[{
    RowBox[{"pipeline", " ", "//", "\n", "  ", 
     RowBox[{"GEESelectBands", "[", 
      RowBox[{"{", 
       RowBox[{"\"\<B4_median\>\"", ",", " ", "\"\<B3_median\>\"", ",", 
        " ", "\"\<B2_median\>\""}], "}"}], "]"}]}], " ", "//", "\n", "  ", 
    RowBox[{"GEEUpdateMask", "[", "scl", "]"}]}]}], ";"}], "\n", 
 RowBox[{"GEEComputePixels", "[", 
  RowBox[{"bbox", ",", " ", "cleanRGB", ",", "\n", "  ", 
   RowBox[{"\"\<VisParams\>\"", " ", "->", " ", 
    RowBox[{"<|", 
     RowBox[{
      RowBox[{"\"\<min\>\"", " ", "->", " ", "0"}], ",", " ", 
      RowBox[{"\"\<max\>\"", " ", "->", " ", "3000"}]}], "|>"}]}]}], 
  "]"}]}], "Input",ExpressionUUID->"59bc1749-3d57-8d43-94c7-be1b0a78de05"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Scale Factor Conversion with Multiply", "Section",ExpressionUUID->"09990294-8b40-0343-8405-6bf1aa06b3b4"],

Cell[TextData[{
 "MODIS Land Surface Temperature stores values as raw integers that need a \
scale factor (0.02) and offset (subtract 273.15 for Celsius). Use ",
 Cell["GEEMultiply", "InlineCode",ExpressionUUID->
  "b5113b77-a128-484c-9dc7-26f7811dae87"],
 " and ",
 Cell["GEEAdd", "InlineCode",ExpressionUUID->
  "24e1974c-d552-c447-8c62-cbb8fc76bbf3"],
 " to convert server-side:"
}], "Text",ExpressionUUID->"7856aee2-1125-8248-b936-9da6f0b511b0"],

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"bbox", " ", "=", " ", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{"-", "5.0"}], ",", " ", "35.5", ",", " ", 
      RowBox[{"-", "3.5"}], ",", " ", "37.0"}], "}"}]}], ";"}], "  ", 
  RowBox[{"(*", " ", 
   RowBox[{"Southern", " ", "Spain"}], " ", "*)"}]}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"lstKelvin", " ", "=", " ", 
    RowBox[{
     RowBox[{
      RowBox[{
       RowBox[{
        RowBox[{
         RowBox[{"GEECollection", "[", "\"\<MODIS/061/MOD11A2\>\"", "]"}], 
         " ", "//", "\n", "  ", 
         RowBox[{"GEEFilterDate", "[", 
          RowBox[{"\"\<2023-07-01\>\"", ",", " ", "\"\<2023-08-01\>\""}], 
          "]"}]}], " ", "//", "\n", "  ", 
        RowBox[{"GEEFilterBounds", "[", "bbox", "]"}]}], " ", "//", "\n", 
       "  ", 
       RowBox[{"GEESelectBands", "[", 
        RowBox[{"{", "\"\<LST_Day_1km\>\"", "}"}], "]"}]}], " ", "//", "\n", 
      "  ", "GEEMedian"}], " ", "//", "\n", "  ", 
     RowBox[{"GEEMultiply", "[", "0.02", "]"}]}]}], ";"}], "\n", 
  RowBox[{"(*", " ", 
   RowBox[{
    RowBox[{"Visualize", " ", "in", " ", "Kelvin"}], " ", "\[LongDash]", " ", 
    RowBox[{
     RowBox[{"typical", " ", "summer", " ", "range", " ", "290"}], "-", 
     RowBox[{"320", " ", "K"}]}]}], " ", "*)"}]}], "\n", 
 RowBox[{"GEEComputePixels", "[", 
  RowBox[{"bbox", ",", " ", "lstKelvin", ",", "\n", "  ", 
   RowBox[{"\"\<VisParams\>\"", " ", "->", " ", 
    RowBox[{"<|", 
     RowBox[{
      RowBox[{"\"\<min\>\"", " ", "->", " ", "290"}], ",", " ", 
      RowBox[{"\"\<max\>\"", " ", "->", " ", "320"}], ",", "\n", "    ", 
      RowBox[{"\"\<palette\>\"", " ", "->", " ", 
       RowBox[{"{", 
        RowBox[{"\"\<blue\>\"", ",", " ", "\"\<yellow\>\"", ",", 
         " ", "\"\<red\>\""}], "}"}]}]}], "|>"}]}]}], "]"}]}], "Input",Express\
ionUUID->"2c765cf7-3870-4f44-b87c-771a29ab972a"]
}, Open  ]],

Cell[CellGroupData[{

Cell["EVI with GEEExpression", "Section",ExpressionUUID->"48ddcbaf-df1a-3646-9679-ed656ffb35c8"],

Cell[TextData[{
 "The Enhanced Vegetation Index (EVI) requires a multi-band math expression. ",
 Cell["GEEExpression", "InlineCode",ExpressionUUID->
  "77a486e9-4c4a-014e-94a8-42b13a42aa6f"],
 " evaluates it server-side in a single call:"
}], "Text",ExpressionUUID->"09694de0-12a5-d947-b588-2118fb6bf6e3"],

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"bbox", " ", "=", " ", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{"-", "48.6"}], ",", " ", 
      RowBox[{"-", "1.5"}], ",", " ", 
      RowBox[{"-", "48.2"}], ",", " ", 
      RowBox[{"-", "1.1"}]}], "}"}]}], ";"}], "  ", 
  RowBox[{"(*", " ", 
   RowBox[{"Bel\[EAcute]m", ",", " ", "Brazil", " ", "\[LongDash]", " ", 
    RowBox[{"Amazon", " ", "edge"}]}], " ", "*)"}]}], "\n", 
 RowBox[{
  RowBox[{"img", " ", "=", " ", 
   RowBox[{
    RowBox[{
     RowBox[{
      RowBox[{
       RowBox[{
        RowBox[{
        "GEECollection", "[", "\"\<COPERNICUS/S2_SR_HARMONIZED\>\"", "]"}], 
        " ", "//", "\n", "  ", 
        RowBox[{"GEEFilterDate", "[", 
         RowBox[{"\"\<2023-07-01\>\"", ",", " ", "\"\<2023-10-01\>\""}], 
         "]"}]}], " ", "//", "\n", "  ", 
       RowBox[{"GEEFilterBounds", "[", "bbox", "]"}]}], " ", "//", "\n", "  ", 
      RowBox[{"GEEFilterProperty", "[", 
       RowBox[{"\"\<CLOUDY_PIXEL_PERCENTAGE\>\"", ",", " ", "\"\<LessThan\>\"",
         ",", " ", "20"}], "]"}]}], " ", "//", "\n", "  ", 
     RowBox[{"GEESelectBands", "[", 
      RowBox[{"{", 
       RowBox[{"\"\<B8\>\"", ",", " ", "\"\<B4\>\"", ",", " ", "\"\<B2\>\""}],
        "}"}], "]"}]}], " ", "//", "\n", "  ", "GEEMedian"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{"evi", " ", "=", " ", 
   RowBox[{"img", " ", "//", " ", 
    RowBox[{"GEEExpression", "[", "\n", "  ", 
     RowBox[{"\"\<2.5 * ((nir - red) / (nir + 6 * red - 7.5 * blue + 1))\>\"",
       ",", "\n", "  ", 
      RowBox[{"<|", 
       RowBox[{
        RowBox[{"\"\<nir\>\"", " ", "->", " ", "\"\<B8_median\>\""}], ",", 
        " ", 
        RowBox[{"\"\<red\>\"", " ", "->", " ", "\"\<B4_median\>\""}], ",", 
        "\n", "    ", 
        RowBox[{"\"\<blue\>\"", " ", "->", " ", "\"\<B2_median\>\""}]}], 
       "|>"}]}], "]"}]}]}], ";"}], "\n", 
 RowBox[{"GEEComputePixels", "[", 
  RowBox[{"bbox", ",", " ", "evi", ",", "\n", "  ", 
   RowBox[{"\"\<VisParams\>\"", " ", "->", " ", 
    RowBox[{"<|", 
     RowBox[{
      RowBox[{"\"\<min\>\"", " ", "->", " ", "0"}], ",", " ", 
      RowBox[{"\"\<max\>\"", " ", "->", " ", "0.6"}], ",", "\n", "    ", 
      RowBox[{"\"\<palette\>\"", " ", "->", " ", 
       RowBox[{"{", 
        RowBox[{"\"\<white\>\"", ",", " ", "\"\<green\>\"", ",", 
         " ", "\"\<darkgreen\>\""}], "}"}]}]}], "|>"}]}]}], "]"}]}], "Input",E\
xpressionUUID->"5b4b8196-f07e-3f49-aa68-4a506b796e1b"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Compositing Derived Bands with AddBands", "Section",ExpressionUUID->"6ccd05db-0052-5b42-96b6-9a4d28cadbc2"],

Cell["\<\
Add an NDVI band to a Sentinel-2 RGB image so that both layers are available \
in a single expression tree:\
\>", "Text",ExpressionUUID->"ccda0121-b2c4-ec42-b7d7-98ff6fe4ea74"],

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"bbox", " ", "=", " ", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{"-", "121.8"}], ",", " ", "38.3", ",", " ", 
      RowBox[{"-", "121.4"}], ",", " ", "38.7"}], "}"}]}], ";"}], "  ", 
  RowBox[{"(*", " ", 
   RowBox[{"Sacramento", " ", "Valley"}], " ", "*)"}]}], "\n", 
 RowBox[{
  RowBox[{"base", " ", "=", " ", 
   RowBox[{
    RowBox[{
     RowBox[{
      RowBox[{
       RowBox[{
        RowBox[{
        "GEECollection", "[", "\"\<COPERNICUS/S2_SR_HARMONIZED\>\"", "]"}], 
        " ", "//", "\n", "  ", 
        RowBox[{"GEEFilterDate", "[", 
         RowBox[{"\"\<2023-06-01\>\"", ",", " ", "\"\<2023-09-01\>\""}], 
         "]"}]}], " ", "//", "\n", "  ", 
       RowBox[{"GEEFilterBounds", "[", "bbox", "]"}]}], " ", "//", "\n", "  ", 
      RowBox[{"GEEFilterProperty", "[", 
       RowBox[{"\"\<CLOUDY_PIXEL_PERCENTAGE\>\"", ",", " ", "\"\<LessThan\>\"",
         ",", " ", "10"}], "]"}]}], " ", "//", "\n", "  ", 
     RowBox[{"GEESelectBands", "[", 
      RowBox[{"{", 
       RowBox[{"\"\<B8\>\"", ",", " ", "\"\<B4\>\"", ",", " ", "\"\<B3\>\"", ",",
         " ", "\"\<B2\>\""}], "}"}], "]"}]}], " ", "//", "\n", "  ", 
    "GEEMedian"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{"ndvi", " ", "=", " ", 
   RowBox[{
    RowBox[{"base", " ", "//", "\n", "  ", 
     RowBox[{"GEENormalizedDifference", "[", 
      RowBox[{"{", 
       RowBox[{"\"\<B8_median\>\"", ",", " ", "\"\<B4_median\>\""}], "}"}], 
      "]"}]}], " ", "//", "\n", "  ", 
    RowBox[{"GEERename", "[", 
     RowBox[{"{", "\"\<NDVI\>\"", "}"}], "]"}]}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"composite", " ", "=", " ", 
    RowBox[{"base", " ", "//", " ", 
     RowBox[{"GEEAddBands", "[", "ndvi", "]"}]}]}], ";"}], "\n", 
  RowBox[{"(*", " ", 
   RowBox[{
    RowBox[{
    "Now", " ", "query", " ", "any", " ", "point", " ", "and", " ", "get", " ",
      "both", " ", "reflectance"}], " ", "+", " ", "NDVI"}], " ", "*)"}]}], "\n", 
 RowBox[{"GEEIdentify", "[", 
  RowBox[{
   RowBox[{"GeoPosition", "[", 
    RowBox[{"{", 
     RowBox[{"38.55", ",", " ", 
      RowBox[{"-", "121.6"}]}], "}"}], "]"}], ",", " ", "composite"}], 
  "]"}]}], "Input",ExpressionUUID->"9a143a1d-8207-db47-88c7-5775198b325d"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Clipping to a Region of Interest", "Section",ExpressionUUID->"58fe9b76-18d4-eb40-98f1-8477305ea4e5"],

Cell["\<\
Clip a global DEM to a specific bounding box so that pixels outside the area \
of interest are masked:\
\>", "Text",ExpressionUUID->"e39e1745-d990-944b-80a9-0bcd3c1e201e"],

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"roi", " ", "=", " ", 
    RowBox[{"GEEGeometry", "[", 
     RowBox[{"{", 
      RowBox[{"6.5", ",", " ", "45.8", ",", " ", "8.5", ",", " ", "47.0"}], 
      "}"}], "]"}]}], ";"}], "  ", 
  RowBox[{"(*", " ", 
   RowBox[{"Swiss", " ", "Alps"}], " ", "*)"}]}], "\n", 
 RowBox[{
  RowBox[{"dem", " ", "=", " ", 
   RowBox[{
    RowBox[{"GEELoadImage", "[", "\"\<USGS/SRTMGL1_003\>\"", "]"}], " ", "//",
     " ", 
    RowBox[{"GEEClip", "[", "roi", "]"}]}]}], ";"}], "\n", 
 RowBox[{"GEEComputePixels", "[", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{"6.5", ",", " ", "45.8", ",", " ", "8.5", ",", " ", "47.0"}], 
    "}"}], ",", " ", "dem", ",", "\n", "  ", 
   RowBox[{"\"\<VisParams\>\"", " ", "->", " ", 
    RowBox[{"<|", 
     RowBox[{
      RowBox[{"\"\<min\>\"", " ", "->", " ", "200"}], ",", " ", 
      RowBox[{"\"\<max\>\"", " ", "->", " ", "4500"}], ",", "\n", "    ", 
      RowBox[{"\"\<palette\>\"", " ", "->", " ", 
       RowBox[{"{", 
        RowBox[{"\"\<green\>\"", ",", " ", "\"\<yellow\>\"", ",", 
         " ", "\"\<brown\>\"", ",", " ", "\"\<white\>\""}], "}"}]}]}], 
     "|>"}]}], ",", "\n", "  ", 
   RowBox[{"\"\<ImageSize\>\"", " ", "->", " ", 
    RowBox[{"{", 
     RowBox[{"1024", ",", " ", "1024"}], "}"}]}]}], "]"}]}], "Input",Expressio\
nUUID->"d7294e44-3e98-a743-9c70-834cf8212bb5"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Water Body Detection with SelfMask", "Section",ExpressionUUID->"a181cd0e-1f8c-de4e-adaa-94b782eb0ca0"],

Cell[TextData[{
 "Use NDWI (Normalized Difference Water Index) to detect water bodies. ",
 Cell["GEESelfMask", "InlineCode",ExpressionUUID->
  "d671d13a-de10-0946-a9b9-7b0c63d17532"],
 " removes zero-value pixels (non-water) so only water pixels remain:"
}], "Text",ExpressionUUID->"548d2a27-4e8b-dc4a-9a6c-8e0beaebc5b0"],

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"bbox", " ", "=", " ", 
    RowBox[{"{", 
     RowBox[{"31.0", ",", " ", "29.9", ",", " ", "31.4", ",", " ", "30.2"}], 
     "}"}]}], ";"}], "  ", 
  RowBox[{"(*", " ", 
   RowBox[{
    RowBox[{"Cairo", " ", "/", " ", "Nile"}], " ", "Delta"}], " ", "*)"}]}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"ndwi", " ", "=", " ", 
    RowBox[{
     RowBox[{
      RowBox[{
       RowBox[{
        RowBox[{
         RowBox[{
          RowBox[{
          "GEECollection", "[", "\"\<COPERNICUS/S2_SR_HARMONIZED\>\"", "]"}], 
          " ", "//", "\n", "  ", 
          RowBox[{"GEEFilterDate", "[", 
           RowBox[{"\"\<2023-01-01\>\"", ",", " ", "\"\<2023-12-01\>\""}], 
           "]"}]}], " ", "//", "\n", "  ", 
         RowBox[{"GEEFilterBounds", "[", "bbox", "]"}]}], " ", "//", "\n", 
        "  ", 
        RowBox[{"GEEFilterProperty", "[", 
         RowBox[{"\"\<CLOUDY_PIXEL_PERCENTAGE\>\"", ",", 
          " ", "\"\<LessThan\>\"", ",", " ", "10"}], "]"}]}], " ", "//", "\n",
        "  ", 
       RowBox[{"GEESelectBands", "[", 
        RowBox[{"{", 
         RowBox[{"\"\<B3\>\"", ",", " ", "\"\<B8\>\""}], "}"}], "]"}]}], " ", 
      "//", "\n", "  ", "GEEMedian"}], " ", "//", "\n", "  ", 
     RowBox[{"GEENormalizedDifference", "[", 
      RowBox[{"{", 
       RowBox[{"\"\<B3_median\>\"", ",", " ", "\"\<B8_median\>\""}], "}"}], 
      "]"}]}]}], ";"}], "\n", 
  RowBox[{"(*", " ", 
   RowBox[{
    RowBox[{"Threshold", ":", " ", 
     RowBox[{"NDWI", " ", ">", " ", 
      RowBox[{
       RowBox[{"0", " ", "indicates", " ", 
        RowBox[{"water", ".", " ", "Multiply"}], " ", "by", " ", "boolean", " ",
         "to", " ", "zero", " ", "out", "\n", "   ", "non"}], "-", 
       "water"}]}]}], ",", " ", 
    RowBox[{
    "then", " ", "selfMask", " ", "to", " ", "remove", " ", "those", " ", 
     "zeros"}]}], " ", "*)"}]}], "\n", 
 RowBox[{
  RowBox[{"waterMask", " ", "=", " ", 
   RowBox[{
    RowBox[{"ndwi", " ", "//", " ", 
     RowBox[{"GEEMultiply", "[", "ndwi", "]"}]}], " ", "//", " ", 
    "GEESelfMask"}]}], ";"}], "\n", 
 RowBox[{"GEEComputePixels", "[", 
  RowBox[{"bbox", ",", " ", "waterMask", ",", "\n", "  ", 
   RowBox[{"\"\<VisParams\>\"", " ", "->", " ", 
    RowBox[{"<|", 
     RowBox[{
      RowBox[{"\"\<min\>\"", " ", "->", " ", "0"}], ",", " ", 
      RowBox[{"\"\<max\>\"", " ", "->", " ", "0.5"}], ",", "\n", "    ", 
      RowBox[{"\"\<palette\>\"", " ", "->", " ", 
       RowBox[{"{", 
        RowBox[{"\"\<lightblue\>\"", ",", " ", "\"\<blue\>\"", ",", 
         " ", "\"\<darkblue\>\""}], "}"}]}]}], "|>"}]}]}], "]"}]}], "Input",Ex\
pressionUUID->"c5036067-d813-464a-8635-5ebc418c2e7c"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Filling Nodata Gaps with Unmask", "Section",ExpressionUUID->"e95ba338-4bc0-2f46-b40c-384b17f6009b"],

Cell["\<\
Replace masked (nodata) pixels in a Sentinel-2 composite with zero to ensure \
a complete image for export:\
\>", "Text",ExpressionUUID->"2657978b-6992-c54b-8e9f-1af4ba734d7b"],

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"bbox", " ", "=", " ", 
    RowBox[{"{", 
     RowBox[{"13.2", ",", " ", "52.4", ",", " ", "13.6", ",", " ", "52.6"}], 
     "}"}]}], ";"}], "  ", 
  RowBox[{"(*", " ", "Berlin", " ", "*)"}]}], "\n", 
 RowBox[{
  RowBox[{"img", " ", "=", " ", 
   RowBox[{
    RowBox[{
     RowBox[{
      RowBox[{
       RowBox[{
        RowBox[{
         RowBox[{
         "GEECollection", "[", "\"\<COPERNICUS/S2_SR_HARMONIZED\>\"", "]"}], 
         " ", "//", "\n", "  ", 
         RowBox[{"GEEFilterDate", "[", 
          RowBox[{"\"\<2023-06-01\>\"", ",", " ", "\"\<2023-09-01\>\""}], 
          "]"}]}], " ", "//", "\n", "  ", 
        RowBox[{"GEEFilterBounds", "[", "bbox", "]"}]}], " ", "//", "\n", 
       "  ", 
       RowBox[{"GEEFilterProperty", "[", 
        RowBox[{"\"\<CLOUDY_PIXEL_PERCENTAGE\>\"", ",", 
         " ", "\"\<LessThan\>\"", ",", " ", "10"}], "]"}]}], " ", "//", "\n", 
      "  ", 
      RowBox[{"GEESelectBands", "[", 
       RowBox[{"{", 
        RowBox[{"\"\<B4\>\"", ",", " ", "\"\<B3\>\"", ",", 
         " ", "\"\<B2\>\""}], "}"}], "]"}]}], " ", "//", "\n", "  ", 
     "GEEMedian"}], " ", "//", "\n", "  ", 
    RowBox[{"GEEUnmask", "[", "0", "]"}]}]}], ";"}], "\n", 
 RowBox[{"GEEComputePixels", "[", 
  RowBox[{"bbox", ",", " ", "img", ",", "\n", "  ", 
   RowBox[{"\"\<VisParams\>\"", " ", "->", " ", 
    RowBox[{"<|", 
     RowBox[{
      RowBox[{"\"\<min\>\"", " ", "->", " ", "0"}], ",", " ", 
      RowBox[{"\"\<max\>\"", " ", "->", " ", "3000"}]}], "|>"}]}], ",", "\n", 
   "  ", 
   RowBox[{"\"\<FileFormat\>\"", " ", "->", " ", "\"\<GEO_TIFF\>\""}], ",", 
   "\n", "  ", 
   RowBox[{"\"\<ImageSize\>\"", " ", "->", " ", 
    RowBox[{"{", 
     RowBox[{"1024", ",", " ", "1024"}], "}"}]}]}], "]"}]}], "Input",Expressio\
nUUID->"4a63ad0f-4bad-ff46-ba18-aeeb130e465a"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Change Detection: Before vs. After Subtraction", "Section",ExpressionUUID->"feddfc80-bd41-4e47-9355-1dc4b379a15a"],

Cell["\<\
Compute the difference in NDVI between two seasons to detect vegetation loss \
or gain:\
\>", "Text",ExpressionUUID->"59334dd9-9590-a342-92c8-e5c3c686b77a"],

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"bbox", " ", "=", " ", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{"-", "120.5"}], ",", " ", "37.5", ",", " ", 
      RowBox[{"-", "119.5"}], ",", " ", "38.0"}], "}"}]}], ";"}], "  ", 
  RowBox[{"(*", " ", 
   RowBox[{"Sierra", " ", "Nevada", " ", "foothills"}], " ", "*)"}]}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"buildNDVI", "[", 
    RowBox[{"start_", ",", " ", "end_"}], "]"}], " ", ":=", "\n", "  ", 
   RowBox[{
    RowBox[{
     RowBox[{
      RowBox[{
       RowBox[{
        RowBox[{
         RowBox[{
         "GEECollection", "[", "\"\<COPERNICUS/S2_SR_HARMONIZED\>\"", "]"}], 
         " ", "//", "\n", "    ", 
         RowBox[{"GEEFilterDate", "[", 
          RowBox[{"start", ",", " ", "end"}], "]"}]}], " ", "//", "\n", 
        "    ", 
        RowBox[{"GEEFilterBounds", "[", "bbox", "]"}]}], " ", "//", "\n", 
       "    ", 
       RowBox[{"GEEFilterProperty", "[", 
        RowBox[{"\"\<CLOUDY_PIXEL_PERCENTAGE\>\"", ",", 
         " ", "\"\<LessThan\>\"", ",", " ", "15"}], "]"}]}], " ", "//", "\n", 
      "    ", 
      RowBox[{"GEESelectBands", "[", 
       RowBox[{"{", 
        RowBox[{"\"\<B8\>\"", ",", " ", "\"\<B4\>\""}], "}"}], "]"}]}], " ", "//",
      "\n", "    ", "GEEMedian"}], " ", "//", "\n", "    ", 
    RowBox[{"GEENormalizedDifference", "[", 
     RowBox[{"{", 
      RowBox[{"\"\<B8_median\>\"", ",", " ", "\"\<B4_median\>\""}], "}"}], 
     "]"}]}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{"spring", " ", "=", " ", 
   RowBox[{"buildNDVI", "[", 
    RowBox[{"\"\<2023-04-01\>\"", ",", " ", "\"\<2023-06-01\>\""}], "]"}]}], 
  ";"}], "\n", 
 RowBox[{
  RowBox[{"fall", " ", "=", " ", 
   RowBox[{"buildNDVI", "[", 
    RowBox[{"\"\<2023-09-01\>\"", ",", " ", "\"\<2023-11-01\>\""}], "]"}]}], 
  ";"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"change", " ", "=", " ", 
    RowBox[{"GEESubtract", "[", 
     RowBox[{"fall", ",", " ", "spring"}], "]"}]}], ";"}], "\n", 
  RowBox[{"(*", " ", 
   RowBox[{
    RowBox[{"Negative", " ", "=", " ", 
     RowBox[{"vegetation", " ", "loss", " ", 
      RowBox[{"(", "brown", ")"}]}]}], ",", " ", 
    RowBox[{"Positive", " ", "=", " ", 
     RowBox[{"growth", " ", 
      RowBox[{"(", "green", ")"}]}]}]}], " ", "*)"}]}], "\n", 
 RowBox[{"GEEComputePixels", "[", 
  RowBox[{"bbox", ",", " ", "change", ",", "\n", "  ", 
   RowBox[{"\"\<VisParams\>\"", " ", "->", " ", 
    RowBox[{"<|", 
     RowBox[{
      RowBox[{"\"\<min\>\"", " ", "->", " ", 
       RowBox[{"-", "0.3"}]}], ",", " ", 
      RowBox[{"\"\<max\>\"", " ", "->", " ", "0.3"}], ",", "\n", "    ", 
      RowBox[{"\"\<palette\>\"", " ", "->", " ", 
       RowBox[{"{", 
        RowBox[{"\"\<red\>\"", ",", " ", "\"\<white\>\"", ",", 
         " ", "\"\<green\>\""}], "}"}]}]}], "|>"}]}], ",", "\n", "  ", 
   RowBox[{"\"\<ImageSize\>\"", " ", "->", " ", 
    RowBox[{"{", 
     RowBox[{"1024", ",", " ", "1024"}], "}"}]}]}], "]"}]}], "Input",Expressio\
nUUID->"ce0a4583-65d4-4149-88fc-d4795459837c"]
}, Open  ]],

Cell[CellGroupData[{

Cell["SCL Cloud Masking with Comparison Operators", "Section",ExpressionUUID->"0962f31b-ca6d-5148-8772-a8d215953d2c"],

Cell[TextData[{
 "Build a cloud mask from the Sentinel-2 Scene Classification Layer using \
comparison and logical operators, then apply with ",
 Cell["GEEUpdateMask", "InlineCode",ExpressionUUID->
  "ea8402a2-b6ff-6946-b9d5-0d3a432a7770"],
 ":"
}], "Text",ExpressionUUID->"b712639d-0ced-ad4d-b303-d0132166db52"],

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"bbox", " ", "=", " ", 
    RowBox[{"{", 
     RowBox[{"12.4", ",", " ", "41.8", ",", " ", "12.6", ",", " ", "42.0"}], 
     "}"}]}], ";"}], "  ", 
  RowBox[{"(*", " ", "Rome", " ", "*)"}]}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"pipeline", " ", "=", " ", 
    RowBox[{
     RowBox[{
      RowBox[{
       RowBox[{
        RowBox[{
         RowBox[{
         "GEECollection", "[", "\"\<COPERNICUS/S2_SR_HARMONIZED\>\"", "]"}], 
         " ", "//", "\n", "  ", 
         RowBox[{"GEEFilterDate", "[", 
          RowBox[{"\"\<2023-04-01\>\"", ",", " ", "\"\<2023-10-01\>\""}], 
          "]"}]}], " ", "//", "\n", "  ", 
        RowBox[{"GEEFilterBounds", "[", "bbox", "]"}]}], " ", "//", "\n", 
       "  ", 
       RowBox[{"GEEFilterProperty", "[", 
        RowBox[{"\"\<CLOUDY_PIXEL_PERCENTAGE\>\"", ",", 
         " ", "\"\<LessThan\>\"", ",", " ", "30"}], "]"}]}], " ", "//", "\n", 
      "  ", 
      RowBox[{"GEESelectBands", "[", 
       RowBox[{"{", 
        RowBox[{"\"\<B4\>\"", ",", " ", "\"\<B3\>\"", ",", " ", "\"\<B2\>\"", 
         ",", " ", "\"\<SCL\>\""}], "}"}], "]"}]}], " ", "//", "\n", "  ", 
     "GEEMedian"}]}], ";"}], "\n", 
  RowBox[{"(*", " ", 
   RowBox[{
    RowBox[{
     RowBox[{"SCL", " ", 
      RowBox[{"values", ":", " ", "3"}]}], "=", 
     RowBox[{"cloud", " ", "shadow"}]}], ",", " ", 
    RowBox[{"8", "=", 
     RowBox[{"cloud", " ", "medium", " ", "prob"}]}], ",", " ", 
    RowBox[{"9", "=", 
     RowBox[{"cloud", " ", "high", " ", "prob"}]}]}], " ", "*)"}]}], "\n", 
 RowBox[{
  RowBox[{"scl", " ", "=", " ", 
   RowBox[{"pipeline", " ", "//", " ", 
    RowBox[{"GEESelectBands", "[", 
     RowBox[{"{", "\"\<SCL_median\>\"", "}"}], "]"}]}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{"mask", " ", "=", " ", 
   RowBox[{
    RowBox[{
     RowBox[{"scl", " ", "//", " ", 
      RowBox[{"GEENotEquals", "[", "3", "]"}]}], " ", "//", "\n", "  ", 
     RowBox[{"GEEAnd", "[", 
      RowBox[{"scl", " ", "//", " ", 
       RowBox[{"GEENotEquals", "[", "8", "]"}]}], "]"}]}], " ", "//", "\n", 
    "  ", 
    RowBox[{"GEEAnd", "[", 
     RowBox[{"scl", " ", "//", " ", 
      RowBox[{"GEENotEquals", "[", "9", "]"}]}], "]"}]}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{"cleanRGB", " ", "=", " ", 
   RowBox[{
    RowBox[{"pipeline", " ", "//", "\n", "  ", 
     RowBox[{"GEESelectBands", "[", 
      RowBox[{"{", 
       RowBox[{"\"\<B4_median\>\"", ",", " ", "\"\<B3_median\>\"", ",", 
        " ", "\"\<B2_median\>\""}], "}"}], "]"}]}], " ", "//", "\n", "  ", 
    RowBox[{"GEEUpdateMask", "[", "mask", "]"}]}]}], ";"}], "\n", 
 RowBox[{"GEEComputePixels", "[", 
  RowBox[{"bbox", ",", " ", "cleanRGB", ",", "\n", "  ", 
   RowBox[{"\"\<VisParams\>\"", " ", "->", " ", 
    RowBox[{"<|", 
     RowBox[{
      RowBox[{"\"\<min\>\"", " ", "->", " ", "0"}], ",", " ", 
      RowBox[{"\"\<max\>\"", " ", "->", " ", "3000"}]}], "|>"}]}]}], 
  "]"}]}], "Input",ExpressionUUID->"9db99b6c-1052-0c4b-8741-45877371f164"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Urban Heat Island with GEEWhere", "Section",ExpressionUUID->"cd04f4e4-72ac-fc42-a98b-8ff893d5111f"],

Cell[TextData[{
 "Classify land surface temperature into hot and cool zones using ",
 Cell["GEEWhere", "InlineCode",ExpressionUUID->
  "8edf632b-bc79-f34c-b455-7b18a62ab88a"],
 " and ",
 Cell["GEEGreaterThan", "InlineCode",ExpressionUUID->
  "8e9e3bcc-04fc-3849-a067-a3324674a260"],
 ":"
}], "Text",ExpressionUUID->"04524f87-9e95-cc4c-bc8d-b1f473a42e80"],

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"bbox", " ", "=", " ", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{"-", "74.1"}], ",", " ", "40.6", ",", " ", 
      RowBox[{"-", "73.8"}], ",", " ", "40.85"}], "}"}]}], ";"}], "  ", 
  RowBox[{"(*", " ", 
   RowBox[{"New", " ", "York", " ", "City"}], " ", "*)"}]}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"lst", " ", "=", " ", 
    RowBox[{
     RowBox[{
      RowBox[{
       RowBox[{
        RowBox[{
         RowBox[{"GEECollection", "[", "\"\<MODIS/061/MOD11A2\>\"", "]"}], 
         " ", "//", "\n", "  ", 
         RowBox[{"GEEFilterDate", "[", 
          RowBox[{"\"\<2023-07-01\>\"", ",", " ", "\"\<2023-08-01\>\""}], 
          "]"}]}], " ", "//", "\n", "  ", 
        RowBox[{"GEEFilterBounds", "[", "bbox", "]"}]}], " ", "//", "\n", 
       "  ", 
       RowBox[{"GEESelectBands", "[", 
        RowBox[{"{", "\"\<LST_Day_1km\>\"", "}"}], "]"}]}], " ", "//", "\n", 
      "  ", "GEEMedian"}], " ", "//", "\n", "  ", 
     RowBox[{"GEEMultiply", "[", "0.02", "]"}]}]}], ";"}], "\n", 
  RowBox[{"(*", " ", 
   RowBox[{
    RowBox[{"Highlight", " ", "hot", " ", 
     RowBox[{"zones", ":", " ", 
      RowBox[{
      "replace", " ", "pixels", " ", "above", " ", "310", " ", "K", " ", 
       "with", " ", "red", " ", 
       RowBox[{"(", 
        RowBox[{"high", " ", "value"}], ")"}]}]}]}], ",", "\n", "   ", 
    RowBox[{"keep", " ", "others", " ", "unchanged"}]}], " ", "*)"}]}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"hotMask", " ", "=", " ", 
    RowBox[{"lst", " ", "//", " ", 
     RowBox[{"GEEGreaterThan", "[", "310", "]"}]}]}], ";"}], "\n", 
  RowBox[{"(*", " ", 
   RowBox[{"Visualize", ":", " ", 
    RowBox[{"hot", " ", "spots", " ", "stand", " ", "out"}]}], " ", 
   "*)"}]}], "\n", 
 RowBox[{"GEEComputePixels", "[", 
  RowBox[{"bbox", ",", " ", "lst", ",", "\n", "  ", 
   RowBox[{"\"\<VisParams\>\"", " ", "->", " ", 
    RowBox[{"<|", 
     RowBox[{
      RowBox[{"\"\<min\>\"", " ", "->", " ", "295"}], ",", " ", 
      RowBox[{"\"\<max\>\"", " ", "->", " ", "320"}], ",", "\n", "    ", 
      RowBox[{"\"\<palette\>\"", " ", "->", " ", 
       RowBox[{"{", 
        RowBox[{"\"\<blue\>\"", ",", " ", "\"\<cyan\>\"", ",", 
         " ", "\"\<yellow\>\"", ",", " ", "\"\<red\>\""}], "}"}]}]}], 
     "|>"}]}]}], "]"}]}], "Input",ExpressionUUID->"a5d1cb85-fe37-e341-a989-\
3090fca73f71"]
}, Open  ]],

Cell[CellGroupData[{

Cell["NDVI Variability with GEEReduceStdDev", "Section",ExpressionUUID->"0558ae84-bc95-eb42-b515-4bca28166b88"],

Cell["\<\
Map the standard deviation of NDVI across a growing season to identify areas \
with unstable vegetation (drought stress, harvest cycles):\
\>", "Text",ExpressionUUID->"f39b8a3b-18eb-1a4f-be72-a77c7d2dc5cb"],

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"bbox", " ", "=", " ", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{"-", "100.0"}], ",", " ", "40.0", ",", " ", 
      RowBox[{"-", "99.0"}], ",", " ", "41.0"}], "}"}]}], ";"}], "  ", 
  RowBox[{"(*", " ", 
   RowBox[{"Nebraska", " ", "farmland"}], " ", "*)"}]}], "\n", 
 RowBox[{
  RowBox[{"ndviColl", " ", "=", " ", 
   RowBox[{
    RowBox[{
     RowBox[{
      RowBox[{
       RowBox[{
        RowBox[{
        "GEECollection", "[", "\"\<COPERNICUS/S2_SR_HARMONIZED\>\"", "]"}], 
        " ", "//", "\n", "  ", 
        RowBox[{"GEEFilterDate", "[", 
         RowBox[{"\"\<2023-04-01\>\"", ",", " ", "\"\<2023-10-01\>\""}], 
         "]"}]}], " ", "//", "\n", "  ", 
       RowBox[{"GEEFilterBounds", "[", "bbox", "]"}]}], " ", "//", "\n", "  ", 
      RowBox[{"GEEFilterProperty", "[", 
       RowBox[{"\"\<CLOUDY_PIXEL_PERCENTAGE\>\"", ",", " ", "\"\<LessThan\>\"",
         ",", " ", "15"}], "]"}]}], " ", "//", "\n", "  ", 
     RowBox[{"GEESelectBands", "[", 
      RowBox[{"{", 
       RowBox[{"\"\<B8\>\"", ",", " ", "\"\<B4\>\""}], "}"}], "]"}]}], " ", "//",
     "\n", "  ", 
    RowBox[{"GEECollectionMap", "[", "\n", "    ", 
     RowBox[{"Function", "[", 
      RowBox[{"img", ",", " ", 
       RowBox[{"GEENormalizedDifference", "[", 
        RowBox[{"img", ",", " ", 
         RowBox[{"{", 
          RowBox[{"\"\<B8\>\"", ",", " ", "\"\<B4\>\""}], "}"}]}], "]"}]}], 
      "]"}], "]"}]}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{"stddev", " ", "=", " ", 
   RowBox[{"ndviColl", " ", "//", " ", "GEEReduceStdDev"}]}], ";"}], "\n", 
 RowBox[{"GEEComputePixels", "[", 
  RowBox[{"bbox", ",", " ", "stddev", ",", "\n", "  ", 
   RowBox[{"\"\<VisParams\>\"", " ", "->", " ", 
    RowBox[{"<|", 
     RowBox[{
      RowBox[{"\"\<min\>\"", " ", "->", " ", "0"}], ",", " ", 
      RowBox[{"\"\<max\>\"", " ", "->", " ", "0.2"}], ",", "\n", "    ", 
      RowBox[{"\"\<palette\>\"", " ", "->", " ", 
       RowBox[{"{", 
        RowBox[{"\"\<green\>\"", ",", " ", "\"\<yellow\>\"", ",", 
         " ", "\"\<red\>\""}], "}"}]}]}], "|>"}]}], ",", "\n", "  ", 
   RowBox[{"\"\<ImageSize\>\"", " ", "->", " ", 
    RowBox[{"{", 
     RowBox[{"1024", ",", " ", "1024"}], "}"}]}]}], "]"}], "\n", 
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{
    RowBox[{"Green", " ", "=", " ", 
     RowBox[{"stable", " ", "vegetation"}]}], ",", " ", 
    RowBox[{"Red", " ", "=", " ", 
     RowBox[{"high", " ", "variability", " ", 
      RowBox[{"(", 
       RowBox[{
        RowBox[{"e", ".", "g", "."}], ",", " ", 
        RowBox[{"crop", " ", "harvest"}]}], ")"}]}]}]}], " ", 
   "*)"}]}]}], "Input",ExpressionUUID->"cc1bf829-8ba0-5b44-a342-c637873e0e48"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Data Coverage Assessment with GEEReduceCount", "Section",ExpressionUUID->"f7765cb0-41a5-c54a-8b8d-c9a73fb0e7a8"],

Cell["\<\
Count how many cloud-free Sentinel-2 observations exist per pixel over a \
region to assess data availability:\
\>", "Text",ExpressionUUID->"89c25e6c-5d45-9340-84c1-38c96ccc17a2"],

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"bbox", " ", "=", " ", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{"-", "5.0"}], ",", " ", "35.5", ",", " ", 
      RowBox[{"-", "3.5"}], ",", " ", "37.0"}], "}"}]}], ";"}], "  ", 
  RowBox[{"(*", " ", 
   RowBox[{"Southern", " ", "Spain"}], " ", "*)"}]}], "\n", 
 RowBox[{
  RowBox[{"coverage", " ", "=", " ", 
   RowBox[{
    RowBox[{
     RowBox[{
      RowBox[{
       RowBox[{
        RowBox[{
        "GEECollection", "[", "\"\<COPERNICUS/S2_SR_HARMONIZED\>\"", "]"}], 
        " ", "//", "\n", "  ", 
        RowBox[{"GEEFilterDate", "[", 
         RowBox[{"\"\<2023-01-01\>\"", ",", " ", "\"\<2024-01-01\>\""}], 
         "]"}]}], " ", "//", "\n", "  ", 
       RowBox[{"GEEFilterBounds", "[", "bbox", "]"}]}], " ", "//", "\n", "  ", 
      RowBox[{"GEEFilterProperty", "[", 
       RowBox[{"\"\<CLOUDY_PIXEL_PERCENTAGE\>\"", ",", " ", "\"\<LessThan\>\"",
         ",", " ", "20"}], "]"}]}], " ", "//", "\n", "  ", 
     RowBox[{"GEESelectBands", "[", 
      RowBox[{"{", "\"\<B4\>\"", "}"}], "]"}]}], " ", "//", "\n", "  ", 
    "GEEReduceCount"}]}], ";"}], "\n", 
 RowBox[{"GEEComputePixels", "[", 
  RowBox[{"bbox", ",", " ", "coverage", ",", "\n", "  ", 
   RowBox[{"\"\<VisParams\>\"", " ", "->", " ", 
    RowBox[{"<|", 
     RowBox[{
      RowBox[{"\"\<min\>\"", " ", "->", " ", "0"}], ",", " ", 
      RowBox[{"\"\<max\>\"", " ", "->", " ", "60"}], ",", "\n", "    ", 
      RowBox[{"\"\<palette\>\"", " ", "->", " ", 
       RowBox[{"{", 
        RowBox[{"\"\<red\>\"", ",", " ", "\"\<yellow\>\"", ",", 
         " ", "\"\<green\>\""}], "}"}]}]}], "|>"}]}]}], "]"}], "\n", 
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{
    RowBox[{"Red", " ", "=", " ", 
     RowBox[{"few", " ", "observations"}]}], ",", " ", 
    RowBox[{"Green", " ", "=", " ", "many"}], " ", "\[LongDash]", " ", 
    RowBox[{"helps", " ", "plan", " ", "analysis", " ", "windows"}]}], " ", 
   "*)"}]}]}], "Input",ExpressionUUID->"e5ca0d86-b8e7-e94b-ab21-3c4648a4baf5"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Percentile Compositing for Robust Baselines", "Section",ExpressionUUID->"d30d6f4c-ef19-fb4c-958c-417582a63137"],

Cell["\<\
Use the 10th and 90th percentiles to create robust min/max baselines that are \
less sensitive to outliers than CollectionMin/CollectionMax:\
\>", "Text",ExpressionUUID->"37bfe231-d2d6-7e45-b374-fcd64171c2ea"],

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"bbox", " ", "=", " ", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{"-", "122.5"}], ",", " ", "37.7", ",", " ", 
      RowBox[{"-", "122.3"}], ",", " ", "37.85"}], "}"}]}], ";"}], "  ", 
  RowBox[{"(*", " ", 
   RowBox[{"San", " ", "Francisco"}], " ", "*)"}]}], "\n", 
 RowBox[{
  RowBox[{"coll", " ", "=", " ", 
   RowBox[{
    RowBox[{
     RowBox[{
      RowBox[{
       RowBox[{
        RowBox[{
        "GEECollection", "[", "\"\<COPERNICUS/S2_SR_HARMONIZED\>\"", "]"}], 
        " ", "//", "\n", "  ", 
        RowBox[{"GEEFilterDate", "[", 
         RowBox[{"\"\<2023-01-01\>\"", ",", " ", "\"\<2024-01-01\>\""}], 
         "]"}]}], " ", "//", "\n", "  ", 
       RowBox[{"GEEFilterBounds", "[", "bbox", "]"}]}], " ", "//", "\n", "  ", 
      RowBox[{"GEEFilterProperty", "[", 
       RowBox[{"\"\<CLOUDY_PIXEL_PERCENTAGE\>\"", ",", " ", "\"\<LessThan\>\"",
         ",", " ", "10"}], "]"}]}], " ", "//", "\n", "  ", 
     RowBox[{"GEESelectBands", "[", 
      RowBox[{"{", 
       RowBox[{"\"\<B8\>\"", ",", " ", "\"\<B4\>\""}], "}"}], "]"}]}], " ", "//",
     "\n", "  ", 
    RowBox[{"GEECollectionMap", "[", "\n", "    ", 
     RowBox[{"Function", "[", 
      RowBox[{"img", ",", " ", 
       RowBox[{"GEENormalizedDifference", "[", 
        RowBox[{"img", ",", " ", 
         RowBox[{"{", 
          RowBox[{"\"\<B8\>\"", ",", " ", "\"\<B4\>\""}], "}"}]}], "]"}]}], 
      "]"}], "]"}]}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"pctls", " ", "=", " ", 
    RowBox[{"coll", " ", "//", " ", 
     RowBox[{"GEEReducePercentile", "[", 
      RowBox[{"{", 
       RowBox[{"10", ",", " ", "90"}], "}"}], "]"}]}]}], ";"}], "\n", 
  RowBox[{"(*", " ", 
   RowBox[{
    RowBox[{"Returns", " ", "bands", " ", "like", " ", "nd_p10"}], ",", " ", 
    "nd_p90", " ", "\[LongDash]", " ", 
    RowBox[{
    "the", " ", "range", " ", "shows", " ", "seasonal", " ", "dynamics"}]}], 
   " ", "*)"}]}], "\n", 
 RowBox[{"GEEComputePixels", "[", 
  RowBox[{"bbox", ",", " ", 
   RowBox[{"pctls", " ", "//", " ", 
    RowBox[{"GEESelectBands", "[", 
     RowBox[{"{", "\"\<nd_p90\>\"", "}"}], "]"}]}], ",", "\n", "  ", 
   RowBox[{"\"\<VisParams\>\"", " ", "->", " ", 
    RowBox[{"<|", 
     RowBox[{
      RowBox[{"\"\<min\>\"", " ", "->", " ", "0"}], ",", " ", 
      RowBox[{"\"\<max\>\"", " ", "->", " ", "0.8"}], ",", "\n", "    ", 
      RowBox[{"\"\<palette\>\"", " ", "->", " ", 
       RowBox[{"{", 
        RowBox[{"\"\<brown\>\"", ",", " ", "\"\<yellow\>\"", ",", 
         " ", "\"\<green\>\"", ",", " ", "\"\<darkgreen\>\""}], "}"}]}]}], 
     "|>"}]}]}], "]"}]}], "Input",ExpressionUUID->"3f0bf0cf-0e49-1c42-b3c4-\
f4a47ca9d710"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Merging Two Satellite Collections", "Section",ExpressionUUID->"f71b6474-73e0-c140-a8d3-5b5a3c11129d"],

Cell["\<\
Merge Sentinel-2A and 2B orbit collections filtered to different months for a \
wider temporal baseline:\
