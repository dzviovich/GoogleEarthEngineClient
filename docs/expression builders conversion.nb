 " according to the ",
 Cell["condition", "InlineCode",ExpressionUUID->
  "515fa909-6372-d34a-bcb3-aeb123c4a46f"],
 "."
}], "Text",ExpressionUUID->"39f07fce-11df-e84f-8127-e0dcc890258a"]
}, Open  ]],

