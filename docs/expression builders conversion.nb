Cell[CellGroupData[{

Cell["Complete Examples", "Chapter",ExpressionUUID->"838b9b68-0833-874a-b9ea-d0e8cceab109"],

Cell[CellGroupData[{

Cell["Sentinel-2 True Color RGB (Cloud-Filtered Median)", "Section",ExpressionUUID->"01b64b04-b85a-784a-aba7-cbbe0093ad31"],

Cell["\<\
The most common use case: fetch a clean, cloud-free satellite image by \
filtering a Sentinel-2 collection by date, location, and cloud cover, then \
taking the per-pixel median.\
\>", "Text",ExpressionUUID->"14eceb2e-0f00-4441-afa4-41904ba40025"],

Cell[BoxData[
 RowBox[{"GEEComputePixels", "[", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{
     RowBox[{"-", "3.8"}], ",", " ", "40.3", ",", " ", 
     RowBox[{"-", "3.6"}], ",", " ", "40.5"}], "}"}], ",", "\n", "  ", 
   RowBox[{
    RowBox[{
     RowBox[{
      RowBox[{
       RowBox[{
        RowBox[{
        "GEECollection", "[", "\"\<COPERNICUS/S2_SR_HARMONIZED\>\"", "]"}], 
        " ", "//", "\n", "    ", 
        RowBox[{"GEEFilterDate", "[", 
         RowBox[{"\"\<2023-01-01\>\"", ",", " ", "\"\<2024-01-01\>\""}], 
         "]"}]}], " ", "//", "\n", "    ", 
       RowBox[{"GEEFilterBounds", "[", 
        RowBox[{"{", 
         RowBox[{
          RowBox[{"-", "3.8"}], ",", " ", "40.3", ",", " ", 
          RowBox[{"-", "3.6"}], ",", " ", "40.5"}], "}"}], "]"}]}], " ", "//",
       "\n", "    ", 
      RowBox[{"GEEFilterProperty", "[", 
       RowBox[{"\"\<CLOUDY_PIXEL_PERCENTAGE\>\"", ",", " ", "\"\<LessThan\>\"",
         ",", " ", "20"}], "]"}]}], " ", "//", "\n", "    ", 
     RowBox[{"GEESelectBands", "[", 
      RowBox[{"{", 
       RowBox[{"\"\<B4\>\"", ",", " ", "\"\<B3\>\"", ",", " ", "\"\<B2\>\""}],
        "}"}], "]"}]}], " ", "//", "\n", "    ", "GEEMedian"}], ",", "\n", 
   "  ", 
   RowBox[{"\"\<VisParams\>\"", " ", "->", " ", 
    RowBox[{"<|", 
     RowBox[{
      RowBox[{"\"\<min\>\"", " ", "->", " ", "0"}], ",", " ", 
      RowBox[{"\"\<max\>\"", " ", "->", " ", "3000"}]}], "|>"}]}]}], 
  "]"}]], "Input",ExpressionUUID->"6d18b385-aa4c-c848-8561-7f5b8f38165f"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Landsat 8 True Color with Cloud Filtering", "Section",ExpressionUUID->"d153b5ed-ffa6-5249-aca5-4ea91f61123b"],

Cell[BoxData[
 RowBox[{"GEEComputePixels", "[", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{
     RowBox[{"-", "122.5"}], ",", " ", "37.7", ",", " ", 
     RowBox[{"-", "122.3"}], ",", " ", "37.85"}], "}"}], ",", "\n", "  ", 
   RowBox[{
    RowBox[{
     RowBox[{
      RowBox[{
       RowBox[{
        RowBox[{"GEECollection", "[", "\"\<LANDSAT/LC08/C02/T1_L2\>\"", "]"}],
         " ", "//", "\n", "    ", 
        RowBox[{"GEEFilterDate", "[", 
         RowBox[{"\"\<2022-06-01\>\"", ",", " ", "\"\<2022-10-01\>\""}], 
         "]"}]}], " ", "//", "\n", "    ", 
       RowBox[{"GEEFilterBounds", "[", 
        RowBox[{"{", 
         RowBox[{
          RowBox[{"-", "122.5"}], ",", " ", "37.7", ",", " ", 
          RowBox[{"-", "122.3"}], ",", " ", "37.85"}], "}"}], "]"}]}], " ", "//",
       "\n", "    ", 
      RowBox[{"GEEFilterProperty", "[", 
       RowBox[{"\"\<CLOUD_COVER\>\"", ",", " ", "\"\<LessThan\>\"", ",", " ", 
        "10"}], "]"}]}], " ", "//", "\n", "    ", 
     RowBox[{"GEESelectBands", "[", 
      RowBox[{"{", 
       RowBox[{"\"\<SR_B4\>\"", ",", " ", "\"\<SR_B3\>\"", ",", 
        " ", "\"\<SR_B2\>\""}], "}"}], "]"}]}], " ", "//", "\n", "    ", 
    "GEEMedian"}], ",", "\n", "  ", 
   RowBox[{"\"\<VisParams\>\"", " ", "->", " ", 
    RowBox[{"<|", 
     RowBox[{
      RowBox[{"\"\<min\>\"", " ", "->", " ", "7000"}], ",", " ", 
      RowBox[{"\"\<max\>\"", " ", "->", " ", "12000"}]}], "|>"}]}], ",", "\n",
    "  ", 
   RowBox[{"\"\<ImageSize\>\"", " ", "->", " ", 
    RowBox[{"{", 
