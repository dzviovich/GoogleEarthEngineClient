Cell[CellGroupData[{

Cell["Line Transect for Elevation Profile", "Section",ExpressionUUID->"1f5b404f-b6b2-5c4b-b5e2-70caf78f0dac"],

Cell["\<\
Create a line geometry for sampling elevation along a transect:\
\>", "Text",ExpressionUUID->"80a6c2b9-51a6-014e-8dc6-07a4da342641"],

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{
   "Transect", " ", "across", " ", "a", " ", "mountain", " ", "pass"}], " ", 
   "*)"}], "\n", 
  RowBox[{
   RowBox[{
    RowBox[{"transect", " ", "=", " ", 
     RowBox[{"GEELineString", "[", 
      RowBox[{"{", "\n", "  ", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{"6.85", ",", " ", "46.10"}], "}"}], ",", " ", 
        RowBox[{"{", 
         RowBox[{"7.05", ",", " ", "46.05"}], "}"}], ",", " ", 
        RowBox[{"{", 
         RowBox[{"7.20", ",", " ", "46.10"}], "}"}]}], "\n", "}"}], "]"}]}], 
    ";"}], "\n", 
   RowBox[{"(*", " ", 
    RowBox[{
    "Sample", " ", "elevation", " ", "every", " ", "100", "m", " ", "along", " ",
      "the", " ", "transect"}], " ", "*)"}], "\n", 
   RowBox[{
    RowBox[{"samples", " ", "=", " ", 
     RowBox[{
      RowBox[{"GEELoadImage", "[", "\"\<USGS/SRTMGL1_003\>\"", "]"}], " ", "//",
       "\n", "  ", 
      RowBox[{"GEESample", "[", 
       RowBox[{"transect", ",", " ", "100"}], "]"}]}]}], ";"}], "\n", 
   RowBox[{"GEECompute", "[", "samples", "]"}]}]}]], "Input",ExpressionUUID->\
"461a11b9-36ba-4b41-aef3-f826910c4a4f"]
}, Open  ]]
}, Open  ]],

Cell[CellGroupData[{

Cell["String vs. Expression: When to Use Each", "Chapter",ExpressionUUID->"d2752d82-32cf-9a4a-b421-ea0713b6ace6"],

Cell[BoxData[
 TemplateBox[<|
  "Summary" -> 
   TemplateBox[<|
     "RowCount" -> 2, "ColumnCount" -> 3, "ColumnTypes" -> 
      Grid[{{"Approach", "InertExpression"}, {"Syntax", "InertExpression"}, {
         "Best For", "String"}}, Alignment -> Left], "Backend" -> 
      "Tabular`Backend`WolframKernel", "UUID" -> 
      "Tabular-eda928c8-97a6-4574-a753-d596c7d749e6", "Form" -> StandardForm, 
      "Interpretable" -> True|>, "TabularSummary", 
     BaseStyle -> (DynamicUpdating -> True)], "Main" -> TableViewBox[
     Tabular[<|
      "RawSchema" -> <|
        "ColumnProperties" -> <|
          "Approach" -> <|"ElementType" -> "InertExpression"|>, 
           "Syntax" -> <|"ElementType" -> "InertExpression"|>, 
           "Best For" -> <|"ElementType" -> "String"|>|>, "KeyColumns" -> 
         None, "Backend" -> "WolframKernel"|>, "Options" -> {}, 
       "BackendData" -> <|"ColumnData" -> DataStructure["ColumnTable", {{
             TabularColumn[<|"Data" -> {{
                  Style["String asset ID", Bold], 
                  Style["Expression pipeline", Bold]}, {}, None}, 
               "ElementType" -> "InertExpression", "CachedOriginalExpression" -> {
                 Style["String asset ID", Bold], 
                 Style["Expression pipeline", Bold]}|>], 
             TabularColumn[<|"Data" -> {{
                  Style[
                  "GEEComputePixels[bbox, \"USGS/SRTMGL1_003\"]", "Code", 
                   "ShowStringCharacters" -> False], 
                  Style[
                  "GEEComputePixels[bbox, GEECollection[...] // ... // \
GEEMedian]", "Code", "ShowStringCharacters" -> False]}, {}, None}, 
               "ElementType" -> "InertExpression", "CachedOriginalExpression" -> {
                 Style[
                 "GEEComputePixels[bbox, \"USGS/SRTMGL1_003\"]", "Code", 
                  "ShowStringCharacters" -> False], 
                 Style[
                 "GEEComputePixels[bbox, GEECollection[...] // ... // \
GEEMedian]", "Code", "ShowStringCharacters" -> False]}|>], 
             
             TabularColumn[<|
              "Data" -> {{
                 3, {0, 141, 286}, 
                  "Quick retrieval with default filtering. The package \
auto-filters IMAGE_COLLECTION assets by bounds and the most recent 3 years, \
then mosaics.Full control over date range, cloud filtering, band selection, \
and aggregation method. Required for metadata-based filtering (e.g., cloud \
cover)."}, {}, None}, "ElementType" -> "String"|>]}}]|>|>], Expression, 
     AppearanceElements -> {"RowHeaders", "ColumnHeaders", "ResizeArea"}, 
     DefaultBaseStyle -> "TabularTableview", 
     TableViewBoxAlignment -> <|
      "ColumnsIndexed" -> {1 -> Left, 2 -> Left, 3 -> Left}|>, 
     "TableViewBoxFieldType" -> <|
      "ColumnsIndexed" -> {1 -> Expression, 2 -> Expression, 3 -> String}|>, 
     "TableViewBoxItemDisplayRules" -> <|
      "Columns" -> {{{Blank[Missing] -> (MakeBoxes[#, TraditionalForm]& )}}}, 
       "ColumnsIndexed" -> {
        1 -> {Blank[] -> 
           Function[{
             Tabular`Typesetting`TableView`Private`val$, 
              Tabular`Typesetting`TableView`Private`pos$}, 
             
             Function[{
              Tabular`Typesetting`TableView`Private`val, 
               Tabular`Typesetting`TableView`Private`pos}, 
              MakeBoxes[Tabular`Typesetting`TableView`Private`val]][
              RawBoxes[
               (Tabular`Typesetting`ToBoxesWithMinimalSummary[#]& )[
               Tabular`Typesetting`TableView`Private`val$, 
                Tabular`Typesetting`TableView`Private`pos$]], 
              Tabular`Typesetting`TableView`Private`pos$]], Blank[] :> 
           Function[{
             Tabular`Typesetting`TableView`Private`val, 
              Tabular`Typesetting`TableView`Private`pos}, 
             MakeBoxes[Tabular`Typesetting`TableView`Private`val]]}, 
         2 -> {Blank[] -> 
           Function[{
             Tabular`Typesetting`TableView`Private`val$, 
              Tabular`Typesetting`TableView`Private`pos$}, 
             
             Function[{
              Tabular`Typesetting`TableView`Private`val, 
               Tabular`Typesetting`TableView`Private`pos}, 
              MakeBoxes[Tabular`Typesetting`TableView`Private`val]][
              RawBoxes[
               (Tabular`Typesetting`ToBoxesWithMinimalSummary[#]& )[
               Tabular`Typesetting`TableView`Private`val$, 
                Tabular`Typesetting`TableView`Private`pos$]], 
              Tabular`Typesetting`TableView`Private`pos$]], Blank[] :> 
           Function[{
             Tabular`Typesetting`TableView`Private`val, 
              Tabular`Typesetting`TableView`Private`pos}, 
             MakeBoxes[Tabular`Typesetting`TableView`Private`val]]}, 
         3 -> {Blank[] :> 
           Function[{
             Tabular`Typesetting`TableView`Private`val, 
