Cell["Per-pixel equality comparison.", "Text",ExpressionUUID->"3e1bbeb7-ab0d-f64e-bf4f-ec6d65951f3b"],

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{"Pixels", " ", "classified", " ", "as", " ", "water", " ", 
