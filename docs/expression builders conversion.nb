Cell[CellGroupData[{

Cell["Bilinear Resampling for Smooth Visualization", "Section",ExpressionUUID->"51abc676-1535-e94f-bd94-30febb915633"],

Cell["\<\
Apply bilinear resampling to a coarse MODIS product for smoother rendering:\
\>", "Text",ExpressionUUID->"39934b59-bd37-0d40-9d8a-02ffd88e1d60"],

Cell[BoxData[{
 RowBox[{
  RowBox[{
