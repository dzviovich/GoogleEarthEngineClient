 RowBox[{"GEESelfMask", "[", "image", "]"}]], "Input",ExpressionUUID->"7500e4cb-e3fb-ad4d-84df-b23af626a6a0"],

Cell["\<\
Mask pixels where the value is 0 or already masked. Useful after a comparison \
operation to remove false pixels from a binary mask.\
\>", "Text",ExpressionUUID->"c8c3fb17-17c0-ee46-bf90-9d571eb4dedf"],

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{
    RowBox[{"Keep", " ", "only", " ", "pixels", " ", "where", " ", "NDVI"}], 
    " ", ">", " ", "0.3"}], " ", "*)"}], "\n", 
  RowBox[{"vegetated", " ", "=", " ", 
   RowBox[{"ndviThreshold", " ", "//", " ", "GEESelfMask"}]}]}]], "Input",Expr\
essionUUID->"f0e6a663-2949-4143-b55b-a4c4ed65e168"]
}, Open  ]]
}, Open  ]],

