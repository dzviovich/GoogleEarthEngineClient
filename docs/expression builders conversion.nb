 Cell["scale", "InlineCode",ExpressionUUID->
  "568ba548-8dfa-f045-839d-0f3cfe5dd527"],
 " is the pixel resolution in meters."
}], "Text",ExpressionUUID->"2d60cb7a-499a-7243-91d4-c1034e795365"],

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{
   "Compute", " ", "mean", " ", "elevation", " ", "across", " ", "all", " ", 
    "US", " ", "states"}], " ", "*)"}], "\n", 
  RowBox[{
   RowBox[{
    RowBox[{"states", " ", "=", " ", 
     RowBox[{
     "GEEFeatureCollection", "[", "\"\<TIGER/2018/States\>\"", "]"}]}], ";"}],
    "\n", 
   RowBox[{"result", " ", "=", " ", 
    RowBox[{
     RowBox[{"GEELoadImage", "[", "\"\<USGS/SRTMGL1_003\>\"", "]"}], " ", "//",
      "\n", "  ", 
     RowBox[{"GEEReduceRegions", "[", 
      RowBox[{"states", ",", " ", "\"\<mean\>\"", ",", " ", "1000"}], 
      "]"}]}]}]}]}]], "Input",ExpressionUUID->"f1343a6a-c6be-8a40-8f73-\
ef0cf2db7185"]
}, Open  ]],

