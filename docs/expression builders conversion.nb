   "*)"}], "\n", 
  RowBox[{"clipped", " ", "=", " ", 
   RowBox[{"img", " ", "//", " ", 
    RowBox[{"GEEClip", "[", 
     RowBox[{"GEEGeometry", "[", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"-", "105.3"}], ",", " ", "39.6", ",", " ", 
        RowBox[{"-", "105.1"}], ",", " ", "39.8"}], "}"}], "]"}], 
     "]"}]}]}]}]], "Input",ExpressionUUID->"106f48ec-e3eb-c744-8f44-\
5a60b06852d3"]
}, Open  ]]
}, Open  ]],

Cell[CellGroupData[{

Cell["Band Manipulation", "Section",ExpressionUUID->"5888bfd4-dc0c-7d49-a6ff-512f26d1b5b0"],

Cell[CellGroupData[{

Cell["GEEAddBands", "Subsection",ExpressionUUID->"74936df3-11f5-b74c-a3ed-3f8f3198b800"],

Cell[BoxData[{
 RowBox[{"GEEAddBands", "[", 
  RowBox[{"image", ",", " ", "other"}], "]"}], "\n", 
 RowBox[{
  RowBox[{"GEEAddBands", "[", "other", "]"}], "                         ", 
  RowBox[{"(*", " ", 
   RowBox[{"operator", " ", "form"}], " ", "*)"}]}]}], "Input",ExpressionUUID->\
"9fc5ec8c-18b9-2945-81bd-772fedaa78ab"],

Cell[TextData[{
 "Add all bands from ",
 Cell["other", "InlineCode",ExpressionUUID->
  "98c2795e-ed18-9a4a-9898-6b90f2d819bd"],
 " to ",
 Cell["image", "InlineCode",ExpressionUUID->
  "08065a37-0d24-5c4a-a02a-8fead817bec5"],
 ". The result has all bands from both images. Use this to composite derived \
bands (like NDVI) back onto the original image."
}], "Text",ExpressionUUID->"fe5b6d34-8253-f24a-b9c4-0b13056a7db6"],

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{
   "Add", " ", "an", " ", "NDVI", " ", "band", " ", "to", " ", "the", " ", 
    "original", " ", "image"}], " ", "*)"}], "\n", 
  RowBox[{"withNDVI", " ", "=", " ", 
   RowBox[{"originalImage", " ", "//", " ", 
    RowBox[{"GEEAddBands", "[", "ndviBand", "]"}]}]}]}]], "Input",ExpressionUU\
ID->"a57d19a0-8360-f24f-ae54-88645b52fffe"]
}, Open  ]],

Cell[CellGroupData[{

Cell["GEERename", "Subsection",ExpressionUUID->"84912100-440f-c040-9088-72b646cb104d"],

