Notebook[{

Cell[CellGroupData[{
Cell["GEE Expression Builders", "Title",ExpressionUUID->"5eb9a6cc-d31a-2d45-a093-a8b9c75c7891"],

Cell[TextData[{
 "Build composable GEE processing pipelines using Wolfram Language's ",
 Cell["//", "InlineCode",ExpressionUUID->
  "eb3f0165-506a-2f46-b295-ab6b755a1c79"],
 " (postfix) operator."
}], "Text",ExpressionUUID->"d2c5ebad-b27e-1b42-a5c8-2363b810d689"],

Cell[CellGroupData[{

Cell["Overview", "Chapter",ExpressionUUID->"6a308b66-1277-0242-8b78-3635c93c414b"],

Cell[TextData[{
 "When you pass a plain asset ID string (e.g., ",
 Cell["\"USGS/SRTMGL1_003\"", "InlineCode",ExpressionUUID->
  "219060c9-8b56-0e4e-8e62-650a4d25bbc5"],
 ") to functions like ",
 Cell["GEEComputePixels", "InlineCode",ExpressionUUID->
  "73647253-6d99-6a4c-97d4-d18602dd64ed"],
 ", the package automatically handles loading, filtering, and mosaicking \
behind the scenes. Expression builders give you ",
 StyleBox["full control",
  FontWeight->Bold],
 " over the processing pipeline: which date range to use, how to filter by \
metadata, which bands to select, and how to aggregate."
}], "Text",ExpressionUUID->"537859a9-e07e-f040-a1f0-9bbc91a12a61"],

Cell[TextData[{
 "Every expression builder returns an Association representing a GEE \
expression tree. This Association can be passed directly to ",
 Cell["GEEComputePixels", "InlineCode",ExpressionUUID->
  "8d4641a8-c24f-a747-bf15-e7624678b070"],
 ", ",
 Cell["GEEImage", "InlineCode",ExpressionUUID->
  "8d07a1b6-c01b-214a-9c03-7b3b20600a5f"],
 ", ",
 Cell["GEEGetTile", "InlineCode",ExpressionUUID->
  "f195c82c-1a0e-7446-993d-7671adc307bb"],
 ", ",
 Cell["GEEIdentify", "InlineCode",ExpressionUUID->
  "08b8deef-2b06-b44b-aad2-2b297cd7222b"],
 ", ",
 Cell["GEEGetSamples", "InlineCode",ExpressionUUID->
  "fc7bd847-454d-e249-8a08-6606b40eb380"],
 ", ",
 Cell["GEEComputeFeatures", "InlineCode",ExpressionUUID->
  "a9e5c1e5-8bde-a74a-907a-99178718cd38"],
 ", ",
 Cell["GEECompute", "InlineCode",ExpressionUUID->
  "98a52667-17ec-c941-bd8e-c23bf0d25b25"],
 ", and ",
 Cell["GEEGeoGraphics", "InlineCode",ExpressionUUID->
  "d268120a-20ba-b546-99ad-b1c3ee1dce03"],
 " in place of an asset ID string."
}], "Text",ExpressionUUID->"04a165e9-b217-c348-b52e-d0bc29e8ba90"]
}, Open  ]],

Cell[CellGroupData[{

Cell[TextData[{
 "The Pipe Operator (",
 Cell[BoxData[
 Cell["//", "InlineCode",ExpressionUUID->
   "0d067dff-59b1-af4f-a970-c4bcbe7270d2"]],ExpressionUUID->
  "a733459a-f861-9446-bcf1-2258c4503408"],
 ")"
}], "Chapter",ExpressionUUID->"cd963167-b832-2949-9914-540b29023687"],

Cell[TextData[{
 "Most expression builders support an ",
 StyleBox["operator form",
  FontWeight->Bold],
 " (curried form) that lets you chain operations with ",
 Cell["//", "InlineCode",ExpressionUUID->
  "9b79ad51-2dd3-694c-b2dc-77f794aeead8"],
 ":"
}], "Text",ExpressionUUID->"2a5efb7b-c350-f441-af70-99af815d0af2"],

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{"Operator", " ", 
    RowBox[{"form", ":", " ", 
     RowBox[{
     "returns", " ", "a", " ", "function", " ", "that", " ", "takes", " ", 
      "a", " ", "collection"}]}]}], " ", "*)"}], "\n", 
  RowBox[{
   RowBox[{"GEEFilterDate", "[", 
    RowBox[{"\"\<2023-01-01\>\"", ",", " ", "\"\<2024-01-01\>\""}], "]"}], 
   "\n", "\n", 
   RowBox[{"(*", " ", 
    RowBox[{"Direct", " ", 
     RowBox[{"form", ":", " ", 
      RowBox[{"takes", " ", "a", " ", "collection", " ", "explicitly"}]}]}], 
    " ", "*)"}], "\n", 
   RowBox[{"GEEFilterDate", "[", 
    RowBox[{
    "collection", ",", " ", "\"\<2023-01-01\>\"", ",", 
     " ", "\"\<2024-01-01\>\""}], "]"}]}]}]], "Input",ExpressionUUID->\
"166210cc-13e8-724f-a321-919b823e1970"],

Cell["\<\
Both forms produce the same result. The operator form enables clean pipeline \
syntax:\
\>", "Text",ExpressionUUID->"3afcb83f-34a0-7d4a-9929-23eff2c6906b"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{
    "GEECollection", "[", "\"\<COPERNICUS/S2_SR_HARMONIZED\>\"", "]"}], " ", "//",
     "\n", "  ", 
    RowBox[{"GEEFilterDate", "[", 
     RowBox[{"\"\<2023-01-01\>\"", ",", " ", "\"\<2024-01-01\>\""}], "]"}]}], 
   " ", "//", "\n", "  ", 
   RowBox[{"GEEFilterBounds", "[", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{"-", "3.8"}], ",", " ", "40.3", ",", " ", 
      RowBox[{"-", "3.6"}], ",", " ", "40.5"}], "}"}], "]"}]}], " ", "//", 
  "\n", "  ", "GEEMosaic"}]], "Input",ExpressionUUID->"4119243c-a530-bf43-\
b027-c929cf0b3cc7"],

Cell[TextData[{
 "The ",
 Cell["//", "InlineCode",ExpressionUUID->
  "98fd45ec-24bf-e646-a6b4-8376712fb5c2"],
 " operator applies each function left to right: the result of ",
 Cell["GEECollection", "InlineCode",ExpressionUUID->
  "1507d847-8adb-9742-a589-dabfb6090575"],
 " flows into ",
 Cell["GEEFilterDate", "InlineCode",ExpressionUUID->
  "3c40aebb-7a7b-9142-838d-1ec205592063"],
 ", then into ",
 Cell["GEEFilterBounds", "InlineCode",ExpressionUUID->
  "ff05f503-49a9-5345-8789-0806c09451dc"],
 ", then into ",
 Cell["GEEMosaic", "InlineCode",ExpressionUUID->
  "121f8194-1832-a84c-9031-d943770d23c4"],
 "."
}], "Text",ExpressionUUID->"c52149c2-3e2b-204b-844a-3edc7f735a67"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Pipeline Order", "Chapter",ExpressionUUID->"32050442-1e52-b14c-81b6-9f4aded6d27b"],

Cell["\<\
Filters can be applied in any order, but the following conventions are \
recommended:\
\>", "Text",ExpressionUUID->"640519cb-56ec-9642-8ce2-de57f8845a4a"],

Cell[TextData[{
 StyleBox["Load",
  FontWeight->Bold],
 " the collection (",
 Cell["GEECollection", "InlineCode",ExpressionUUID->
  "05bb07f9-d8ef-224e-b63e-d2f310c655bc"],
 ")"
}], "ItemNumbered",ExpressionUUID->"a48c422c-3637-b44d-8ccb-808e48053a15"],

Cell[TextData[{
 StyleBox["Filter",
  FontWeight->Bold],
 " by date, bounds, and/or metadata properties (",
 Cell["GEEFilterDate", "InlineCode",ExpressionUUID->
  "4b03df3d-63a2-1e48-b6c2-87b2cdae60f8"],
 ", ",
 Cell["GEEFilterBounds", "InlineCode",ExpressionUUID->
  "13640bfa-38aa-f74e-98fc-4fae78a5aeea"],
 ", ",
 Cell["GEEFilterProperty", "InlineCode",ExpressionUUID->
  "406421be-8007-c743-9f41-6d50f2e18713"],
 ") -- these reduce the number of images before any per-image operations, \
which improves performance and avoids errors from heterogeneous band \
structures in older images"
}], "ItemNumbered",ExpressionUUID->"c4fbb4e0-400b-4946-b494-d905a7f1aea2"],

Cell[TextData[{
 StyleBox["Select bands",
  FontWeight->Bold],
 " (",
 Cell["GEESelectBands", "InlineCode",ExpressionUUID->
  "1c14b222-d9fd-634d-be6a-46eacd177d19"],
 ") -- must come before aggregation when operating on collections with many \
bands, as some collections have inconsistent band structures across their \
history"
}], "ItemNumbered",ExpressionUUID->"203872d4-2d02-8548-a3e4-70b0cba21a86"],

Cell[TextData[{
 StyleBox["Sort and limit",
  FontWeight->Bold],
 " (",
 Cell["GEESort", "InlineCode",ExpressionUUID->
  "3e9a9a5f-0ca8-cf47-8874-bcc6a74ba955"],
 ", ",
 Cell["GEELimit", "InlineCode",ExpressionUUID->
  "d3c3c322-8597-9549-b469-54a831a8cb9b"],
 ", ",
 Cell["GEEFirst", "InlineCode",ExpressionUUID->
  "95d7a918-0706-dd4c-a2bc-d49274c5d1ca"],
 ") -- if you need a specific image rather than an aggregate"
}], "ItemNumbered",ExpressionUUID->"23e91e8c-cb0f-df4b-ab56-8590116aa526"],

Cell[TextData[{
 StyleBox["Aggregate",
  FontWeight->Bold],
 " into a single image (",
 Cell["GEEMosaic", "InlineCode",ExpressionUUID->
  "6aedf793-e057-314f-ae0a-29ef6167f5f2"],
 ", ",
 Cell["GEEMedian", "InlineCode",ExpressionUUID->
  "623799c1-364e-0441-9f78-01bdd5de788b"],
 ", ",
 Cell["GEEMean", "InlineCode",ExpressionUUID->
  "e3dff69d-4bb4-d940-a941-10a9848f2bdf"],
 ") -- the final step must produce a single image for functions like ",
 Cell["GEEComputePixels", "InlineCode",ExpressionUUID->
  "bfb0a234-d5d5-d64c-9425-61f48d22def7"]
}], "ItemNumbered",ExpressionUUID->"3bf46783-45e7-074f-8394-9bcdad082e3c"],

Cell[TextData[{
 "The ",
 StyleBox["aggregation step",
  FontWeight->Bold],
 " (",
 Cell["GEEMosaic", "InlineCode",ExpressionUUID->
  "da41d116-256b-ef4b-85a2-0b332e727848"],
 ", ",
 Cell["GEEMedian", "InlineCode",ExpressionUUID->
  "c115d224-31eb-464e-9f9d-bd09e592e27f"],
 ", or ",
 Cell["GEEMean", "InlineCode",ExpressionUUID->
  "435254e5-f2f4-2e4a-9d40-27c2bec10cfb"],
 ") must come ",
 StyleBox["last",
  FontWeight->Bold],
 " in the pipeline before passing to a rendering function. It converts the \
collection into a single image. Functions like ",
 Cell["GEEComputePixels", "InlineCode",ExpressionUUID->
  "f033e1b7-c3c2-734a-a59d-eedf90252d12"],
 " and ",
 Cell["GEEImage", "InlineCode",ExpressionUUID->
  "f03e16d2-1d8e-d843-9c66-0eaf2592d47c"],
 " require a single image, not a collection."
}], "Text",ExpressionUUID->"02b827cc-a9e6-244b-9732-d5a678d5048e"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Function Reference", "Chapter",ExpressionUUID->"9d16bd47-9b11-c546-ae47-2b810e5159d2"],

Cell[CellGroupData[{

Cell["Loading", "Section",ExpressionUUID->"aebe3057-bd44-0b48-b250-fe21a2301949"],

Cell[CellGroupData[{

Cell["GEECollection", "Subsection",ExpressionUUID->"cd1af774-c0c0-3142-a727-eb98ead449af"],

Cell[BoxData[
 RowBox[{"GEECollection", "[", "assetId", "]"}]], "Input",ExpressionUUID->"bbcc31e8-39f4-7647-976e-a8ce5ee97dcc"],

Cell["Create a GEE expression for an ImageCollection asset.", "Text",ExpressionUUID->"23cdb6a5-7ded-2a41-a467-50b8ce257146"],

Cell[BoxData[
 RowBox[{"coll", " ", "=", " ", 
  RowBox[{
  "GEECollection", "[", "\"\<COPERNICUS/S2_SR_HARMONIZED\>\"", 
   "]"}]}]], "Input",ExpressionUUID->"deb4a61f-cb60-d34d-82c8-2e358f2530c8"]
}, Open  ]],

Cell[CellGroupData[{

Cell["GEELoadImage", "Subsection",ExpressionUUID->"2afadcf7-0daa-2d47-9149-74685d86d382"],

Cell[BoxData[
 RowBox[{"GEELoadImage", "[", "assetId", "]"}]], "Input",ExpressionUUID->"d68686ba-d7eb-1641-99b8-754e8fd80982"],

Cell[TextData[{
 "Create a GEE expression for a single Image asset. Use this for ",
 Cell["IMAGE", "InlineCode",ExpressionUUID->
  "2228c36a-e73b-6b48-b786-32b91481d0fd"],
 " type assets (not collections)."
}], "Text",ExpressionUUID->"0abc9585-83e3-d64d-9688-1177e7ef26fd"],

Cell[BoxData[
 RowBox[{"img", " ", "=", " ", 
  RowBox[{"GEELoadImage", "[", "\"\<USGS/SRTMGL1_003\>\"", "]"}]}]], "Input",E\
xpressionUUID->"5cea7636-41c9-bd4b-9901-161188108e73"]
}, Open  ]],

Cell[CellGroupData[{

Cell["GEEFeatureCollection", "Subsection",ExpressionUUID->"9a9dacb4-214c-494b-858a-58167b4449ba"],

Cell[BoxData[
 RowBox[{"GEEFeatureCollection", "[", "assetId", "]"}]], "Input",ExpressionUUI\
D->"1ba54b88-be55-cb41-ac65-11a6ecc6327d"],

Cell["\<\
Create a GEE expression for a FeatureCollection (table) asset.\
\>", "Text",ExpressionUUID->"5c525a46-2e89-d642-8e50-3876c4bdebe2"],

Cell[BoxData[
 RowBox[{"fc", " ", "=", " ", 
  RowBox[{
  "GEEFeatureCollection", "[", "\"\<TIGER/2018/States\>\"", "]"}]}]], "Input",\
ExpressionUUID->"bb50aed8-3167-004b-8c40-e138f4c54c49"]
}, Open  ]]
}, Open  ]],

Cell[CellGroupData[{

Cell["Filtering", "Section",ExpressionUUID->"cbb14a71-9a92-3d4c-8589-ada65f265e99"],

Cell[CellGroupData[{

Cell["GEEFilterDate", "Subsection",ExpressionUUID->"5a5dfb10-c241-4a43-a830-6aa8bcbda3c0"],

Cell[BoxData[{
 RowBox[{"GEEFilterDate", "[", 
  RowBox[{"collection", ",", " ", "start", ",", " ", "end"}], "]"}], "\n", 
 RowBox[{
  RowBox[{"GEEFilterDate", "[", 
   RowBox[{"start", ",", " ", "end"}], "]"}], "                  ", 
  RowBox[{"(*", " ", 
   RowBox[{"operator", " ", "form"}], " ", "*)"}]}]}], "Input",ExpressionUUID->\
"f5936c8e-be3f-cc4f-bfbb-d05240cba1b5"],

Cell[TextData[{
 "Filter a collection by date range. ",
 Cell["start", "InlineCode",ExpressionUUID->
  "13d7084e-0741-224c-99d2-52459003e308"],
 " and ",
 Cell["end", "InlineCode",ExpressionUUID->
  "c3e9e8d9-6d91-3043-858c-4bb1d6921963"],
 " are ISO 8601 date strings (",
 Cell["\"YYYY-MM-DD\"", "InlineCode",ExpressionUUID->
  "58ed10a2-a7f2-f245-a4e2-27ffdae3a547"],
 "). The range is inclusive of ",
 Cell["start", "InlineCode",ExpressionUUID->
  "8f3b0955-d41c-074c-b08d-d1b9dfe6e9dd"],
 " and exclusive of ",
 Cell["end", "InlineCode",ExpressionUUID->
  "424ad322-7ea8-5840-9068-0250c12f191b"],
 "."
}], "Text",ExpressionUUID->"e0ead38d-e8b7-0349-8ee5-6bbb0593fb87"],

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{"Direct", " ", "form"}], " ", "*)"}], "\n", 
  RowBox[{
   RowBox[{"filtered", " ", "=", " ", 
    RowBox[{"GEEFilterDate", "[", 
     RowBox[{
     "coll", ",", " ", "\"\<2023-06-01\>\"", ",", " ", "\"\<2023-09-01\>\""}],
      "]"}]}], "\n", "\n", 
   RowBox[{"(*", " ", 
    RowBox[{"Operator", " ", "form"}], " ", "*)"}], "\n", 
   RowBox[{"filtered", " ", "=", " ", 
    RowBox[{"coll", " ", "//", " ", 
     RowBox[{"GEEFilterDate", "[", 
      RowBox[{"\"\<2023-06-01\>\"", ",", " ", "\"\<2023-09-01\>\""}], 
      "]"}]}]}]}]}]], "Input",ExpressionUUID->"4f9db971-a6b8-3c40-b6bd-\
95dc562dc532"]
}, Open  ]],

Cell[CellGroupData[{

Cell["GEEFilterBounds", "Subsection",ExpressionUUID->"d29f09cd-cd6a-e54c-a177-91d2309caa92"],

Cell[BoxData[{
 RowBox[{"GEEFilterBounds", "[", 
  RowBox[{"collection", ",", " ", "bbox"}], "]"}], "\n", 
 RowBox[{
  RowBox[{"GEEFilterBounds", "[", "bbox", "]"}], "                      ", 
  RowBox[{"(*", " ", 
   RowBox[{"operator", " ", "form"}], " ", "*)"}]}], "\n", 
 RowBox[{"GEEFilterBounds", "[", 
  RowBox[{"collection", ",", " ", "region"}], "]"}], "\n", 
 RowBox[{
  RowBox[{"GEEFilterBounds", "[", "region", "]"}], "                    ", 
  RowBox[{"(*", " ", 
   RowBox[{"operator", " ", "form"}], " ", "*)"}]}]}], "Input",ExpressionUUID->\
"a815106a-a49e-274f-b017-87cdb96ee907"],

Cell["\<\
Filter a collection to images that intersect a geographic region. The region \
can be:\
\>", "Text",ExpressionUUID->"2b024c36-8be3-ff45-8ae6-fc67164749ba"],

Cell[TextData[{
 "A bounding box ",
 Cell["{west, south, east, north}", "InlineCode",ExpressionUUID->
  "84116868-56bf-a343-a575-139d00e71c10"],
 " in EPSG:4326 coordinates"
}], "Item",ExpressionUUID->"a3ccb0d4-5cec-2240-a0b2-79ce91ecff09"],

Cell[TextData[{
 "Any geo primitive accepted by ",
 Cell["GeoBoundingBox", "InlineCode",ExpressionUUID->
  "2448c346-44ae-d640-b754-04afc7966de2"],
 ": ",
 Cell["GeoPosition", "InlineCode",ExpressionUUID->
  "85dfc969-cae6-9749-93b5-46bceb96d087"],
 ", ",
 Cell["Polygon", "InlineCode",ExpressionUUID->
  "0712f7ab-8c45-9346-b7c1-752c34e423a3"],
 ", ",
 Cell["GeoPolygon", "InlineCode",ExpressionUUID->
  "efeb4fba-8e3c-2e45-881f-1d561f28277c"],
 ", ",
 Cell["GeoDisk", "InlineCode",ExpressionUUID->
  "89fea012-c4ba-5843-bbed-05e0112bb42c"],
 ", ",
 Cell["GeoCircle", "InlineCode",ExpressionUUID->
  "beb7e37d-142b-2f45-9b9e-73e75dfbecfc"],
 ", ",
 Cell["Rectangle", "InlineCode",ExpressionUUID->
  "ddc6ee1d-9526-2f41-9524-c1afc83e2a47"],
 ", ",
 Cell["Entity", "InlineCode",ExpressionUUID->
  "66521aad-7b5d-ae44-a18e-33e8aacb45ce"],
 ", ",
 Cell["GeoPath", "InlineCode",ExpressionUUID->
  "20141698-4ece-884c-9d76-6bdc2f2ecfed"],
 ", ",
 Cell["Line", "InlineCode",ExpressionUUID->
  "60642801-1e1c-6b44-a1d6-7ce7688c42a5"],
 ", ",
 Cell["GeoMarker", "InlineCode",ExpressionUUID->
  "77f14c4a-0937-c348-a144-5240273d9784"],
 ", etc."
}], "Item",ExpressionUUID->"f6527058-1891-614c-919c-507de9e0cff3"],

Cell[CellGroupData[{

Cell["\<\
A list of geo primitives \[LongDash] the bounding box is computed to cover \
all of them\
\>", "Item",ExpressionUUID->"e431accb-fdbc-c242-9b9e-c9d3531d7a21"],

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{"Bounding", " ", "box", " ", "coordinates"}], " ", "*)"}], "\n", 
  RowBox[{
   RowBox[{"filtered", " ", "=", " ", 
    RowBox[{"coll", " ", "//", " ", 
     RowBox[{"GEEFilterBounds", "[", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"-", "3.8"}], ",", " ", "40.3", ",", " ", 
        RowBox[{"-", "3.6"}], ",", " ", "40.5"}], "}"}], "]"}]}]}], "\n", 
   "\n", 
   RowBox[{"(*", " ", 
    RowBox[{"Country", " ", "entity"}], " ", "*)"}], "\n", 
   RowBox[{"filtered", " ", "=", " ", 
    RowBox[{"coll", " ", "//", " ", 
     RowBox[{"GEEFilterBounds", "[", 
      RowBox[{"Entity", "[", 
       RowBox[{"\"\<Country\>\"", ",", " ", "\"\<Switzerland\>\""}], "]"}], 
      "]"}]}]}], "\n", "\n", 
   RowBox[{"(*", " ", 
    RowBox[{"Geo", " ", "primitive"}], " ", "*)"}], "\n", 
   RowBox[{"filtered", " ", "=", " ", 
    RowBox[{"coll", " ", "//", " ", 
     RowBox[{"GEEFilterBounds", "[", "\n", "  ", 
      RowBox[{"GeoDisk", "[", 
       RowBox[{
        RowBox[{"GeoPosition", "[", 
         RowBox[{"{", 
          RowBox[{"40.4", ",", " ", 
           RowBox[{"-", "3.7"}]}], "}"}], "]"}], ",", " ", 
        RowBox[{"Quantity", "[", 
         RowBox[{"20", ",", " ", "\"\<Kilometers\>\""}], "]"}]}], "]"}], 
      "]"}]}]}], "\n", "\n", 
   RowBox[{"(*", " ", 
    RowBox[{
     RowBox[{"List", " ", "of", " ", "primitives"}], " ", "\[LongDash]", " ", 
     RowBox[{"bbox", " ", "covers", " ", "all"}]}], " ", "*)"}], "\n", 
   RowBox[{"filtered", " ", "=", " ", 
    RowBox[{"coll", " ", "//", " ", 
     RowBox[{"GEEFilterBounds", "[", 
      RowBox[{"{", "\n", "  ", 
       RowBox[{
        RowBox[{"Polygon", "[", 
         RowBox[{"{", 
          RowBox[{
           RowBox[{"GeoPosition", "[", 
            RowBox[{"{", 
             RowBox[{"30.2", ",", " ", 
              RowBox[{"-", "97.8"}]}], "}"}], "]"}], ",", " ", 
           RowBox[{"GeoPosition", "[", 
            RowBox[{"{", 
             RowBox[{"30.3", ",", " ", 
              RowBox[{"-", "97.7"}]}], "}"}], "]"}], ",", "\n", "    ", 
           RowBox[{"GeoPosition", "[", 
            RowBox[{"{", 
             RowBox[{"30.3", ",", " ", 
              RowBox[{"-", "97.8"}]}], "}"}], "]"}]}], "}"}], "]"}], ",", 
        "\n", "  ", 
        RowBox[{"GeoDisk", "[", 
         RowBox[{
          RowBox[{"GeoPosition", "[", 
           RowBox[{"{", 
            RowBox[{"29.5", ",", " ", 
             RowBox[{"-", "95.0"}]}], "}"}], "]"}], ",", " ", 
          RowBox[{"Quantity", "[", 
           RowBox[{"10", ",", " ", "\"\<Kilometers\>\""}], "]"}]}], "]"}]}], 
       "}"}], "]"}]}]}]}]}]], "Input",ExpressionUUID->"7602ef11-185a-dc47-\
be7a-cccea9d41793"]
}, Open  ]]
