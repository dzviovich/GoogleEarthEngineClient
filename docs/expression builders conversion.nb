 "Compute the area of a bounding box in square kilometers using ",
 Cell["GEEArea", "InlineCode",ExpressionUUID->
  "3296d8c6-6426-f246-82f9-896e13f2fee2"],
 ":"
}], "Text",ExpressionUUID->"18d00fd7-673d-4247-b4c8-cfbdea3984c0"],

Cell[BoxData[{
 RowBox[{
  RowBox[{"geom", " ", "=", " ", 
   RowBox[{"GEEGeometry", "[", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{"-", "73.0"}], ",", " ", "40.7", ",", " ", 
