Cell[CellGroupData[{

Cell["Band Selection", "Section",ExpressionUUID->"e9c7b77e-7677-ac45-b6dc-b73b28326e88"],

Cell[CellGroupData[{

Cell["GEESelectBands", "Subsection",ExpressionUUID->"b14a8083-aac7-1d41-a0aa-928b22f08215"],

Cell[BoxData[{
 RowBox[{"GEESelectBands", "[", 
  RowBox[{"expr", ",", " ", "bands"}], "]"}], "\n", 
 RowBox[{
  RowBox[{"GEESelectBands", "[", "bands", "]"}], "                      ", 
  RowBox[{"(*", " ", 
   RowBox[{"operator", " ", "form"}], " ", "*)"}]}]}], "Input",ExpressionUUID->\
"fda1e2bf-59aa-5340-8647-4a26a42e752b"],

Cell["\<\
Select specific bands from an image or collection. When applied to a \
collection, the band selection is mapped over each image in the collection \
automatically.\
\>", "Text",ExpressionUUID->"b3cad9e9-8b1c-fa4f-88e9-06612fb2ab43"],

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{
    RowBox[{
    "Select", " ", "RGB", " ", "bands", " ", "from", " ", "Sentinel"}], "-", 
    "2"}], " ", "*)"}], "\n", 
  RowBox[{
   RowBox[{"rgb", " ", "=", " ", 
    RowBox[{"coll", " ", "//", " ", 
     RowBox[{"GEESelectBands", "[", 
      RowBox[{"{", 
       RowBox[{"\"\<B4\>\"", ",", " ", "\"\<B3\>\"", ",", " ", "\"\<B2\>\""}],
        "}"}], "]"}]}]}], "\n", "\n", 
   RowBox[{"(*", " ", 
    RowBox[{"Select", " ", "a", " ", "single", " ", "band"}], " ", "*)"}], "\n", 
   RowBox[{"nir", " ", "=", " ", 
    RowBox[{"coll", " ", "//", " ", 
     RowBox[{"GEESelectBands", "[", 
      RowBox[{"{", "\"\<B8\>\"", "}"}], "]"}]}]}]}]}]], "Input",ExpressionUUID\
->"76ca50f9-181a-714f-bcee-e91ad1b00b2f"]
}, Open  ]]
}, Open  ]],

Cell[CellGroupData[{

Cell["Aggregation", "Section",ExpressionUUID->"e27f4c5c-37b2-494e-a295-ad35bd2fd007"],

Cell["\<\
These functions reduce a collection of images into a single image. Exactly \
one aggregation function should appear at the end of a collection pipeline.\
\>", "Text",ExpressionUUID->"5709e6c9-4326-1142-b8b3-4020c4caefb3"],

Cell[CellGroupData[{

Cell["GEEMosaic", "Subsection",ExpressionUUID->"8b845ee0-c300-6949-b034-0af67306dd3a"],

Cell[BoxData[
 RowBox[{"GEEMosaic", "[", "collection", "]"}]], "Input",ExpressionUUID->"0134ae74-1d5b-d147-b5a1-a9e90b235764"],

Cell["\<\
Mosaic (overlay) all images in the collection into a single image. Where \
images overlap, the last image in the collection takes precedence. Band names \
are preserved.\
\>", "Text",ExpressionUUID->"5ff766da-2057-d74a-8447-1c11bca7ebd6"],

Cell[BoxData[
 RowBox[{"img", " ", "=", " ", 
  RowBox[{"coll", " ", "//", " ", "GEEMosaic"}]}]], "Input",ExpressionUUID->\
"2d53dd49-7ade-a943-b7d9-1205734fd380"]
}, Open  ]],

Cell[CellGroupData[{

Cell["GEEMedian", "Subsection",ExpressionUUID->"5a9f1cd3-ad6b-5141-be0f-87239532bd12"],

Cell[BoxData[
 RowBox[{"GEEMedian", "[", "collection", "]"}]], "Input",ExpressionUUID->"59c7dfa0-e63f-a340-a8e7-60273d86c1cb"],

Cell[TextData[{
 "Compute the per-pixel median across all images in the collection. This is \
useful for removing clouds and transient artifacts. Uses ",
 Cell["ImageCollection.reduce", "InlineCode",ExpressionUUID->
  "47d2badf-b988-484d-b724-9415cfbafdfd"],
 " with ",
 Cell["Reducer.median", "InlineCode",ExpressionUUID->
  "8b1c5be9-ff4a-3442-a1b3-c8e085cd35de"],
 " internally; band names receive a ",
 Cell["_median", "InlineCode",ExpressionUUID->
  "23d43557-65d5-ac47-b7de-21be6fc072aa"],
 " suffix (e.g., ",
 Cell["\"B4\"", "InlineCode",ExpressionUUID->
  "20faef87-405d-1843-b5f2-f3cf72f03587"],
 " becomes ",
 Cell["\"B4_median\"", "InlineCode",ExpressionUUID->
  "d00f4166-78c0-5541-8086-23a83f69ba98"],
 ")."
}], "Text",ExpressionUUID->"72322353-4b87-ce4e-8098-8b1241eb07a9"],

Cell[BoxData[
 RowBox[{"img", " ", "=", " ", 
  RowBox[{"coll", " ", "//", " ", "GEEMedian"}]}]], "Input",ExpressionUUID->\
"ff69f242-702a-1846-9b0d-4a9392fabafd"]
}, Open  ]],

Cell[CellGroupData[{

Cell["GEEMean", "Subsection",ExpressionUUID->"d275cfbc-85e4-aa48-a5b6-9e41532d5af9"],

Cell[BoxData[
 RowBox[{"GEEMean", "[", "collection", "]"}]], "Input",ExpressionUUID->"d4d2699c-6579-4d4a-a4f5-e63e46c8e4f4"],

Cell[TextData[{
 "Compute the per-pixel mean across all images in the collection. Uses ",
 Cell["ImageCollection.reduce", "InlineCode",ExpressionUUID->
  "0cd53027-7c0d-4a42-aa9b-da6a96d43081"],
 " with ",
 Cell["Reducer.mean", "InlineCode",ExpressionUUID->
  "73d44a56-c00a-cf4a-a2ab-193746df4715"],
 " internally; band names receive a ",
 Cell["_mean", "InlineCode",ExpressionUUID->
  "fc1c7ca3-8b2c-514f-83de-8a9f9f5e971f"],
 " suffix."
}], "Text",ExpressionUUID->"5b0cceff-447b-364b-8f39-199e757e8020"],

Cell[BoxData[
 RowBox[{"img", " ", "=", " ", 
  RowBox[{"coll", " ", "//", " ", "GEEMean"}]}]], "Input",ExpressionUUID->\
"2bbce2df-a233-de4b-8fe9-de4813c96edd"]
}, Open  ]]
}, Open  ]],

