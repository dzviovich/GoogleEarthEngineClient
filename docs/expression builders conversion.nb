Cell[CellGroupData[{

Cell["Math Expressions", "Section",ExpressionUUID->"928bf741-f704-f54a-9136-76dcc5cdfc71"],

Cell[CellGroupData[{

Cell["GEEExpression", "Subsection",ExpressionUUID->"24b9a532-39be-7d4d-8fd0-ee017da7e01e"],

Cell[BoxData[{
 RowBox[{"GEEExpression", "[", 
  RowBox[{"image", ",", " ", "expr", ",", " ", "bindings"}], "]"}], "\n", 
 RowBox[{
  RowBox[{"GEEExpression", "[", 
   RowBox[{"expr", ",", " ", "bindings"}], "]"}], "              ", 
  RowBox[{"(*", " ", 
   RowBox[{"operator", " ", "form"}], " ", "*)"}]}]}], "Input",ExpressionUUID->\
"48246b7b-58ac-9848-b3d9-e179508b9211"],

Cell[TextData[{
 "Evaluate a text math expression with band variable bindings. ",
 Cell["expr", "InlineCode",ExpressionUUID->
  "2999bb7a-7315-f341-bc1a-96e3b49b1219"],
 " is a string using standard math operators (",
 Cell["+", "InlineCode",ExpressionUUID->
  "3ab11856-a517-f547-b3f6-e3b115eb04cc"],
 ", ",
 Cell["-", "InlineCode",ExpressionUUID->
  "76baed2f-960f-ec4a-befa-d56f7b635c56"],
 ", ",
 Cell["*", "InlineCode",ExpressionUUID->
  "1b01cbaf-d5ec-4541-bc42-08fe31e7be7d"],
 ", ",
 Cell["/", "InlineCode",ExpressionUUID->
  "737711bc-23aa-6048-bf48-06df355af852"],
 ", ",
 Cell["**", "InlineCode",ExpressionUUID->
  "77a32a85-1240-3545-8660-349a36fea472"],
 ", ",
 Cell["%", "InlineCode",ExpressionUUID->
  "f12a8e5c-1083-f941-9b3e-5cf18b4747b2"],
 ") and comparison operators (",
 Cell[">", "InlineCode",ExpressionUUID->
  "98c52612-2444-3846-899b-eb8631075f85"],
 ", ",
 Cell["<", "InlineCode",ExpressionUUID->
  "ff54dbbd-016e-ce4e-8f3b-1cf693624dc5"],
 ", ",
 Cell[">=", "InlineCode",ExpressionUUID->
  "c50d91ca-b888-484c-8163-cf16e0ac15e7"],
 ", ",
 Cell["<=", "InlineCode",ExpressionUUID->
  "c2c7be5c-566f-8848-8e3c-426beaf4e0a2"],
 ", ",
 Cell["==", "InlineCode",ExpressionUUID->
  "445ba10a-b857-7042-8318-09121abb45e4"],
 ", ",
 Cell["!=", "InlineCode",ExpressionUUID->
  "a25485e8-06a7-f742-a716-6da079b8dbcb"],
 "). Ternary conditionals (",
 Cell["condition ? trueVal : falseVal", "InlineCode",ExpressionUUID->
  "6887226c-3242-1f49-8e98-979596f6a24d"],
 ") are also supported."
}], "Text",ExpressionUUID->"af8e955e-3c8e-6c40-9510-a16dcc03f70e"],

Cell[TextData[{
 Cell["bindings", "InlineCode",ExpressionUUID->
  "ab49ae7f-585b-d343-a8e0-511ae70c5a57"],
 " is an Association mapping variable names in the expression to band names \
in the image."
}], "Text",ExpressionUUID->"e3338348-f928-7843-917e-01f9555904ca"],

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{"Enhanced", " ", "Vegetation", " ", "Index", " ", 
    RowBox[{"(", "EVI", ")"}]}], " ", "*)"}], "\n", 
  RowBox[{"evi", " ", "=", " ", 
   RowBox[{"img", " ", "//", " ", 
    RowBox[{"GEEExpression", "[", "\n", "  ", 
     RowBox[{"\"\<2.5 * ((nir - red) / (nir + 6 * red - 7.5 * blue + 1))\>\"",
       ",", "\n", "  ", 
      RowBox[{"<|", 
       RowBox[{
        RowBox[{"\"\<nir\>\"", " ", "->", " ", "\"\<B8\>\""}], ",", " ", 
        RowBox[{"\"\<red\>\"", " ", "->", " ", "\"\<B4\>\""}], ",", " ", 
        RowBox[{"\"\<blue\>\"", " ", "->", " ", "\"\<B2\>\""}]}], "|>"}]}], 
     "]"}]}]}]}]], "Input",ExpressionUUID->"556c4779-cfc5-7c4d-8ecc-\
c4b3925c7035"]
}, Open  ]]
}, Open  ]],

Cell[CellGroupData[{

Cell["Comparison Operators", "Section",ExpressionUUID->"9283ede8-5318-6546-9bc7-2a3e91f13ffa"],

Cell["\<\
These functions compare two images (or an image and a constant) per-pixel and \
return a binary 0/1 image. Use them to build masks for conditional processing.\
\>", "Text",ExpressionUUID->"aa70e29f-b17a-7348-9c80-a205909afa9d"],

Cell[CellGroupData[{

Cell["GEEGreaterThan", "Subsection",ExpressionUUID->"c819592e-d702-8e42-bfcb-2a95bea8ab75"],

Cell[BoxData[{
 RowBox[{"GEEGreaterThan", "[", 
  RowBox[{"image", ",", " ", "other"}], "]"}], "\n", 
 RowBox[{
  RowBox[{"GEEGreaterThan", "[", "other", "]"}], "                      ", 
  RowBox[{"(*", " ", 
   RowBox[{"operator", " ", "form"}], " ", "*)"}]}]}], "Input",ExpressionUUID->\
"9b307640-472a-d74e-8d85-9c33b26c0206"],

Cell[TextData[{
 "Per-pixel greater than comparison. Returns 1 where ",
 Cell["image > other", "InlineCode",ExpressionUUID->
  "a8841e2a-8224-5f4d-b485-edd48b313a81"],
 ", 0 otherwise. ",
 Cell["other", "InlineCode",ExpressionUUID->
  "2c639b05-5164-8240-a036-3e32b640da4d"],
 " can be an image or a number."
}], "Text",ExpressionUUID->"3fe236c0-2551-1b4e-a55f-d7463a72b784"],

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{
    RowBox[{"Pixels", " ", "where", " ", "NDVI"}], " ", ">", " ", "0.3"}], 
   " ", "*)"}], "\n", 
  RowBox[{"vegMask", " ", "=", " ", 
   RowBox[{"ndvi", " ", "//", " ", 
    RowBox[{"GEEGreaterThan", "[", "0.3", "]"}]}]}]}]], "Input",ExpressionUUID\
->"652342fb-94a7-d54b-a8e2-5190cc303210"]
}, Open  ]],

Cell[CellGroupData[{

Cell["GEELessThan", "Subsection",ExpressionUUID->"8f42113e-b2a9-7048-93d6-8de564aa08fe"],

Cell[BoxData[{
 RowBox[{"GEELessThan", "[", 
  RowBox[{"image", ",", " ", "other"}], "]"}], "\n", 
 RowBox[{
  RowBox[{"GEELessThan", "[", "other", "]"}], "                         ", 
  RowBox[{"(*", " ", 
   RowBox[{"operator", " ", "form"}], " ", "*)"}]}]}], "Input",ExpressionUUID->\
"12761833-9201-cb45-9407-792214ec6abd"],

Cell["Per-pixel less than comparison.", "Text",ExpressionUUID->"8d21e413-8f7b-5541-8a9f-e1e259f739e7"],

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{
    RowBox[{"Pixels", " ", "where", " ", "elevation"}], " ", "<", " ", 
