"71c6b065-1fe8-7e4d-a501-7371131118f2"],

Cell[TextData[{
 "Apply a function to each image in a collection. ",
 Cell["func", "InlineCode",ExpressionUUID->
  "5ec60275-4ff9-b242-bacd-14a628f27ebf"],
 " receives an image expression (Association) and must return an image \
expression. This is the general-purpose per-image transform \[LongDash] use \
it when no specialized helper exists."
}], "Text",ExpressionUUID->"efc35b24-7840-1748-90a0-4010f5849ec7"],

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{
   "Compute", " ", "NDVI", " ", "for", " ", "every", " ", "image", " ", "in", 
    " ", "a", " ", "collection"}], " ", "*)"}], "\n", 
  RowBox[{"ndviCollection", " ", "=", " ", 
   RowBox[{"coll", " ", "//", " ", 
    RowBox[{"GEECollectionMap", "[", "\n", "  ", 
     RowBox[{"Function", "[", 
      RowBox[{"img", ",", " ", 
       RowBox[{"GEENormalizedDifference", "[", 
        RowBox[{"img", ",", " ", 
         RowBox[{"{", 
          RowBox[{"\"\<B8\>\"", ",", " ", "\"\<B4\>\""}], "}"}]}], "]"}]}], 
      "]"}], "]"}]}]}]}]], "Input",ExpressionUUID->"3aab0e56-78d9-784b-8d1e-\
db9cad349491"]
