Cell[CellGroupData[{
Cell["GEEIdentify", "ObjectName",
 CellID->156120826,ExpressionUUID->"69e600ed-c711-3e43-8d8f-e27836221669"],

Cell["\<\
Identify pixel values at a GeoPosition from a Google Earth Engine image asset.\
\>", "ExampleText",
 CellChangeTimes->{3.9843396002402325`*^9},
 CellID->253478814,ExpressionUUID->"e6afc0a1-29d8-9d40-9245-85895873faa6"],

Cell[TextData[{
 Cell["   ", "ModInfo",ExpressionUUID->"3357cd7d-a8bb-9c49-8872-7594d0e9a94c"],
 Cell[BoxData[
  RowBox[{
   ButtonBox["GEEIdentify",
    BaseStyle->"Link",
    ButtonData->"paclet:GoogleEarthEngineClient/ref/GEEIdentify"], "[", 
   RowBox[{
    StyleBox["point", "TI"], ",", 
    StyleBox["assetId", "TI"]}], "]"}]], "InlineFormula",ExpressionUUID->
  "1bc83813-d021-a14a-be5b-2421c83949a4"],
 "\[LineSeparator]identify pixel values at a ",
 Cell[BoxData[
  ButtonBox["GeoPosition",
   BaseStyle->"Link"]], "InlineFormula",ExpressionUUID->
  "a067dad3-112e-ce4c-a154-b9121a9c3a9a"],
 " from a Google Earth Engine image asset. ",
 Cell[BoxData[
  ButtonBox["Return",
   BaseStyle->"Link"]], "InlineFormula",ExpressionUUID->
  "00742294-7e7e-1b4a-8239-b554f097bb5d"],
 " an ",
 Cell[BoxData[
  ButtonBox["Association",
   BaseStyle->"Link"]], "InlineFormula",ExpressionUUID->
  "7d8a4844-9cf5-6342-b8e7-3a38b6c019a0"],
 " with keys \"Position\", \"Values\", and \"Bands\". \n",
 Cell["   ", "ModInfo",ExpressionUUID->"0b5c4304-f42b-4140-9c17-86dd073d39b9"],
 Cell[BoxData[
  RowBox[{
   ButtonBox["GEEIdentify",
    BaseStyle->"Link",
    ButtonData->"paclet:GoogleEarthEngineClient/ref/GEEIdentify"], "[", 
   RowBox[{
    StyleBox["point", "TI"], ",", 
    StyleBox["assetId", "TI"], ",", 
    StyleBox[
     RowBox[{"\"\<Bands\>\"", "->", "bandList"}], "TI"]}], "]"}]], 
  "InlineFormula",ExpressionUUID->"201b5f62-2429-2845-9607-a7d69278e176"],
 "\[LineSeparator]identify with option \"Bands\"."
}], "Usage",
 CellChangeTimes->{{3.9841675210069504`*^9, 3.984167521220028*^9}, {
  3.9843396190206585`*^9, 3.9843396448606434`*^9}},
 CellID->149143653,ExpressionUUID->"cd4cab7f-135e-e84a-9ae1-c2bec1014038"],

Cell["The following options can be given: ", "Notes",
 CellID->561662561,ExpressionUUID->"19437139-52e0-2841-9bb4-a927d21711cf"],

Cell[BoxData[GridBox[{
   {Cell["   ", "ModInfo",ExpressionUUID->
     "c0484e95-9ba1-0840-aa00-9e49a6a36f4c"], "\"\<Bands\>\"", 
    ButtonBox["Automatic",
     BaseStyle->"Link"], Cell[
    "List of band names, or Automatic for all", "TableText",ExpressionUUID->
     "6903cdeb-61bd-8245-bd3a-159e27c6db71"]},
   {Cell["   ", "ModInfo",ExpressionUUID->
     "c23e1e49-9e19-1c46-b75e-88d3c52d6fc5"], "\"\<Project\>\"", 
    ButtonBox["Automatic",
     BaseStyle->"Link"], 
    RowBox[{"GCP", " ", "Project", " ", "ID"}]}
  }]], "3ColumnTableMod",
 CellChangeTimes->{{3.984339656229786*^9, 3.984339692947525*^9}},
 CellID->464626124,ExpressionUUID->"2779829f-3a55-a040-8d73-e4c1def8643d"],

Cell["\<\
- `point` can be a `GeoPosition` or any geographic `Entity` such as \
`Entity[\"City\", ...]`, `Entity[\"Mountain\", ...]`, `Entity[\"Country\", \
...]`, etc. Entities are resolved to coordinates via `GeoPosition[entity]`.
- `assetId` can refer to an `IMAGE` or `IMAGE_COLLECTION` asset. Collections \
are automatically filtered to a small region around the query point and the \
most recent 3 years of data, then mosaicked into a single image.
- Returns an Association with keys `\"Position\"`, `\"Values\"`, and `\"Bands\
\"`.
- `\"Values\"` is a list of numeric pixel values (one per band). Nodata \
pixels return `Null`.
- `\"Bands\"` is a list of band name strings. Band order is determined by the \
server (alphabetical), not by the order specified in the `\"Bands\"` option.
- Uses `value:compute` with a `reduceRegion` expression internally.\
\>", "ExampleText",
 CellChangeTimes->{3.9843400096810226`*^9, 3.9844286820904922`*^9},
 CellID->765780597,ExpressionUUID->"89ab96b0-5a04-a347-b8b6-d37f97275e7c"],

Cell[CellGroupData[{

