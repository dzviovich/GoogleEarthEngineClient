Cell["Elevation at a Named Location", "ExampleText",
 CellChangeTimes->{3.9843400240374546`*^9},
 CellID->396942906,ExpressionUUID->"9a5045e0-2766-ee4d-bb7f-0f7fe7ff1622"],

Cell["Query the elevation of Mount Kilimanjaro's summit (5,895 m):", \
"ExampleText",
 CellChangeTimes->{3.984340032631607*^9},
 CellID->471556339,ExpressionUUID->"45598a5b-6308-754d-b3b4-2ccf788f3df7"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{"result", "=", 
  RowBox[{"GEEIdentify", "[", 
   RowBox[{
    RowBox[{"GeoPosition", "[", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"-", "3.0674"}], ",", "37.3556"}], "}"}], "]"}], 
    ",", "\"\<USGS/SRTMGL1_003\>\""}], "]"}]}], "\n", 
 RowBox[{
  RowBox[{"result", "[", "\"\<Values\>\"", "]"}], "   ", 
  RowBox[{"(*", 
   RowBox[{
    RowBox[{"{", "5880", "}"}], "\[LongDash]", 
    RowBox[{"SRTM", " ", "30", " ", "m", " ", "resolution"}]}], "*)"}]}], "\n", 
 RowBox[{
  RowBox[{"result", "[", "\"\<Bands\>\"", "]"}], "    ", 
  RowBox[{"(*", 
   RowBox[{"{", "\"\<elevation\>\"", "}"}], "*)"}]}]}], "Input",
 CellChangeTimes->{{3.984340039839081*^9, 3.984340039839081*^9}},
 CellLabel->"In[75]:=",
 CellID->1056449,ExpressionUUID->"f08a6fc9-7841-3646-aaca-13ee01c267ad"],

Cell[BoxData[
 RowBox[{"\[LeftAssociation]", 
  RowBox[{
   RowBox[{"\<\"Position\"\>", "\[Rule]", 
    RowBox[{"GeoPosition", "[", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"-", "3.0674`"}], ",", "37.3556`"}], "}"}], "]"}]}], ",", 
   RowBox[{"\<\"Values\"\>", "\[Rule]", 
    RowBox[{"{", "5832", "}"}]}], ",", 
   RowBox[{"\<\"Bands\"\>", "\[Rule]", 
    RowBox[{"{", "\<\"elevation\"\>", "}"}]}]}], 
  "\[RightAssociation]"}]], "Output",
 CellChangeTimes->{3.984340042077261*^9},
 CellLabel->"Out[75]=",
