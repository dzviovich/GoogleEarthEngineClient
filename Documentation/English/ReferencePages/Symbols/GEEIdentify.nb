   "df06020b-0e41-2943-826f-5b244fd1f01b"],
  $Line = 0; Null]], "ExampleDelimiter",
 CellID->459340429,ExpressionUUID->"d532360e-818f-7741-b136-386b635e36fa"],

Cell["Using Geographic Entities", "ExampleText",
 CellChangeTimes->{3.9844287447353783`*^9},
 CellID->465349056,ExpressionUUID->"c1e34a84-19b5-9145-9907-c323f229945d"],

Cell["\<\
Query pixel values using geographic entities instead of raw coordinates. Any \
entity that `GeoPosition` can resolve is supported:\
\>", "ExampleText",
 CellChangeTimes->{3.9844287561679726`*^9},
 CellID->638723508,ExpressionUUID->"44129434-d2a4-8842-8f2a-92d45f7a6840"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", 
   RowBox[{"Mountain", " ", "entity"}], "*)"}], "\[IndentingNewLine]", 
  RowBox[{"GEEIdentify", "[", 
   RowBox[{
    RowBox[{"Entity", "[", 
     RowBox[{"\"\<Mountain\>\"", ",", "\"\<MountEverest\>\""}], "]"}], 
    ",", "\"\<USGS/SRTMGL1_003\>\""}], "]"}]}]], "Input",
 CellChangeTimes->{{3.98442876377425*^9, 3.9844287746403236`*^9}},
 CellLabel->"In[5]:=",
 CellID->233203050,ExpressionUUID->"216c2648-8b2c-204d-8097-6f1b23849389"],

Cell[BoxData[
 RowBox[{"\[LeftAssociation]", 
  RowBox[{
   RowBox[{"\<\"Position\"\>", "\[Rule]", 
    RowBox[{"GeoPosition", "[", 
     RowBox[{"{", 
      RowBox[{"27.9881`", ",", "86.9253`"}], "}"}], "]"}]}], ",", 
   RowBox[{"\<\"Values\"\>", "\[Rule]", 
    RowBox[{"{", "8718", "}"}]}], ",", 
   RowBox[{"\<\"Bands\"\>", "\[Rule]", 
    RowBox[{"{", "\<\"elevation\"\>", "}"}]}]}], 
  "\[RightAssociation]"}]], "Output",
 CellChangeTimes->{3.984428776003973*^9, 3.9844288910846577`*^9},
 CellLabel->"Out[5]=",
 CellID->500332857,ExpressionUUID->"7bb8ce5e-bdca-7044-af0f-ad445afd26d7"]
}, Open  ]]
}, Open  ]],

