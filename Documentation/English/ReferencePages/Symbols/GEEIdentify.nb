Cell["Land Cover Classification", "ExampleText",
 CellChangeTimes->{3.9843403875306587`*^9},
 CellID->283908935,ExpressionUUID->"5da56ac3-b2ad-1c42-940a-4ede19e28554"],

Cell["\<\
Determine the ESA WorldCover land class at a point. Class IDs: 10=Tree, \
20=Shrub, 30=Grass, 40=Crop, 50=Built-up, 60=Bare, 70=Snow, 80=Water, \
90=Wetland, 95=Mangrove, 100=Moss:\
\>", "ExampleText",
 CellChangeTimes->{3.984340422138674*^9},
