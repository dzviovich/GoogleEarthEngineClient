Cell["Compare Elevations Across Locations", "ExampleText",
 CellChangeTimes->{3.9844289174362755`*^9},
 CellID->422488800,ExpressionUUID->"2154d494-0d42-594a-9d58-0a8f22840fd2"],

Cell["\<\
Retrieve elevations for several world capitals using entities and display as \
a bar chart:\
\>", "ExampleText",
 CellChangeTimes->{3.9844289318150864`*^9},
 CellID->55053769,ExpressionUUID->"0080d6d5-2ab1-7743-a534-cbd1634a0535"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"cities", "=", 
   RowBox[{"<|", 
    RowBox[{
     RowBox[{"\"\<Mexico City\>\"", "->", 
      RowBox[{"Entity", "[", 
       RowBox[{"\"\<City\>\"", ",", 
        RowBox[{"{", 
         RowBox[{"\"\<MexicoCity\>\"", ",", "\"\<DistritoFederal\>\"", 
          ",", "\"\<Mexico\>\""}], "}"}]}], "]"}]}], ",", 
     RowBox[{"\"\<Denver\>\"", "->", 
      RowBox[{"Entity", "[", 
       RowBox[{"\"\<City\>\"", ",", 
        RowBox[{"{", 
         RowBox[{"\"\<Denver\>\"", ",", "\"\<Colorado\>\"", 
          ",", "\"\<UnitedStates\>\""}], "}"}]}], "]"}]}], ",", 
     RowBox[{"\"\<Nairobi\>\"", "->", 
      RowBox[{"Entity", "[", 
       RowBox[{"\"\<City\>\"", ",", 
        RowBox[{"{", 
         RowBox[{"\"\<Nairobi\>\"", ",", "\"\<Nairobi\>\"", 
          ",", "\"\<Kenya\>\""}], "}"}]}], "]"}]}], ",", 
     RowBox[{"\"\<Bogota\>\"", "->", 
      RowBox[{"Entity", "[", 
       RowBox[{"\"\<City\>\"", ",", 
        RowBox[{"{", 
         RowBox[{"\"\<Bogota\>\"", ",", "\"\<Bogota\>\"", 
          ",", "\"\<Colombia\>\""}], "}"}]}], "]"}]}]}], "|>"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{"elevations", "=", 
   RowBox[{"Association", "@", 
    RowBox[{"Map", "[", 
     RowBox[{
      RowBox[{
       RowBox[{"#", "->", 
        RowBox[{
         RowBox[{
          RowBox[{"GEEIdentify", "[", 
           RowBox[{
            RowBox[{"cities", "[", "#", "]"}], 
            ",", "\"\<USGS/SRTMGL1_003\>\""}], "]"}], "[", "\"\<Values\>\"", 
          "]"}], "[", 
         RowBox[{"[", "1", "]"}], "]"}]}], "&"}], ",", 
      RowBox[{"Keys", "[", "cities", "]"}]}], "]"}]}]}], ";"}], "\n", 
 RowBox[{"BarChart", "[", 
  RowBox[{"elevations", ",", 
   RowBox[{"ChartLabels", "->", 
    RowBox[{"Keys", "[", "elevations", "]"}]}], ",", 
   RowBox[{"AxesLabel", "->", 
    RowBox[{"{", 
     RowBox[{"None", ",", "\"\<Elevation (m)\>\""}], "}"}]}], ",", 
   RowBox[{"PlotLabel", "->", "\"\<Capital City Elevations\>\""}]}], 
  "]"}]}], "Input",
 CellChangeTimes->{{3.9844289375359*^9, 3.9844289375368996`*^9}, 
   3.984429138478527*^9},
 CellLabel->"In[4]:=",
 CellID->222304622,ExpressionUUID->"19a9b67d-9fd8-084f-88bc-fb2d0f2f2511"],

