Cell["Compare Elevations Across Locations", "ExampleText",
 CellChangeTimes->{3.9843400690869865`*^9},
 CellID->234547999,ExpressionUUID->"6924fc7b-5844-b84b-bb91-2d4f1d14d9b2"],

Cell["\<\
Retrieve elevations for several world capitals and display as a bar chart:\
\>", "ExampleText",
 CellChangeTimes->{3.9843400779976006`*^9},
 CellID->1253178,ExpressionUUID->"6e1a3f11-826c-844a-b918-5d21ec0c54ae"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"cities", "=", 
   RowBox[{"<|", 
    RowBox[{
     RowBox[{"\"\<Mexico City\>\"", "->", 
      RowBox[{"GeoPosition", "[", 
       RowBox[{"{", 
        RowBox[{"19.43", ",", 
         RowBox[{"-", "99.13"}]}], "}"}], "]"}]}], ",", 
     RowBox[{"\"\<Denver\>\"", "->", 
      RowBox[{"GeoPosition", "[", 
       RowBox[{"{", 
        RowBox[{"39.74", ",", 
         RowBox[{"-", "104.99"}]}], "}"}], "]"}]}], ",", 
     RowBox[{"\"\<Nairobi\>\"", "->", 
      RowBox[{"GeoPosition", "[", 
       RowBox[{"{", 
        RowBox[{
         RowBox[{"-", "1.29"}], ",", "36.82"}], "}"}], "]"}]}], ",", 
     RowBox[{"\"\<Bogota\>\"", "->", 
      RowBox[{"GeoPosition", "[", 
       RowBox[{"{", 
        RowBox[{"4.71", ",", 
         RowBox[{"-", "74.07"}]}], "}"}], "]"}]}], ",", 
     RowBox[{"\"\<Kathmandu\>\"", "->", 
      RowBox[{"GeoPosition", "[", 
       RowBox[{"{", 
        RowBox[{"27.70", ",", "85.32"}], "}"}], "]"}]}]}], "|>"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{"elevations", "=", 
   RowBox[{"Association", "@", 
    RowBox[{"Map", "[", 
     RowBox[{
      RowBox[{
       RowBox[{"#", "->", 
        RowBox[{
         RowBox[{
          RowBox[{"GEEIdentify", "[", 
           RowBox[{
            RowBox[{"cities", "[", "#", "]"}], 
            ",", "\"\<USGS/SRTMGL1_003\>\""}], "]"}], "[", "\"\<Values\>\"", 
          "]"}], "[", 
         RowBox[{"[", "1", "]"}], "]"}]}], "&"}], ",", 
      RowBox[{"Keys", "[", "cities", "]"}]}], "]"}]}]}], ";"}], "\n", 
 RowBox[{"BarChart", "[", 
  RowBox[{"elevations", ",", 
   RowBox[{"ChartLabels", "->", 
    RowBox[{"Keys", "[", "elevations", "]"}]}], ",", 
   RowBox[{"AxesLabel", "->", 
    RowBox[{"{", 
     RowBox[{"None", ",", "\"\<Elevation (m)\>\""}], "}"}]}], ",", 
   RowBox[{"PlotLabel", "->", "\"\<Capital City Elevations\>\""}], ",", 
   RowBox[{"ImageSize", "->", "Medium"}]}], "]"}]}], "Input",
 CellChangeTimes->{{3.984340360012829*^9, 3.984340360012829*^9}, {
  3.9843403984445*^9, 3.984340411156292*^9}},
 CellLabel->"In[88]:=",
 CellID->200619663,ExpressionUUID->"83ec51f1-ff66-904d-9ef8-dec321a3651c"],

