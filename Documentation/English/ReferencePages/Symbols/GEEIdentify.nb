Cell[BoxData[GridBox[{
   {Cell["      ", "ModInfo",ExpressionUUID->
     "19165bf4-34ce-314c-9b0f-6ead9ecc03b8"], Cell[TextData[{
     "For ",
     Cell[
     "IMAGE_COLLECTION", "InlineCode",ExpressionUUID->
      "45c2a37e-5911-4146-814b-eb973f41ab3d"],
     " assets, the collection is filtered spatially and temporally (last 3 \
years) before mosaicking. This prevents errors from heterogeneous band \
orderings in older images."
    }], "TableText",ExpressionUUID->"9f544892-8e0f-7d47-be30-94492e96c760"]},
   {Cell["      ", "ModInfo",ExpressionUUID->
     "ef59d611-90be-9246-8cc3-888438178efb"], Cell[TextData[{
     "Band names in the result are returned in server order (alphabetical), \
which may differ from the order specified in the ",
     Cell[
     "\"Bands\"", "InlineCode",ExpressionUUID->
      "06c5ec75-3f20-e44b-9fc5-01b402f6eadf"],
     " option."
    }], "TableText",ExpressionUUID->"63437a5e-578e-dc4e-a1ce-be314bbfd93a"]},
   {Cell["      ", "ModInfo",ExpressionUUID->
     "ac008506-c4b0-b141-8d16-227746070628"], Cell[TextData[{
     "Points over nodata regions (e.g., ocean for SRTM) return ",
     Cell[
     "Null", "InlineCode",ExpressionUUID->
      "8d63facf-dc5a-284c-8a7e-bb1d074575cb"],
     " values rather than numeric values."
    }], "TableText",ExpressionUUID->"888e3344-d28b-3e40-b0ee-ca2feac53594"]},
   {Cell["      ", "ModInfo",ExpressionUUID->
     "0a3f1be0-1545-4647-9e6b-450d5602913f"], Cell[TextData[{
     "The ",
     Cell[
     "GEEIdentify::apierr", "InlineCode",ExpressionUUID->
      "cc641815-210b-1547-a5ec-ef99f3ae9c68"],
     " message surfaces the actual GEE API error when a request fails (e.g., \
invalid asset name)."
