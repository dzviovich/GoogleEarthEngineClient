Cell["\<\
Query VIIRS nighttime radiance to compare urban vs. rural brightness:\
\>", "ExampleText",
 CellChangeTimes->{3.984342766168785*^9},
 CellID->117065327,ExpressionUUID->"7bc84242-cc2c-7a40-9154-ad4bce067a84"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", 
   RowBox[{"Urban", ":", 
    RowBox[{"central", " ", "Tokyo"}]}], "*)"}], 
  RowBox[{
   RowBox[{"urban", "=", 
    RowBox[{"GEEIdentify", "[", 
     RowBox[{
      RowBox[{"GeoPosition", "[", 
       RowBox[{"{", 
        RowBox[{"35.68", ",", "139.69"}], "}"}], "]"}], 
      ",", "\"\<NOAA/VIIRS/DNB/MONTHLY_V1/VCMSLCFG\>\"", ",", 
      RowBox[{"\"\<Bands\>\"", "->", 
       RowBox[{"{", "\"\<avg_rad\>\"", "}"}]}]}], "]"}]}], "\n", 
   RowBox[{"(*", 
    RowBox[{"Rural", ":", 
     RowBox[{"Japanese", " ", "Alps"}]}], "*)"}], "\[IndentingNewLine]", 
   RowBox[{"rural", "=", 
    RowBox[{"GEEIdentify", "[", 
     RowBox[{
      RowBox[{"GeoPosition", "[", 
       RowBox[{"{", 
        RowBox[{"36.29", ",", "137.65"}], "}"}], "]"}], 
      ",", "\"\<NOAA/VIIRS/DNB/MONTHLY_V1/VCMSLCFG\>\"", ",", 
      RowBox[{"\"\<Bands\>\"", "->", 
       RowBox[{"{", "\"\<avg_rad\>\"", "}"}]}]}], "]"}]}], "\n", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{
      RowBox[{"urban", "[", "\"\<Values\>\"", "]"}], "[", 
      RowBox[{"[", "1", "]"}], "]"}], ",", 
     RowBox[{
      RowBox[{"rural", "[", "\"\<Values\>\"", "]"}], "[", 
      RowBox[{"[", "1", "]"}], "]"}]}], "}"}], "\n", 
   RowBox[{"(*", 
    RowBox[{
     RowBox[{"e", ".", "g", "."}], ",", 
     RowBox[{"{", 
      RowBox[{"148.3", ",", "2.1"}], "}"}], "\[LongDash]", 
     RowBox[{
      RowBox[{"nanoWatts", "/", 
       RowBox[{"cm", "^", "2"}]}], "/", "sr"}]}], "*)"}]}]}]], "Input",
 CellChangeTimes->{{3.9843427730604*^9, 3.9843427730609303`*^9}},
