Cell[TextData[StyleBox["Vegetation Index (NDVI) from Sentinel-2",
 FontWeight->"Bold"]], "ExampleText",
 CellChangeTimes->{3.9843428019239635`*^9},
 CellID->567562898,ExpressionUUID->"eb407e72-9300-f24f-9ac9-2458c6ff0d67"],

Cell["\<\
Compute NDVI at a point from a cloud-filtered Sentinel-2 composite. Fetch NIR \
(B8) and Red (B4), then compute (NIR-Red)/(NIR+Red):\
\>", "ExampleText",
 CellChangeTimes->{3.9843428106783924`*^9},
 CellID->249537585,ExpressionUUID->"dadd5795-9e8d-4e46-ae82-53310e22db19"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{"result", "=", 
  RowBox[{"GEEIdentify", "[", 
   RowBox[{
    RowBox[{"GeoPosition", "[", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"-", "1.95"}], ",", "30.06"}], "}"}], "]"}], ",", 
    RowBox[{
     RowBox[{
      RowBox[{
       RowBox[{
        RowBox[{
         RowBox[{
         "GEECollection", "[", "\"\<COPERNICUS/S2_SR_HARMONIZED\>\"", "]"}], "//", 
         RowBox[{"GEEFilterDate", "[", 
          RowBox[{"\"\<2024-06-01\>\"", ",", "\"\<2024-09-01\>\""}], "]"}]}], 
        "//", 
        RowBox[{"GEEFilterBounds", "[", 
         RowBox[{"{", 
          RowBox[{"29.9", ",", 
           RowBox[{"-", "2.1"}], ",", "30.2", ",", 
           RowBox[{"-", "1.8"}]}], "}"}], "]"}]}], "//", 
       RowBox[{"GEEFilterProperty", "[", 
        RowBox[{"\"\<CLOUDY_PIXEL_PERCENTAGE\>\"", ",", "\"\<LessThan\>\"", ",",
          "10"}], "]"}]}], "//", 
      RowBox[{"GEESelectBands", "[", 
       RowBox[{"{", 
        RowBox[{"\"\<B8\>\"", ",", "\"\<B4\>\""}], "}"}], "]"}]}], "//", 
     "GEEMedian"}]}], "]"}]}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"{", 
    RowBox[{"nir", ",", "red"}], "}"}], "=", 
   RowBox[{"result", "[", "\"\<Values\>\"", "]"}]}], ";"}], "\n", 
 RowBox[{"ndvi", "=", 
  RowBox[{"N", "[", 
   RowBox[{
    RowBox[{"(", 
     RowBox[{"nir", "-", "red"}], ")"}], "/", 
    RowBox[{"(", 
     RowBox[{"nir", "+", "red"}], ")"}]}], "]"}]}], "\n", 
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{
    RowBox[{
     RowBox[{"~", "0.7"}], " ", "for", " ", "dense", " ", "forest", " ", "in",
      " ", "Nyungwe"}], ",", "Rwanda"}], "*)"}]}]}], "Input",
 CellChangeTimes->{{3.984342827650652*^9, 3.984342839075308*^9}},
 CellLabel->"In[124]:=",
 CellID->110422053,ExpressionUUID->"ce8b03b4-de81-6441-8196-042388e6763a"],

Cell[BoxData[
 RowBox[{"\[LeftAssociation]", 
  RowBox[{
   RowBox[{"\<\"Position\"\>", "\[Rule]", 
    RowBox[{"GeoPosition", "[", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"-", "1.95`"}], ",", "30.06`"}], "}"}], "]"}]}], ",", 
   RowBox[{"\<\"Values\"\>", "\[Rule]", 
    RowBox[{"{", 
     RowBox[{"1743", ",", "2298"}], "}"}]}], ",", 
   RowBox[{"\<\"Bands\"\>", "\[Rule]", 
    RowBox[{"{", 
     RowBox[{"\<\"B4_median\"\>", ",", "\<\"B8_median\"\>"}], "}"}]}]}], 
  "\[RightAssociation]"}]], "Output",
 CellChangeTimes->{{3.9843428296237335`*^9, 3.984342839951832*^9}},
 CellLabel->"Out[124]=",
 CellID->122039741,ExpressionUUID->"45546f94-7405-3341-ba2e-a9fd5f9e3a0e"],

Cell[BoxData[
 RowBox[{"-", "0.13734224201930215`"}]], "Output",
