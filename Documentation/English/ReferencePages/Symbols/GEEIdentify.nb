Cell["\<\
Query MODIS land surface temperature. Values are in Kelvin * 0.02 (scale \
factor). Convert to Celsius:\
\>", "ExampleText",
 CellChangeTimes->{3.9843428561334343`*^9},
 CellID->376099018,ExpressionUUID->"20830d79-6464-5f42-9c84-420fe949e8d6"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{"result", "=", 
  RowBox[{"GEEIdentify", "[", 
   RowBox[{
    RowBox[{"GeoPosition", "[", 
     RowBox[{"{", 
      RowBox[{"25.20", ",", "55.27"}], "}"}], "]"}], 
    ",", "\"\<MODIS/061/MOD11A1\>\"", ",", 
    RowBox[{"\"\<Bands\>\"", "->", 
     RowBox[{"{", "\"\<LST_Day_1km\>\"", "}"}]}]}], "]"}]}], "\n", 
 RowBox[{
  RowBox[{"kelvinScaled", "=", 
   RowBox[{
    RowBox[{"result", "[", "\"\<Values\>\"", "]"}], "[", 
    RowBox[{"[", "1", "]"}], "]"}]}], ";"}], "\n", 
 RowBox[{"tempC", "=", 
  RowBox[{
   RowBox[{"kelvinScaled", "*", "0.02"}], "-", "273.15"}]}], "\n", 
 RowBox[{
  RowBox[{"(*", 
   RowBox[{
   "Surface", " ", "temperature", " ", "in", " ", "Dubai", " ", "in", " ", 
    "degrees", " ", "Celsius"}], "*)"}]}]}], "Input",
