Cell["Ocean Point Returns Null", "ExampleText",
 CellChangeTimes->{{3.9843429107201405`*^9, 3.984342919181057*^9}},
 CellID->274568475,ExpressionUUID->"ebd26337-7944-5244-a61a-a83f132a6dac"],

Cell["\<\
Points over ocean (where SRTM has no data) return `Null`, which is useful for \
distinguishing land from water:\
\>", "ExampleText",
 CellChangeTimes->{3.984342927299383*^9},
 CellID->556254017,ExpressionUUID->"9f6b2835-7da7-7f47-8487-bfca09e74a6a"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{"result", "=", 
  RowBox[{"GEEIdentify", "[", 
   RowBox[{
    RowBox[{"GeoPosition", "[", 
     RowBox[{"{", 
      RowBox[{"0.0", ",", 
       RowBox[{"-", "30.0"}]}], "}"}], "]"}], 
    ",", "\"\<USGS/SRTMGL1_003\>\""}], "]"}]}], "\n", 
 RowBox[{
  RowBox[{"result", "[", "\"\<Values\>\"", "]"}], "   ", 
  RowBox[{"(*", 
   RowBox[{
    RowBox[{"{", "Null", "}"}], "\[LongDash]", 
    RowBox[{"mid", "-", 
     RowBox[{"Atlantic", " ", "ocean"}]}]}], "*)"}]}]}], "Input",
 CellChangeTimes->{{3.9843429320318832`*^9, 3.9843429320318832`*^9}},
 CellLabel->"In[130]:=",
