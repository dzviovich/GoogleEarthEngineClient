Notebook[{

Cell[CellGroupData[{
Cell["GEEConnect", "ObjectName",
 CellID->135673584,ExpressionUUID->"602986f0-22b7-c447-beef-98d3c66b10d6"],

Cell["\<\
Authenticate with Google Earth Engine using a service account key file.\
\>", "ExampleText",
 CellChangeTimes->{3.984324061287752*^9},
 CellID->341384349,ExpressionUUID->"edc78599-d51a-3948-8e6a-6dccb43f672d"],

Cell[TextData[{
 Cell["   ", "ModInfo",ExpressionUUID->"5fe84f70-5331-cd43-810e-610844f242bc"],
 Cell[BoxData[
  RowBox[{
   ButtonBox["GEEConnect",
    BaseStyle->"Link",
    ButtonData->"paclet:GoogleEarthEngineClient/ref/GEEConnect"], "[", 
   StyleBox["keyFile", "TI"], "]"}]], "InlineFormula",ExpressionUUID->
  "c9037d3d-2730-e54a-acd4-5430ceaaa44a"],
 "\[LineSeparator]Authenticate with Google Earth Engine using a service \
account JSON key file and store the connection in $GEEConnection.\n",
 Cell["   ", "ModInfo",ExpressionUUID->"0ff73411-802e-b747-b81d-32395f6fb7a2"],
 Cell[BoxData[
  RowBox[{
   ButtonBox["GEEConnect",
    BaseStyle->"Link",
    ButtonData->"paclet:GoogleEarthEngineClient/ref/GEEConnect"], "[", 
   RowBox[{
    StyleBox["keyFile", "TI"], ",", 
    StyleBox["opts", "TI"]}], "]"}]], "InlineFormula",ExpressionUUID->
  "fc565907-ca50-ed41-b3dc-64064d969cd6"],
 "\[LineSeparator]Authenticate with Google Earth Engine using a service \
account JSON key file and store the connection in $GEEConnection."
}], "Usage",
 CellChangeTimes->{{3.9841663940107784`*^9, 3.984166394535904*^9}, {
  3.9842614325078945`*^9, 3.9842614640676956`*^9}},
 CellID->357121079,ExpressionUUID->"bdbc5f2b-d1c3-d142-b928-f06ab231934a"],

Cell[TextData[{
 "- ",
 StyleBox["keyFile",
  FontSlant->"Italic"],
 " must be a path to a valid service account JSON key file containing \
\"client_email\", \"private_key\", and \"project_id\" fields.\n- On success, \
stores the connection in ",
 StyleBox["$GEEConnection",
  FontWeight->"Bold"],
 " and returns a status Association with keys \"Project\", \"Status\", and \
\"Expiry\".\n- The access token is automatically refreshed when it expires \
(1-hour lifetime).\n- All other ",
 StyleBox["GEE*",
  FontWeight->"Bold"],
 " functions require ",
 StyleBox["GEEConnect",
  FontWeight->"Bold"],
 " to be called first.\n- JWT signing requires Wolfram Language 14.0+ (",
 StyleBox["GenerateDigitalSignature",
  FontWeight->"Bold"],
 ")."
}], "Notes",
 CellChangeTimes->{{3.984261623341139*^9, 3.9842616234285088`*^9}},
 CellID->83631907,ExpressionUUID->"6b821680-c2aa-814e-9c77-6802d27aba13"],

Cell["The following options can be given: ", "Notes",
 CellID->95653413,ExpressionUUID->"9c0169d8-a546-1647-bf55-74e8d6ed4130"],

Cell[BoxData[GridBox[{
   {Cell["   ", "ModInfo",ExpressionUUID->
     "138b3be4-b492-5d41-a85d-454346bff695"], "\"\<Project\>\"", 
    ButtonBox["Automatic",
     BaseStyle->"Link"], Cell[
    "GCP project ID; auto-detected from key file when Automatic", "TableText",
     ExpressionUUID->"b155aa6d-c191-4c4b-b396-0c967166db07"]}
  }]], "3ColumnTableMod",
 CellChangeTimes->{{3.984261492191494*^9, 3.984261492191494*^9}},
 CellID->466117390,ExpressionUUID->"847233ea-fe13-ad4a-ac8e-58777b53586b"]
}, Open  ]],

