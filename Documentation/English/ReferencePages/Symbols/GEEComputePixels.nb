 CellChangeTimes->{{3.984167477221321*^9, 3.984167477443495*^9}, {
  3.9843295474892235`*^9, 3.9843295743573017`*^9}, {3.9843296886180515`*^9, 
  3.9843297508145943`*^9}, {3.9843298020289097`*^9, 3.9843298535784836`*^9}},
 CellID->662221894,ExpressionUUID->"9e7653dc-4a3e-c14d-93f8-c4ed88022604"],

Cell[TextData[{
 "- ",
 StyleBox["bbox",
  FontSlant->"Italic"],
 " is {west, south, east, north} in EPSG:4326 coordinates.\n- ",
 StyleBox["assetId",
  FontSlant->"Italic"],
 " can refer to an IMAGE or IMAGE_COLLECTION asset. Collections are \
automatically filtered to the bounding box and the most recent 3 years of \
data, then mosaicked into a single image. The spatial and temporal filtering \
ensures compatibility with collections that have heterogeneous band \
structures (e.g., Sentinel-2).\n- Returns an Image object.\n- Maximum \
uncompressed output is 48 MB per request.\n- When \"Bands\" is Automatic and \
the format is PNG or JPEG, assets with more than 3 bands are automatically \
trimmed to the first 3 bands (RGB). Single-band assets are returned as \
grayscale.\n- When no \"VisParams\" are provided, pixel data is fetched as \
GeoTIFF internally and auto-rescaled (2nd\[Dash]98th percentile) for display. \
This correctly handles nodata values and signed integer data.\n- When \
\"VisParams\" are provided, the GEE server applies the visualization and \
returns the requested format directly."
}], "Notes",
 CellChangeTimes->{{3.984321157161537*^9, 3.984321157245632*^9}},
 CellID->34434085,ExpressionUUID->"acd01f70-991f-b84b-80f1-2cbbc2a34f52"],

Cell["The following options can be given: ", "Notes",
 CellID->335132842,ExpressionUUID->"601b0746-50d1-ce40-b41c-7b199aa19553"],

Cell[BoxData[GridBox[{
   {Cell["   ", "ModInfo",ExpressionUUID->
     "56488348-e88f-d042-9ec5-ed39fcf63205"], "\"\<ImageSize\>\"", 
    RowBox[{"{", 
     RowBox[{"512", ",", " ", "512"}], "}"}], Cell[
    "output image dimensions {width, height}", "TableText",ExpressionUUID->
     "d4f91ff9-5f71-c94c-9f09-59ef10bb296a"]},
   {Cell["   ", "ModInfo",ExpressionUUID->
     "3aedabf5-4b35-3043-866a-83736cc73dbd"], "\"\<FileFormat\>\"", \
"\"\<PNG\>\"", Cell[
    "output format: \"PNG\", \"JPEG\", or \"GEO_TIFF\"", "TableText",
     ExpressionUUID->"a329971d-099c-a143-9dbb-67dabc9a7b7f"]},
   {Cell["   ", "ModInfo",ExpressionUUID->
     "dd79746a-537a-0249-aeb0-dabf7ef50fe8"], "\"\<Bands\>\"", 
    ButtonBox["Automatic",
     BaseStyle->"Link"], Cell["\<\
list of band names, or Automatic for all; auto-selects first 3 for PNG/JPEG \
when asset has >3 bands\
\>", "TableText",ExpressionUUID->"d3788a10-dbc3-3244-a4cc-a7b0bb411cd4"]},
   {Cell["   ", "ModInfo",ExpressionUUID->
     "73bd7a95-71df-2948-af3f-b8ed35e84fbb"], "\"\<CRS\>\"", "\"\<EPSG:4326\>\
\"", Cell[
    "coordinate reference system", "TableText",ExpressionUUID->
     "f0ba1f96-e181-b741-acf9-72bfa1aa3f4d"]},
   {Cell["   ", "ModInfo",ExpressionUUID->
     "729d9a8e-5c9f-2845-be9d-c77ada01d917"], "\"\<VisParams\>\"", 
    RowBox[{"<|", "|>"}], Cell["\<\
visualization parameters: \"min\", \"max\", \"palette\", \"bands\", \"gamma\"\
\>", "TableText",ExpressionUUID->"a1cd5bbd-1fe1-1f44-91d9-d70d973f1030"]},
   {Cell["   ", "ModInfo",ExpressionUUID->
     "eb205c3b-01d9-d24a-9df4-cda80d9da7ea"], "\"\<Project\>\"", 
    ButtonBox["Automatic",
     BaseStyle->"Link"], Cell[
    "GCP project ID", "TableText",ExpressionUUID->
     "e5f99b17-b0d2-0b4e-b192-1d1bf3b0e7ee"]}
  }]], "3ColumnTableMod",
