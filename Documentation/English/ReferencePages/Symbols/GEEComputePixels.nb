 InterpretationBox[Cell[
  "Interactive Examples", "ExampleSection",ExpressionUUID->
   "e328c188-cec2-614b-bde6-5d4a8f43892a"],
  $Line = 0; Null]], "ExampleSection",
 CellID->399292779,ExpressionUUID->"9301825d-97bf-d947-b0c0-cbdee93bc23d"],

Cell[CellGroupData[{

Cell[BoxData[
 InterpretationBox[Cell[
  "Neat Examples", "ExampleSection",ExpressionUUID->
   "c1f65415-8ef9-4d44-a4d6-9d99c370720d"],
  $Line = 0; Null]], "ExampleSection",
 CellID->99028686,ExpressionUUID->"a4c2c0c0-c08c-9245-b037-3b79ce6d82ee"],

Cell[TextData[StyleBox["Expression Builder Pipeline:",
 FontWeight->"Bold"]], "ExampleText",
 CellChangeTimes->{{3.9843302430400085`*^9, 3.9843302780271187`*^9}},
 CellID->459437707,ExpressionUUID->"cf4232ff-e74b-2845-a8c7-c10d5ac0c76e"],

Cell["\<\
Build a cloud-filtered Sentinel-2 median composite using the `//` pipe \
operator:\
\>", "ExampleText",
 CellChangeTimes->{{3.984330278319668*^9, 3.9843302866445885`*^9}},
 CellID->1274378,ExpressionUUID->"41f37c6b-030f-7d4d-8e7c-9abadbe283a9"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"img", "=", 
   RowBox[{"GEEComputePixels", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
       RowBox[{"-", "3.8"}], ",", "40.3", ",", 
       RowBox[{"-", "3.6"}], ",", "40.5"}], "}"}], ",", 
     RowBox[{
      RowBox[{
       RowBox[{
        RowBox[{
         RowBox[{
          RowBox[{
          "GEECollection", "[", "\"\<COPERNICUS/S2_SR_HARMONIZED\>\"", "]"}], 
          "//", 
          RowBox[{"GEEFilterDate", "[", 
           RowBox[{"\"\<2023-01-01\>\"", ",", "\"\<2024-01-01\>\""}], "]"}]}],
          "//", 
         RowBox[{"GEEFilterBounds", "[", 
          RowBox[{"{", 
           RowBox[{
            RowBox[{"-", "3.8"}], ",", "40.3", ",", 
            RowBox[{"-", "3.6"}], ",", "40.5"}], "}"}], "]"}]}], "//", 
        RowBox[{"GEEFilterProperty", "[", 
         RowBox[{"\"\<CLOUDY_PIXEL_PERCENTAGE\>\"", ",", "\"\<LessThan\>\"", ",",
           "20"}], "]"}]}], "//", 
       RowBox[{"GEESelectBands", "[", 
        RowBox[{"{", 
         RowBox[{"\"\<B4\>\"", ",", "\"\<B3\>\"", ",", "\"\<B2\>\""}], "}"}], 
        "]"}]}], "//", "GEEMedian"}], ",", 
     RowBox[{"\"\<VisParams\>\"", "->", 
      RowBox[{"<|", 
       RowBox[{
        RowBox[{"\"\<min\>\"", "->", "0"}], ",", 
        RowBox[{"\"\<max\>\"", "->", "3000"}]}], "|>"}]}]}], "]"}]}], 
  "\n"}]], "Input",
 CellChangeTimes->{{3.9843302701068573`*^9, 3.984330320736269*^9}},
 CellLabel->"In[9]:=",
 CellID->626935613,ExpressionUUID->"fe480f49-501d-ab42-b250-9b9ddfaba1bc"],

