Cell[TextData[{
 Cell["   ", "ModInfo",ExpressionUUID->"cfeb841f-37ab-3542-aeb1-689cd4fd3f69"],
 Cell[BoxData[
  RowBox[{
   ButtonBox["GEEComputePixels",
    BaseStyle->"Link",
    ButtonData->"paclet:GoogleEarthEngineClient/ref/GEEComputePixels"], "[", 
   RowBox[{
    StyleBox["bbox", "TI"], ",", 
    StyleBox["assetId", "TI"]}], "]"}]], "InlineFormula",ExpressionUUID->
  "80cba6e3-3ba8-b243-bbd7-300c83570e98"],
 "\[LineSeparator]compute pixels for a GEE image asset over the bounding box \
{west, south, east, north}. ",
 Cell[BoxData[
  ButtonBox["Return",
   BaseStyle->"Link"]], "InlineFormula",ExpressionUUID->
  "e50217fd-f7fc-ae48-bf30-c9a6291cbbea"],
 " an Image. \n",
 Cell["   ", "ModInfo",ExpressionUUID->"4a703c9f-37cd-e149-99bd-54d6b6946c0b"],
 Cell[BoxData[
  RowBox[{
   ButtonBox["GEEComputePixels",
    BaseStyle->"Link",
    ButtonData->"paclet:GoogleEarthEngineClient/ref/GEEComputePixels"], "[", 
   RowBox[{
    StyleBox["bbox", "TI"], 
    StyleBox[",", "TI"], 
    StyleBox["assetId", "TI"], ",", 
    StyleBox["opts", "TI"]}], "]"}]], "InlineFormula",ExpressionUUID->
  "17468202-eb1c-644b-8374-682fc89056d8"],
 "\[LineSeparator]compute with options \"ImageSize\", \"FileFormat\", \"Bands\
\", and \"CRS\".\n",
 Cell["   ", "ModInfo",ExpressionUUID->"61f61281-9db4-d84e-896a-8d51b6955ce6"],
 Cell[BoxData[
  RowBox[{
   ButtonBox["GEEComputePixels",
    BaseStyle->"Link",
    ButtonData->"paclet:GoogleEarthEngineClient/ref/GEEComputePixels"], "[", 
   StyleBox[
    RowBox[{"primitives", ",", "assetId"}], "TI"], "]"}]], "InlineFormula",
  ExpressionUUID->"e057dd67-113e-8e40-9daf-7e33a08efe45"],
 "\[LineSeparator]uses the same ",
 StyleBox["primitives",
  FontSlant->"Italic"],
 "as ",
 ButtonBox["GeoGraphics.",
  BaseStyle->"Link",
  ButtonData->"paclet:ref/GeoGraphics"],
 "\n",
 Cell["   ", "ModInfo",ExpressionUUID->"d9943a01-e04b-8a44-903f-a198379869df"],
 Cell[BoxData[
