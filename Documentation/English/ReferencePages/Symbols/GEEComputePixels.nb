 CellChangeTimes->{{3.9843213403278904`*^9, 3.984321350717211*^9}},
 CellLabel->"Out[12]=",
 CellID->162771374,ExpressionUUID->"7dc9fcaf-11f7-2146-bf54-d7b9b03040f6"]
}, Open  ]],

Cell["Fetch Sentinel-2 true color RGB from an ImageCollection:", "ExampleText",
 CellChangeTimes->{3.984321368427021*^9},
 CellID->250651944,ExpressionUUID->"90d8cd68-330d-2d4d-bb54-54cb4b39a2b6"]
}, Open  ]],

Cell[BoxData[
 InterpretationBox[Cell[
  "Properties & Relations", "ExampleSection",ExpressionUUID->
   "8f7af514-349b-564c-979b-a50791b89ebd"],
  $Line = 0; Null]], "ExampleSection",
 CellID->713284243,ExpressionUUID->"4acf6346-8d8c-4045-b5a0-6c9cc2003697"],

Cell[CellGroupData[{

Cell[BoxData[
 InterpretationBox[Cell[
  "Possible Issues", "ExampleSection",ExpressionUUID->
   "e92ed760-6e09-6349-96b8-814294b4bc19"],
  $Line = 0; Null]], "ExampleSection",
 CellID->344610947,ExpressionUUID->"f28d3c60-521f-3347-8e2f-bbf076ceb0bd"],

Cell["-Requests exceeding 48 MB uncompressed will fail . ", "ExampleText",
 CellChangeTimes->{{3.9843301031953545`*^9, 3.9843301160382843`*^9}},
 CellID->471461747,ExpressionUUID->"fc0cabca-8923-6d4e-becd-51a0912bd2ee"],

Cell["\<\
-Band names must match those in the asset . -PNG and JPEG formats require 1 \
or 3 bands . If an asset has more bands and no explicit  \"Bands\"  selection \
is provided, the first 3 bands are auto - selected . \
\>", "ExampleText",
 CellChangeTimes->{{3.9843301031953545`*^9, 3.984330124904621*^9}, {
  3.984330156441065*^9, 3.9843301564455776`*^9}},
 CellID->80778161,ExpressionUUID->"cf7c8dc6-d0d3-994c-bbe4-8925603ef040"],

Cell[TextData[{
 "-The ",
 StyleBox["GEEComputePixels::apierr ",
  FontSlant->"Italic"],
 "message surfaces the actual GEE API error when a request fails . "
}], "ExampleText",
 CellChangeTimes->{{3.9843301031953545`*^9, 3.9843301564525795`*^9}},
 CellID->71294867,ExpressionUUID->"c3b8d33b-6446-dc40-956e-645c85e97289"],

Cell["\<\
-The  \"CRS\"  option controls the output projection metadata but the \
bounding box is always specified in EPSG : 4326 (lat/lon) coordinates . \
\>", "ExampleText",
 CellChangeTimes->{{3.9843301031953545`*^9, 3.9843301564605255`*^9}},
 CellID->267197211,ExpressionUUID->"25a37d8b-f5c9-184b-8f83-3f19143ca80d"],

Cell["\<\
-For IMAGE_COLLECTION assets, the collection is filtered by Filter . \
intersects (spatial) and Filter . dateRangeContains (last 3 years) before \
mosaicking . This prevents errors from heterogeneous band orderings in older \
images .\
\>", "ExampleText",
 CellChangeTimes->{{3.9843301031953545`*^9, 3.984330111631855*^9}, {
  3.9843301564645367`*^9, 3.9843301564815464`*^9}},
 CellID->524063058,ExpressionUUID->"502f3fd9-cb31-d441-802e-8d36594fdeb0"]
}, Open  ]],

