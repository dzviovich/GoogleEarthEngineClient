Cell[CellGroupData[{
Cell["GEEGetSamples", "ObjectName",
 CellID->109725863,ExpressionUUID->"ee66ad5b-7ab3-5a40-9fa5-c39774d3d9e7"],

Cell["\<\
Extract pixel values at multiple GeoPosition points from a GEE image asset.\
\>", "ExampleText",
 CellChangeTimes->{3.9843431275692883`*^9},
 CellID->209324202,ExpressionUUID->"01d81eb0-a1da-1e41-a404-b26a2222beaa"],

Cell[TextData[{
 Cell["   ", "ModInfo",ExpressionUUID->"7bd13010-bd00-464f-9fe7-a80709e4b4b3"],
 Cell[BoxData[
  RowBox[{
   ButtonBox["GEEGetSamples",
    BaseStyle->"Link",
    ButtonData->"paclet:GoogleEarthEngineClient/ref/GEEGetSamples"], "[", 
   RowBox[{
    StyleBox["points", "TI"], ",", 
    StyleBox["assetId", "TI"]}], "]"}]], "InlineFormula",ExpressionUUID->
  "97c0014f-ba6e-8a44-ade1-17fe334ec7ee"],
 "\[LineSeparator]extract pixel values at a list of ",
 Cell[BoxData[
  ButtonBox["GeoPosition",
   BaseStyle->"Link"]], "InlineFormula",ExpressionUUID->
  "ee882494-23ae-3f4e-a910-d773881fbdbc"],
 " ",
 Cell[BoxData[
  StyleBox["points", "TI"]], "InlineFormula",ExpressionUUID->
  "cc5d5859-5c93-164c-a9e9-bbc865dc1930"],
 " from a GEE image asset. ",
 Cell[BoxData[
  ButtonBox["Return",
   BaseStyle->"Link"]], "InlineFormula",ExpressionUUID->
  "ddb9982d-c276-3841-9dd7-e3f137077ac6"],
 " a list of Associations with keys \"Position\" and \"Values\". \n",
 Cell["   ", "ModInfo",ExpressionUUID->"c24c0a89-b031-bc4e-8692-506b9360788e"],
 Cell[BoxData[
  RowBox[{
   ButtonBox["GEEGetSamples",
    BaseStyle->"Link",
    ButtonData->"paclet:GoogleEarthEngineClient/ref/GEEGetSamples"], "[", 
   RowBox[{
    StyleBox["points", "TI"], ",", 
    StyleBox["assetId", "TI"], ",", 
    StyleBox["opts", "TI"]}], "]"}]], "InlineFormula",ExpressionUUID->
  "03a3e4da-57f6-8d44-a61b-403a552b6d64"],
 "\[LineSeparator]extract with option \"Bands\"."
}], "Usage",
 CellChangeTimes->{{3.98416753085108*^9, 3.984167531069992*^9}},
 CellID->324583524,ExpressionUUID->"b41d59ea-88f1-ce45-9243-970cf1fd8ac9"],

Cell["The following options can be given: ", "Notes",
 CellID->259053299,ExpressionUUID->"b00fb6fb-d466-ca44-a8e7-c7c4152b9f01"],

Cell[BoxData[GridBox[{
   {Cell["   ", "ModInfo",ExpressionUUID->
     "c5a3af67-a1f4-c940-9e8e-95be36a37005"], "\"\<Bands\>\"", 
    ButtonBox["Automatic",
     BaseStyle->"Link"], Cell[
