Cell[TextData[StyleBox["Surface Temperature at Weather Station Locations",
 FontWeight->"Bold"]], "ExampleText",
 CellChangeTimes->{3.984343562275997*^9},
 CellID->9489526,ExpressionUUID->"97bff335-b8f0-cc45-bcfc-bf3019906d61"],

Cell["\<\
Sample MODIS land surface temperature at known weather station coordinates to \
validate satellite-derived temperatures. Values are Kelvin \[Times] 0.02:\
\>", "ExampleText",
 CellChangeTimes->{3.984343569501499*^9},
 CellID->364799054,ExpressionUUID->"fe123c98-eb27-3345-8854-7ebb62e7bca9"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", 
   RowBox[{
   "Weather", " ", "stations", " ", "across", " ", "the", " ", "US", " ", 
    "Southwest"}], "*)"}], 
  RowBox[{
   RowBox[{
    RowBox[{"stations", "=", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"GeoPosition", "[", 
        RowBox[{"{", 
         RowBox[{"33.45", ",", 
          RowBox[{"-", "112.07"}]}], "}"}], "]"}], ",", 
       RowBox[{"(*", "Phoenix", "*)"}], 
       RowBox[{"GeoPosition", "[", 
        RowBox[{"{", 
         RowBox[{"36.17", ",", 
          RowBox[{"-", "115.14"}]}], "}"}], "]"}], ",", 
       RowBox[{"(*", 
        RowBox[{"Las", " ", "Vegas"}], "*)"}], 
       RowBox[{"GeoPosition", "[", 
        RowBox[{"{", 
         RowBox[{"32.22", ",", 
          RowBox[{"-", "110.93"}]}], "}"}], "]"}], ",", 
       RowBox[{"(*", "Tucson", "*)"}], 
       RowBox[{"GeoPosition", "[", 
        RowBox[{"{", 
         RowBox[{"35.08", ",", 
          RowBox[{"-", "106.65"}]}], "}"}], "]"}]}], "   ", 
      RowBox[{"(*", "Albuquerque", "*)"}], "}"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"results", "=", 
     RowBox[{"GEEGetSamples", "[", 
      RowBox[{"stations", ",", "\"\<MODIS/061/MOD11A1\>\"", ",", 
       RowBox[{"\"\<Bands\>\"", "->", 
        RowBox[{"{", "\"\<LST_Day_1km\>\"", "}"}]}]}], "]"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"tempC", "=", 
     RowBox[{"Map", "[", 
      RowBox[{
       RowBox[{
        RowBox[{"If", "[", 
         RowBox[{
          RowBox[{
           RowBox[{
            RowBox[{"#", "[", "\"\<Values\>\"", "]"}], "[", 
            RowBox[{"[", "1", "]"}], "]"}], "===", "Null"}], ",", 
          RowBox[{"Missing", "[", "\"\<NoData\>\"", "]"}], ",", 
          RowBox[{
           RowBox[{
            RowBox[{
             RowBox[{"#", "[", "\"\<Values\>\"", "]"}], "[", 
             RowBox[{"[", "1", "]"}], "]"}], "*", "0.02"}], "-", "273.15"}]}],
          "]"}], "&"}], ",", "results"}], "]"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"labels", "=", 
     RowBox[{"{", 
      RowBox[{"\"\<Phoenix\>\"", ",", "\"\<Las Vegas\>\"", 
       ",", "\"\<Tucson\>\"", ",", "\"\<Albuquerque\>\""}], "}"}]}], ";"}], "\n", 
   RowBox[{"TableForm", "[", 
    RowBox[{
     RowBox[{"Transpose", "[", 
      RowBox[{"{", 
       RowBox[{"labels", ",", 
        RowBox[{"Round", "[", 
         RowBox[{"tempC", ",", "0.1"}], "]"}]}], "}"}], "]"}], ",", 
     RowBox[{"TableHeadings", "->", 
      RowBox[{"{", 
       RowBox[{"None", ",", 
        RowBox[{"{", 
