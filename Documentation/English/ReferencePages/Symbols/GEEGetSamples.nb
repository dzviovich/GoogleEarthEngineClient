Cell[TextData[StyleBox["Handling Nodata: Coastal Transect",
 FontWeight->"Bold"]], "ExampleText",
 CellChangeTimes->{3.9843436802107697`*^9},
 CellID->239166642,ExpressionUUID->"02677c92-f848-9447-b800-5ac213ce8b10"],

Cell["\<\
Sample elevation along a transect that crosses from land to ocean. Ocean \
pixels return `Null` in SRTM, useful for detecting coastlines \
programmatically:\
\>", "ExampleText",
 CellChangeTimes->{3.984343688195816*^9},
 CellID->775200867,ExpressionUUID->"0c69b49c-57fe-c14c-9807-da101f9255b3"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", 
   RowBox[{
   "Transect", " ", "from", " ", "Miami", " ", "Beach", " ", "into", " ", 
    "the", " ", "Atlantic"}], "*)"}], 
  RowBox[{
   RowBox[{
    RowBox[{"transect", "=", 
     RowBox[{"Table", "[", 
      RowBox[{
       RowBox[{"GeoPosition", "[", 
        RowBox[{"{", 
         RowBox[{"25.79", ",", "lon"}], "}"}], "]"}], ",", 
       RowBox[{"{", 
        RowBox[{"lon", ",", 
         RowBox[{"-", "80.15"}], ",", 
         RowBox[{"-", "79.95"}], ",", "0.02"}], "}"}]}], "]"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"results", "=", 
     RowBox[{"GEEGetSamples", "[", 
      RowBox[{"transect", ",", "\"\<USGS/SRTMGL1_003\>\""}], "]"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"Table", "[", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{
        RowBox[{
         RowBox[{
          RowBox[{"results", "[", 
           RowBox[{"[", "i", "]"}], "]"}], "[", "\"\<Position\>\"", "]"}], "[", 
         RowBox[{"[", 
          RowBox[{"1", ",", "2"}], "]"}], "]"}], ",", 
        RowBox[{
         RowBox[{
          RowBox[{"results", "[", 
           RowBox[{"[", "i", "]"}], "]"}], "[", "\"\<Values\>\"", "]"}], "[", 
         RowBox[{"[", "1", "]"}], "]"}]}], "}"}], ",", 
      RowBox[{"{", 
       RowBox[{"i", ",", 
        RowBox[{"Length", "[", "results", "]"}]}], "}"}]}], "]"}], "//", 
    "TableForm"}], "\n", 
   RowBox[{"(*", 
    RowBox[{
     RowBox[{
     "Land", " ", "points", " ", "show", " ", "small", " ", "positive", " ", 
      "values"}], ";", 
     RowBox[{"ocean", " ", "points", " ", "show", " ", "Null"}]}], 
    "*)"}]}]}]], "Input",
 CellChangeTimes->{{3.9843437052122364`*^9, 3.9843437052122364`*^9}},
 CellLabel->"In[180]:=",
 CellID->105140764,ExpressionUUID->"171ad87b-61aa-b540-922d-92b847f9767e"],

