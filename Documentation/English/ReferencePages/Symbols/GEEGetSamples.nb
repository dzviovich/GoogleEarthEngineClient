   "d9aa6e12-6d3e-8043-9f4d-5b5243870686"],
  $Line = 0; Null]], "ExampleSection",
 CellID->18594466,ExpressionUUID->"eacd5b84-ff97-274d-a077-e2c7e1a76ae0"],

Cell["Land Cover at Sampling Stations", "ExampleText",
 CellChangeTimes->{3.984343366918583*^9},
 CellID->263822614,ExpressionUUID->"6457174f-92ba-5643-9de3-97b53db07ccd"],

Cell["\<\
Identify ESA WorldCover land class at field stations to verify ground truth. \
Class IDs: 10=Tree, 20=Shrub, 30=Grass, 40=Crop, 50=Built-up, 60=Bare, \
80=Water:\
\>", "ExampleText",
 CellChangeTimes->{3.9843434035499897`*^9},
 CellID->299343439,ExpressionUUID->"7dd95b83-c369-e94b-8c22-d75f4e787d6b"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"stations", "=", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"GeoPosition", "[", 
      RowBox[{"{", 
       RowBox[{"52.52", ",", "13.40"}], "}"}], "]"}], ",", 
     RowBox[{"(*", 
      RowBox[{"Berlin", "\[LongDash]", 
       RowBox[{
        RowBox[{"expect", " ", "50", " ", "Built"}], "-", "up"}]}], "*)"}], 
     RowBox[{"GeoPosition", "[", 
      RowBox[{"{", 
       RowBox[{"47.37", ",", "8.54"}], "}"}], "]"}], ",", 
     RowBox[{"(*", 
      RowBox[{"Zurich", "\[LongDash]", 
       RowBox[{
        RowBox[{"expect", " ", "50", " ", "Built"}], "-", "up"}]}], "*)"}], 
     RowBox[{"GeoPosition", "[", 
      RowBox[{"{", 
       RowBox[{"46.95", ",", "7.45"}], "}"}], "]"}], ",", 
     RowBox[{"(*", 
      RowBox[{
       RowBox[{"Swiss", " ", "farmland"}], "\[LongDash]", 
       RowBox[{"expect", " ", "40", " ", "Crop"}]}], "*)"}], 
     RowBox[{"GeoPosition", "[", 
      RowBox[{"{", 
       RowBox[{"46.60", ",", "7.10"}], "}"}], "]"}]}], "     ", 
    RowBox[{"(*", 
     RowBox[{
      RowBox[{"Swiss", " ", "Alps", " ", "forest"}], "\[LongDash]", 
      RowBox[{"expect", " ", "10", " ", "Tree"}]}], "*)"}], "}"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{"results", "=", 
   RowBox[{"GEEGetSamples", "[", 
    RowBox[{"stations", ",", 
     RowBox[{
      RowBox[{
       RowBox[{
        RowBox[{"GEECollection", "[", "\"\<ESA/WorldCover/v200\>\"", "]"}], "//", 
        RowBox[{"GEEFilterDate", "[", 
         RowBox[{"\"\<2021-01-01\>\"", ",", "\"\<2022-01-01\>\""}], "]"}]}], "//", 
       RowBox[{"GEESelectBands", "[", 
        RowBox[{"{", "\"\<Map\>\"", "}"}], "]"}]}], "//", "GEEMosaic"}]}], 
    "]"}]}], ";"}], "\n", 
 RowBox[{"classIds", "=", 
  RowBox[{"First", "/@", 
   RowBox[{"(", 
    RowBox[{
     RowBox[{
      RowBox[{"#", "[", "\"\<Values\>\"", "]"}], "&"}], "/@", "results"}], 
    ")"}]}]}], "\n", 
 RowBox[{
  RowBox[{"(*", 
   RowBox[{
    RowBox[{"e", ".", "g", "."}], ",", 
    RowBox[{"{", 
     RowBox[{"50", ",", "50", ",", "40", ",", "10"}], "}"}]}], 
   "*)"}]}]}], "Input",
 CellChangeTimes->{{3.984343410957569*^9, 3.9843434109585724`*^9}},
 CellLabel->"In[147]:=",
 CellID->30651423,ExpressionUUID->"abcfb652-c03d-eb4f-8297-a93fc5553649"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{"10", ",", "50", ",", "10", ",", "40"}], "}"}]], "Output",
 CellChangeTimes->{3.9843434142106686`*^9},
 CellLabel->"Out[149]=",
 CellID->29093613,ExpressionUUID->"ae10d116-9287-4e4b-932f-dd65ac3a5f43"]
}, Open  ]],

Cell["NDVI Transect Across a Vegetation Gradient", "ExampleText",
 CellChangeTimes->{3.984343451185961*^9},
 CellID->8489179,ExpressionUUID->"faba84f9-6aed-c841-929f-dc4230ef8cd3"],

Cell["\<\
Sample Sentinel-2 NIR and Red along a transect from Spanish plateau to \
forested mountains to compute NDVI at each point. NDVI near 0 = bare soil, \
near 1 = dense vegetation.\
\>", "ExampleText",
 CellChangeTimes->{
  3.9843434572612743`*^9, {3.984343604041897*^9, 3.9843436165544796`*^9}},
 CellID->163158166,ExpressionUUID->"9e7ab62c-a2de-d046-a7d4-1917cd9dc96e"],

Cell["\<\
Note: bands are returned in alphabetical order (B4 before B8), not the order \
specified in `GEESelectBands`. Destructure as `{red, nir}` accordingly:\
\>", "ExampleText",
 CellChangeTimes->{
  3.9843434572612743`*^9, {3.984343604041897*^9, 3.98434361430229*^9}},
 CellID->31787889,ExpressionUUID->"f768714a-c1a0-874d-870a-bc87e047c772"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", 
   RowBox[{
    RowBox[{"Transect", " ", "from", " ", "dry", " ", "Castilla"}], "-", 
    RowBox[{
    "La", " ", "Mancha", " ", "north", " ", "into", " ", "the", " ", 
     "Cantabrian", " ", "forests"}]}], "*)"}], 
  RowBox[{
   RowBox[{
    RowBox[{"transect", "=", 
     RowBox[{"Table", "[", 
      RowBox[{
       RowBox[{"GeoPosition", "[", 
        RowBox[{"{", 
         RowBox[{"lat", ",", 
          RowBox[{"-", "3.7"}]}], "}"}], "]"}], ",", 
       RowBox[{"{", 
        RowBox[{"lat", ",", "39.0", ",", "43.0", ",", "0.5"}], "}"}]}], 
      "]"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"results", "=", 
     RowBox[{"GEEGetSamples", "[", 
      RowBox[{"transect", ",", 
       RowBox[{
        RowBox[{
         RowBox[{
          RowBox[{
           RowBox[{
            RowBox[{
            "GEECollection", "[", "\"\<COPERNICUS/S2_SR_HARMONIZED\>\"", 
             "]"}], "//", 
            RowBox[{"GEEFilterDate", "[", 
             RowBox[{"\"\<2024-05-01\>\"", ",", "\"\<2024-09-01\>\""}], 
             "]"}]}], "//", 
           RowBox[{"GEEFilterBounds", "[", 
            RowBox[{"{", 
             RowBox[{
              RowBox[{"-", "4.2"}], ",", "38.5", ",", 
              RowBox[{"-", "3.2"}], ",", "43.5"}], "}"}], "]"}]}], "//", 
          RowBox[{"GEEFilterProperty", "[", 
           
           RowBox[{"\"\<CLOUDY_PIXEL_PERCENTAGE\>\"", ",", "\"\<LessThan\>\"",
             ",", "15"}], "]"}]}], "//", 
         RowBox[{"GEESelectBands", "[", 
          RowBox[{"{", 
           RowBox[{"\"\<B8\>\"", ",", "\"\<B4\>\""}], "}"}], "]"}]}], "//", 
        "GEEMedian"}]}], "]"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"ndvi", "=", 
     RowBox[{"Map", "[", 
      RowBox[{
       RowBox[{
        RowBox[{"Module", "[", 
         RowBox[{
          RowBox[{"{", 
           RowBox[{"red", ",", "nir"}], "}"}], ",", 
          RowBox[{"(*", 
           RowBox[{
            RowBox[{
             RowBox[{"Alphabetical", " ", 
              RowBox[{"order", ":", "B4"}]}], "=", 
             RowBox[{"Red", " ", "first"}]}], ",", 
            RowBox[{"B8", "=", 
             RowBox[{"NIR", " ", "second"}]}]}], "*)"}], 
          RowBox[{
           RowBox[{
            RowBox[{"{", 
             RowBox[{"red", ",", "nir"}], "}"}], "=", 
            RowBox[{"#", "[", "\"\<Values\>\"", "]"}]}], ";", 
           "\[IndentingNewLine]", 
           RowBox[{"If", "[", 
            RowBox[{
             RowBox[{"AnyTrue", "[", 
              RowBox[{
               RowBox[{"{", 
                RowBox[{"nir", ",", "red"}], "}"}], ",", 
               RowBox[{"(", 
                RowBox[{
                 RowBox[{"#", "===", "Null"}], "&"}], ")"}]}], "]"}], ",", 
             RowBox[{"Missing", "[", "\"\<NoData\>\"", "]"}], ",", 
             RowBox[{
              RowBox[{"(", 
               RowBox[{"nir", "-", "red"}], ")"}], "/", 
              RowBox[{"(", 
               RowBox[{"nir", "+", "red"}], ")"}]}]}], "]"}]}]}], "]"}], 
        "&"}], ",", "results"}], "]"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"lats", "=", 
     RowBox[{"First", "/@", 
      RowBox[{"(", 
       RowBox[{"First", "/@", "transect"}], ")"}]}]}], ";"}], "\n", 
   RowBox[{"ListLinePlot", "[", 
    RowBox[{
     RowBox[{"Transpose", "[", 
      RowBox[{"{", 
       RowBox[{"lats", ",", "ndvi"}], "}"}], "]"}], ",", 
     RowBox[{
     "PlotLabel", 
      "->", "\"\<NDVI Transect: Spanish Plateau to Cantabrian Forest\>\""}], ",", 
     RowBox[{"AxesLabel", "->", 
      RowBox[{"{", 
       RowBox[{"\"\<Latitude (\[Degree]N)\>\"", ",", "\"\<NDVI\>\""}], 
       "}"}]}], ",", 
     RowBox[{"PlotRange", "->", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"-", "0.1"}], ",", "1"}], "}"}]}], ",", 
     RowBox[{"ImageSize", "->", "Medium"}], ",", 
     RowBox[{"PlotTheme", "->", "\"\<Detailed\>\""}]}], "]"}]}]}]], "Input",
 CellChangeTimes->{{3.984343626145174*^9, 3.984343666260025*^9}},
 CellLabel->"In[175]:=",
 CellID->578276165,ExpressionUUID->"09f4c7ca-d71f-dd4f-af82-e65604e7b74d"],

