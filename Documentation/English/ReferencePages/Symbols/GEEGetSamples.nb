  }]], "3ColumnTableMod",
 CellChangeTimes->{{3.9843431577670937`*^9, 3.9843431652134113`*^9}, {
  3.9843432923244724`*^9, 3.9843432923294716`*^9}},
 CellID->653479007,ExpressionUUID->"bea94937-ed4e-524b-b127-725c7ccd2612"],

Cell["\<\
- points is a list of GeoPosition objects.
- Returns a list of Associations, each with keys \"Position\" and \"Values\".
- Delegates to GEEIdentify for each point.\
\>", "ExampleText",
 CellChangeTimes->{
  3.9843431474160576`*^9, {3.9843432923334713`*^9, 3.984343292372902*^9}},
 CellID->67164155,ExpressionUUID->"6cb5a24b-a010-b34e-a401-f7bf06c26a24"]
}, Open  ]],

