Cell["Elevation Profile Along a Hiking Trail", "ExampleText",
 CellChangeTimes->{3.9843433113158016`*^9},
 CellID->559075587,ExpressionUUID->"ee40a974-5e56-0043-afc7-3d7d03eae9a5"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", 
   RowBox[{
   "Points", " ", "along", " ", "the", " ", "Appalachian", " ", "Trail", " ", 
    "near", " ", "Clingmans", " ", "Dome"}], "*)"}], 
  RowBox[{
   RowBox[{
    RowBox[{"trailPoints", "=", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"GeoPosition", "[", 
        RowBox[{"{", 
         RowBox[{"35.559", ",", 
          RowBox[{"-", "83.500"}]}], "}"}], "]"}], ",", 
       RowBox[{"GeoPosition", "[", 
        RowBox[{"{", 
         RowBox[{"35.562", ",", 
          RowBox[{"-", "83.495"}]}], "}"}], "]"}], ",", 
       RowBox[{"GeoPosition", "[", 
        RowBox[{"{", 
         RowBox[{"35.564", ",", 
          RowBox[{"-", "83.490"}]}], "}"}], "]"}], ",", 
       RowBox[{"GeoPosition", "[", 
        RowBox[{"{", 
         RowBox[{"35.567", ",", 
          RowBox[{"-", "83.485"}]}], "}"}], "]"}], ",", 
       RowBox[{"GeoPosition", "[", 
        RowBox[{"{", 
         RowBox[{"35.570", ",", 
          RowBox[{"-", "83.480"}]}], "}"}], "]"}], ",", 
       RowBox[{"GeoPosition", "[", 
        RowBox[{"{", 
         RowBox[{"35.573", ",", 
          RowBox[{"-", "83.475"}]}], "}"}], "]"}]}], "}"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"results", "=", 
     RowBox[{"GEEGetSamples", "[", 
      RowBox[{"trailPoints", ",", "\"\<USGS/SRTMGL1_003\>\""}], "]"}]}], 
    ";"}], "\n", 
   RowBox[{
    RowBox[{"elevations", "=", 
     RowBox[{"First", "/@", 
      RowBox[{"(", 
       RowBox[{
        RowBox[{
         RowBox[{"#", "[", "\"\<Values\>\"", "]"}], "&"}], "/@", "results"}], 
       ")"}]}]}], ";"}], "\n", 
   RowBox[{"ListLinePlot", "[", 
    RowBox[{"elevations", ",", 
     RowBox[{
     "PlotLabel", "->", "\"\<Appalachian Trail Elevation Profile\>\""}], ",", 
     RowBox[{"AxesLabel", "->", 
      RowBox[{"{", 
       RowBox[{"\"\<Sample Point\>\"", ",", "\"\<Elevation (m)\>\""}], 
       "}"}]}], ",", 
     RowBox[{"Filling", "->", "Bottom"}]}], "]"}]}]}]], "Input",
 CellChangeTimes->{{3.9843433155730114`*^9, 3.9843433155730114`*^9}},
 CellLabel->"In[135]:=",
 CellID->177231990,ExpressionUUID->"b103f09c-9290-494c-abd5-02dc8665f0dc"],

