Cell["Compare Nighttime Brightness Across Cities", "ExampleText",
 CellChangeTimes->{3.984343329902607*^9},
 CellID->16022157,ExpressionUUID->"0d8a1d4c-8769-b143-96a7-4970055d4835"],

Cell["\<\
Sample VIIRS nighttime radiance at city centers to compare urbanization \
levels:\
\>", "ExampleText",
 CellChangeTimes->{3.98434333588904*^9},
 CellID->44289131,ExpressionUUID->"f88d4c6e-366b-7145-a855-5edbbffc13b3"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"cities", "=", 
   RowBox[{"<|", 
    RowBox[{
     RowBox[{"\"\<Tokyo\>\"", "->", 
      RowBox[{"GeoPosition", "[", 
       RowBox[{"{", 
        RowBox[{"35.68", ",", "139.69"}], "}"}], "]"}]}], ",", 
     RowBox[{"\"\<London\>\"", "->", 
      RowBox[{"GeoPosition", "[", 
       RowBox[{"{", 
        RowBox[{"51.51", ",", 
         RowBox[{"-", "0.13"}]}], "}"}], "]"}]}], ",", 
     RowBox[{"\"\<Cairo\>\"", "->", 
      RowBox[{"GeoPosition", "[", 
       RowBox[{"{", 
        RowBox[{"30.04", ",", "31.24"}], "}"}], "]"}]}], ",", 
     RowBox[{"\"\<S\[ATilde]o Paulo\>\"", "->", 
      RowBox[{"GeoPosition", "[", 
       RowBox[{"{", 
        RowBox[{
         RowBox[{"-", "23.55"}], ",", 
         RowBox[{"-", "46.63"}]}], "}"}], "]"}]}], ",", 
     RowBox[{"\"\<Nairobi\>\"", "->", 
      RowBox[{"GeoPosition", "[", 
       RowBox[{"{", 
        RowBox[{
         RowBox[{"-", "1.29"}], ",", "36.82"}], "}"}], "]"}]}]}], "|>"}]}], 
  ";"}], "\n", 
 RowBox[{
  RowBox[{"results", "=", 
   RowBox[{"GEEGetSamples", "[", 
    RowBox[{
     RowBox[{"Values", "[", "cities", "]"}], 
     ",", "\"\<NOAA/VIIRS/DNB/MONTHLY_V1/VCMSLCFG\>\"", ",", 
     RowBox[{"\"\<Bands\>\"", "->", 
      RowBox[{"{", "\"\<avg_rad\>\"", "}"}]}]}], "]"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{"radiance", "=", 
   RowBox[{"AssociationThread", "[", 
    RowBox[{
     RowBox[{"Keys", "[", "cities", "]"}], ",", 
     RowBox[{"First", "/@", 
      RowBox[{"(", 
       RowBox[{
        RowBox[{
         RowBox[{"#", "[", "\"\<Values\>\"", "]"}], "&"}], "/@", "results"}], 
       ")"}]}]}], "]"}]}], ";"}], "\n", 
 RowBox[{"BarChart", "[", 
  RowBox[{"radiance", ",", 
   RowBox[{"ChartLabels", "->", 
    RowBox[{"Keys", "[", "radiance", "]"}]}], ",", 
   RowBox[{"AxesLabel", "->", 
    RowBox[{"{", 
     RowBox[{"None", ",", "\"\<Radiance (nW/cm\.b2/sr)\>\""}], "}"}]}], ",", 
   RowBox[{"PlotLabel", "->", "\"\<Nighttime Light Intensity\>\""}], ",", 
   RowBox[{"ImageSize", "->", "Medium"}]}], "]"}]}], "Input",
 CellChangeTimes->{{3.9843433409126625`*^9, 3.9843433585988007`*^9}},
 CellLabel->"In[143]:=",
 CellID->171524867,ExpressionUUID->"50f44702-2c01-3941-981d-6695a14ccc21"],

