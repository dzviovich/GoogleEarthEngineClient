Cell["Batch Sampling with Generated Grid", "ExampleText",
 CellChangeTimes->{3.9843437245138264`*^9},
 CellID->674397739,ExpressionUUID->"27edc7bf-7731-7d42-9b50-de67d782aadd"],

Cell["\<\
Generate a regular grid of sample points over an area and extract values. \
Useful for creating a coarse raster from point queries:\
\>", "ExampleText",
 CellChangeTimes->{3.9843437336278267`*^9},
 CellID->366530040,ExpressionUUID->"50e8ecb1-059f-6c41-82c4-224bb012bce1"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", 
   RowBox[{
   "5", "x5", " ", "grid", " ", "over", " ", "the", " ", "Swiss", " ", 
    "Alps"}], "*)"}], 
  RowBox[{
   RowBox[{
    RowBox[{"points", "=", 
     RowBox[{"Flatten", "[", 
      RowBox[{
       RowBox[{"Table", "[", 
        RowBox[{
         RowBox[{"GeoPosition", "[", 
          RowBox[{"{", 
           RowBox[{"lat", ",", "lon"}], "}"}], "]"}], ",", 
         RowBox[{"{", 
          RowBox[{"lat", ",", "46.2", ",", "47.0", ",", "0.2"}], "}"}], ",", 
         RowBox[{"{", 
          RowBox[{"lon", ",", "7.0", ",", "8.6", ",", "0.4"}], "}"}]}], "]"}],
        ",", "1"}], "]"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"results", "=", 
     RowBox[{"GEEGetSamples", "[", 
      RowBox[{"points", ",", "\"\<USGS/SRTMGL1_003\>\""}], "]"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"elevations", "=", 
     RowBox[{"First", "/@", 
      RowBox[{"(", 
       RowBox[{
        RowBox[{
         RowBox[{"#", "[", "\"\<Values\>\"", "]"}], "&"}], "/@", "results"}], 
       ")"}]}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"grid", "=", 
     RowBox[{"Partition", "[", 
      RowBox[{"elevations", ",", "5"}], "]"}]}], ";"}], "\n", 
   RowBox[{"ListDensityPlot", "[", 
    RowBox[{
     RowBox[{"Flatten", "[", 
      RowBox[{
       RowBox[{"Table", "[", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{"j", ",", 
           RowBox[{"5", "-", "i", "+", "1"}], ",", 
           RowBox[{"grid", "[", 
            RowBox[{"[", 
             RowBox[{"i", ",", "j"}], "]"}], "]"}]}], "}"}], ",", 
         RowBox[{"{", 
          RowBox[{"i", ",", 
           RowBox[{"Length", "[", "grid", "]"}]}], "}"}], ",", 
         RowBox[{"{", 
          RowBox[{"j", ",", 
           RowBox[{"Length", "[", 
            RowBox[{"grid", "[", 
             RowBox[{"[", "1", "]"}], "]"}], "]"}]}], "}"}]}], "]"}], ",", 
       "1"}], "]"}], ",", 
     RowBox[{"ColorFunction", "->", "\"\<AlpineColors\>\""}], ",", 
     RowBox[{"PlotLegends", "->", "Automatic"}], ",", 
     RowBox[{"PlotLabel", "->", "\"\<Swiss Alps Elevation Grid (m)\>\""}]}], 
    "]"}]}]}]], "Input",
 CellChangeTimes->{{3.9843439169296303`*^9, 3.9843439169296303`*^9}},
 CellLabel->"In[193]:=",
 CellID->221736649,ExpressionUUID->"4b2c7d0b-6679-374f-821f-28c9004a7d63"],

