Notebook[{

Cell[CellGroupData[{
Cell["Expression Builders", "Title",
 CellChangeTimes->{{3.984350416710005*^9, 3.984350419884964*^9}},
 CellID->133581410,ExpressionUUID->"b4511476-a964-1444-ba8c-44f9f8d73709"],

Cell["\<\
The expression builder functions share a common pattern and are documented \
together as a group. Each function has a direct form and (where applicable) \
an operator form for use with //.\
\>", "Text",
 CellChangeTimes->{
  3.984349546149084*^9, {3.9843504245641975`*^9, 3.984350424564705*^9}, {
   3.984351187452202*^9, 3.9843511874572086`*^9}},
 CellID->178130570,ExpressionUUID->"b4979a4b-8b03-d543-ae9b-43df3254a59f"],

Cell[BoxData[GridBox[{
   {
    RowBox[{"GEECollection", "[", 
     StyleBox["assetId",
      FontSlant->"Italic"], "]"}], Cell[
    "Create a GEE expression for an ImageCollection asset.", "TableText",
     ExpressionUUID->"45fd0745-d3b4-6440-a17a-7dd4859ec36a"]},
   {
    RowBox[{"GEELoadImage", "[", 
     StyleBox["assetId",
      FontSlant->"Italic"], "]"}], Cell[
    "Create a GEE expression for a single Image asset.", "TableText",
     ExpressionUUID->"d5137020-5efa-684a-acd0-092962dafb7e"]},
   {
    RowBox[{"GEEFeatureCollection", "[", 
     StyleBox["assetId",
      FontSlant->"Italic"], "]"}], Cell["\<\
Create a GEE expression for a FeatureCollection (table) asset.\
\>", "TableText",ExpressionUUID->"8fe96e8a-5dd7-2641-a5ad-df493d995b25"]},
   {
    RowBox[{"GEEFilterDate", "[", 
     StyleBox[
      RowBox[{"collection", ",", "start", ",", "end"}],
      FontSlant->"Italic"], "]"}], Cell[
    "Filter a collection by date range (ISO 8601 strings).", "TableText",
     ExpressionUUID->"3d7e31da-e2c6-784a-8645-7fb7e1a6d1ae"]},
   {
    RowBox[{"GEEFilterBounds", "[", 
     StyleBox[
      RowBox[{"collection", ",", "bbox"}],
      FontSlant->"Italic"], "]"}], Cell["\<\
Filter a collection by spatial bounding box {west, south, east, north}.\
\>", "TableText",ExpressionUUID->"09df8dd1-cc24-bf46-ad44-0ac180f831c8"]},
   {
    RowBox[{"GEEFilterBounds", "[", 
     StyleBox["bbox",
      FontSlant->"Italic"], "]"}], Cell[
    "Operator form for use with //.", "TableText",ExpressionUUID->
     "2ec70bd7-40b2-1b43-a1f2-ceeebb8b4493"]},
   {
    RowBox[{"GEEFilterProperty", "[", 
     RowBox[{
      StyleBox["collection",
       FontSlant->"Italic"], 
      StyleBox[",",
       FontSlant->"Italic"], 
      StyleBox["property",
       FontSlant->"Italic"], 
      StyleBox[",",
       FontSlant->"Italic"], 
      StyleBox["op",
       FontSlant->"Italic"], 
      StyleBox[",",
       FontSlant->"Italic"], 
      StyleBox[
       RowBox[{
        StyleBox["valu",
         FontSlant->"Italic"], "e"}]]}], "]"}], Cell[
    "Filter a collection by metadata property comparison.", "TableText",
     ExpressionUUID->"b81c550a-c22b-eb42-be08-39b3346dbb1e"]},
   {
    RowBox[{"GEEFilterProperty", "[", 
     StyleBox[
      RowBox[{"property", ",", "op", ",", "value"}],
      FontSlant->"Italic"], "]"}], Cell[
    "Operator form for use with //.", "TableText",ExpressionUUID->
     "6660dbc5-09bb-da46-bed7-a7c24c00e5f3"]},
   {
    RowBox[{"GEESelectBands", "[", 
     StyleBox[
      RowBox[{"expr", ",", "bands"}],
      FontSlant->"Italic"], "]"}], Cell[
    "Select specific bands from an image or collection.", "TableText",
     ExpressionUUID->"011df5ef-c2ba-e147-8a62-a7f4cd2329ab"]},
   {
    RowBox[{"GEESelectBands", "[", 
     StyleBox["bands",
      FontSlant->"Italic"], "]"}], Cell[
    "SOperator form for use with //.", "TableText",ExpressionUUID->
     "bb9c6d5c-adcf-c649-8e2a-e36bde91fb96"]},
   {
    RowBox[{"GEEMosaic", "[", 
     StyleBox["collection",
      FontSlant->"Italic"], "]"}], Cell[
    "Mosaic a collection into a single image (last-pixel-wins).", "TableText",
     ExpressionUUID->"96018a45-887a-004e-a20d-a1b983e69b46"]},
   {
    RowBox[{"GEEMedian", "[", 
     StyleBox["collection",
      FontSlant->"Italic"], "]"}], Cell[
    "Per-pixel median composite of a collection.", "TableText",ExpressionUUID->
     "05d40edf-d4a8-bb44-a9c2-c551e0d3e783"]},
   {
    RowBox[{"GEEMean", "[", 
     StyleBox["collection",
      FontSlant->"Italic"], "]"}], Cell[
    "Per-pixel mean composite of a collection.", "TableText",ExpressionUUID->
     "998a3f5c-5ca7-414e-b5b6-f745de41030c"]},
   {
    RowBox[{"GEESort", "[", 
     StyleBox[
      RowBox[{"collection", ",", "property"}],
      FontSlant->"Italic"], "]"}], Cell[
    "Sort a collection by a metadata property (ascending).", "TableText",
     ExpressionUUID->"14273475-3008-9348-8ccc-4c1899144dbd"]},
   {
    RowBox[{"GEESort", "[", 
     StyleBox[
      RowBox[{"collection", ",", "property", ",", "ascending"}],
      FontSlant->"Italic"], "]"}], Cell[
    "Sort with explicit direction.", "TableText",ExpressionUUID->
     "ecc6a7d3-ea1c-2a49-9519-66bfe721c711"]},
   {
    RowBox[{"GEESort", "[", 
     StyleBox["property",
      FontSlant->"Italic"], "]"}], Cell[
    "Operator form for use with //.", "TableText",ExpressionUUID->
     "fad69d28-faba-c54e-bfb2-a406a1d1c12c"]},
   {
    RowBox[{"GEEFirst", "[", 
     StyleBox["collection",
      FontSlant->"Italic"], "]"}], Cell[
    "Get the first image from a collection.", "TableText",ExpressionUUID->
     "780099c0-7202-ca46-9b15-e8e5fdb5cfa8"]},
   {
    RowBox[{"GEELimit", "[", 
     StyleBox[
      RowBox[{"collection", ",", "n"}],
      FontSlant->"Italic"], "]"}], Cell[
    "Limit a collection to at most n images.", "TableText",ExpressionUUID->
     "21f23698-8e86-7244-9d3e-21f88ba17909"]},
   {
    RowBox[{"GEELimit", "[", 
     StyleBox["n",
      FontSlant->"Italic"], "]"}], Cell[
    "Operator form for use with //.", "TableText",ExpressionUUID->
     "8bb8b520-4c05-9044-b40e-b07b1d9c993f"]},
   {
    RowBox[{"GEEVisualize", "[", 
     StyleBox[
      RowBox[{"image", ",", "visParams"}],
      FontSlant->"Italic"], "]"}], Cell[
    "Apply server-side visualization to an image.", "TableText",
     ExpressionUUID->"5a07bd86-d2f3-c746-89a5-b010c0286e00"]},
   {
    RowBox[{"GEEVisualize", "[", 
     StyleBox["visParams",
      FontSlant->"Italic"], "]"}], Cell[
    "Operator form for use with //", "TableText",ExpressionUUID->
     "1270e902-6925-ac4b-93bb-1a4aea91b2b0"]},
   {
    RowBox[{"GEEGeometry", "[", 
     RowBox[{"{", 
      StyleBox[
       RowBox[{"lat", ",", "lon"}],
       FontSlant->"Italic"], "}"}], "]"}], Cell[
    "Create a GEE point geometry expression.", "TableText",ExpressionUUID->
     "10924cc3-8495-d34c-ba58-fe7077b1c48c"]},
   {
    RowBox[{"GEEGeometry", "[", 
     RowBox[{"{", 
      StyleBox[
       RowBox[{"west", ",", "south", ",", "east", ",", "north"}],
       FontSlant->"Italic"], "}"}], "]"}], Cell[
    "Create a GEE rectangle geometry expression.", "TableText",ExpressionUUID->
     "dedef52a-ad2f-4443-94d4-1010058f9526"]},
   {
    RowBox[{"GEEReduceRegion", "[", 
     StyleBox[
      RowBox[{"image", ",", "geometry", ",", "reducer", ",", "scale"}],
      FontSlant->"Italic"], "]"}], Cell[
    "Compute a statistic over a region.", "TableText",ExpressionUUID->
     "c446224c-6598-fd4d-8b82-c17d57341337"]},
   {
    RowBox[{"GEEReduceRegion", "[", 
     StyleBox[
      RowBox[{"geometry", ",", "reducer", ",", "scale"}],
      FontSlant->"Italic"], "]"}], Cell[
    "Operator form for use with //", "TableText",ExpressionUUID->
     "03d5ad95-300f-a542-b316-f6d38809e3c1"]}
  }]], "DefinitionBox",
 CellChangeTimes->{{3.984350783732212*^9, 3.984351054362238*^9}, {
  3.984351094464407*^9, 3.984351148754318*^9}, {3.984351187464449*^9, 
  3.984351187543352*^9}},
 CellID->828295942,ExpressionUUID->"fb063e7c-11d4-9047-84ca-f1404d5b6f63"],

Cell["\<\
- All expression builders return an Association representing a GEE expression \
tree. This Association can be passed to GEEComputePixels, GEEImage, \
GEEGetTile, GEEIdentify, GEEGetSamples, GEEComputeFeatures, GEECompute, and \
GEEGeoGraphics in place of an asset ID string.
- **Operator forms** return a Function that takes a collection/image as its \
argument, enabling // piping: coll // GEEFilterDate[\"2023-01-01\", \
\"2024-01-01\"].
- **Pipeline order**: Load -> Filter (date, bounds, properties) -> Select \
bands -> Sort/Limit -> Aggregate (mosaic/median/mean). Filters can be applied \
in any order, but date and spatial filters should come first for performance.
- **Aggregation is required** before passing a collection to rendering \
functions (GEEComputePixels, GEEImage, etc.). Use GEEMosaic, GEEMedian, \
GEEMean, or GEEFirst.
- GEEFilterProperty op values: \"LessThan\", \"GreaterThan\", \"Equals\", \
\"LessThanOrEquals\", \"GreaterThanOrEquals\", \"NotEquals\".
- GEEMedian and GEEMean use ImageCollection.reduce internally, which appends \
_median or _mean to band names. GEEMosaic preserves original band names.
- GEESelectBands automatically detects whether its input is a collection or a \
single image and uses the appropriate API call.
- GEEReduceRegion reducer values: \"mean\", \"min\", \"max\", \"sum\", \
\"first\", \"median\".\
\>", "Text",
 CellChangeTimes->{{3.9843511598861294`*^9, 3.9843511880348473`*^9}},
 CellID->22200001,ExpressionUUID->"6e7b7eb7-c2fa-ae49-813c-51c922a89237"],

Cell["", "Text",
 CellChangeTimes->{{3.984350728765764*^9, 3.9843507509270973`*^9}},
 CellID->158703073,ExpressionUUID->"dfc498da-901b-5342-a354-fe9c64601527"],

Cell[CellGroupData[{

Cell["Possible Issues", "Subsection",
 CellChangeTimes->{{3.984350740333004*^9, 3.9843507431461353`*^9}},
 CellID->151069672,ExpressionUUID->"90e63cf4-d049-ce4c-84cd-a8dac8336aaa"],

Cell["\<\
- A collection pipeline must end with GEEMosaic, GEEMedian, GEEMean, or \
GEEFirst before passing to GEEComputePixels or GEEImage.
- GEEMedian and GEEMean append suffixes to band names (_median, _mean). This \
does not affect rendering but may matter for downstream band references.
- Always filter by date and bounds before GEESelectBands to avoid errors from \
collections with heterogeneous band structures across their history (e.g., \
Sentinel-2).
- Common metadata properties vary by dataset: Sentinel-2 uses \
\"CLOUDY_PIXEL_PERCENTAGE\", Landsat uses \"CLOUD_COVER\". Use \
GEEGetAssetInfo to discover available properties.\
\>", "Text",
 CellChangeTimes->{
  3.9843507480357037`*^9, {3.9843511880422935`*^9, 3.9843511881885433`*^9}},
 CellID->649455815,ExpressionUUID->"4cb999fc-1334-774a-b4f1-2cc5381fe208"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Examples", "Section",
 CellChangeTimes->{{3.984350471711935*^9, 3.984350472832388*^9}},
 CellID->325189997,ExpressionUUID->"f49edf73-8ffa-0d4a-adac-be98f4fc6d73"],

Cell[CellGroupData[{

Cell["Cloud-filtered Sentinel-2 true color RGB:", "MathCaption",
 CellChangeTimes->{3.9843504805944023`*^9},
 CellID->2796150,ExpressionUUID->"b124ceec-08f6-ba49-8698-52ae727110a9"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"img", "=", 
  RowBox[{"GEEComputePixels", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{
      RowBox[{"-", "3.8"}], ",", "40.3", ",", 
      RowBox[{"-", "3.6"}], ",", "40.5"}], "}"}], ",", 
    RowBox[{
     RowBox[{
      RowBox[{
       RowBox[{
        RowBox[{
         RowBox[{
         "GEECollection", "[", "\"\<COPERNICUS/S2_SR_HARMONIZED\>\"", "]"}], "//", 
         RowBox[{"GEEFilterDate", "[", 
          RowBox[{"\"\<2023-01-01\>\"", ",", "\"\<2024-01-01\>\""}], "]"}]}], 
        "//", 
        RowBox[{"GEEFilterBounds", "[", 
         RowBox[{"{", 
          RowBox[{
           RowBox[{"-", "3.8"}], ",", "40.3", ",", 
           RowBox[{"-", "3.6"}], ",", "40.5"}], "}"}], "]"}]}], "//", 
       RowBox[{"GEEFilterProperty", "[", 
        RowBox[{"\"\<CLOUDY_PIXEL_PERCENTAGE\>\"", ",", "\"\<LessThan\>\"", ",",
          "20"}], "]"}]}], "//", 
      RowBox[{"GEESelectBands", "[", 
       RowBox[{"{", 
        RowBox[{"\"\<B4\>\"", ",", "\"\<B3\>\"", ",", "\"\<B2\>\""}], "}"}], 
       "]"}]}], "//", "GEEMedian"}], ",", 
    RowBox[{"\"\<VisParams\>\"", "->", 
     RowBox[{"<|", 
      RowBox[{
       RowBox[{"\"\<min\>\"", "->", "0"}], ",", 
       RowBox[{"\"\<max\>\"", "->", "3000"}]}], "|>"}]}]}], "]"}]}]], "Input",
 CellChangeTimes->{3.984350487863203*^9},
 CellLabel->"In[43]:=",
 CellID->67849854,ExpressionUUID->"f64d109e-47b4-d24a-b5a2-1b69e50199af"],

